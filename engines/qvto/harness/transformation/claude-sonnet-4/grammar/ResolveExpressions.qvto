modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
  inModel.rootObjects()[EPackage]->map p2p();
  var outPkg := inModel.rootObjects()[EPackage]->any(true).resolveoneIn(EPackage::p2p, EPackage);
  if outPkg <> null then {
    var firstClass := inModel.rootObjects()[EPackage]->any(true).eClassifiers->selectByKind(EClass)->first();
    if firstClass <> null then {
      outPkg.name := firstClass.name.substring(1, 1) + outPkg.name;
    } endif;
  } endif;
}

mapping EPackage::p2p() : EPackage {
  name := self.name;
  eClassifiers += self.eClassifiers->map c2c();
}

mapping EClassifier::c2c() : EClass {
  name := 'mapped' + self.name;
}
