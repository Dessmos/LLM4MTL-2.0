modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation t(in inp : ECORE, out outp : ECORE);

main() {
    inp.rootObjects()[EPackage]->map p2p();
    var outPkg := inp.rootObjects()[EPackage]->any(true).resolveoneIn(EPackage::p2p, EPackage);
    if not inp.rootObjects()[EPackage].eClassifiers->isEmpty() then
        var firstClass := inp.rootObjects()[EPackage].eClassifiers->selectByKind(EClass)->first();
        if firstClass <> null then
            outPkg.name := firstClass.name.substring(1, 1) + outPkg.name;
        endif;
    endif;
}

mapping EPackage::p2p() : EPackage {
    name := self.name;
    eClassifiers := self.eClassifiers->map c2c();
}

mapping EClassifier::c2c() : EClass
    when { self.oclIsKindOf(EClass) } {
    name := 'mapped' + self.name;
}
