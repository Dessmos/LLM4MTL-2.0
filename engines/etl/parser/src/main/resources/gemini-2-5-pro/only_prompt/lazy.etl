transformation FlowchartToHtml

model Flowchart metamodel "http://vitruv.tools/methodologisttemplate/flowchart"
model HTML metamodel "http://vitruv.tools/methodologisttemplate/HTML"

rule Flowchart2Heading
	transform s : flowchart!Flowchart
	to t : HTML!DIV {
		t.children.addAll(s.nodes.equivalent());
	}

rule Action2Heading
	transform s : flowchart!Action
	to t : HTML!H1 {
		t.value = s.name;
	}

rule Decision2Heading
	transform s : flowchart!Decision
	to t : HTML!H1 {
		t.value = s.name;
	}

rule Transition2Heading
	transform s : flowchart!Transition
	to t : HTML!H1 {
		t.value = s.name;
	}