rule Rss2Atom
	transform r : RSS!Rss
	to f : Atom!Feed {

	Atom#Root = f;
	f.appendEquivalentsOfChildrenOf(r);
}

@lazy
rule Item2Entry
	transform i : RSS!Item
	to e : Atom!Entry {

	e.appendEquivalentsOfChildrenOf(i);
}

@lazy
rule Title2Title
	transform s : RSS!Title
	to t : Atom!Title {

	t.text = s.text;
}

@lazy
rule Link2Link
	transform s : RSS!Link
	to l : Atom!Link {

	l.href = s.href;
	l.text = s.text;
}

@lazy
rule Generator2Generator
	transform s : RSS!Generator
	to g : Atom!Generator {

	g.text = s.text;
}

@lazy
rule Creator2Author
	transform s : RSS!Creator
	to a : Atom!Author {

	a.name = s.text;
}

@lazy
rule Description2Summary
	transform s : RSS!Description
	to su : Atom!Summary {

	su.text = s.text;
}

@lazy
rule ContentEncoded2Content
	transform s : RSS!ContentEncoded
	to c : Atom!Content {

	c.text = s.text;
}

@lazy
rule PubDate2Published
	transform s : RSS!PubDate
	to p : Atom!Published {

	p.text = s.text;
}

operation Atom!Feed appendChildren(children : Sequence(Atom!Element)) {
	self.children.addAll(children);
}

operation Atom!Entry appendChildren(children : Sequence(Atom!Element)) {
	self.children.addAll(children);
}

operation Atom!Feed appendEquivalentsOfChildrenOf(rssElement : RSS!Element) {
	self.appendChildren(rssElement.children.equivalent());
}

operation Atom!Entry appendEquivalentsOfChildrenOf(rssElement : RSS!Element) {
	self.appendChildren(rssElement.children.equivalent());
}