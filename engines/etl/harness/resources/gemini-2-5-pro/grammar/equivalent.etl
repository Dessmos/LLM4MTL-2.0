transformation Flowchart2Html

source flowchart "http://vitruv.tools/methodologisttemplate/flowchart"
target html "http://vitruv.tools/methodologisttemplate/HTML"

rule Flowchart2Div
	transform f : flowchart!Flowchart
	to d : html!DIV {
		d.children.addAll(f.transitions.equivalent());
	}

rule Transition2Heading
	transform t : flowchart!Transition
	to h : html!H1 {
		h.value = t.name;
	}