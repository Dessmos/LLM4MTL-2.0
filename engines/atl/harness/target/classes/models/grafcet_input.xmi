<xmi:XMI xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:Grafcet="Grafcet">
  <Grafcet:Grafcet xmi:id="g1" name="TestGrafcet" location="line1">
    <elements xmi:type="Grafcet:Step" xmi:id="s1" name="Step1" location="line2" isInitial="true" isActive="true" action="action1" grafcet="g1"/>
    <elements xmi:type="Grafcet:Step" xmi:id="s2" name="Step2" location="line3" isInitial="false" isActive="false" action="action2" grafcet="g1"/>
    <elements xmi:type="Grafcet:Transition" xmi:id="t1" name="Transition1" location="line4" condition="cond1" grafcet="g1"/>
    <connections xmi:type="Grafcet:StepToTransition" xmi:id="c1" name="conn1" location="line5" grafcet="g1" from="s1" to="t1"/>
    <connections xmi:type="Grafcet:TransitionToStep" xmi:id="c2" name="conn2" location="line6" grafcet="g1" from="t1" to="s2"/>
  </Grafcet:Grafcet>
