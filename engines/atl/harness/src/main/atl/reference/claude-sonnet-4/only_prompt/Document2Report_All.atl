module Document2Report_All;
create OUT : Report from IN : Document;

rule Document2Report {
	from
		d : Document!Document
	to
		r : Report!Report (
			title <- d.title,
			author <- d.author,
			sections <- d.sections
		)
}

rule Section2Section {
	from
		s : Document!Section
	to
		t : Report!Section (
			title <- s.title,
			content <- s.content,
			order <- s.order
		)
}