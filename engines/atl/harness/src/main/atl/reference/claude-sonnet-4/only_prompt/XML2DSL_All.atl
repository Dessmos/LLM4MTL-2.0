module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrBool(attrName : String) : Boolean =
	let attr : XML!Attribute = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName)->first() in
	if attr.oclIsUndefined() then
		false
	else
		attr.value = 'true'
	endif;

helper context XML!Element def: getAttrVal(attrName : String) : String =
	let attr : XML!Attribute = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName)->first() in
	if attr.oclIsUndefined() then
		''
	else
		attr.value
	endif;

helper context XML!Element def: get(childName : String) : XML!Element =
	self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = childName)->first();

helper context XML!Element def: getType() : String =
	self.getAttrVal('type');

helper context XML!Element def: getEnumId() : String =
	self.getAttrVal('id');

helper context XML!Element def: getText() : String =
	let textNode : XML!Text = self.children->select(c | c.oclIsTypeOf(XML!Text))->first() in
	if textNode.oclIsUndefined() then
		''
	else
		textNode.value
	endif;

helper context XML!Element def: getSeq(childName : String) : Sequence(XML!Element) =
	self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = childName);

helper context XML!Element def: hasChildren(childName : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Element) and c.name = childName);

helper context XML!Element def: hasAttr(attrName : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName);

helper context XML!Element def: isAbstract() : Boolean =
	self.getAttrBool('isAbstract');

helper def: dslElementsById : Map(String, XML!Element) =
	XML!Element.allInstances()->iterate(e; m : Map(String, XML!Element) = Map{} |
		if e.hasAttr('id') then
			m.including(e.getAttrVal('id'), e)
		else
			m
		endif
	);

helper def: getSubTypes(superTypeId : String) : Sequence(XML!Element) =
	XML!Element.allInstances()->select(e | e.hasAttr('superType') and e.getAttrVal('superType') = superTypeId);

helper def: findType(typeId : String) : DSL!Type =
	if typeId = 'Boolean' then
		DSL!SimpleType.allInstances()->select(t | t.name = 'Boolean')->first()
	else if typeId = 'Integer' then
		DSL!SimpleType.allInstances()->select(t | t.name = 'Integer')->first()
	else if typeId = 'String' then
		DSL!SimpleType.allInstances()->select(t | t.name = 'String')->first()
	else
		DSL!Type.allInstances()->select(t | t.identity = typeId)->first()
	endif endif endif;

rule DomainModel {
	from
		s : XML!Root
	to
		t : DSL!DomainModel (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			namespace <- s.getAttrVal('namespace'),
			isLoaded <- s.getAttrBool('isLoaded'),
			classifiers <- s.getSeq('Class')->union(s.getSeq('Relationship')),
			types <- Sequence{booleanType, integerType, stringType}->union(s.getSeq('Enumeration'))
		),
		booleanType : DSL!SimpleType (
			name <- 'Boolean',
			identity <- 'Boolean',
			namespace <- 'PrimitiveTypes'
		),
		integerType : DSL!SimpleType (
			name <- 'Integer',
			identity <- 'Integer',
			namespace <- 'PrimitiveTypes'
		),
		stringType : DSL!SimpleType (
			name <- 'String',
			identity <- 'String',
			namespace <- 'PrimitiveTypes'
		)
}

rule Class {
	from
		s : XML!Element (s.name = 'Class')
	to
		t : DSL!Class (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			namespace <- s.getAttrVal('namespace'),
			isLoaded <- s.getAttrBool('isLoaded'),
			isAbstract <- s.isAbstract(),
			properties <- s.getSeq('ValueProperty'),
			superType <- if s.hasAttr('superType') then thisModule.findClassifier(s.getAttrVal('superType')) else OclUndefined endif,
			subTypes <- thisModule.getSubTypes(s.getAttrVal('id'))->collect(e | thisModule.resolveTemp(e, 't'))
		)
}

rule Relationship {
	from
		s : XML!Element (s.name = 'Relationship')
	to
		t : DSL!Relationship (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			namespace <- s.getAttrVal('namespace'),
			isLoaded <- s.getAttrBool('isLoaded'),
			isAbstract <- s.isAbstract(),
			isEmbedding <- s.getAttrBool('isEmbedding'),
			properties <- s.getSeq('ValueProperty'),
			roles <- s.getSeq('Role'),
			superType <- if s.hasAttr('superType') then thisModule.findClassifier(s.getAttrVal('superType')) else OclUndefined endif,
			subTypes <- thisModule.getSubTypes(s.getAttrVal('id'))->collect(e | thisModule.resolveTemp(e, 't'))
		)
}

rule Role {
	from
		s : XML!Element (s.name = 'Role')
	to
		t : DSL!Role (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			min <- s.getAttrVal('min').toInteger(),
			max <- s.getAttrVal('max').toInteger(),
			isUnbounded <- s.getAttrBool('isUnbounded'),
			accepts <- s.getAttrVal('accepts'),
			isOrdered <- s.getAttrBool('isOrdered'),
			isNavigableFrom <- s.getAttrBool('isNavigableFrom'),
			isPropertyGenerator <- s.getAttrBool('isPropertyGenerator'),
			source <- thisModule.findClassifier(s.getAttrVal('source')),
			type <- thisModule.findClassifier(s.getAttrVal('type'))
		)
}

rule ValueProperty {
	from
		s : XML!Element (s.name = 'ValueProperty')
	to
		t : DSL!ValueProperty (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			type <- thisModule.findType(s.getType())
		)
}

rule Enumeration {
	from
		s : XML!Element (s.name = 'Enumeration')
	to
		t : DSL!Enumeration (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			namespace <- s.getAttrVal('namespace'),
			literals <- s.getSeq('EnumerationLiteral')
		)
}

rule EnumerationLiteral {
	from
