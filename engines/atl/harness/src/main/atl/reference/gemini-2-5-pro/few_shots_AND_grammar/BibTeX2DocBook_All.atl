module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context Collection(String) def: join(separator : String) : String =
    self->iterate(elem; acc : String = '' |
        if acc = '' then
            elem
        else
            acc + separator + elem
        endif
    );

helper context BibTeX!BibTeXEntry def: buildEntryPara() : String =
    '[' + self.id + '] ' + self.oclType().name +
    (if self.oclIsKindOf(BibTeX!TitledEntry) and self.title.oclIsUndefined().not() then '; title: ' + self.title else '' endif) +
    (if self.oclIsKindOf(BibTeX!AuthoredEntry) and self.authors->notEmpty() then '; authors: ' + self.authors->collect(a | a.author)->join(', ') else '' endif) +
    (if self.oclIsKindOf(BibTeX!DatedEntry) and self.year.oclIsUndefined().not() then '; year: ' + self.year else '' endif) +
    (if self.oclIsKindOf(BibTeX!BookTitledEntry) and self.booktitle.oclIsUndefined().not() then '; booktitle: ' + self.booktitle else '' endif) +
    (if self.oclIsKindOf(BibTeX!ThesisEntry) and self.school.oclIsUndefined().not() then '; school: ' + self.school else '' endif) +
    (if self.oclIsKindOf(BibTeX!Article) and self.journal.oclIsUndefined().not() then '; journal: ' + self.journal else '' endif) +
    (if self.oclIsKindOf(BibTeX!Unpublished) and self.note.oclIsUndefined().not() then '; note: ' + self.note else '' endif) +
    (if self.oclIsKindOf(BibTeX!Book) and self.publisher.oclIsUndefined().not() then '; publisher: ' + self.publisher else '' endif) +
    (if self.oclIsKindOf(BibTeX!InBook) and self.chapter.oclIsUndefined().not() then '; chapter: ' + self.chapter.toString() else '' endif);

helper def: authorSet() : Set(BibTeX!Author) =
    BibTeX!Author.allInstances()->iterate(a; acc : Set(BibTeX!Author) = Set{} |
        if acc->collect(x | x.author)->excludes(a.author) then
            acc->including(a)
        else
            acc
        endif
    );

helper def: titledEntrySet() : Set(BibTeX!TitledEntry) =
    BibTeX!TitledEntry.allInstances()->asSet();

helper def: articleSet() : Set(BibTeX!Article) =
    BibTeX!Article.allInstances()->asSet();

rule Main {
    from f : BibTeX!BibTeXFile
    to db : DocBook!DocBook (
        books <- Sequence { book }
    ),
    book : DocBook!Book (
        articles <- Sequence { article }
    ),
    article : DocBook!Article (
        title <- 'BibTeXML to DocBook',
        sections_1 <- Sequence { ref_list, authors_list, titles_list, journals_list }
    ),
    ref_list : DocBook!Sect1 (
        title <- 'References List',
        paras <- f.entries->sortedBy(e | e.id)
    ),
    authors_list : DocBook!Sect1 (
        title <- 'Authors list',
        paras <- thisModule.authorSet()->sortedBy(a | a.author)
    ),
    titles_list : DocBook!Sect1 (
        title <- 'Titles List',
        paras <- thisModule.titledEntrySet()->sortedBy(e | e.title)->collect(e | thisModule.resolveTemp(e, 'titlePara'))
    ),
    journals_list : DocBook!Sect1 (
        title <- 'Journals List',
        paras <- thisModule.articleSet()->collect(e | e.journal)->asSet()->sortedBy(j | j)
                 ->collect(j | thisModule.resolveTemp(
                     thisModule.articleSet()->select(e | e.journal = j)->first(), 'journalPara'
                 ))
    )
}

rule Author {
    from a : BibTeX!Author
    to p : DocBook!Para (
        content <- a.author
    )
}

rule UntitledEntry {
    from e : BibTeX!BibTeXEntry (not e.oclIsKindOf(BibTeX!TitledEntry))
    to entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    )
}

rule TitledEntry_Title_NoArticle {
    from e : BibTeX!TitledEntry (not e.oclIsKindOf(BibTeX!Article) and thisModule.titledEntrySet()->includes(e))
    to
    entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    ),
    titlePara : DocBook!Para (
        content <- e.title
    )
}

rule TitledEntry_NoTitle_NoArticle {
    from e : BibTeX!TitledEntry (not e.oclIsKindOf(BibTeX!Article) and not thisModule.titledEntrySet()->includes(e))
    to
    entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    )
}

rule Article_Title_Journal {
    from e : BibTeX!Article (thisModule.titledEntrySet()->includes(e) and thisModule.articleSet()->includes(e))
    to
    entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    ),
    titlePara : DocBook!Para (
        content <- e.title
    ),
    journalPara : DocBook!Para (
        content <- e.journal
    )
}

rule Article_NoTitle_Journal {
    from e : BibTeX!Article (not thisModule.titledEntrySet()->includes(e) and thisModule.articleSet()->includes(e))
    to
    entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    ),
    journalPara : DocBook!Para (
        content <- e.journal
    )
}

rule Article_Title_NoJournal {
    from e : BibTeX!Article (thisModule.titledEntrySet()->includes(e) and not thisModule.articleSet()->includes(e))
    to
    entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    ),
    titlePara : DocBook!Para (
        content <- e.title
    )
}

rule Article_NoTitle_NoJournal {
    from e : BibTeX!Article (not thisModule.titledEntrySet()->includes(e) and not thisModule.articleSet()->includes(e))
    to
    entryPara : DocBook!Para (
        content <- e.buildEntryPara()
    )
}