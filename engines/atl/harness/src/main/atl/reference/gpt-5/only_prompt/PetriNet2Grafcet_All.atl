module PetriNet2Grafcet;

create OUT : Grafcet from IN : PetriNet;

rule Grafcet {
	from
		src : PetriNet!PetriNet
	to
		trg : Grafcet!Grafcet (
			location <- src.location,
			name <- src.name,
			elements <- src.elements,
			connections <- src.arcs
		)
}

rule Step {
	from
		src : PetriNet!Place
	to
		trg : Grafcet!Step (
			location <- src.location,
			name <- src.name,
			grafcet <- src.net,
			isInitial <- false,
			isActive <- false,
			incomingConnections <- src.incomingArc,
			outgoingConnections <- src.outgoingArc
		)
}

rule Transition {
	from
		src : PetriNet!Transition
	to
		trg : Grafcet!Transition (
			location <- src.location,
			name <- src.name,
			grafcet <- src.net,
			condition <- '',
			incomingConnections <- src.incomingArc,
			outgoingConnections <- src.outgoingArc
		)
}

rule StepToTransition {
	from
		src : PetriNet!PlaceToTransition
	to
		trg : Grafcet!StepToTransition (
			location <- src.location,
			name <- src.name,
			grafcet <- src.net,
			from <- src.from,
			to <- src.to
		)
}

rule TransitionToStep {
	from
		src : PetriNet!TransitionToPlace
	to
		trg : Grafcet!TransitionToStep (
			location <- src.location,
			name <- src.name,
			grafcet <- src.net,
			from <- src.from,
			to <- src.to
		)
}