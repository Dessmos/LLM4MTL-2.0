module DSL2KM3;

create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	self.roles->exists(r | r.isPropertyGenerator) or
	self.superType->notEmpty() or
	self.subTypes->notEmpty() or
	self.properties->notEmpty() or
	self.roles->exists(r | r.isNavigableFrom = false);

helper def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
	DSL!Role.allInstances()
		->select(r | r.source = c and not r.relation.needTurnOnClass());

helper context DSL!Role def: isEmbedding() : Boolean =
	if self.relation.isEmbedding then
		true
	else
		self.min > 0 and (self.isUnbounded or self.max > 1)
	endif;

rule Metamodel {
	from
		dm : DSL!DomainModel
	to
		mm : KM3!Metamodel (
			location <- dm.location,
			contents <- Sequence{ mainPkg, primPkg }
		),
		mainPkg : KM3!Package (
			location <- dm.location,
			name <- dm.name,
			metamodel <- mm,
			contents <- dm.classifiers->select(c | c.oclIsKindOf(DSL!Classifier))
				->collect(c | thisModule.resolveTemp(c,'km3Classifier'))
		),
		primPkg : KM3!Package (
			location <- dm.location,
			name <- 'PrimitiveTypes',
			metamodel <- mm,
			contents <- Sequence{ boolDT, intDT, stringDT }
		),
		boolDT : KM3!DataType (
			location <- dm.location,
			name <- 'Boolean',
			package <- primPkg
		),
		intDT : KM3!DataType (
			location <- dm.location,
			name <- 'Integer',
			package <- primPkg
		),
		stringDT : KM3!DataType (
			location <- dm.location,
			name <- 'String',
			package <- primPkg
		)
}

rule Class {
	from
		c : DSL!Class
	to
		kc : KM3!Class (
			location <- c.location,
			name <- c.name,
			isAbstract <- c.isAbstract,
			package <- thisModule.getMainPackage(c.domainModel),
			supertypes <- if c.superType.oclIsUndefined() then Sequence{} else Sequence{ thisModule.resolveTemp(c.superType,'km3Class') } endif,
			structuralFeatures <- c.properties->collect(p | thisModule.resolveTemp(p,'km3Attribute'))
				->union(thisModule.getRoles(c)
					->collect(r | thisModule.resolveTemp(r,'km3Reference')))
		),
		km3Classifier <- kc,
		km3Class <- kc
}

rule Relation2Class {
	from
		r : DSL!Relationship (r.needTurnOnClass())
	to
		kc : KM3!Class (
			location <- r.location,
			name <- r.name,
			isAbstract <- r.isAbstract,
			package <- thisModule.getMainPackage(r.domainModel),
			supertypes <- if r.superType.oclIsUndefined() then Sequence{} else Sequence{ thisModule.resolveTemp(r.superType,'km3Class') } endif,
			structuralFeatures <- r.properties->collect(p | thisModule.resolveTemp(p,'km3Attribute'))
		),
		km3Classifier <- kc,
		km3Class <- kc
}

rule SimpleReference {
	from
		r1 : DSL!Role (
			r1.isNavigableFrom and
			not r1.relation.needTurnOnClass() and
			r1.relation.roles->exists(r2 | r2 <> r1 and not r2.isNavigableFrom)
		)
	to
		ref : KM3!Reference (
			location <- r1.location,
			name <- r1.name,
			lower <- r1.min,
			upper <- if r1.isUnbounded then -1 else r1.max endif,
			isOrdered <- r1.isOrdered,
			isUnique <- true,
			owner <- thisModule.resolveTemp(r1.source,'km3Class'),
			type <- thisModule.resolveTemp(r1.type,'km3Class'),
			isContainer <- r1.isEmbedding(),
			opposite <- OclUndefined(KM3!Reference)
		),
		km3Reference <- ref
}

rule ComplexReference {
	from
		r1 : DSL!Role (
			r1.isNavigableFrom and
			not r1.relation.needTurnOnClass() and
			r1.relation.roles->exists(r2 | r2 <> r1 and r2.isNavigableFrom)
		),
		r2 : DSL!Role (
			r2.relation = r1.relation and
			r2 <> r1 and
			r2.isNavigableFrom
		)
	to
		ref1 : KM3!Reference (
			location <- r1.location,
			name <- r1.name,
			lower <- r1.min,
			upper <- if r1.isUnbounded then -1 else r1.max endif,
			isOrdered <- r1.isOrdered,
			isUnique <- true,
			owner <- thisModule.resolveTemp(r1.source,'km3Class'),
			type <- thisModule.resolveTemp(r1.type,'km3Class'),
			isContainer <- r1.isEmbedding(),
			opposite <- ref2
		),
		ref2 : KM3!Reference (
			location <- r2.location,
			name <- r2.name,
			lower <- r2.min,
			upper <- if r2.isUnbounded then -1 else r2.max endif,
			isOrdered <- r2.isOrdered,
			isUnique <- true,
			owner <- thisModule.resolveTemp(r2.source,'km3Class'),
			type <- thisModule.resolveTemp(r2.type,'km3Class'),
			isContainer <- r2.isEmbedding(),
			opposite <- ref1
		),
		km3Reference <- ref1
}

rule Attribute {
	from
		vp : DSL!ValueProperty
	to
		attr : KM3!Attribute (
			location <- vp.location,
			name <- vp.name,
			lower <- 1,
			upper <- 1,
			isOrdered <- false,
			isUnique <- true,
			owner <- thisModule.resolveTemp(vp.owner,'km3Class'),
			type <- thisModule.resolveTemp(vp.type,'km3Classifier')
		),
		km3Attribute <- attr
}

rule Enumeration {
	from
		e : DSL!Enumeration
	to
		ke : KM3!Enumeration (
			location <- e.location,
			name <- e.name,
			package <- thisModule.getMainPackage(e.domainModel),
			literals <- e.literals->collect(l | thisModule.resolveTemp(l,'km3EnumLiteral'))
		),
		km3Classifier <- ke
}

rule EnumLiteral {
	from
		l : DSL!EnumerationLiteral
	to
		kel : KM3!EnumLiteral (
			location <- l.location,
			name <- l.name,
			package <- thisModule.getEnumPackage(l)
		),
		km3EnumLiteral <- kel
}

rule DataType {
	from
		st : DSL!SimpleType
	to
		dt : KM3!DataType (
			location <- st.location,
			name <- st.name,
			package <- thisModule.getMainPackage(st.domainModel)
		),
		km3Classifier <- dt
}

helper def: getMainPackage(dm : DSL!DomainModel) : KM3!Package =
	KM3!Metamodel.allInstances()
		->any(m | m.location = dm.location)
		.contents->any(p | p.name <> 'PrimitiveTypes');

helper def: getEnumPackage(l : DSL!EnumerationLiteral) : KM3!Package =
	thisModule.resolveTemp(l.oclAsType(DSL!NamedElement).oclContainer(),'km3Classifier').package;