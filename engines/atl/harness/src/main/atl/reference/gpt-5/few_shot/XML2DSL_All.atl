module XML2DSL;

create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrBool(name : String) : Boolean =
  let a : XML!Attribute = self.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->first() in
    if a.oclIsUndefined() or a.value.oclIsUndefined() then
      false
    else
      a.value = 'true' or a.value = '1'
    endif;

helper context XML!Element def: getAttrVal(name : String) : String =
  let a : XML!Attribute = self.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->first() in
    if a.oclIsUndefined() or a.value.oclIsUndefined() then
      ''
    else
      a.value
    endif;

helper context XML!Element def: hasAttr(name : String) : Boolean =
  self.children->exists(c | c.oclIsKindOf(XML!Attribute) and c.name = name);

helper context XML!Element def: get(name : String) : XML!Element =
  self.children->select(c | c.oclIsKindOf(XML!Element) and c.name = name)->first().oclAsType(XML!Element);

helper context XML!Element def: getSeq(name : String) : Sequence(XML!Element) =
  self.children->select(c | c.oclIsKindOf(XML!Element) and c.name = name)->collect(e | e.oclAsType(XML!Element));

helper context XML!Element def: getText() : String =
  self.children->select(c | c.oclIsKindOf(XML!Text))->iterate(t; res : String = '' | res + t.value);

helper context XML!Element def: hasChildren(name : String) : Boolean =
  self.children->exists(c | c.oclIsKindOf(XML!Element) and c.name = name);

helper context XML!Element def: getType() : String =
  self.getAttrVal('type');

helper context XML!Element def: getEnumId() : String =
  self.getAttrVal('id');

helper context XML!Element def: isAbstract() : Boolean =
  self.getAttrBool('abstract');

helper def: dslElementsById : Map(String, DSL!NamedElement) =
  Map{}; -- placeholder, to be populated if IDs are introduced

helper def: getSubTypes(tn : String) : Sequence(String) =
  Sequence{}; -- placeholder, depends on XML schema specifics

helper def: findType(name : String, dm : DSL!DomainModel) : DSL!Type =
  dm.types->select(t | t.name = name)->first();

helper def: rootElement : XML!Element =
  XML!Root.allInstances()->first().oclAsType(XML!Element);

lazy rule DomainModel {
  from r : XML!Root
  to   dm : DSL!DomainModel (
    name      <- 'DomainModel',
    identity  <- 'DomainModel',
    namespace <- 'http://vitruv.tools/methodologisttemplate/DSL',
    isLoaded  <- true,
    types     <- Sequence{
      sString, sInteger, sBoolean, sDate
    }
  ),
       sString  : DSL!SimpleType (
         name      <- 'String',
         identity  <- 'String',
         namespace <- 'PrimitiveTypes'
       ),
       sInteger : DSL!SimpleType (
         name      <- 'Integer',
         identity  <- 'Integer',
         namespace <- 'PrimitiveTypes'
       ),
       sBoolean : DSL!SimpleType (
         name      <- 'Boolean',
         identity  <- 'Boolean',
         namespace <- 'PrimitiveTypes'
       ),
       sDate    : DSL!SimpleType (
         name      <- 'Date',
         identity  <- 'Date',
         namespace <- 'PrimitiveTypes'
       )
}

lazy rule Class {
  from e : XML!Element (e.name = 'class')
  to   c : DSL!Class (
    name        <- e.getAttrVal('name'),
    identity    <- e.getAttrVal('id'),
    namespace   <- e.getAttrVal('namespace'),
    isLoaded    <- true,
    isAbstract  <- e.isAbstract(),
    domainModel <- thisModule.DomainModel(thisModule.rootElement),
    properties  <- e.getSeq('property')->collect(p | thisModule.ValueProperty(p)),
    superType   <- if e.hasAttr('super') then
                     thisModule.findClassifier(e.getAttrVal('super'))
                   else
                     OclUndefined
                   endif,
    subTypes    <- thisModule.getSubTypes(e.getAttrVal('name'))->collect(n | thisModule.findClassifier(n))
  )

}

lazy rule Relationship {
  from e : XML!Element (e.name = 'relationship')
  to   r : DSL!Relationship (
    name        <- e.getAttrVal('name'),
    identity    <- e.getAttrVal('id'),
    namespace   <- e.getAttrVal('namespace'),
    isLoaded    <- true,
    isAbstract  <- e.isAbstract(),
    domainModel <- thisModule.DomainModel(thisModule.rootElement),
    isEmbedding <- e.getAttrBool('embedding'),
    roles       <- Sequence{ thisModule.Role(e.get('left')), thisModule.Role(e.get('right')) },
    superType   <- if e.hasAttr('super') then
                     thisModule.findClassifier(e.getAttrVal('super'))
                   else
                     OclUndefined
                   endif,
    subTypes    <- thisModule.getSubTypes(e.getAttrVal('name'))->collect(n | thisModule.findClassifier(n))
  )
}

lazy rule Role {
  from e : XML!Element (e.name = 'role')
  to   r : DSL!Role (
    name                 <- e.getAttrVal('name'),
    identity             <- e.getAttrVal('id'),
    min                  <- e.getAttrVal('min').toInteger(),
    max                  <- e.getAttrVal('max').toInteger(),
    isUnbounded          <- e.getAttrBool('unbounded'),
    accepts              <- e.getAttrVal('accepts'),
    isOrdered            <- e.getAttrBool('ordered'),
    isNavigableFrom      <- e.getAttrBool('navigableFrom'),
    isPropertyGenerator  <- e.getAttrBool('propertyGenerator'),
    source               <- thisModule.findClassifier(e.getAttrVal('source')),
    type                 <- thisModule.findClassifier(e.getAttrVal('type')),
    relation             <- thisModule.Relationship(e.parent.oclAsType(XML!Element)),
    namespace            <- thisModule.Relationship(e.parent.oclAsType(XML!Element)).namespace
  )
}

lazy rule ValueProperty {
  from e : XML!Element (e.name = 'property')
  to   vp : DSL!ValueProperty (
    name     <- e.getAttrVal('name'),
    identity <- e.getAttrVal('id'),
    owner    <- thisModule.findClassifier(e.getAttrVal('owner')),
    type     <- thisModule.findType(e.getType(), thisModule.DomainModel(thisModule.rootElement))
  )
}

lazy rule Enumeration {
  from e : XML!Element (e.name = 'enum')
  to   en : DSL!Enumeration (
    name      <- e.getAttrVal('name'),
    identity  <- e.getAttrVal('id'),
    namespace <- e.getAttrVal('namespace'),
    literals  <- e.getSeq('literal')->collect(l | thisModule.EnumerationLiteral(l))
  )
}

lazy rule EnumerationLiteral {
  from e : XML!Element (e.name = 'literal')
  to   lit : DSL!EnumerationLiteral (
    name     <- e.getAttrVal('name'),
    identity <- e.getEnumId(),
    value    <- e.getAttrVal('value').toInteger()
  )
}

helper def: allClassifiers(dm : DSL!DomainModel) : Sequence(DSL!Classifier) =
  dm.classifiers;

helper def: findClassifier(name : String) : DSL!Classifier =
  thisModule.DomainModel(thisModule.rootElement).classifiers->select(c | c.name = name)->first();