module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def:
	needTurnOnClass() : Boolean =
		self.properties->notEmpty() or self.superType.oclIsUndefined().not() or self.subTypes->notEmpty();

helper context DSL!DomainModel def:
	getRoles(c : DSL!Class) : Sequence(DSL!Role) =
		DSL!Role.allInstances()->select(r | r.source = c and not r.relation.needTurnOnClass() and r.isNavigableFrom);

helper context DSL!Role def:
	isEmbedding() : Boolean =
		self.relation.isEmbedding and self.isPropertyGenerator;

rule Metamodel {
	from
		s : DSL!DomainModel
	to
		t : KM3!Metamodel (
			contents <- Sequence{p, pt}
		),
		p : KM3!Package (
			name <- s.name,
			contents <- s.classifiers->union(s.types)
		),
		pt : KM3!Package (
			name <- 'PrimitiveTypes',
			contents <- Sequence{stringType, integerType, booleanType}
		),
		stringType : KM3!DataType ( name <- 'String' ),
		integerType : KM3!DataType ( name <- 'Integer' ),
		booleanType : KM3!DataType ( name <- 'Boolean' )
}

rule Class {
	from
		s : DSL!Class
	to
		t : KM3!Class (
			name <- s.name,
			package <- s.domainModel,
			isAbstract <- s.isAbstract,
			supertypes <- s.superType,
			structuralFeatures <- s.properties->union(s.domainModel.getRoles(s))->union(DSL!Role.allInstances()->select(r | r.source = s and r.relation.needTurnOnClass() and r.isNavigableFrom))
		)
}

rule Relation2Class {
	from
		s : DSL!Relationship (s.needTurnOnClass())
	to
		t : KM3!Class (
			name <- s.name,
			package <- s.domainModel,
			isAbstract <- s.isAbstract,
			supertypes <- s.superType,
			structuralFeatures <- s.properties->union(s.roles)
		)
}

rule SimpleReference {
	from
		s : DSL!Role (not s.relation.needTurnOnClass() and s.isNavigableFrom)
	to
		t : KM3!Reference (
			name <- s.name,
			owner <- s.source,
			type <- s.type,
			lower <- s.min,
			upper <- if s.isUnbounded then -1 else s.max endif,
			isOrdered <- s.isOrdered,
			isUnique <- true,
			isContainer <- s.isEmbedding(),
			opposite <- s.relation.roles->any(r | r <> s)
		)
}

lazy rule InverseComplexReference {
	from
		s : DSL!Role (s.relation.needTurnOnClass())
	to
		t : KM3!Reference (
			name <- s.source.name.toLower(),
			owner <- s.relation,
			type <- s.source,
			lower <- 1,
			upper <- 1,
			isOrdered <- false,
			isUnique <- true,
			isContainer <- s.isEmbedding(),
			opposite <- thisModule.ComplexReference(s)
		)
}

rule ComplexReference {
	from
		s : DSL!Role (s.relation.needTurnOnClass() and s.isNavigableFrom)
	to
		t : KM3!Reference (
			name <- s.name,
			owner <- s.source,
			type <- s.relation,
			lower <- s.min,
			upper <- if s.isUnbounded then -1 else s.max endif,
			isOrdered <- s.isOrdered,
			isUnique <- true,
			isContainer <- false,
			opposite <- thisModule.InverseComplexReference(s)
		)
}

rule Attribute {
	from
		s : DSL!ValueProperty
	to
		t : KM3!Attribute (
			name <- s.name,
			owner <- s.owner,
			type <- s.type,
			lower <- 1,
			upper <- 1,
			isOrdered <- false,
			isUnique <- true
		)
}

rule Enumeration {
	from
		s : DSL!Enumeration
	to
		t : KM3!Enumeration (
			name <- s.name,
			package <- s.eContainer(),
			literals <- s.literals
		)
}

rule EnumLiteral {
	from
		s : DSL!EnumerationLiteral
	to
		t : KM3!EnumLiteral (
			name <- s.name,
			package <- s.eContainer().eContainer()
		)
}

rule DataType {
	from
		s : DSL!SimpleType
	to
		t : KM3!DataType (
			name <- s.name,
			package <- s.eContainer()
		)
}