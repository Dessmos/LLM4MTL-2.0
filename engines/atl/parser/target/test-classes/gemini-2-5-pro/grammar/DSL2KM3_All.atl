module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	self.roles->exists(r | not r.isNavigableFrom) or
	not self.superType.oclIsUndefined() or
	not self.subTypes->isEmpty() or
	not self.properties->isEmpty();

helper context DSL!DomainModel def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
	DSL!Relationship.allInstances()->collect(r | r.roles)->flatten()->select(r | r.source = c and not r.relation.needTurnOnClass());

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding and not self.relation.roles->at(1) = self;

rule Metamodel {
	from s : DSL!DomainModel
	to t : KM3!Metamodel (
		contents <- Sequence{mainPackage, primitiveTypesPackage}
	),
	mainPackage : KM3!Package (
		name <- s.name,
		contents <- s.classifiers->select(c | c.oclIsTypeOf(DSL!Class))
			->union(s.classifiers->select(c | c.oclIsTypeOf(DSL!Relationship) and c.needTurnOnClass()))
			->union(s.types)
	),
	primitiveTypesPackage : KM3!Package (
		name <- 'PrimitiveTypes',
		contents <- Sequence{stringType, integerType, booleanType}
	),
	stringType : KM3!DataType (
		name <- 'String'
	),
	integerType : KM3!DataType (
		name <- 'Integer'
	),
	booleanType : KM3!DataType (
		name <- 'Boolean'
	)
}

rule Class {
	from s : DSL!Class
	to t : KM3!Class (
		name <- s.name,
		package <- s.domainModel,
		isAbstract <- s.isAbstract,
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(thisModule.getRoles(s))
	)
}

rule Relation2Class {
	from s : DSL!Relationship (s.needTurnOnClass())
	to t : KM3!Class (
		name <- s.name,
		package <- s.domainModel,
		isAbstract <- s.isAbstract,
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(s.roles)
	)
}

rule SimpleReference {
	from s : DSL!Role (not s.relation.needTurnOnClass())
	to t : KM3!Reference (
		name <- s.name,
		owner <- s.source,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isOrdered <- s.isOrdered,
		isUnique <- true,
		type <- s.type,
		isContainer <- s.isEmbedding(),
		opposite <- s.relation.roles->select(r | r <> s)->first()
	)
}

rule ComplexReference {
	from s : DSL!Role (s.relation.needTurnOnClass())
	to t : KM3!Reference (
		name <- s.name,
		owner <- s.relation,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isOrdered <- s.isOrdered,
		isUnique <- true,
		type <- s.type,
		isContainer <- s.isEmbedding()
	)
}

rule Attribute {
	from s : DSL!ValueProperty
	to t : KM3!Attribute (
		name <- s.name,
		owner <- s.owner,
		lower <- 1,
		upper <- 1,
		isOrdered <- false,
		isUnique <- true,
		type <- s.type
	)
}

rule Enumeration {
	from s : DSL!Enumeration
	to t : KM3!Enumeration (
		name <- s.name,
		package <- s.domainModel,
		literals <- s.literals
	)
}

rule EnumLiteral {
	from s : DSL!EnumerationLiteral
	to t : KM3!EnumLiteral (
		name <- s.name,
		package <- s.eContainer().domainModel
	)
}

rule DataType {
	from s : DSL!SimpleType
	to t : KM3!DataType (
		name <- s.name,
		package <- s.domainModel
	)
}