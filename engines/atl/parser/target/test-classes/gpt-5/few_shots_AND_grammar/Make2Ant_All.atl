module Make2Ant;
create OUT : Ant from IN : Make;

helper context Make!Makefile def: allMacros : Sequence(Make!Macro) =
  self.elements->select(e | e.oclIsKindOf(Make!Macro))->collect(e | e.oclAsType(Make!Macro));

helper context Make!Makefile def: allRules : Sequence(Make!Rule) =
  self.elements->select(e | e.oclIsKindOf(Make!Rule))->collect(e | e.oclAsType(Make!Rule));

rule Makefile2Project {
  from src : Make!Makefile
  to   dst : Ant!Project (
    name      <- src.name,
    properties<- src.allMacros->collect(m | thisModule.Macro2Property(m)),
    targets   <- src.allRules->collect(r | thisModule.Rule2Target(r)),
    default   <- if src.allRules->notEmpty() then thisModule.Rule2Target(src.allRules->first()) else OclUndefined endif
  )
}

unique lazy rule Macro2Property {
  from src : Make!Macro
  to   dst : Ant!PropertyValue (
    name  <- src.name,
    value <- src.value
  )
}

unique lazy rule Rule2Target {
  from src : Make!Rule
  to   dst : Ant!Target (
    name    <- src.name,
    tasks   <- src.shellLines->collect(sl | if sl.display then
                                          Sequence{ thisModule.ShellLine2Task_Display_Echo(sl), thisModule.ShellLine2Task_Display_Exec(sl) }
                                        else
                                          Sequence{ thisModule.ShellLine2Task_NoDisplay_Exec(sl) }
                                        endif)->flatten(),
    depends <- src.dependencies->select(d | d.oclIsKindOf(Make!RuleDep))
                 ->collect(rd | thisModule.Rule2Target(rd.oclAsType(Make!RuleDep).ruledep))
  )
}

unique lazy rule ShellLine2Task_Display_Echo {
  from src : Make!ShellLine (src.display = true)
  to   dst : Ant!Echo (
    message <- src.command,
    target  <- thisModule.Rule2Target(src.ruleShellLine)
  )
}

unique lazy rule ShellLine2Task_Display_Exec {
  from src : Make!ShellLine (src.display = true)
  to   dst : Ant!Exec (
    executable <- src.command,
    dir        <- '',
    target     <- thisModule.Rule2Target(src.ruleShellLine)
  )
}

unique lazy rule ShellLine2Task_NoDisplay_Exec {
  from src : Make!ShellLine (src.display = false)
  to   dst : Ant!Exec (
    executable <- src.command,
    dir        <- '',
    target     <- thisModule.Rule2Target(src.ruleShellLine)
  )
}