module XML2DSL;

create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrVal(name : String) : String =
  self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->first().value;

helper context XML!Element def: getAttrBool(name : String) : Boolean =
  if self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->notEmpty() then
    let v : String = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->first().value in
      v = 'true' or v = '1' or v = 'yes'
  else
    false
  endif;

helper context XML!Element def: hasAttr(name : String) : Boolean =
  self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = name);

helper context XML!Element def: hasChildren() : Boolean =
  self.children->exists(c | c.oclIsTypeOf(XML!Element) or c.oclIsTypeOf(XML!Text));

helper context XML!Element def: get(name : String) : XML!Element =
  self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = name)->first().oclAsType(XML!Element);

helper context XML!Element def: getType() : String =
  if self.hasAttr('type') then
    self.getAttrVal('type')
  else
    ''
  endif;

helper context XML!Element def: getEnumId() : String =
  if self.hasAttr('id') then
    self.getAttrVal('id')
  else
    ''
  endif;

helper context XML!Element def: getText() : String =
  self.children->select(c | c.oclIsTypeOf(XML!Text))->collect(t | t.value)->iterate(s; acc : String = '' | acc + s);

helper context XML!Element def: getSeq(name : String) : Sequence(XML!Element) =
  self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = name)->collect(e | e.oclAsType(XML!Element));

helper context XML!Element def: isAbstract() : Boolean =
  self.getAttrBool('abstract');

helper def: dslElementsById() : Map(String, DSL!NamedElement) =
  Map{};

helper def: getSubTypes(name : String) : Sequence(DSL!Classifier) =
  OUT!Classifier.allInstances()->select(c | c.superType <> OclUndefined and c.superType.name = name);

helper def: findType(name : String) : DSL!Type =
  let sts : Sequence(DSL!SimpleType) = OUT!SimpleType.allInstances()->select(t | t.name = name) in
    if sts->notEmpty() then
      sts->first()
    else
      let ens : Sequence(DSL!Enumeration) = OUT!Enumeration.allInstances()->select(e | e.name = name) in
        if ens->notEmpty() then
          ens->first()
        else
          OclUndefined
        endif
      endif;

rule DomainModel {
  from
    r : XML!Root
  to
    dm : DSL!DomainModel (
      name <- 'DomainModel',
      identity <- 'DomainModel',
      namespace <- 'http://vitruv.tools/methodologisttemplate',
      isLoaded <- true,
      types <- Sequence{ stString, stInteger, stBoolean, stDefault }
    ),
    stString : DSL!SimpleType (
      name <- 'String',
      identity <- 'String',
      namespace <- 'http://vitruv.tools/methodologisttemplate/PrimitiveTypes'
    ),
    stInteger : DSL!SimpleType (
      name <- 'Integer',
      identity <- 'Integer',
      namespace <- 'http://vitruv.tools/methodologisttemplate/PrimitiveTypes'
    ),
    stBoolean : DSL!SimpleType (
      name <- 'Boolean',
      identity <- 'Boolean',
      namespace <- 'http://vitruv.tools/methodologisttemplate/PrimitiveTypes'
    ),
    stDefault : DSL!SimpleType (
      name <- 'Default',
      identity <- 'Default',
      namespace <- 'http://vitruv.tools/methodologisttemplate/PrimitiveTypes'
    )
}

rule Class {
  from
    e : XML!Element (e.name = 'class')
  to
    c : DSL!Class (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- 'http://vitruv.tools/methodologisttemplate',
      isLoaded <- true,
      isAbstract <- e.isAbstract(),
      domainModel <- DSL!DomainModel.allInstances()->first(),
      superType <- if e.hasAttr('super') then
                     OUT!Classifier.allInstances()->select(cl | cl.identity = e.getAttrVal('super'))->first()
                   else
                     OclUndefined
                   endif,
      subTypes <- thisModule.getSubTypes(e.getAttrVal('name')),
      properties <- e.getSeq('property')->collect(p | thisModule.resolveTemp(p, 'vp'))
    )
}

rule Relationship {
  from
    e : XML!Element (e.name = 'relationship')
  to
    r : DSL!Relationship (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- 'http://vitruv.tools/methodologisttemplate',
      isLoaded <- true,
      isAbstract <- e.isAbstract(),
      domainModel <- DSL!DomainModel.allInstances()->first(),
      isEmbedding <- e.getAttrBool('embedding'),
      roles <- Sequence{ thisModule.resolveTemp(e.getSeq('role')->first(), 'r1'),
                         thisModule.resolveTemp(e.getSeq('role')->at(2), 'r2') }
    )
}

rule Role {
  from
    e : XML!Element (e.name = 'role')
  to
    r1 : DSL!Role (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      min <- if e.hasAttr('min') then e.getAttrVal('min').toInteger() else 0 endif,
      max <- if e.hasAttr('max') then e.getAttrVal('max').toInteger() else 0 endif,
      isUnbounded <- e.getAttrBool('unbounded'),
      accepts <- if e.hasAttr('accepts') then e.getAttrVal('accepts') else '' endif,
      isOrdered <- e.getAttrBool('ordered'),
      isNavigableFrom <- e.getAttrBool('navigableFrom'),
      isPropertyGenerator <- e.getAttrBool('propertyGenerator'),
      source <- OUT!Classifier.allInstances()->select(c | c.identity = e.getAttrVal('source'))->first(),
      type <- OUT!Classifier.allInstances()->select(c | c.identity = e.getAttrVal('type'))->first(),
      relation <- OUT!Relationship.allInstances()->select(rel | rel.identity = e.getAttrVal('relation'))->first()
    ),
    r2 : DSL!Role (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id') + '_2',
      min <- if e.hasAttr('min') then e.getAttrVal('min').toInteger() else 0 endif,
      max <- if e.hasAttr('max') then e.getAttrVal('max').toInteger() else 0 endif,
      isUnbounded <- e.getAttrBool('unbounded'),
      accepts <- if e.hasAttr('accepts') then e.getAttrVal('accepts') else '' endif,
      isOrdered <- e.getAttrBool('ordered'),
      isNavigableFrom <- e.getAttrBool('navigableFrom'),
      isPropertyGenerator <- e.getAttrBool('propertyGenerator'),
      source <- OUT!Classifier.allInstances()->select(c | c.identity = e.getAttrVal('type'))->first(),
      type <- OUT!Classifier.allInstances()->select(c | c.identity = e.getAttrVal('source'))->first(),
      relation <- OUT!Relationship.allInstances()->select(rel | rel.identity = e.getAttrVal('relation'))->first()
    )
}

rule ValueProperty {
  from
    e : XML!Element (e.name = 'property')
  to
    vp : DSL!ValueProperty (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      owner <- OUT!Classifier.allInstances()->select(c | c.identity = e.getAttrVal('owner'))->first(),
      type <- thisModule.findType(e.getType())
    )
}

rule Enumeration {
  from
    e : XML!Element (e.name = 'enum')
  to
    en : DSL!Enumeration (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- 'http://vitruv.tools/methodologisttemplate',
      literals <- e.getSeq('literal')->collect(l | thisModule.resolveTemp(l, 'el'))
    )
}

rule EnumerationLiteral {
  from
    e : XML!Element (e.name = 'literal')
  to
    el : DSL!EnumerationLiteral (
      name <- e.getAttrVal('name'),
      identity <- e.getEnumId(),
      value <- if e.hasAttr('value') then e.getAttrVal('value').toInteger() else 0 endif
    )
}