module NetworkToGraph_All;

create OUT : Graph from IN : Network;

helper context Network!Component def: toEntity() : Graph!Entity =
	Graph!Entity.allInstances()->any(e | e.name = self.name)
		ifNull: thisModule.Component2Entity(self);

lazy rule Component2Entity {
	from
		c : Network!Component
	to
		e : Graph!Entity (
			name <- c.name
		)
}

rule System2Root {
	from
		s : Network!System
	to
		r : Graph!Root (
			entities <- s.components->collect(c | c.toEntity())
		)
}

rule Link2Link {
	from
		l : Network!Link
	to
		gl : Graph!Link (
			Entitys <- l.components->collect(c | c.toEntity())
		)
}