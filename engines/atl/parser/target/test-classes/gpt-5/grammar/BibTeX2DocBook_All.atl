module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context BibTex!BibTeXEntry def: buildEntryPara() : String =
    self.id.concat(' [').concat(self.oclType().name).concat('] ').concat(
        if self.oclIsKindOf(BibTex!TitledEntry) then
            'title=' .concat(self.oclAsType(BibTex!TitledEntry).title).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!AuthoredEntry) then
            'authors='
            .concat(self.oclAsType(BibTex!AuthoredEntry).authors->collect(a | a.author)->asSequence()->sortedBy(a | a)->iterate(s; acc : String = '' | 
                if acc = '' then s else acc.concat(', ').concat(s) endif
            )).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!DatedEntry) then
            'year=' .concat(self.oclAsType(BibTex!DatedEntry).year).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!BookTitledEntry) then
            'booktitle=' .concat(self.oclAsType(BibTex!BookTitledEntry).booktitle).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!ThesisEntry) then
            'school=' .concat(self.oclAsType(BibTex!ThesisEntry).school).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!Article) then
            'journal=' .concat(self.oclAsType(BibTex!Article).journal).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!Unpublished) then
            'note=' .concat(self.oclAsType(BibTex!Unpublished).note).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!Book) then
            'publisher=' .concat(self.oclAsType(BibTex!Book).publisher).concat(' ')
        else '' endif
    ).concat(
        if self.oclIsKindOf(BibTex!InBook) then
            'chapter='
            .concat(self.oclAsType(BibTex!InBook).chapter.toString()).concat(' ')
        else '' endif
    );

helper def: authorSet(inFile : BibTex!BibTeXFile) : Set(BibTex!Author) =
    inFile.entries->select(e | e.oclIsKindOf(BibTex!AuthoredEntry))
        ->collect(e | e.oclAsType(BibTex!AuthoredEntry).authors)
        ->flatten()
        ->asSet();

helper def: titledEntrySet(inFile : BibTex!BibTeXFile) : Set(BibTex!TitledEntry) =
    inFile.entries->select(e | e.oclIsKindOf(BibTex!TitledEntry))
        ->collect(e | e.oclAsType(BibTex!TitledEntry))
        ->asSet();

helper def: articleSet(inFile : BibTex!BibTeXFile) : Set(BibTex!Article) =
    inFile.entries->select(e | e.oclIsKindOf(BibTex!Article))
        ->collect(e | e.oclAsType(BibTex!Article))
        ->asSet();

rule Main {
    from
        b : BibTex!BibTeXFile
    to
        d : DocBook!DocBook (
            books <- Sequence{bk}
        ),
        bk : DocBook!Book (
            articles <- Sequence{art}
        ),
        art : DocBook!Article (
            title <- 'BibTeXML to DocBook',
            sections_1 <- Sequence{refsSect, authorsSect, titlesSect, journalsSect}
        ),
        refsSect : DocBook!Sect1 (
            title <- 'References List',
            paras <- b.entries->asSequence()->sortedBy(e | e.id)->collect(e |
                thisModule.buildRefPara(e)
            )
        ),
        authorsSect : DocBook!Sect1 (
            title <- 'Authors list',
            paras <- thisModule.authorSet(b)->asSequence()->sortedBy(a | a.author)->collect(a |
                resolveTemp(a, 'authPara')
            )
        ),
        titlesSect : DocBook!Sect1 (
            title <- 'Titles List',
            paras <- thisModule.titledEntrySet(b)->asSequence()->sortedBy(t | t.title)->collect(t |
                resolveTemp(t, 'titlePara')
            )
        ),
        journalsSect : DocBook!Sect1 (
            title <- 'Journals List',
            paras <- thisModule.articleSet(b)->asSequence()->sortedBy(j | j.journal)->collect(j |
                resolveTemp(j, 'journalPara')
            )
        )
}

helper def: buildRefPara(e : BibTex!BibTeXEntry) : DocBook!Para =
    OclUndefined;

lazy rule UntitledEntry {
    from
        e : BibTex!BibTeXEntry (
            not e.oclIsKindOf(BibTex!TitledEntry)
        )
    to
        refPara : DocBook!Para (
            content <- e.buildEntryPara()
        )
}

lazy rule TitledEntry_Title_NoArticle {
    from
        e : BibTex!TitledEntry (
            not e.oclIsKindOf(BibTex!Article) and
            thisModule.titledEntrySet(e.package.entries->first().package).includes(e)
        )
    to
        refPara : DocBook!Para (
            content <- e.buildEntryPara()
        ),
        titlePara : DocBook!Para (
            content <- e.title
        )
}

lazy rule TitledEntry_NoTitle_NoArticle {
    from
        e : BibTex!TitledEntry (
            not e.oclIsKindOf(BibTex!Article) and
            not thisModule.titledEntrySet(e.package.entries->first().package).includes(e)
        )
    to
        refPara : DocBook!Para (
            content <- e.buildEntryPara()
        )
}

lazy rule Article_Title_Journal {
    from
        a : BibTex!Article (
            thisModule.titledEntrySet(a.package.entries->first().package).includes(a) and
            thisModule.articleSet(a.package.entries->first().package).includes(a)
        )
    to
        refPara : DocBook!Para (
            content <- a.buildEntryPara()
        ),
        titlePara : DocBook!Para (
            content <- a.title
        ),
        journalPara : DocBook!Para (
            content <- a.journal
        )
}

lazy rule Article_NoTitle_Journal {
    from
        a : BibTex!Article (
            not thisModule.titledEntrySet(a.package.entries->first().package).includes(a) and
            thisModule.articleSet(a.package.entries->first().package).includes(a)
        )
    to
        refPara : DocBook!Para (
            content <- a.buildEntryPara()
        ),
        journalPara : DocBook!Para (
            content <- a.journal
        )
}

lazy rule Article_Title_NoJournal {
    from
        a : BibTex!Article (
            thisModule.titledEntrySet(a.package.entries->first().package).includes(a) and
            not thisModule.articleSet(a.package.entries->first().package).includes(a)
        )
    to
        refPara : DocBook!Para (
            content <- a.buildEntryPara()
        ),
        titlePara : DocBook!Para (
            content <- a.title
        )
}

lazy rule Article_NoTitle_NoJournal {
    from
        a : BibTex!Article (
            not thisModule.titledEntrySet(a.package.entries->first().package).includes(a) and
            not thisModule.articleSet(a.package.entries->first().package).includes(a)
        )
    to
        refPara : DocBook!Para (
            content <- a.buildEntryPara()
        )
}

lazy rule Author {
    from
        a : BibTex!Author
    to
        authPara : DocBook!Para (
            content <- a.author
        )
}

rule BuildRefParas {
    from
        e : BibTex!BibTeXEntry
    to
        p : DocBook!Para (
            content <- e.buildEntryPara()
        )
}