module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper def : rationale : String =
  let r : IEEE1471!Rationale = IEEE1471!Rationale.allInstances()->first() in
  if not r.oclIsUndefined() then
    r.name + ' ' + r.content
  else
    ''
  endif;

rule IEEE1471Model2MoDAFModel {
  from src : IEEE1471!IEEE1471Model
  to dst : MoDAF!MoDAFModel (
    name <- src.name,
    content <- src.content,
    enterprise <- src.system,
    environment <- src.environment,
    operationalMissions <- src.missions,
    architectures <- src.architecture,
    architecturalDescription <- Sequence{src.architecturalDescription},
    stakeholders <- src.stakeholders,
    stakeholderHasConcerns <- src.stakeholders->collect(s | s.has->collect(c | thisModule.StakeholderHasConcern(s, c)))->flatten(),
    architecturalFrameworks <- Sequence{thisModule.DefaultArchitecturalFramework(src)}
  )
}

lazy rule DefaultArchitecturalFramework {
  from src : IEEE1471!IEEE1471Model
  to af : MoDAF!ArchitecturalFramework (
    name <- 'DefaultArchitecturalFramework',
    content <- '',
    ownedMember <- src.viewpoints->select(vp | vp.hasSource.oclIsUndefined())
  )
}

rule System2Enterprise {
  from src : IEEE1471!System
  to dst : MoDAF!Enterprise (
    name <- src.name,
    content <- src.content,
    inhabits <- src.inhabits,
    fulfills <- src.fulfills
  )
}

rule Environment2Environment {
  from src : IEEE1471!Environment
  to dst : MoDAF!Environment (
    name <- src.name,
    content <- src.content,
    influences <- src.influences
  )
}

rule Mission2OperationalMission {
  from src : IEEE1471!Mission
  to dst : MoDAF!OperationalMission (
    name <- src.name,
    content <- src.content
  )
}

rule Architecture2Architecture {
  from src : IEEE1471!Architecture
  to dst : MoDAF!Architecture (
    name <- src.name,
    content <- src.content,
    describedBy <- src.describedBy
  )
}

rule AD2AD {
  from src : IEEE1471!ArchitecturalDescription
  to dst : MoDAF!ArchitecturalDescription (
    name <- src.name,
    content <- src.content,
    approvialAuthority <- '',
    architect <- '',
    assumptionAndConstraints <- '',
    creatingOrganisation <- '',
    dateCompleted <- '',
    purpose <- '',
    recommendations <- '',
    summaryOfFindings <- thisModule.rationale,
    tollsUsed <- '',
    viewpoints <- src.selects,
    products <- src.organizedBy
  )
}

rule Stakeholder2Stakeholder {
  from src : IEEE1471!Stakeholder
  to dst : MoDAF!Stakeholder (
    name <- src.name,
    content <- src.content
  )
}

rule Viewpoint2View {
  from src : IEEE1471!Viewpoint
  to dst : MoDAF!View (
    name <- src.name,
    content <- src.content,
    framework <- '',
    frameworkWebsite <- '',
    viewCode <- '',
    viewDescription <- '',
    viewName <- src.name,
    definingFramework <- src.hasSource,
    usedToCover <- src.usedToCover
  )
}

rule View2ArchitecturalProduct {
  from src : IEEE1471!View
  to dst : MoDAF!ArchitecturalProduct (
    name <- src.name,
    content <- src.content,
    description <- '',
    architecturalElements <- src.consitsOf,
    definingView <- src.conformsTo
  )
}

rule Model2Element {
  from src : IEEE1471!Model
  to dst : MoDAF!Elements (
    name <- src.name,
    content <- src.content
  )
}

rule Concern2Concern {
  from src : IEEE1471!Concern
  to dst : MoDAF!Concern (
    name <- src.name,
    content <- src.content
  )
}

rule LibraryViewpoint2ArchitecturalFramework {
  from src : IEEE1471!LibraryViewpoint
  to dst : MoDAF!ArchitecturalFramework (
    name <- src.name,
    content <- src.content,
    ownedMember <- IEEE1471!Viewpoint.allInstances()->select(vp | vp.hasSource = src)
  )
}

lazy rule StakeholderHasConcern {
  from src_stakeholder : IEEE1471!Stakeholder, src_concern : IEEE1471!Concern
  to dst : MoDAF!StakeholderHasConcern (
    client <- src_stakeholder,
    supplier <- src_concern,
    owner <- IEEE1471!IEEE1471Model.allInstances()->first()
  )
}
