module PetriNet2Grafcet;
create OUT : Grafcet from IN : PetriNet;

rule Grafcet {
  from
    src : PetriNet!PetriNet
  to
    tgt : Grafcet!Grafcet (
      location <- src.location,
      name <- src.name,
      elements <- src.elements,
      connections <- src.arcs
    )
}

rule Step {
  from
    src : PetriNet!Place
  to
    tgt : Grafcet!Step (
      location <- src.location,
      name <- src.name,
      grafcet <- src.net,
      incomingConnections <- src.incomingArc,
      outgoingConnections <- src.outgoingArc,
      isInitial <- false,
      isActive <- false
    )
}

rule Transition {
  from
    src : PetriNet!Transition
  to
    tgt : Grafcet!Transition (
      location <- src.location,
      name <- src.name,
      grafcet <- src.net,
      incomingConnections <- src.incomingArc,
      outgoingConnections <- src.outgoingArc
    )
}

rule StepToTransition {
  from
    src : PetriNet!PlaceToTransition
  to
    tgt : Grafcet!StepToTransition (
      location <- src.location,
      name <- src.name,
      grafcet <- src.net,
      from <- src.from,
      to <- src.to
    )
}

rule TransitionToStep {
  from
    src : PetriNet!TransitionToPlace
  to
    tgt : Grafcet!TransitionToStep (
      location <- src.location,
      name <- src.name,
      grafcet <- src.net,
      from <- src.from,
      to <- src.to
    )
}
