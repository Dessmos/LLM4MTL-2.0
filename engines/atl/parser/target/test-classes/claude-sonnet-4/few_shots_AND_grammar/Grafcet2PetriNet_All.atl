module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
from
g : Grafcet!Grafcet
to
pn : PetriNet!PetriNet (
location <- g.location,
name <- g.name,
elements <- g.elements,
arcs <- g.connections
)
}

rule Place {
from
s : Grafcet!Step
to
p : PetriNet!Place (
location <- s.location,
name <- s.name,
net <- s.grafcet,
incomingArc <- s.incomingConnections,
outgoingArc <- s.outgoingConnections
)
}

rule Transition {
from
t : Grafcet!Transition
to
tr : PetriNet!Transition (
location <- t.location,
name <- t.name,
net <- t.grafcet,
incomingArc <- t.incomingConnections,
outgoingArc <- t.outgoingConnections
)
}

rule PlaceToTransition {
from
stt : Grafcet!StepToTransition
to
ptt : PetriNet!PlaceToTransition (
location <- stt.location,
name <- stt.name,
net <- stt.grafcet,
from <- stt.from,
to <- stt.to
)
}

rule TransitionToPlace {
from
tts : Grafcet!TransitionToStep
to
ttp : PetriNet!TransitionToPlace (
location <- tts.location,
name <- tts.name,
net <- tts.grafcet,
from <- tts.from,
to <- tts.to
)
}
