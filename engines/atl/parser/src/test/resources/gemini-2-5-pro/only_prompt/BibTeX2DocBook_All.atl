-- @atlcompiler emftvm
module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context BibTeX!BibTeXEntry def: buildEntryPara() : String =
	self.id + ' (' + self.oclType().name + '): ' +
	(if self.oclIsKindOf(BibTeX!TitledEntry) then 'title="' + self.oclAsType(BibTeX!TitledEntry).title + '" ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!AuthoredEntry) and not self.oclAsType(BibTeX!AuthoredEntry).authors->isEmpty() then 'authors=' + self.oclAsType(BibTeX!AuthoredEntry).authors->collect(a | a.author)->iterate(a; acc : String = '' | acc + if acc = '' then '' else ', ' endif + a) + ' ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!DatedEntry) then 'year=' + self.oclAsType(BibTeX!DatedEntry).year + ' ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!BookTitledEntry) then 'booktitle="' + self.oclAsType(BibTeX!BookTitledEntry).booktitle + '" ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!ThesisEntry) then 'school="' + self.oclAsType(BibTeX!ThesisEntry).school + '" ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!Article) then 'journal="' + self.oclAsType(BibTeX!Article).journal + '" ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!Unpublished) then 'note="' + self.oclAsType(BibTeX!Unpublished).note + '" ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!Book) then 'publisher="' + self.oclAsType(BibTeX!Book).publisher + '" ' else '' endif) +
	(if self.oclIsKindOf(BibTeX!InBook) then 'chapter=' + self.oclAsType(BibTeX!InBook).chapter.toString() + ' ' else '' endif);

helper def: authorSet() : Set(BibTeX!Author) =
	BibTeX!AuthoredEntry.allInstances().authors->iterate(a; acc : Set(BibTeX!Author) = Set{} | if acc->exists(e | e.author = a.author) then acc else acc->including(a) endif);

helper def: titledEntrySet() : Set(BibTeX!TitledEntry) =
	BibTeX!TitledEntry.allInstances()->asSet();

helper def: articleSet() : Set(BibTeX!Article) =
	BibTeX!Article.allInstances()->select(a | not a.journal.oclIsUndefined())->asSet();

rule Main {
	from bib : BibTeX!BibTeXFile
	to
		docbook : DocBook!DocBook (
			books <- Sequence{book}
		),
		book : DocBook!Book (
			articles <- Sequence{article}
		),
		article : DocBook!Article (
			title <- 'BibTeXML to DocBook',
			sections_1 <- Sequence{references, authors, titles, journals}
		),
		references : DocBook!Sect1 (
			title <- 'References List',
			paras <- bib.entries->sortBy(e | e.id)->collect(e | thisModule.resolveTemp(e, 'entryPara'))
		),
		authors : DocBook!Sect1 (
			title <- 'Authors list',
			paras <- thisModule.authorSet()->sortedBy(a | a.author)->collect(a | thisModule.resolveTemp(a, 'authorPara'))
		),
		titles : DocBook!Sect1 (
			title <- 'Titles List',
			paras <- thisModule.titledEntrySet()->sortedBy(e | e.title)->collect(e | thisModule.resolveTemp(e, 'titlePara'))
		),
		journals : DocBook!Sect1 (
			title <- 'Journals List',
			paras <- thisModule.articleSet()->sortedBy(a | a.journal)->collect(a | thisModule.resolveTemp(a, 'journalPara'))
		)
}

rule Author {
	from a : BibTeX!Author (thisModule.authorSet()->includes(a))
	to
		authorPara : DocBook!Para (
			content <- a.author
		)
}

rule UntitledEntry {
	from e : BibTeX!BibTeXEntry (not e.oclIsKindOf(BibTeX!TitledEntry))
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule TitledEntry_Title_NoArticle {
	from e : BibTeX!TitledEntry (not e.oclIsKindOf(BibTeX!Article) and thisModule.titledEntrySet()->includes(e))
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		),
		titlePara : DocBook!Para (
			content <- e.title
		)
}

rule TitledEntry_NoTitle_NoArticle {
	from e : BibTeX!TitledEntry (not e.oclIsKindOf(BibTeX!Article) and not thisModule.titledEntrySet()->includes(e))
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule Article_Title_Journal {
	from a : BibTeX!Article (thisModule.titledEntrySet()->includes(a) and thisModule.articleSet()->includes(a))
	to
		entryPara : DocBook!Para (
			content <- a.buildEntryPara()
		),
		titlePara : DocBook!Para (
			content <- a.title
		),
		journalPara : DocBook!Para (
			content <- a.journal
		)
}

rule Article_NoTitle_Journal {
	from a : BibTeX!Article (not thisModule.titledEntrySet()->includes(a) and thisModule.articleSet()->includes(a))
	to
		entryPara : DocBook!Para (
			content <- a.buildEntryPara()
		),
		journalPara : DocBook!Para (
			content <- a.journal
		)
}

rule Article_Title_NoJournal {
	from a : BibTeX!Article (thisModule.titledEntrySet()->includes(a) and not thisModule.articleSet()->includes(a))
	to
		entryPara : DocBook!Para (
			content <- a.buildEntryPara()
		),
		titlePara : DocBook!Para (
			content <- a.title
		)
}

rule Article_NoTitle_NoJournal {
	from a : BibTeX!Article (not thisModule.titledEntrySet()->includes(a) and not thisModule.articleSet()->includes(a))
	to
		entryPara : DocBook!Para (
			content <- a.buildEntryPara()
		)
}