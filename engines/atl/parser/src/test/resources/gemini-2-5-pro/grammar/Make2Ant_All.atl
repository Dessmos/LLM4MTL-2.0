module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		m : Make!Makefile
	to
		p : Ant!Project (
			name <- m.name,
			properties <- m.elements->select(e | e.oclIsTypeOf(Make!Macro)),
			targets <- m.elements->select(e | e.oclIsTypeOf(Make!Rule)),
			default <- m.elements->select(e | e.oclIsTypeOf(Make!Rule))->first()
		)
}

rule Macro2Property {
	from
		m : Make!Macro
	to
		p : Ant!PropertyValue (
			name <- m.name,
			value <- m.value
		)
}

rule Rule2Target {
	from
		r : Make!Rule
	to
		t : Ant!Target (
			name <- r.name,
			tasks <- r.shellLines,
			depends <- r.dependencies->select(d | d.oclIsTypeOf(Make!RuleDep))->collect(d | d.oclAsType(Make!RuleDep).ruledep)
		)
}

rule ShellLine2Task_Display {
	from
		sl : Make!ShellLine (
			sl.display = true
		)
	to
		echo : Ant!Echo (
			message <- sl.command,
			target <- sl.ruleShellLine
		),
		exec : Ant!Exec (
			executable <- sl.command,
			target <- sl.ruleShellLine
		)
}

rule ShellLine2Task_NoDisplay {
	from
		sl : Make!ShellLine (
			sl.display = false
		)
	to
		exec : Ant!Exec (
			executable <- sl.command,
			target <- sl.ruleShellLine
		)
}