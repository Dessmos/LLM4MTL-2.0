module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Node def: statement(): CPL!Node =
	if self.oclIsKindOf(CPL!NodeContainer) then
		self.oclAsType(CPL!NodeContainer).contents
	else
		self
	endif;

helper context CPL!Proxy def: locations(): Sequence(CPL!Location) =
	let nodes : Sequence(CPL!Node) =
		Sequence{self.busy, self.noAnswer, self.redirection, self.failure, self.default}->
			select(c | not c.oclIsUndefined())->
			collect(c | c.statement())
	in
		nodes->select(n | n.oclIsTypeOf(CPL!Location))->
			oclAsType(Sequence(CPL!Location));

helper context CPL!Proxy def: isSimple(): Boolean =
	self.busy.oclIsUndefined() and
	self.noAnswer.oclIsUndefined() and
	self.redirection.oclIsUndefined() and
	self.failure.oclIsUndefined() and
	not self.default.oclIsUndefined() and
	self.default.statement().oclIsTypeOf(CPL!Location);

rule CPL2Program {
	from s : CPL!CPL
	to t : SPL!Program (
		service <- serv
	),
	serv : SPL!Service (
		name <- 'cplService',
		declarations <- s.subActions,
		sessions <- s.incoming->union(s.outgoing)
	)
}

rule SubAction2Function {
	from s : CPL!SubAction
	to t : SPL!LocalFunctionDeclaration (
		name <- s.id,
		returnType <- vt,
		statements <- Sequence{s.contents}
	),
	vt : SPL!SimpleType (
		type <- #void
	)
}

rule Incoming2Method {
	from s : CPL!Incoming
	to t : SPL!Method (
		type <- vt,
		direction <- #in,
		methodName <- mn,
		statements <- Sequence{s.contents}
	),
	vt : SPL!SimpleType (
		type <- #void
	),
	mn : SPL!SIPMethodName (
		name <- #INVITE
	)
}

rule Proxy2Return {
	from s : CPL!Proxy (s.isSimple())
	to t : SPL!ReturnStat (
		returnedValue <- thisModule.Location2URIConstant(s.locations()->first())
	)
}

rule Proxy2Select {
	from s : CPL!Proxy (not s.isSimple())
	to t : SPL!SelectStat (
		matchedExp <- rsn,
		selectCases <- Sequence{s.busy, s.noAnswer, s.redirection}->select(e | not e.oclIsUndefined()),
		selectDefault <- s.default
	),
	rsn : SPL!ReasonExp
}

rule Busy2SelectCase {
	from s : CPL!Busy
	to t : SPL!SelectCase (
		values <- Sequence{rc1, rc2},
		statements <- Sequence{s.contents}
	),
	rc1 : SPL!ResponseConstant (
		response <- r1
	),
	r1 : SPL!ClientErrorResponse (
		errorKind <- #BUSY_HERE
	),
	rc2 : SPL!ResponseConstant (
		response <- r2
	),
	r2 : SPL!GlobalErrorResponse (
		errorKind <- #BUSY_EVERYWHERE
	)
}

rule NoAnswer2SelectCase {
	from s : CPL!NoAnswer
	to t : SPL!SelectCase (
		values <- Sequence{rc},
		statements <- Sequence{s.contents}
	),
	rc : SPL!ResponseConstant (
		response <- r
	),
	r : SPL!ClientErrorResponse (
		errorKind <- #REQUEST_TIMEOUT
	)
}

rule Redirection2SelectCase {
	from s : CPL!Redirection
	to t : SPL!SelectCase (
		values <- Sequence{rc1, rc2},
		statements <- Sequence{s.contents}
	),
	rc1 : SPL!ResponseConstant (
		response <- r1
	),
	r1 : SPL!RedirectionErrorResponse (
		errorKind <- #MOVED_PERMANENTLY
	),
	rc2 : SPL!ResponseConstant (
		response <- r2
	),
	r2 : SPL!RedirectionErrorResponse (
		errorKind <- #MOVED_TEMPORARILY
	)
}

rule Default2SelectDefault {
	from s : CPL!Default
	to t : SPL!SelectDefault (
		statements <- Sequence{s.contents}
	)
}

rule SubCall2Return {
	from s : CPL!SubCall
	to t : SPL!ReturnStat (
		returnedValue <- fce
	),
	fce : SPL!FunctionCallExp (
		functionCall <- fc
	),
	fc : SPL!FunctionCall (
		function <- CPL!SubAction.allInstances()->select(sa | sa.id = s.ref)->first()
	)
}

rule Redirect2Return {
	from s : CPL!Redirect
	to t : SPL!ReturnStat (
		returnedValue <- thisModule.Location2URIConstant(s.eContainer().oclAsType(CPL!NodeContainer).contents->select(n | n.oclIsTypeOf(CPL!Location))->first())
	)
}

rule AddressSwitch2SelectStat {
	from s : CPL!AddressSwitch
	to t : SPL!SelectStat (
		matchedExp <- hp,
		selectCases <- s.addresses,
		selectDefault <- s.otherwise
	),
	hp : SPL!SIPHeaderPlace (
		header <- s.field.toUpperCase().oclAsType(SPL!SIPHeader)
	)
}

rule SwitchedAddress2SelectCase {
	from s : CPL!SwitchedAddress
	to t : SPL!SelectCase (
		values <- Sequence{uc},
		statements <- Sequence{s.contents}
	),
	uc : SPL!URIConstant (
		uri <- if not s.is.oclIsUndefined() then
				s.is
			else if not s.contains.oclIsUndefined() then
				s.contains
			else
				s.subDomainOf
			endif endif
	)
}

rule Otherwise2SelectDefault {
	from s : CPL!Otherwise
	to t : SPL!SelectDefault (
		statements <- Sequence{s.contents}
	)
}

lazy rule Location2URIConstant {
	from s : CPL!Location
	to t : SPL!URIConstant (
		uri <- s.url
	)
}