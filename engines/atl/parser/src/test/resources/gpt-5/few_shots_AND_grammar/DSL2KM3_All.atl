module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
  self.roles->exists(r | r.isPropertyGenerator) or
  self.superType <> OclUndefined or
  self.subTypes->notEmpty() or
  self.properties->notEmpty();

helper def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
  DSL!Role.allInstances()
    ->select(r | r.source = c and r.isNavigableFrom and not r.relation.needTurnOnClass());

helper context DSL!Role def: isEmbedding() : Boolean =
  self.relation.isEmbedding;

rule Metamodel {
  from dm : DSL!DomainModel
  to mm : KM3!Metamodel (
       location <- dm.location,
       contents <- Sequence{ mainPkg, primPkg }
     ),
     mainPkg : KM3!Package (
       name <- dm.name,
       location <- dm.location,
       metamodel <- mm,
       contents <- 
         dm.classifiers->select(e | e.oclIsKindOf(DSL!Class))->collect(e | thisModule.resolveTemp(e,'outClass'))
         ->union(
           dm.classifiers->select(e | e.oclIsKindOf(DSL!Relationship) and e.needTurnOnClass())
                          ->collect(e | thisModule.resolveTemp(e,'relClass'))
         )
         ->union(
           dm.types->select(t | t.oclIsKindOf(DSL!Enumeration))->collect(t | thisModule.resolveTemp(t,'outEnum'))
         )
         ->union(
           dm.types->select(t | t.oclIsKindOf(DSL!SimpleType))->collect(t | thisModule.resolveTemp(t,'outDT'))
         )
     ),
     primPkg : KM3!Package (
       name <- 'PrimitiveTypes',
       location <- dm.location,
       metamodel <- mm,
       contents <- Sequence{ boolDT, intDT, stringDT }
     ),
     boolDT : KM3!DataType (
       name <- 'Boolean',
       location <- dm.location,
       package <- primPkg
     ),
     intDT : KM3!DataType (
       name <- 'Integer',
       location <- dm.location,
       package <- primPkg
     ),
     stringDT : KM3!DataType (
       name <- 'String',
       location <- dm.location,
       package <- primPkg
     )
}

rule Class {
  from c : DSL!Class
  to outClass : KM3!Class (
       name <- c.name,
       location <- c.location,
       package <- thisModule.getMainPackage(c.domainModel),
       isAbstract <- c.isAbstract,
       supertypes <- 
         if c.superType.oclIsUndefined() then
           Sequence{}
         else
           Sequence{ thisModule.resolveTemp(c.superType,'outClass') }
         endif,
       structuralFeatures <- 
         c.properties->collect(p | thisModule.resolveTemp(p,'outAttr'))
         ->union(thisModule.getRoles(c)->collect(r | thisModule.resolveTemp(r,'outRef')))
     )
}

rule Relation2Class {
  from r : DSL!Relationship ( r.needTurnOnClass() )
  to relClass : KM3!Class (
       name <- r.name,
       location <- r.location,
       package <- thisModule.getMainPackage(r.domainModel),
       isAbstract <- r.isAbstract,
       supertypes <- 
         if r.superType.oclIsUndefined() then
           Sequence{}
         else
           Sequence{ thisModule.resolveTemp(r.superType,'relClass') }
         endif,
       structuralFeatures <- 
         r.properties->collect(p | thisModule.resolveTemp(p,'outAttr'))
         ->union(r.roles->collect(role | thisModule.resolveTemp(role,'outRef')))
     )
}

rule SimpleReference {
  from r : DSL!Role (
    not r.relation.needTurnOnClass()
  )
  to outRef : KM3!Reference (
       name <- r.name,
       location <- r.location,
       owner <- thisModule.resolveTemp(r.source,'outClass'),
       type <- thisModule.resolveTemp(r.type,'outClass'),
       lower <- r.min,
       upper <- if r.isUnbounded then -1 else r.max endif,
       isOrdered <- r.isOrdered,
       isUnique <- true,
       isContainer <- r.isEmbedding(),
       opposite <- if r.relation.roles->size() = 2 then
                     let other : DSL!Role = r.relation.roles->any(o | o <> r) in
                       if other.isNavigableFrom then
                         thisModule.resolveTemp(other,'outRef')
                       else
                         OclUndefined
                       endif
                   else
                     OclUndefined
                   endif
     )
}

rule ComplexReference {
  from r : DSL!Role (
    r.relation.needTurnOnClass()
  )
  to outRef : KM3!Reference (
       name <- r.name,
       location <- r.location,
       owner <- thisModule.resolveTemp(r.source,'outClass'),
       type <- thisModule.resolveTemp(r.relation,'relClass'),
       lower <- r.min,
       upper <- if r.isUnbounded then -1 else r.max endif,
       isOrdered <- r.isOrdered,
       isUnique <- true,
       isContainer <- r.isEmbedding(),
       opposite <- if r.relation.roles->size() = 2 then
                     let other : DSL!Role = r.relation.roles->any(o | o <> r) in
                       if other.isNavigableFrom then
                         thisModule.resolveTemp(other,'outRef')
                       else
                         OclUndefined
                       endif
                   else
                     OclUndefined
                   endif
     )
}

rule Attribute {
  from vp : DSL!ValueProperty
  to outAttr : KM3!Attribute (
       name <- vp.name,
       location <- vp.location,
       owner <- thisModule.resolveClassifierForPropertyOwner(vp.owner),
       type <- thisModule.resolveType(vp.type),
       lower <- 0,
       upper <- 1,
       isOrdered <- false,
       isUnique <- true
     )
}

rule Enumeration {
  from e : DSL!Enumeration
  to outEnum : KM3!Enumeration (
       name <- e.name,
       location <- e.location,
       package <- thisModule.getMainPackage(e.domainModel),
       literals <- e.literals->collect(l | thisModule.resolveTemp(l,'outLit'))
     )
}

rule EnumLiteral {
  from l : DSL!EnumerationLiteral
  to outLit : KM3!EnumLiteral (
       name <- l.name,
       location <- l.location,
       package <- thisModule.getMainPackage(l.value.oclAsType(DSL!Enumeration).domainModel)
     )
}

rule DataType {
  from st : DSL!SimpleType
  to outDT : KM3!DataType (
       name <- st.name,
       location <- st.location,
       package <- thisModule.getMainPackage(st.domainModel)
     )
}

helper def: getMainPackage(dm : DSL!DomainModel) : KM3!Package =
  KM3!Package.allInstances()->any(p | p.metamodel.contents->includes(p) and p.name = dm.name);

helper def: resolveClassifierForPropertyOwner(c : DSL!Classifier) : KM3!Class =
  if c.oclIsKindOf(DSL!Class) then
    thisModule.resolveTemp(c.oclAsType(DSL!Class),'outClass')
  else
    thisModule.resolveTemp(c.oclAsType(DSL!Relationship),'relClass')
  endif;

helper def: resolveType(t : DSL!Type) : KM3!Classifier =
  if t.oclIsKindOf(DSL!SimpleType) then
    thisModule.resolveTemp(t.oclAsType(DSL!SimpleType),'outDT')
  else
    if t.oclIsKindOf(DSL!Enumeration) then
      thisModule.resolveTemp(t.oclAsType(DSL!Enumeration),'outEnum')
    else
      OclUndefined
    endif
  endif;