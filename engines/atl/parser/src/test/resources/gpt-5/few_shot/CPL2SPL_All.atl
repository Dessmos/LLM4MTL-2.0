module CPL2SPL;

create OUT : SPL from IN : CPL;

helper context CPL!Node def : statement : CPL!Node =
  if self.oclIsKindOf(CPL!NodeContainer) and not self.oclAsType(CPL!NodeContainer).contents.oclIsUndefined() then
    self.oclAsType(CPL!NodeContainer).contents.statement
  else
    self
  endif;

helper context CPL!Node def : locations : Sequence(CPL!Location) =
  if self.oclIsKindOf(CPL!Location) then
    Sequence{ self.oclAsType(CPL!Location) }->union(
      if self.oclIsKindOf(CPL!NodeContainer) and not self.oclAsType(CPL!NodeContainer).contents.oclIsUndefined() then
        self.oclAsType(CPL!NodeContainer).contents.locations
      else
        Sequence{}
      endif
    )
  else
    if self.oclIsKindOf(CPL!NodeContainer) and not self.oclAsType(CPL!NodeContainer).contents.oclIsUndefined() then
      self.oclAsType(CPL!NodeContainer).contents.locations
    else
      Sequence{}
    endif
  endif;

helper context CPL!Proxy def : isSimple : Boolean =
  self.busy.oclIsUndefined()
  and self.noAnswer.oclIsUndefined()
  and self.redirection.oclIsUndefined()
  and self.failure.oclIsUndefined()
  and self.default.oclIsUndefined();

rule CPL2Program {
  from
    c : CPL!CPL
  to
    p : SPL!Program (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      service <- s
    ),
    s : SPL!Service (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      name <- 'CPLService',
      declarations <- c.subActions->collect(sa | thisModule.SubAction2Function(sa)),
      sessions <- Sequence{ d_incoming }
    ),
    d_incoming : SPL!Dialog (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      declarations <- Sequence{},
      methods <- Sequence{ m_incoming }
    ),
    m_incoming : SPL!Method (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      type <- t_void,
      direction <- Enum!Direction#in,
      methodName <- mn_invite,
      arguments <- Sequence{},
      statements <- Sequence{},
      branches <- Sequence{}
    ),
    t_void : SPL!SimpleType (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      type <- Enum!PrimitiveType#void
    ),
    mn_invite : SPL!SIPMethodName (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      name <- Enum!SIPMethod#INVITE
    )
}

lazy rule SubAction2Function {
  from
    sa : CPL!SubAction
  to
    f : SPL!LocalFunctionDeclaration (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      name <- sa.id,
      returnType <- t_void,
      arguments <- Sequence{},
      statements <- sa.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(sa.contents.statement) }
    ),
    t_void : SPL!SimpleType (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      type <- Enum!PrimitiveType#void
    )
}

lazy rule Incoming2Method {
  from
    inc : CPL!Incoming
  to
    m : SPL!Method (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      type <- t_void,
      direction <- Enum!Direction#in,
      methodName <- mn_invite,
      arguments <- Sequence{},
      statements <- inc.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(inc.contents.statement) },
      branches <- Sequence{}
    ),
    t_void : SPL!SimpleType (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      type <- Enum!PrimitiveType#void
    ),
    mn_invite : SPL!SIPMethodName (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      name <- Enum!SIPMethod#INVITE
    )
}

lazy rule Proxy2Return {
  from
    p : CPL!Proxy (p.isSimple)
  to
    r : SPL!ReturnStat (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      returnedValue <- if p.locations()->isEmpty() then OclUndefined else thisModule.locationsToSequenceConstant(p.locations()) endif,
      branch <- OclUndefined
    )
}

lazy rule Proxy2Select {
  from
    p : CPL!Proxy (not p.isSimple)
  to
    s : SPL!SelectStat (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      matchedExp <- me,
      selectCases <- Sequence{
        if not p.busy.oclIsUndefined() then thisModule.Busy2SelectCase(p.busy) else OclUndefined endif,
        if not p.noAnswer.oclIsUndefined() then thisModule.NoAnswer2SelectCase(p.noAnswer) else OclUndefined endif,
        if not p.redirection.oclIsUndefined() then thisModule.Redirection2SelectCase(p.redirection) else OclUndefined endif
      }->excluding(OclUndefined),
      selectDefault <- if p.default.oclIsUndefined() then OclUndefined else thisModule.Default2SelectDefault(p.default) endif
    ),
    me : SPL!Expression (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{}
    )
}

lazy rule Busy2SelectCase {
  from
    b : CPL!Busy
  to
    sc : SPL!SelectCase (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      values <- Sequence{ rc },
      statements <- b.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(b.contents.statement) }
    ),
    rc : SPL!ResponseConstant (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      response <- cer
    ),
    cer : SPL!ClientErrorResponse (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      errorKind <- Enum!ClientErrorKind#BUSY_HERE
    )
}

lazy rule NoAnswer2SelectCase {
  from
    n : CPL!NoAnswer
  to
    sc : SPL!SelectCase (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      values <- Sequence{ rc },
      statements <- n.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(n.contents.statement) }
    ),
    rc : SPL!ResponseConstant (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      response <- cer
    ),
    cer : SPL!ClientErrorResponse (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      errorKind <- Enum!ClientErrorKind#REQUEST_TIMEOUT
    )
}

lazy rule Redirection2SelectCase {
  from
    rsrc : CPL!Redirection
  to
    sc : SPL!SelectCase (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      values <- Sequence{ rc },
      statements <- rsrc.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(rsrc.contents.statement) }
    ),
    rc : SPL!ResponseConstant (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      response <- rerr
    ),
    rerr : SPL!RedirectionErrorResponse (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      errorKind <- Enum!RedirectionErrorKind#MOVED_TEMPORARILY
    )
}

lazy rule Default2SelectDefault {
  from
    d : CPL!Default
  to
    sd : SPL!SelectDefault (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      statements <- d.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(d.contents.statement) }
    )
}

lazy rule SubCall2Return {
  from
    sc : CPL!SubCall
  to
    r : SPL!ReturnStat (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      returnedValue <- OclUndefined,
      branch <- OclUndefined
    )
}

lazy rule Redirect2Return {
  from
    rd : CPL!Redirect
  to
    r : SPL!ReturnStat (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      returnedValue <- OclUndefined,
      branch <- OclUndefined
    )
}

lazy rule AddressSwitch2SelectStat {
  from
    asw : CPL!AddressSwitch
  to
    ss : SPL!SelectStat (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      matchedExp <- mexp,
      selectCases <- asw.addresses->collect(a | thisModule.SwitchedAddress2SelectCase(a)),
      selectDefault <- if asw.otherwise.oclIsUndefined() then OclUndefined else thisModule.Otherwise2SelectDefault(asw.otherwise) endif
    ),
    mexp : SPL!Expression (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{}
    )
}

lazy rule SwitchedAddress2SelectCase {
  from
    sa : CPL!SwitchedAddress
  to
    sc : SPL!SelectCase (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      values <- Sequence{ thisModule.Location2URIConstant(sa.contents.locations->first()) },
      statements <- sa.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(sa.contents.statement) }
    )
}

lazy rule Otherwise2SelectDefault {
  from
    o : CPL!Otherwise
  to
    sd : SPL!SelectDefault (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      statements <- o.contents.statement.oclIsUndefined()
        ? Sequence{}
        : Sequence{ thisModule.statementToStatement(o.contents.statement) }
    )
}

lazy rule Location2URIConstant {
  from
    l : CPL!Location
  to
    uc : SPL!URIConstant (
      location <- '',
      commentsBefore <- Sequence{},
      commentsAfter <- Sequence{},
      uri <- l.url
    )
}

helper def : locationsToSequenceConstant(ls : Sequence(CPL!Location)) : SPL!SequenceConstant =
  SPL!SequenceConstant.allInstances()->any(false);

helper def : statementToStatement(n : CPL!Node) : SPL!Statement =
  SPL!Statement.allInstances()->any(false);