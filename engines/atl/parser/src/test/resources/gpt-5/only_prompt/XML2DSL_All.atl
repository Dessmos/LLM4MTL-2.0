module XML2DSL;

create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrVal(name : String) : String =
  self.children->select(e | e.oclIsTypeOf(XML!Attribute) and e.name = name)->first().value;

helper context XML!Element def: getAttrBool(name : String) : Boolean =
  if self.children->exists(e | e.oclIsTypeOf(XML!Attribute) and e.name = name) then
    let v : String = self.getAttrVal(name) in
      v = 'true' or v = '1' or v = 'yes'
  else
    false
  endif;

helper context XML!Element def: hasAttr(name : String) : Boolean =
  self.children->exists(e | e.oclIsTypeOf(XML!Attribute) and e.name = name);

helper context XML!Element def: hasChildren() : Boolean =
  self.children->exists(e | e.oclIsTypeOf(XML!Element));

helper context XML!Element def: get(name : String) : XML!Element =
  self.children->select(e | e.oclIsTypeOf(XML!Element) and e.name = name)->first().oclAsType(XML!Element);

helper context XML!Element def: getType() : String =
  self.getAttrVal('type');

helper context XML!Element def: getEnumId() : String =
  self.getAttrVal('id');

helper context XML!Element def: getText() : String =
  self.children->select(e | e.oclIsTypeOf(XML!Text))->collect(t | t.value)->first();

helper context XML!Element def: getSeq(name : String) : Sequence(XML!Element) =
  self.children->select(e | e.oclIsTypeOf(XML!Element) and e.name = name)->collect(e | e.oclAsType(XML!Element));

helper context XML!Element def: isAbstract() : Boolean =
  self.getAttrBool('abstract');

helper def: dslElementsById : Map(String, DSL!NamedElement) =
  Map{}; 

helper def: getSubTypes(t : DSL!Classifier) : Sequence(DSL!Classifier) =
  DSL!Classifier.allInstances()->select(c | c.superType = t);

helper def: findType(name : String) : DSL!Type =
  DSL!Type.allInstances()->select(t | t.name = name)->first();

rule DomainModel {
  from
    r : XML!Root
  to
    dm : DSL!DomainModel (
      name <- 'DomainModel',
      identity <- 'root',
      namespace <- 'http://vitruv.tools/methodologisttemplate/DSL',
      isLoaded <- true,
      classifiers <- XML!Element.allInstances()->select(e | e.name = 'class' or e.name = 'relationship' or e.name = 'enumeration')->collect(e |
        if e.name = 'class' then
          thisModule.resolveTemp(e, 'classOut').oclAsType(DSL!Classifier)
        else if e.name = 'relationship' then
          thisModule.resolveTemp(e, 'relOut').oclAsType(DSL!Classifier)
        else
          thisModule.resolveTemp(e, 'enumOut').oclAsType(DSL!Classifier)
        endif
        endif
      ),
      types <- Sequence{
        stString,
        stInteger,
        stBoolean,
        stDate
      }
    ),
    stString : DSL!SimpleType (
      name <- 'String',
      identity <- 'String',
      namespace <- 'PrimitiveTypes'
    ),
    stInteger : DSL!SimpleType (
      name <- 'Integer',
      identity <- 'Integer',
      namespace <- 'PrimitiveTypes'
    ),
    stBoolean : DSL!SimpleType (
      name <- 'Boolean',
      identity <- 'Boolean',
      namespace <- 'PrimitiveTypes'
    ),
    stDate : DSL!SimpleType (
      name <- 'Date',
      identity <- 'Date',
      namespace <- 'PrimitiveTypes'
    )
}

rule Class {
  from
    s : XML!Element (s.name = 'class')
  to
    c : DSL!Class (
      name <- s.getAttrVal('name'),
      identity <- s.getAttrVal('id'),
      namespace <- s.getAttrVal('namespace'),
      isLoaded <- true,
      isAbstract <- s.isAbstract(),
      domainModel <- DSL!DomainModel.allInstances()->first(),
      superType <- if s.hasAttr('super') then
                    DSL!Classifier.allInstances()->select(cl | cl.name = s.getAttrVal('super'))->first()
                   else
                    OclUndefined
                   endif,
      subTypes <- thisModule.getSubTypes(c),
      properties <- s.getSeq('property')->collect(p | thisModule.resolveTemp(p, 'valPropOut').oclAsType(DSL!ValueProperty))
    ),
    dummy : OclAny
  do {
  }

rule Relationship {
  from
    s : XML!Element (s.name = 'relationship')
  to
    r : DSL!Relationship (
      name <- s.getAttrVal('name'),
      identity <- s.getAttrVal('id'),
      namespace <- s.getAttrVal('namespace'),
      isLoaded <- true,
      isAbstract <- false,
      domainModel <- DSL!DomainModel.allInstances()->first(),
      isEmbedding <- s.getAttrBool('embedding'),
      roles <- Sequence{
        thisModule.resolveTemp(s.getSeq('role')->first(), 'roleOut').oclAsType(DSL!Role),
        thisModule.resolveTemp(s.getSeq('role')->last(), 'roleOut').oclAsType(DSL!Role)
      }
    ),
    relOut : DSL!Relationship (
      name <- r.name,
      identity <- r.identity,
      namespace <- r.namespace,
      isLoaded <- r.isLoaded,
      isAbstract <- r.isAbstract,
      domainModel <- r.domainModel,
      isEmbedding <- r.isEmbedding,
      roles <- r.roles
    )
}

rule Role {
  from
    s : XML!Element (s.name = 'role')
  to
    ro : DSL!Role (
      name <- s.getAttrVal('name'),
      identity <- s.getAttrVal('id'),
      accepts <- s.getAttrVal('accepts'),
      min <- s.getAttrVal('min').toInteger(),
      max <- s.getAttrVal('max').toInteger(),
      isUnbounded <- s.getAttrBool('unbounded'),
      isOrdered <- s.getAttrBool('ordered'),
      isNavigableFrom <- s.getAttrBool('navigable'),
      isPropertyGenerator <- s.getAttrBool('propertyGenerator'),
      source <- DSL!Classifier.allInstances()->select(c | c.name = s.getAttrVal('source'))->first(),
      type <- DSL!Classifier.allInstances()->select(c | c.name = s.getAttrVal('type'))->first(),
      relation <- thisModule.resolveTemp(s.parent, 'relOut').oclAsType(DSL!Relationship)
    ),
    roleOut : DSL!Role (
      name <- ro.name,
      identity <- ro.identity,
      accepts <- ro.accepts,
      min <- ro.min,
      max <- ro.max,
      isUnbounded <- ro.isUnbounded,
      isOrdered <- ro.isOrdered,
      isNavigableFrom <- ro.isNavigableFrom,
      isPropertyGenerator <- ro.isPropertyGenerator,
      source <- ro.source,
      type <- ro.type,
      relation <- ro.relation
    )
}

rule ValueProperty {
  from
    s : XML!Element (s.name = 'property')
  to
    vp : DSL!ValueProperty (
      name <- s.getAttrVal('name'),
      identity <- s.getAttrVal('id'),
      owner <- thisModule.resolveTemp(s.parent, 'classOut').oclAsType(DSL!Classifier),
      type <- thisModule.findType(s.getType())
    ),
    valPropOut : DSL!ValueProperty (
      name <- vp.name,
      identity <- vp.identity,
      owner <- vp.owner,
      type <- vp.type
    )
}

rule Enumeration {
  from
    s : XML!Element (s.name = 'enumeration')
  to
    e : DSL!Enumeration (
      name <- s.getAttrVal('name'),
      identity <- s.getAttrVal('id'),
      namespace <- s.getAttrVal('namespace'),
      literals <- s.getSeq('literal')->collect(l | thisModule.resolveTemp(l, 'enumLitOut').oclAsType(DSL!EnumerationLiteral))
    ),
    enumOut : DSL!Enumeration (
      name <- e.name,
      identity <- e.identity,
      namespace <- e.namespace,
      literals <- e.literals
    )
}

rule EnumerationLiteral {
  from
    s : XML!Element (s.name = 'literal')
  to
    el : DSL!EnumerationLiteral (
      name <- s.getAttrVal('name'),
      identity <- s.getEnumId(),
      value <- s.getAttrVal('value').toInteger()
    ),
    enumLitOut : DSL!EnumerationLiteral (
      name <- el.name,
      identity <- el.identity,
      value <- el.value
    )
}