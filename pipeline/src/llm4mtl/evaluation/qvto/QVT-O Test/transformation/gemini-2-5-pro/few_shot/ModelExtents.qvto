modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation transf(in inModel : ECORE, out out1 : ECORE, out out2 : ECORE);

main() {
	var pkg_a := object EPackage@out1 {
		name := 'a'
	};
	var pkg_b := object EPackage@out2 {
		name := 'b'
	};
	pkg_b.eClassifiers += inModel.rootObjects()[EPackage].eClassifiers[EClass]->map toClass();
}

mapping EClass::toClass() : EClass@out2 {
	name := self.name;
}