modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()[EPackage]->map p2p();
}

mapping EPackage::p2p() : EPackage {
	init {
		result.name := self.name;
	}
	self.eClassifiers->map c2c();
}

mapping EClassifier::c2c() : EClass
	when { self.name = 'A' } {
	init {
		result := new EClass();
		result.EClass(self.name);
		result.name := 'mapped' + self.name;
	}
}

constructor EClass::EClass(op : EOperation) {
	self.eOperations += op;
}