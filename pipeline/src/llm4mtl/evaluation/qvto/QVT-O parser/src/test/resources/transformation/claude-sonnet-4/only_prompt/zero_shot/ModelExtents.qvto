modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation transf(in inModel : ECORE, out outModel1 : ECORE, out outModel2 : ECORE);

main() {
    var pkgA : EPackage := object EPackage {
        name := "a";
    };
    outModel1.objectsOfType(EPackage) += pkgA;
    
    var pkgB : EPackage := object EPackage {
        name := "b";
    };
    outModel2.objectsOfType(EPackage) += pkgB;
}

mapping EClass::toClass() : EClass {
    name := self.name;
}
