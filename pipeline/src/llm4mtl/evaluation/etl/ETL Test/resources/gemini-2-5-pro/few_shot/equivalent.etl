transformation FlowchartToHtml

model flowchart driver EMF {nsuri = "http://vitruv.tools/methodologisttemplate/flowchart"};
model HTML driver EMF {nsuri = "http://vitruv.tools/methodologisttemplate/HTML"};

rule Flowchart2Div
	transform f : flowchart!Flowchart
	to d : HTML!DIV {
	
	d.children.addAll(f.transitions.equivalent());
}

rule Transition2Heading
	transform t : flowchart!Transition
	to h : HTML!H1 {
	
	h.value = t.name;
}