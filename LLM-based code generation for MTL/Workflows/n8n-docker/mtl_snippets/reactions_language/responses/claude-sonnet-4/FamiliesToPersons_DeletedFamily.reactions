import epackage families from "http://vitruv.tools/methodologisttemplate/families"
import epackage persons from "http://vitruv.tools/methodologisttemplate/persons"

transformation familiesToPersons {
  persistence {
    families "http://vitruv.tools/methodologisttemplate/families"
    persons "http://vitruv.tools/methodologisttemplate/persons"
  }

  reaction DeletedFamily {
    after delete families::Family family
    call deletePersonsOfFamily(family)
  }

  routine deletePersonsOfFamily(family : families::Family) {
    xtend {
      if (family !== null) {
        if (family.father !== null) {
          deletePerson(family.father)
        }
        if (family.mother !== null) {
          deletePerson(family.mother)
        }
        if (family.sons !== null) {
          for (m : family.sons) {
            if (m !== null) {
              deletePerson(m)
            }
          }
        }
        if (family.daughters !== null) {
          for (m : family.daughters) {
            if (m !== null) {
              deletePerson(m)
            }
          }
        }
      }
    }
  }

  routine deletePerson(member : families::Member) {
    xtend {
      if (member === null) {
        return
      }
      val person = getCorrespondingElement(member, typeof(persons.Person))
      val fam =
        if (member.familyFather !== null) member.familyFather
        else if (member.familyMother !== null) member.familyMother
        else if (member.familySon !== null) member.familySon
        else member.familyDaughter
      if (person !== null) {
        deleteObject(person)
        removeCorrespondences(member, person)
        if (fam !== null) {
          removeCorrespondences(fam, person)
        }
      }
    }
  }
}