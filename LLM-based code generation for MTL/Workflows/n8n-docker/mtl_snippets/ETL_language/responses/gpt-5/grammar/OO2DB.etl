pre InitialiseDatabase {
	var db : DB!Database := new DB!Database;
	DB!Database.all.add(db);
}

post BuildTrace {
	var trace : SimpleTrace!Trace := new SimpleTrace!Trace;
	SimpleTrace!Trace.all.add(trace);
	for (s in OO!Package.all + OO!PackageableElement.all + OO!Feature.all) {
		var targets : Sequence(EObject) := new Sequence;
		targets.addAll(ETL!TransformationTrace.getTargets(s));
		if (not targets.isEmpty()) {
			var link : SimpleTrace!TraceLink := new SimpleTrace!TraceLink;
			link.description := "Trace for " + s.eClass().name + " '" + s.eGet("name") + "'";
			link.sources.add(s);
			for (t in targets) {
				link.targets.add(t);
			}
			trace.links.add(link);
		}
	}
}

operation OO!Class primaryKeyName() : String {
	return self.name.toLowerCase() + "_id";
}

operation OO!Attribute valuesTableName() : String {
	return self.owner.name + "_" + self.name + "_values";
}

operation OO!Classifier toDbType(tm : TM!TypeMap) : String {
	var mapping : TM!TypeMapping := tm.mappings.selectOne(m|m.source = self.name);
	if (mapping.isDefined()) {
		return mapping.target;
	} else if (tm.default.isDefined()) {
		return tm.default.target;
	} else {
		return "VARCHAR(255)";
	}
}

rule Class2Table
	transform s : OO!Class
	to t : DB!Table {
	var db : DB!Database := DB!Database.all.first();
	t.name := s.name.toLowerCase();
	t.database := db;
	db.contents.add(t);
	if (s.extends.isDefined()) {
		var parentTable : DB!Table := s.extends;
		for (pk in parentTable.primaryKeys) {
			t.columns.add(pk);
			t.primaryKeys.add(pk);
		}
	} else {
		var id : DB!Column := new DB!Column;
		id.name := s.primaryKeyName();
		id.type := "BIGINT";
		id.table := t;
		t.columns.add(id);
		t.primaryKeys.add(id);
	}
}

rule SingleValuedAttribute2Column
	transform s : OO!Attribute
	to c : DB!Column
guard : not s.isMany {
	var ownerTable : DB!Table := s.owner;
	var db : DB!Database := DB!Database.all.first();
	var tm : TM!TypeMap := TM!TypeMap.all.first();
	c.name := s.name.toLowerCase();
	c.type := s.type.toDbType(tm);
	c.table := ownerTable;
	if (not db.contents.contains(ownerTable)) {
		db.contents.add(ownerTable);
	}
}

rule MultiValuedAttribute2Table
	transform s : OO!Attribute
to t : DB!Table,
   valueCol : DB!Column,
   ownerFkCol : DB!Column,
   fk : DB!ForeignKey
guard : s.isMany {
	var db : DB!Database := DB!Database.all.first();
	var tm : TM!TypeMap := TM!TypeMap.all.first();
	t.name := s.valuesTableName().toLowerCase();
	t.database := db;
	db.contents.add(t);
	var ownerIdName : String := s.owner.primaryKeyName();
	ownerFkCol.name := ownerIdName;
	ownerFkCol.type := "BIGINT";
	ownerFkCol.table := t;
	t.columns.add(ownerFkCol);
	t.primaryKeys.add(ownerFkCol);
	valueCol.name := "value";
	valueCol.type := s.type.toDbType(tm);
	valueCol.table := t;
	t.columns.add(valueCol);
	fk.name := t.name + "_to_" + s.owner.name.toLowerCase();
	fk.parent := (s.owner).primaryKeyName().resolveOne();
	fk.child := ownerFkCol;
	fk.database := db;
	db.contents.add(fk);
}

rule Reference2ForeignKey
	transform s : OO!Reference
to fkCol : DB!Column,
   fk : DB!ForeignKey
guard : not s.isMany {
	var db : DB!Database := DB!Database.all.first();
	var ownerTable : DB!Table := s.owner;
	var targetClass : OO!Class := s.type;
	var targetTable : DB!Table := targetClass;
	var pk : DB!Column := targetClass.primaryKeyName().resolveOne();
	fkCol.name := s.name.toLowerCase() + "_id";
	fkCol.type := pk.type;
	fkCol.table := ownerTable;
	ownerTable.columns.add(fkCol);
	fk.name := ownerTable.name + "_to_" + targetTable.name + "_" + fkCol.name;
	fk.parent := pk;
	fk.child := fkCol;
	fk.database := db;
	db.contents.add(fk);
}