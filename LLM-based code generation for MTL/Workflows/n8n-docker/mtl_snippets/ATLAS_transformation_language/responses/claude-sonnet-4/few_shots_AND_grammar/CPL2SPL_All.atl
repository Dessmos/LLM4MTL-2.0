module CPL2SPL;
create OUT : SPL from IN : CPL;

helper def: statement : SPL!Statement = OclUndefined;

helper def: locations : Sequence(CPL!Location) = CPL!Location.allInstances()->select(l | true);

helper context CPL!Proxy def: isSimple : Boolean = self.busy.oclIsUndefined() and self.noAnswer.oclIsUndefined() and self.redirection.oclIsUndefined() and self.failure.oclIsUndefined() and self.default.oclIsUndefined();

rule CPL2Program {
  from c : CPL!CPL
  to p : SPL!Program (
    service <- s,
    location <- ''
  ),
  s : SPL!Service (
    name <- 'CPLService',
    declarations <- c.subActions->collect(sa | thisModule.SubAction2Function(sa))->union(Sequence{thisModule.Incoming2Method(c.incoming)}),
    location <- ''
  )
}

rule SubAction2Function {
  from sa : CPL!SubAction
  to f : SPL!LocalFunctionDeclaration (
    name <- sa.id,
    returnType <- rt,
    statements <- Sequence{thisModule.statement},
    location <- ''
  ),
  rt : SPL!SimpleType (
    type <- #void,
    location <- ''
  )
}

rule Incoming2Method {
  from i : CPL!Incoming
  to m : SPL!Method (
    type <- rt,
    direction <- #inout,
    methodName <- mn,
    statements <- Sequence{thisModule.statement},
    branches <- Sequence{},
    location <- ''
  ),
  rt : SPL!SimpleType (
    type <- #void,
    location <- ''
  ),
  mn : SPL!SIPMethodName (
    name <- #INVITE,
    location <- ''
  )
}

rule Proxy2Return {
  from p : CPL!Proxy (p.isSimple)
  to rs : SPL!ReturnStat (
    returnedValue <- ce,
    location <- ''
  ),
  ce : SPL!ConstantExp (
    value <- bc,
    location <- ''
  ),
  bc : SPL!BooleanConstant (
    value <- true,
    location <- ''
  )
}

rule Proxy2Select {
  from p : CPL!Proxy (not p.isSimple)
  to ss : SPL!SelectStat (
    matchedExp <- ve,
    selectCases <- p.busy->union(p.noAnswer)->union(p.redirection)->collect(e | thisModule.resolveTemp(e, '')),
    selectDefault <- if p.default.oclIsUndefined() then OclUndefined else thisModule.Default2SelectDefault(p.default) endif,
    location <- ''
  ),
  ve : SPL!Variable (
    source <- vd,
    location <- ''
  ),
  vd : SPL!VariableDeclaration (
    name <- 'status',
    type <- st,
    location <- ''
  ),
  st : SPL!SimpleType (
    type <- #string,
    location <- ''
  )
}

rule Busy2SelectCase {
  from b : CPL!Busy
  to sc : SPL!SelectCase (
    values <- Sequence{sc_val},
    statements <- Sequence{thisModule.statement},
    location <- ''
  ),
  sc_val : SPL!StringConstant (
    value <- 'busy',
    location <- ''
  )
}

rule NoAnswer2SelectCase {
  from na : CPL!NoAnswer
  to sc : SPL!SelectCase (
    values <- Sequence{sc_val},
    statements <- Sequence{thisModule.statement},
    location <- ''
  ),
  sc_val : SPL!StringConstant (
    value <- 'noanswer',
    location <- ''
  )
}

rule Redirection2SelectCase {
  from r : CPL!Redirection
  to sc : SPL!SelectCase (
    values <- Sequence{sc_val},
    statements <- Sequence{thisModule.statement},
    location <- ''
  ),
  sc_val : SPL!StringConstant (
    value <- 'redirection',
    location <- ''
  )
}

rule Default2SelectDefault {
  from d : CPL!Default
  to sd : SPL!SelectDefault (
    statements <- Sequence{thisModule.statement},
    location <- ''
  )
}

rule SubCall2Return {
  from sc : CPL!SubCall
  to rs : SPL!ReturnStat (
    returnedValue <- fce,
    location <- ''
  ),
  fce : SPL!FunctionCallExp (
    functionCall <- fc,
    location <- ''
  ),
  fc : SPL!FunctionCall (
    function <- thisModule.resolveTemp(CPL!SubAction.allInstances()->select(sa | sa.id = sc.ref)->first(), ''),
    location <- ''
  )
}

rule Redirect2Return {
  from r : CPL!Redirect
  to rs : SPL!ReturnStat (
    returnedValue <- ce,
    location <- ''
  ),
  ce : SPL!ConstantExp (
    value <- bc,
    location <- ''
  ),
  bc : SPL!BooleanConstant (
    value <- false,
    location <- ''
  )
}

rule AddressSwitch2SelectStat {
  from as : CPL!AddressSwitch
  to ss : SPL!SelectStat (
    matchedExp <- ve,
    selectCases <- as.addresses->collect(a | thisModule.SwitchedAddress2SelectCase(a)),
    selectDefault <- if as.otherwise.oclIsUndefined() then OclUndefined else thisModule.Otherwise2SelectDefault(as.otherwise) endif,
    location <- ''
  ),
  ve : SPL!Variable (
    source <- vd,
    location <- ''
  ),
  vd : SPL!VariableDeclaration (
    name <- as.field,
    type <- st,
    location <- ''
  ),
  st : SPL!SimpleType (
    type <- #string,
    location <- ''
  )
}

rule SwitchedAddress2SelectCase {
  from sa : CPL!SwitchedAddress
  to sc : SPL!SelectCase (
    values <- Sequence{sc_val},
    statements <- Sequence{thisModule.statement},
    location <- ''
  ),
  sc_val : SPL!StringConstant (
    value <- if sa.is.oclIsUndefined() then sa.contains else sa.is endif,
    location <- ''
  )
}

rule Otherwise2SelectDefault {
  from o : CPL!Otherwise
  to sd : SPL!SelectDefault (
    statements <- Sequence{thisModule.statement},
    location <- ''
  )
}

rule Location2URIConstant {
  from l : CPL!Location
  to uc : SPL!URIConstant (
    uri <- l.url,
    location <- ''
  )
}