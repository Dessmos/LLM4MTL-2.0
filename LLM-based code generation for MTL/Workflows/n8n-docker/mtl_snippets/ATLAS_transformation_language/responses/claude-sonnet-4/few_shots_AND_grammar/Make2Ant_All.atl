module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from m : Make!Makefile
	to p : Ant!Project (
		name <- m.name,
		properties <- Make!Macro.allInstances(),
		targets <- Make!Rule.allInstances(),
		default <- Make!Rule.allInstances()->first()
	)
}

rule Macro2Property {
	from m : Make!Macro
	to pv : Ant!PropertyValue (
		name <- m.name,
		value <- m.value
	)
}

rule Rule2Target {
	from r : Make!Rule
	to t : Ant!Target (
		name <- r.name,
		tasks <- r.shellLines,
		depends <- r.dependencies->select(d | d.oclIsTypeOf(Make!RuleDep))->collect(d | d.ruledep)
	)
}

rule ShellLine2Task_Display {
	from sl : Make!ShellLine (sl.display = true)
	to e : Ant!Echo (
		message <- sl.command
	)
}

rule ShellLine2Task_NoDisplay {
	from sl : Make!ShellLine (sl.display = false)
	to ex : Ant!Exec (
		executable <- sl.command,
		dir <- ''
	)
}