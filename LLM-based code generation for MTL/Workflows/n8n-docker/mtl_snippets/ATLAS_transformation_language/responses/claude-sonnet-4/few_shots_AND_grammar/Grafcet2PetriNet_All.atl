module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
  from g : Grafcet!Grafcet
  to   p : PetriNet!PetriNet (
    name <- g.name,
    location <- g.location,
    elements <- g.elements->collect(e | thisModule.resolveTemp(e, '')),
    arcs <- g.connections->collect(c | thisModule.resolveTemp(c, ''))
  )
}

rule Place {
  from s : Grafcet!Step
  to   p : PetriNet!Place (
    name <- s.name,
    location <- s.location
  )
}

rule Transition {
  from t : Grafcet!Transition
  to   tr : PetriNet!Transition (
    name <- t.name,
    location <- t.location
  )
}

rule PlaceToTransition {
  from st : Grafcet!StepToTransition
  to   pt : PetriNet!PlaceToTransition (
    name <- st.name,
    location <- st.location,
    weight <- 1,
    from <- thisModule.resolveTemp(st.from, ''),
    to <- thisModule.resolveTemp(st.to, '')
  )
}

rule TransitionToPlace {
  from ts : Grafcet!TransitionToStep
  to   tp : PetriNet!TransitionToPlace (
    name <- ts.name,
    location <- ts.location,
    weight <- 1,
    from <- thisModule.resolveTemp(ts.from, ''),
    to <- thisModule.resolveTemp(ts.to, '')
  )
}