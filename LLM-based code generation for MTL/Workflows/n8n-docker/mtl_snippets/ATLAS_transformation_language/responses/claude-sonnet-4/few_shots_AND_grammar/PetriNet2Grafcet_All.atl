module PetriNet2Grafcet;
create OUT : Grafcet from IN : PetriNet;

rule Grafcet {
	from src : PetriNet!PetriNet
	to tgt : Grafcet!Grafcet (
		name <- src.name,
		location <- src.location,
		elements <- src.elements,
		connections <- src.arcs
	)
}

rule Step {
	from src : PetriNet!Place
	to tgt : Grafcet!Step (
		name <- src.name,
		location <- src.location,
		isInitial <- false,
		isActive <- false,
		action <- '',
		incomingConnections <- src.incomingArc,
		outgoingConnections <- src.outgoingArc
	)
}

rule Transition {
	from src : PetriNet!Transition
	to tgt : Grafcet!Transition (
		name <- src.name,
		location <- src.location,
		condition <- '',
		incomingConnections <- src.incomingArc,
		outgoingConnections <- src.outgoingArc
	)
}

rule StepToTransition {
	from src : PetriNet!PlaceToTransition
	to tgt : Grafcet!StepToTransition (
		name <- src.name,
		location <- src.location,
		from <- src.from,
		to <- src.to
	)
}

rule TransitionToStep {
	from src : PetriNet!TransitionToPlace
	to tgt : Grafcet!TransitionToStep (
		name <- src.name,
		location <- src.location,
		from <- src.from,
		to <- src.to
	)
}