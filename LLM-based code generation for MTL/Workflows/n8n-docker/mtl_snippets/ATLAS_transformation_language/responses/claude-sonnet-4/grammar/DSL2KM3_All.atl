```atl
module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	not self.roles->forAll(r | r.source.oclIsUndefined() and r.type.oclIsUndefined()) or
	not self.superType.oclIsUndefined() or
	not self.subTypes->isEmpty() or
	not self.properties->isEmpty();

helper def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
	DSL!Role.allInstances()->select(r | 
		(r.source = c or r.type = c) and 
		not r.relation.needTurnOnClass()
	);

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding;

rule Metamodel {
	from
		s : DSL!DomainModel
	to
		t : KM3!Metamodel (
			location <- '',
			contents <- Sequence{mainPackage, primitivesPackage}
		),
		mainPackage : KM3!Package (
			location <- '',
			name <- s.name,
			package <- t,
			metamodel <- t
		),
		primitivesPackage : KM3!Package (
			location <- '',
			name <- 'PrimitiveTypes',
			package <- t,
			metamodel <- t
		)
}

rule Class {
	from
		s : DSL!Class
	to
		t : KM3!Class (
			location <- '',
			name <- s.name,
			package <- s.domainModel,
			isAbstract <- s.isAbstract,
			supertypes <- if s.superType.oclIsUndefined() then Sequence{} else Sequence{s.superType} endif
		)
}

rule Relation2Class {
	from
		s : DSL!Relationship (
			s.needTurnOnClass()
		)
	to
		t : KM3!Class (
			location <- '',
			name <- s.name,
			package <- s.domainModel,
			isAbstract <- s.isAbstract,
			supertypes <- if s.superType.oclIsUndefined() then Sequence{} else Sequence{s.superType} endif
		)
}

rule SimpleReference {
	from
		s : DSL!Role (
			not s.relation.needTurnOnClass()
		)
	to
		t : KM3!Reference (
			location <- '',
			name <- s.name,
			package <- s.source.domainModel,
			owner <- s.source,
			type <- s.type,
			lower <- s.min,
			upper <- s.max,
			isOrdered <- s.isOrdered,
			isUnique <- true,
			isContainer <- s.isEmbedding(),
			opposite <- s.relation.roles->select(r | r <> s)->first()
		)
}

rule ComplexReference {
	from
		s : DSL!Role (
			s.relation.needTurnOnClass()
		)
	to
		t : KM3!Reference (
			location <- '',
			name <- s.name,
			package <- s.source.domainModel,
			owner <- s.source,
			type <- s.relation,
			lower <- s.min,
			upper <- s.max,
			isOrdered <- s.isOrdered,
			isUnique <- true,
			isContainer <- s.isEmbedding(),
			opposite <- OclUndefined
		)
}

rule Attribute {
	from
		s : DSL!ValueProperty
	to
		t : KM3!Attribute (
			location <- '',
			name <- s.name,
			package <- s.owner.domainModel,
			owner <- s.owner,
			type <- s.type,
			lower <- 1,
			upper <- 1,
			isOrdered <- false,
			isUnique <- true
		)
}

rule Enumeration {
	from
		s : DSL!Enumeration
	to
		t : KM3!Enumeration (
			location <- '',
			name <- s.name,
			package <- s.domainModel
		)
}

rule EnumLiteral {
	from
		s : DSL!EnumerationLiteral
	to
		t : KM3!EnumLiteral (
			location <- '',
			name <- s.name,
			package <- s.refImmediateComposite().domainModel
		)
}

rule DataType {
	from
		s : DSL!SimpleType
	to
		t : KM3!DataType (
			location <- '',
			name <- s.name,
			package <- s.domainModel
		)
}
```