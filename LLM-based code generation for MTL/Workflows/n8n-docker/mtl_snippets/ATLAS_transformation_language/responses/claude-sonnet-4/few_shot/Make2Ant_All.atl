module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from m : Make!Makefile
	to p : Ant!Project (
		name <- m.name,
		properties <- m.elements->select(e | e.oclIsTypeOf(Make!Macro))->collect(macro | thisModule.Macro2Property(macro)),
		targets <- m.elements->select(e | e.oclIsTypeOf(Make!Rule))->collect(rule | thisModule.Rule2Target(rule)),
		default <- m.elements->select(e | e.oclIsTypeOf(Make!Rule))->first()
	)
}

rule Macro2Property {
	from macro : Make!Macro
	to prop : Ant!PropertyValue (
		name <- macro.name,
		value <- macro.value
	)
}

rule Rule2Target {
	from rule : Make!Rule
	to target : Ant!Target (
		name <- rule.name,
		tasks <- rule.shellLines->collect(sl | 
			if sl.display then
				thisModule.ShellLine2Task_Display(sl)
			else
				thisModule.ShellLine2Task_NoDisplay(sl)
			endif
		),
		depends <- rule.dependencies->select(d | d.oclIsTypeOf(Make!RuleDep))->collect(rd | rd.ruledep)
	)
}

rule ShellLine2Task_Display {
	from sl : Make!ShellLine (sl.display = true)
	to task : Ant!Echo (
		message <- sl.command
	)
}

rule ShellLine2Task_NoDisplay {
	from sl : Make!ShellLine (sl.display = false)
	to task : Ant!Exec (
		executable <- sl.command,
		dir <- '.'
	)
}