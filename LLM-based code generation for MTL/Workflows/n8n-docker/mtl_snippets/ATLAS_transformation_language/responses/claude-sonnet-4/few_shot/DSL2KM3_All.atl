module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper def: needTurnOnClass(r : DSL!Relationship) : Boolean =
	not r.isEmbedding;

helper def: getRoles(r : DSL!Relationship) : Sequence(DSL!Role) =
	r.roles->asSequence();

helper def: isEmbedding(r : DSL!Relationship) : Boolean =
	r.isEmbedding;

rule Metamodel {
	from src : DSL!DomainModel
	to dst : KM3!Metamodel (
		location <- '',
		contents <- Sequence{thisModule.Package(src)}
	)
}

rule Package {
	from src : DSL!DomainModel
	to dst : KM3!Package (
		name <- src.name,
		location <- '',
		contents <- src.classifiers->select(c | c.oclIsTypeOf(DSL!Class))->union(
			src.classifiers->select(c | c.oclIsTypeOf(DSL!Relationship) and thisModule.needTurnOnClass(c)))->union(
			src.types->select(t | t.oclIsTypeOf(DSL!Enumeration)))->union(
			src.types->select(t | t.oclIsTypeOf(DSL!SimpleType)))
	)
}

rule Class {
	from src : DSL!Class
	to dst : KM3!Class (
		name <- src.name,
		location <- '',
		isAbstract <- src.isAbstract,
		supertypes <- if src.superType.oclIsUndefined() then Sequence{} else Sequence{src.superType} endif,
		structuralFeatures <- src.properties->union(
			DSL!Role.allInstances()->select(r | r.source = src and r.isPropertyGenerator and thisModule.isEmbedding(r.relation)))
	)
}

rule Relation2Class {
	from src : DSL!Relationship (thisModule.needTurnOnClass(src))
	to dst : KM3!Class (
		name <- src.name,
		location <- '',
		isAbstract <- src.isAbstract,
		supertypes <- if src.superType.oclIsUndefined() then Sequence{} else Sequence{src.superType} endif,
		structuralFeatures <- src.properties->union(thisModule.getRoles(src))
	)
}

rule SimpleReference {
	from src : DSL!Role (src.isPropertyGenerator and thisModule.isEmbedding(src.relation))
	to dst : KM3!Reference (
		name <- src.name,
		location <- '',
		lower <- src.min,
		upper <- if src.isUnbounded then -1 else src.max endif,
		isOrdered <- src.isOrdered,
		isUnique <- true,
		isContainer <- false,
		type <- src.type
	)
}

rule ComplexReference {
	from src : DSL!Role (not thisModule.isEmbedding(src.relation))
	to dst : KM3!Reference (
		name <- src.name,
		location <- '',
		lower <- src.min,
		upper <- if src.isUnbounded then -1 else src.max endif,
		isOrdered <- src.isOrdered,
		isUnique <- true,
		isContainer <- false,
		type <- src.relation,
		opposite <- src.relation.roles->select(r | r <> src)->first()
	)
}

rule Attribute {
	from src : DSL!ValueProperty
	to dst : KM3!Attribute (
		name <- src.name,
		location <- '',
		lower <- 1,
		upper <- 1,
		isOrdered <- false,
		isUnique <- true,
		type <- src.type
	)
}

rule Enumeration {
	from src : DSL!Enumeration
	to dst : KM3!Enumeration (
		name <- src.name,
		location <- '',
		literals <- src.literals
	)
}

rule EnumLiteral {
	from src : DSL!EnumerationLiteral
	to dst : KM3!EnumLiteral (
		name <- src.name,
		location <- ''
	)
}

rule DataType {
	from src : DSL!SimpleType
	to dst : KM3!DataType (
		name <- src.name,
		location <- ''
	)
}