module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
  from g : Grafcet!Grafcet
  to   p : PetriNet!PetriNet (
    name <- g.name,
    location <- g.location,
    elements <- g.elements->collect(e | if e.oclIsTypeOf(Grafcet!Step) then thisModule.resolveTemp(e, 'place') else thisModule.resolveTemp(e, 'transition') endif),
    arcs <- g.connections->collect(c | if c.oclIsTypeOf(Grafcet!StepToTransition) then thisModule.resolveTemp(c, 'arc') else thisModule.resolveTemp(c, 'arc') endif)
  )
}

rule Place {
  from s : Grafcet!Step
  to   p : PetriNet!Place (
    name <- s.name,
    location <- s.location
  )
}

rule Transition {
  from t : Grafcet!Transition
  to   tr : PetriNet!Transition (
    name <- t.name,
    location <- t.location
  )
}

rule PlaceToTransition {
  from c : Grafcet!StepToTransition
  to   a : PetriNet!PlaceToTransition (
    name <- c.name,
    location <- c.location,
    weight <- 1,
    from <- thisModule.resolveTemp(c.from, 'place'),
    to <- thisModule.resolveTemp(c.to, 'transition')
  )
}

rule TransitionToPlace {
  from c : Grafcet!TransitionToStep
  to   a : PetriNet!TransitionToPlace (
    name <- c.name,
    location <- c.location,
    weight <- 1,
    from <- thisModule.resolveTemp(c.from, 'transition'),
    to <- thisModule.resolveTemp(c.to, 'place')
  )
}