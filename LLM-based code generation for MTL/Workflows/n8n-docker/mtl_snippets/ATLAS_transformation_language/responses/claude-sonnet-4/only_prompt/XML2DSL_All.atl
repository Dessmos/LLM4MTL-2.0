module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrBool(n : String) : Boolean =
	let attr : XML!Attribute = self.children->select(a | a.oclIsKindOf(XML!Attribute) and a.name = n)->first() in
	if attr.oclIsUndefined() then false else attr.value = 'true' endif;

helper context XML!Element def: getAttrVal(n : String) : String =
	let attr : XML!Attribute = self.children->select(a | a.oclIsKindOf(XML!Attribute) and a.name = n)->first() in
	if attr.oclIsUndefined() then '' else attr.value endif;

helper context XML!Element def: get(child : String, name : String) : XML!Element =
	self.children->select(e | e.oclIsKindOf(XML!Element) and e.name = child)->select(e | e.getAttrVal('name') = name)->first();

helper context XML!Element def: getType() : String =
	self.getAttrVal('xsi:type');

helper context XML!Element def: getEnumId() : String =
	self.getAttrVal('name');

helper context XML!Element def: getText() : String =
	let textNode : XML!Text = self.children->select(t | t.oclIsKindOf(XML!Text))->first() in
	if textNode.oclIsUndefined() then '' else textNode.value endif;

helper context XML!Element def: getSeq(elemName : String) : Sequence(XML!Element) =
	self.children->select(e | e.oclIsKindOf(XML!Element) and e.name = elemName);

helper context XML!Element def: hasChildren() : Boolean =
	self.children->exists(e | e.oclIsKindOf(XML!Element));

helper context XML!Element def: hasAttr(n : String) : Boolean =
	self.children->exists(a | a.oclIsKindOf(XML!Attribute) and a.name = n);

helper context XML!Element def: isAbstract() : Boolean =
	self.getAttrBool('abstract');

helper def: dslElementsById : Map(String, DSL!NamedElement) =
	Map{};

helper context XML!Element def: getContainment() : Boolean =
	self.getAttrBool('containment');

helper context XML!Element def: getSubTypes() : Sequence(XML!Element) =
	thisModule.allInstances()->select(e | e.oclIsKindOf(XML!Element) and e.getAttrVal('eSuperTypes') = '#//' + self.getAttrVal('name'));

helper context String def: findType() : DSL!Type =
	if self = 'String' then thisModule.stringType
	else if self = 'Integer' then thisModule.intType
	else if self = 'Boolean' then thisModule.boolType
	else if self = 'Double' then thisModule.doubleType
	else OclUndefined endif endif endif endif;

lazy rule stringType {
	from s : String (s = 'String')
	to t : DSL!SimpleType (
		name <- 'String',
		identity <- 'String',
		namespace <- 'PrimitiveTypes'
	)
}

lazy rule intType {
	from s : String (s = 'Integer')
	to t : DSL!SimpleType (
		name <- 'Integer',
		identity <- 'Integer',
		namespace <- 'PrimitiveTypes'
	)
}

lazy rule boolType {
	from s : String (s = 'Boolean')
	to t : DSL!SimpleType (
		name <- 'Boolean',
		identity <- 'Boolean',
		namespace <- 'PrimitiveTypes'
	)
}

lazy rule doubleType {
	from s : String (s = 'Double')
	to t : DSL!SimpleType (
		name <- 'Double',
		identity <- 'Double',
		namespace <- 'PrimitiveTypes'
	)
}

rule DomainModel {
	from s : XML!Element (s.name = 'ecore:EPackage' and s.parent.oclIsKindOf(XML!Root))
	to t : DSL!DomainModel (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('name'),
		namespace <- s.getAttrVal('nsURI'),
		isLoaded <- true,
		classifiers <- s.getSeq('eClassifiers')->select(e | e.getType() = 'ecore:EClass'),
		types <- s.getSeq('eClassifiers')->select(e | e.getType() = 'ecore:EEnum')->union(
			Sequence{'String', 'Integer', 'Boolean', 'Double'}->collect(typeName | thisModule.resolveTemp(typeName, 't'))
		)
	)
}

rule Class {
	from s : XML!Element (s.name = 'eClassifiers' and s.getType() = 'ecore:EClass' and not s.getAttrVal('name').endsWith('Relationship'))
	to t : DSL!Class (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('name'),
		namespace <- s.parent.getAttrVal('nsURI'),
		isLoaded <- true,
		isAbstract <- s.isAbstract(),
		properties <- s.getSeq('eStructuralFeatures')->select(f | f.getType() = 'ecore:EAttribute'),
		domainModel <- s.parent
	)
	do {
		let supertypeRef : String = s.getAttrVal('eSuperTypes') in
		if not supertypeRef.oclIsUndefined() and supertypeRef <> '' then
			t.superType <- thisModule.dslElementsById.get(supertypeRef.substring(4, supertypeRef.size()))
		endif;
	}
}

rule Relationship {
	from s : XML!Element (s.name = 'eClassifiers' and s.getType() = 'ecore:EClass' and s.getAttrVal('name').endsWith('Relationship'))
	to t : DSL!Relationship (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('name'),
		namespace <- s.parent.getAttrVal('nsURI'),
		isLoaded <- true,
		isAbstract <- s.isAbstract(),
		isEmbedding <- false,
		properties <- s.getSeq('eStructuralFeatures')->select(f | f.getType() = 'ecore:EAttribute'),
		roles <- s.getSeq('eStructuralFeatures')->select(f | f.getType() = 'ecore:EReference')->collect(r | thisModule.Role(r)),
		domainModel <- s.parent
	)
	do {
		let supertypeRef : String = s.getAttrVal('eSuperTypes') in
		if not supertypeRef.oclIsUndefined() and supertypeRef <> '' then
			t.superType <- thisModule.dslElementsById.get(supertypeRef.substring(4, supertypeRef.size()))
		endif;
	}
}

rule Role {
	from s : XML!Element (s.name = 'eStructuralFeatures' and s.getType() = 'ecore:EReference')
	to t : DSL!Role (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('name'),
		min <- if s.hasAttr('lowerBound') then s.getAttrVal('lowerBound').toInteger() else 0 endif,
		max <- if s.hasAttr('upperBound') then 
			if s.getAttrVal('upperBound') = '-1' then -1 else s.getAttrVal('upperBound').toInteger() endif
			else 1 endif,
		isUnbounded <- s.getAttrVal('upperB