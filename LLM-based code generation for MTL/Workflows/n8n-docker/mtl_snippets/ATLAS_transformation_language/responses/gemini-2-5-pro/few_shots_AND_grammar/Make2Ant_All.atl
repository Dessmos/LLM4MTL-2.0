module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		s : Make!Makefile
	to
		t : Ant!Project (
			name <- s.name,
			description <- if not s.comment.oclIsUndefined() then s.comment.text else '' endif,
			properties <- s.elements->select(e | e.oclIsTypeOf(Make!Macro)),
			targets <- s.elements->select(e | e.oclIsTypeOf(Make!Rule)),
			default <- s.elements->select(e | e.oclIsTypeOf(Make!Rule))->first()
		)
}

rule Macro2Property {
	from
		s : Make!Macro
	to
		t : Ant!PropertyValue (
			name <- s.name,
			value <- s.value
		)
}

rule Rule2Target {
	from
		s : Make!Rule
	to
		t : Ant!Target (
			name <- s.name,
			tasks <- s.shellLines,
			depends <- s.dependencies->select(d | d.oclIsTypeOf(Make!RuleDep))->collect(rd | rd.ruledep)
		)
}

rule ShellLine2Task_Display {
	from
		s : Make!ShellLine (s.display)
	to
		t : Ant!Echo (
			message <- s.command
		)
}

rule ShellLine2Task_NoDisplay {
	from
		s : Make!ShellLine (not s.display)
	to
		t : Ant!Exec (
			executable <- s.command
		)
}