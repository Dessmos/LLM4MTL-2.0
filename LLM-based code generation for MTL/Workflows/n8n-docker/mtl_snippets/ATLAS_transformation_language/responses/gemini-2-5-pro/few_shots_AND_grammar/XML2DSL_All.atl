module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrVal(n : String) : String = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = n)->first().value;
helper context XML!Element def: hasAttr(n : String) : Boolean = not self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = n)->isEmpty();
helper context XML!Element def: getAttrBool(n : String) : Boolean = if self.hasAttr(n) then self.getAttrVal(n).toBoolean() else false endif;
helper def: get(e : XML!Element, n : String) : XML!Element = e.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = n)->first();
helper def: getType(id : String) : XML!Element = XML!Element.allInstancesFrom('IN')->select(e | (e.name = 'Class' or e.name = 'Relationship' or e.name = 'Enumeration') and e.getAttrVal('identity') = id)->first();
helper context XML!Element def: getText() : String = if self.children->exists(c | c.oclIsTypeOf(XML!Text)) then self.children->select(c | c.oclIsTypeOf(XML!Text))->first().value else '' endif;
helper context XML!Element def: getSeq(n : String) : Sequence(XML!Element) = self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = n);
helper context XML!Element def: hasChildren(n : String) : Boolean = not self.getSeq(n)->isEmpty();
helper context XML!Element def: isAbstract() : Boolean = self.getAttrBool('isAbstract');
helper context XML!Element def: getContainment() : Boolean = self.getAttrBool('isEmbedding');
helper def: getSubTypes(c : XML!Element) : Sequence(XML!Element) = XML!Element.allInstancesFrom('IN')->select(e | (e.name = 'Class' or e.name = 'Relationship') and e.hasAttr('superType') and e.getAttrVal('superType') = c.getAttrVal('identity'));
helper context XML!Element def: getEnumId() : Integer = self.parent.children->select(c | c.name = self.name)->indexOf(self);

rule DomainModel {
	from s : XML!Element (s.name = 'DomainModel')
	to t : DSL!DomainModel (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		namespace <- s.getAttrVal('namespace'),
		isLoaded <- true,
		classifiers <- s.getSeq('classifiers'),
		types <- s.getSeq('enumerations')->union(Sequence{stringType, intType, boolType, doubleType})
	),
	stringType : DSL!SimpleType (
		name <- 'String',
		namespace <- 'PrimitiveTypes'
	),
	intType : DSL!SimpleType (
		name <- 'Integer',
		namespace <- 'PrimitiveTypes'
	),
	boolType : DSL!SimpleType (
		name <- 'Boolean',
		namespace <- 'PrimitiveTypes'
	),
	doubleType : DSL!SimpleType (
		name <- 'Double',
		namespace <- 'PrimitiveTypes'
	)
}

rule Class {
	from s : XML!Element (s.name = 'Class')
	to t : DSL!Class (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		isLoaded <- true,
		namespace <- s.parent.parent.getAttrVal('namespace'),
		isAbstract <- s.isAbstract(),
		properties <- s.getSeq('properties'),
		superType <- if s.hasAttr('superType') then thisModule.getType(s.getAttrVal('superType')) else OclUndefined endif,
		subTypes <- thisModule.getSubTypes(s)
	)
}

rule Relationship {
	from s : XML!Element (s.name = 'Relationship')
	to t : DSL!Relationship (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		isLoaded <- true,
		namespace <- s.parent.parent.getAttrVal('namespace'),
		isAbstract <- s.isAbstract(),
		properties <- s.getSeq('properties'),
		superType <- if s.hasAttr('superType') then thisModule.getType(s.getAttrVal('superType')) else OclUndefined endif,
		subTypes <- thisModule.getSubTypes(s),
		isEmbedding <- s.getContainment(),
		roles <- s.getSeq('roles')
	)
}

rule Role {
	from s : XML!Element (s.name = 'Role')
	to t : DSL!Role (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		min <- s.getAttrVal('min').toInteger(),
		max <- s.getAttrVal('max').toInteger(),
		isUnbounded <- s.getAttrBool('isUnbounded'),
		accepts <- s.getAttrVal('accepts'),
		isOrdered <- s.getAttrBool('isOrdered'),
		isNavigableFrom <- s.getAttrBool('isNavigableFrom'),
		isPropertyGenerator <- s.getAttrBool('isPropertyGenerator'),
		source <- thisModule.getType(s.getAttrVal('source')),
		type <- thisModule.getType(s.getAttrVal('type'))
	)
}

rule ValueProperty {
	from s : XML!Element (s.name = 'ValueProperty')
	to t : DSL!ValueProperty (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		type <- let typeName : String = s.getAttrVal('type') in
			let complexType : XML!Element = XML!Element.allInstancesFrom('IN')->select(e |
				(e.name = 'Class' or e.name = 'Relationship' or e.name = 'Enumeration') and e.getAttrVal('name') = typeName
			)->first() in
			if complexType.oclIsUndefined() then
				DSL!SimpleType.allInstances()->select(st | st.name = typeName)->first()
			else
				complexType
			endif
	)
}

rule Enumeration {
	from s : XML!Element (s.name = 'Enumeration')
	to t : DSL!Enumeration (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		isLoaded <- true,
		namespace <- s.parent.parent.getAttrVal('namespace'),
		literals <- s.getSeq('literals')
	)
}

rule EnumerationLiteral {
	from s : XML!Element (s.name = 'literals')
	to t : DSL!EnumerationLiteral (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('identity'),
		value <- s.getEnumId()
	)
}