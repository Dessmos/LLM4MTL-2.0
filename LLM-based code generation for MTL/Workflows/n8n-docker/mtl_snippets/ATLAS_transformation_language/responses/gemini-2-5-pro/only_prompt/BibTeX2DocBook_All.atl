module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context BibTeX!BibTeXFile def: authorSet() : Set(BibTeX!Author) =
	BibTeX!Author.allInstances();

helper context BibTeX!BibTeXFile def: titledEntrySet() : Set(BibTeX!TitledEntry) =
	BibTeX!TitledEntry.allInstances()->reject(e | e.oclIsKindOf(BibTeX!Article));

helper context BibTeX!BibTeXFile def: articleSet() : Set(BibTeX!Article) =
	BibTeX!Article.allInstances();

helper context BibTeX!BibTeXEntry def: buildEntryPara() : String =
	'[' + self.id + '] ' +
	(if self.oclIsKindOf(BibTeX!AuthoredEntry) then
		'Authored by ' + self.oclAsType(BibTeX!AuthoredEntry).authors->collect(a | a.author)->iterate(auth; acc : String = '' | if acc = '' then auth else acc + ', ' + auth endif) + '. '
	else '' endif) +
	(if self.oclIsKindOf(BibTeX!TitledEntry) then
		'Title: ' + self.oclAsType(BibTeX!TitledEntry).title + '. '
	else '' endif) +
	(if self.oclIsKindOf(BibTeX!DatedEntry) then
		'Year: ' + self.oclAsType(BibTeX!DatedEntry).year + '. '
	else '' endif) +
	(if self.oclIsKindOf(BibTeX!Article) then
		'Journal: ' + self.oclAsType(BibTeX!Article).journal + '. '
	else '' endif);

helper context BibTeX!BibTeXFile def: journalSet() : Set(String) =
	self.articleSet()->collect(a | a.journal)->asSet();

helper context OclAny def: entriesForAuthor(anAuthor : BibTeX!Author) : Set(BibTeX!AuthoredEntry) =
	BibTeX!AuthoredEntry.allInstances()->select(e | e.authors->includes(anAuthor));

helper context OclAny def: articlesForJournal(aJournal : String) : Set(BibTeX!Article) =
	BibTeX!Article.allInstances()->select(a | a.journal = aJournal);

rule Main {
	from s : BibTeX!BibTeXFile
	to t : DocBook!DocBook (
		books <- Sequence{book}
	),
	book : DocBook!Book (
		articles <- Sequence{authors, titles, untitled, journals}
	),
	authors : DocBook!Article (
		title <- 'References by Author',
		sections_1 <- s.authorSet()
	),
	titles : DocBook!Article (
		title <- 'Titled References',
		sections_1 <- s.titledEntrySet()
	),
	untitled : DocBook!Article (
		title <- 'Untitled References',
		sections_1 <- BibTeX!BibTeXEntry.allInstances()->select(e | not e.oclIsKindOf(BibTeX!TitledEntry))
	),
	journals : DocBook!Article (
		title <- 'References by Journal',
		sections_1 <- s.journalSet()
	)
}

rule BibTeXEntry2Para {
	from s : BibTeX!BibTeXEntry
	to t : DocBook!Para (
		content <- s.buildEntryPara()
	)
}

rule JournalName2Sect1 {
	from s : String (BibTeX!BibTeXFile.allInstances()->first().journalSet()->includes(s))
	to t : DocBook!Sect1 (
		title <- s,
		sections_2 <- thisModule.articlesForJournal(s)
	)
}

rule Author {
	from s : BibTeX!Author
	to t : DocBook!Sect1 (
		title <- s.author,
		paras <- thisModule.entriesForAuthor(s)
	)
}

rule UntitledEntry {
	from s : BibTeX!BibTeXEntry (not s.oclIsKindOf(BibTeX!TitledEntry))
	to t : DocBook!Sect1 (
		title <- s.id,
		paras <- Sequence{s}
	)
}

rule TitledEntry_Title_NoArticle {
	from s : BibTeX!TitledEntry (not s.title.oclIsUndefined() and s.title <> '' and not s.oclIsKindOf(BibTeX!Article))
	to t : DocBook!Sect1 (
		title <- s.title,
		paras <- Sequence{s}
	)
}

rule TitledEntry_NoTitle_NoArticle {
	from s : BibTeX!TitledEntry ((s.title.oclIsUndefined() or s.title = '') and not s.oclIsKindOf(BibTeX!Article))
	to t : DocBook!Sect1 (
		title <- s.id,
		paras <- Sequence{s}
	)
}

rule Article_Title_Journal {
	from s : BibTeX!Article (not s.title.oclIsUndefined() and s.title <> '' and not s.journal.oclIsUndefined() and s.journal <> '')
	to t : DocBook!Sect2 (
		title <- s.title,
		paras <- Sequence{s}
	)
}

rule Article_NoTitle_Journal {
	from s : BibTeX!Article ((s.title.oclIsUndefined() or s.title = '') and not s.journal.oclIsUndefined() and s.journal <> '')
	to t : DocBook!Sect2 (
		title <- s.id,
		paras <- Sequence{s}
	)
}

rule Article_Title_NoJournal {
	from s : BibTeX!Article (not s.title.oclIsUndefined() and s.title <> '' and (s.journal.oclIsUndefined() or s.journal = ''))
	to t : DocBook!Sect2 (
		title <- s.title,
		paras <- Sequence{s}
	)
}

rule Article_NoTitle_NoJournal {
	from s : BibTeX!Article ((s.title.oclIsUndefined() or s.title = '') and (s.journal.oclIsUndefined() or s.journal = ''))
	to t : DocBook!Sect2 (
		title <- s.id,
		paras <- Sequence{s}
	)
}