module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
	from
		g : Grafcet!Grafcet
	to
		pn : PetriNet!PetriNet (
			name <- g.name,
			location <- g.location,
			elements <- g.elements,
			arcs <- g.connections
		)
}

rule Place {
	from
		s : Grafcet!Step
	to
		p : PetriNet!Place (
			name <- s.name,
			location <- s.location
		)
}

rule Transition {
	from
		t : Grafcet!Transition
	to
		pt : PetriNet!Transition (
			name <- t.name,
			location <- t.location
		)
}

rule PlaceToTransition {
	from
		stt : Grafcet!StepToTransition
	to
		ptt : PetriNet!PlaceToTransition (
			name <- stt.name,
			location <- stt.location,
			weight <- 1,
			from <- stt.from,
			to <- stt.to
		)
}

rule TransitionToPlace {
	from
		tts : Grafcet!TransitionToStep
	to
		ttp : PetriNet!TransitionToPlace (
			name <- tts.name,
			location <- tts.location,
			weight <- 1,
			from <- tts.from,
			to <- tts.to
		)
}