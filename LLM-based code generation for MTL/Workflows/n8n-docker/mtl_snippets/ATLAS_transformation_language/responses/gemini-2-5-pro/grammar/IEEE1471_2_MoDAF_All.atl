module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!IEEE1471Model def : rationale() : String =
	self.rationale.name + ': ' + self.rationale.content;

rule IEEE1471Model2MoDAFModel {
	from s : IEEE1471!IEEE1471Model
	to t : MoDAF!MoDAFModel (
		name <- s.name,
		content <- s.content,
		enterprise <- s.system,
		environment <- s.environment,
		operationalMissions <- s.missions,
		architectures <- s.architecture,
		architecturalDescription <- s.architecturalDescription,
		architecturalFrameworks <- s.libraryViewpoints->union(Sequence{undefinedFramework}),
		stakeholders <- s.stakeholders
	),
	undefinedFramework : MoDAF!ArchitecturalFramework (
		name <- 'Undefined Architectural Framework',
		content <- 'Contains viewpoints that do not have a source library viewpoint.',
		ownedMember <- IEEE1471!Viewpoint.allInstances()->select(v | v.hasSource.oclIsUndefined())
	),
	defaultTaxonomy : MoDAF!Taxonomy (
		name <- 'Default Taxonomy',
		content <- 'A default taxonomy for classified elements.',
		date <- 'N/A',
		url <- 'N/A',
		version <- '1.0'
	)
}

rule System2Enterprise {
	from s : IEEE1471!System
	to t : MoDAF!Enterprise (
		name <- s.name,
		content <- s.content,
		inhabits <- s.inhabits,
		fulfills <- s.fulfills
	)
}

rule Environment2Environment {
	from s : IEEE1471!Environment
	to t : MoDAF!Environment (
		name <- s.name,
		content <- s.content,
		influences <- s.influences,
		taxonomy <- MoDAF!Taxonomy.allInstances()->first()
	)
}

rule Mission2OperationalMission {
	from s : IEEE1471!Mission
	to t : MoDAF!OperationalMission (
		name <- s.name,
		content <- s.content
	)
}

rule Architecture2Architecture {
	from s : IEEE1471!Architecture
	to t : MoDAF!Architecture (
		name <- s.name,
		content <- s.content,
		enterprise <- IEEE1471!System.allInstances()->select(sys | sys.hasAn = s)->first(),
		describedBy <- s.describedBy
	)
}

rule AD2AD {
	from s : IEEE1471!ArchitecturalDescription
	to t : MoDAF!ArchitecturalDescription (
		name <- s.name,
		content <- s.content,
		approvialAuthority <- 'N/A',
		architect <- 'N/A',
		assumptionAndConstraints <- 'N/A',
		creatingOrganisation <- 'N/A',
		dateCompleted <- 'N/A',
		purpose <- s.oclContainer().rationale(),
		recommendations <- 'N/A',
		summaryOfFindings <- 'N/A',
		tollsUsed <- 'N/A',
		viewpoints <- s.selects,
		products <- s.organizedBy,
		taxonomy <- MoDAF!Taxonomy.allInstances()->first()
	)
}

rule Stakeholder2Stakeholder {
	from s : IEEE1471!Stakeholder
	to t : MoDAF!Stakeholder (
		name <- s.name,
		content <- s.content
	)
}

rule Viewpoint2View {
	from s : IEEE1471!Viewpoint
	to t : MoDAF!View (
		name <- s.name,
		content <- s.content,
		framework <- 'N/A',
		frameworkWebsite <- 'N/A',
		viewCode <- 'N/A',
		viewDescription <- s.content,
		viewName <- s.name,
		definingFramework <- if s.hasSource.oclIsUndefined() then
			MoDAF!ArchitecturalFramework.allInstances()->select(f | f.name = 'Undefined Architectural Framework')->first()
		else
			s.hasSource
		endif,
		usedToCover <- s.usedToCover
	)
}

rule View2ArchitecturalProduct {
	from s : IEEE1471!View
	to t : MoDAF!ArchitecturalProduct (
		name <- s.name,
		content <- s.content,
		description <- s.content,
		architecturalElements <- s.consitsOf,
		definingView <- s.conformsTo,
		addresses <- s.conformsTo.usedToCover
	)
}

rule Model2Element {
	from s : IEEE1471!Model
	to t : MoDAF!Elements (
		name <- s.name,
		content <- s.content
	)
}

rule Concern2Concern {
	from s : IEEE1471!Concern
	to t : MoDAF!Concern (
		name <- s.name,
		content <- s.content
	)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from s : IEEE1471!LibraryViewpoint
	to t : MoDAF!ArchitecturalFramework (
		name <- s.name,
		content <- s.content,
		ownedMember <- IEEE1471!Viewpoint.allInstances()->select(v | v.hasSource = s)
	)
}

rule StakeholderHasConcern {
	from s : IEEE1471!Stakeholder
	to t : distinct MoDAF!StakeholderHasConcern foreach (c in s.has) (
		client <- s,
		supplier <- c,
		owner <- MoDAF!MoDAFModel.allInstances()->first()
	)
}