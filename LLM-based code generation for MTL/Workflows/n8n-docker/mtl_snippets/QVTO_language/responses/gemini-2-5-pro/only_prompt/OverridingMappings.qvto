modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation t(inModel : ECORE, out outModel : ECORE);

main() {
	inModel.objects()[EPackage]->map p2p();
}

mapping EPackage::p2p() : EPackage {
	name := self.name;
	eClassifiers := self.eClassifiers->map makeClass();
}

mapping ENamedElement::makeClass() : EClass
disjuncts EClassifier::makeClass, EClass::makeClass, EDataType::makeClass {
	name := 'ENamedElement_' + self.name;
}

mapping EClassifier::makeClass() : EClass
disjuncts ENamedElement::makeClass, EClass::makeClass, EDataType::makeClass {
	name := 'EClassifier_' + self.name;
}

mapping EClass::makeClass() : EClass
disjuncts ENamedElement::makeClass, EClassifier::makeClass, EDataType::makeClass {
	name := 'EClass_' + self.name;
}

mapping EDataType::makeClass() : EClass
disjuncts ENamedElement::makeClass, EClassifier::makeClass, EClass::makeClass {
	name := 'EDataType_' + self.name;
}

mapping EClassifier::c2c() : EClass {
	name := 'mapped' + self.name;
}