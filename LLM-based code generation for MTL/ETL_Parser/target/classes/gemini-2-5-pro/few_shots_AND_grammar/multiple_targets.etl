transformation Flowchart2Html

model Flowchart metamodel {nsURI: "flowchart"}
model HTML metamodel {nsURI: "HTML"}

rule Action2Elements
	transform a : Flowchart!Action
	to container : HTML!DIV, title : HTML!H1, link : HTML!A {
	
	guard : a.outgoing.notEmpty()
	
	container.children.add(title);
	container.children.add(link);
	
	title.value = a.name;
	
	var targetNode = a.outgoing.first().target;
	link.value = targetNode.name;
	link.ahref = "#" + targetNode.name;
}

rule Decision2Elements
	transform d : Flowchart!Decision
	to container : HTML!DIV, title : HTML!H1 {

	container.children.add(title);
	title.value = d.name;
	
	for (t in d.outgoing) {
		var link = new HTML!A;
		link.value = t.target.name;
		link.ahref = "#" + t.target.name;
		container.children.add(link);
	}
}