```etl
rule Flowchart2Heading
	transform f : Flowchart!Flowchart
	to div : HTML!DIV {
	
	div.children.addAll(f.transitions.equivalent("Transition2Heading"));
}

rule Transition2SourceLink
	transform t : Flowchart!Transition
	to link : HTML!A {
	
	link.value = t.source.name;
	link.ahref = t.source.name;
}

rule Transition2TargetLink
	transform t : Flowchart!Transition
	to link : HTML!A {
	
	link.value = t.name;
	link.ahref = t.target.name;
}

@lazy
rule Transition2Heading
	transform t : Flowchart!Transition
	to h1 : HTML!H1 {
	
	h1.value = t.name;
}
```