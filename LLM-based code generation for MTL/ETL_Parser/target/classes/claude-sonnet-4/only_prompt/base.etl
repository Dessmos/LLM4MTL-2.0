rule Flowchart2Heading
  transform s : flowchart!Flowchart
  to t : HTML!H1 {
  t.value = s.name;
}

rule Action2Heading
  transform s : flowchart!Action
  to t : HTML!H1 {
  t.value = s.name;
}

rule Decision2Heading
  transform s : flowchart!Decision
  to t : HTML!H1 {
  t.value = s.name;
}

rule Transition2Heading
  transform s : flowchart!Transition
  to t : HTML!H1 {
  t.value = s.name;
}