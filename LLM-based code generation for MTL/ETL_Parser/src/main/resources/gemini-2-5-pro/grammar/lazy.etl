transformation Flowchart2Html

model flowchart driver EMF {nsuri = "flowchart"}
model HTML driver EMF {nsuri = "HTML"}

rule Flowchart2Heading
	transform f : flowchart!Flowchart
	to d : HTML!DIV {
		d.children ::= f.nodes;
	}

rule Action2Heading
	transform a : flowchart!Action
	to h : HTML!H1 {
		h.value = a.name;
	}

rule Decision2Heading
	transform d : flowchart!Decision
	to h : HTML!H1 {
		h.value = d.name;
	}

rule Transition2Heading
	transform t : flowchart!Transition
	to h : HTML!H1 {
		h.value = t.name;
	}