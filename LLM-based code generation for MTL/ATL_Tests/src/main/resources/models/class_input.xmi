<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmlns:xmi="http://www.omg.org/XMI" xmlns:class="http://vitruv.tools/methodologisttemplate/class" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <class:ClassModel>
    <classes xmi:id="C1" name="Calculator">
      <methods xmi:id="M1" name="add" returnType="int">
        <parameters xmi:id="P1" name="a" type="int"/>
        <parameters xmi:id="P2" name="b" type="int"/>
      </methods>
      <methods xmi:id="M2" name="subtract" returnType="int">
        <parameters xmi:id="P3" name="a" type="int"/>
        <parameters xmi:id="P4" name="b" type="int"/>
      </methods>
    </classes>
  </class:ClassModel>
