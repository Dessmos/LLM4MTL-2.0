module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!IEEE1471Model def: rationale : String =
if IEEE1471!Rationale.allInstances()->size() > 0 then
  IEEE1471!Rationale.allInstances()->first().name.concat(': ').concat(IEEE1471!Rationale.allInstances()->first().content)
else
  ''
endif;

rule IEEE1471Model2MoDAFModel {
  from
    s : IEEE1471!IEEE1471Model
  to
    t : MoDAF!MoDAFModel (
      name <- s.name,
      content <- s.content,
      enterprise <- s.system,
      environment <- s.environment,
      operationalMissions <- s.missions,
      architectures <- Sequence { s.architecture },
      architecturalDescription <- Sequence { thisModule.mapAD(s.architecturalDescription) },
      architecturalReferences <- Sequence {},
      architecturalFrameworks <- Sequence { thisModule.createDefaultFramework(s) },
      architectureMetadatas <- Sequence {},
      metaDatas <- Sequence {},
      stakeholders <- s.stakeholders,
      stakeholderHasConcerns <- Sequence {}
    )
}

helper def: createDefaultFramework(m : IEEE1471!IEEE1471Model) : MoDAF!ArchitecturalFramework =
MoDAF!ArchitecturalFramework{
  name <- 'DefaultFramework',
  content <- m.rationale.name.concat(': ').concat(m.rationale.content),
  ownedMember <- m.viewpoints->select(v | v.hasSource.oclIsUndefined())->collect(v | thisModule.mapViewpoint(v))
};

lazy rule System2Enterprise {
  from
    s : IEEE1471!System
  to
    t : MoDAF!Enterprise (
      name <- s.name,
      content <- s.content,
      inhabits <- s.inhabits,
      fulfills <- s.fulfills
    )
}

lazy rule Environment2Environment {
  from
    s : IEEE1471!Environment
  to
    t : MoDAF!Environment (
      name <- s.name,
      content <- s.content,
      taxonomy <- thisModule.defaultTaxonomy()
    )
}

helper def: defaultTaxonomy() : MoDAF!Taxonomy =
MoDAF!Taxonomy{
  name <- 'DefaultTaxonomy',
  content <- '',
  date <- '',
  url <- '',
  version <- '',
  contents <- Sequence {}
};

lazy rule Mission2OperationalMission {
  from
    s : IEEE1471!Mission
  to
    t : MoDAF!OperationalMission (
      name <- s.name,
      content <- s.content
    )
}

lazy rule Architecture2Architecture {
  from
    s : IEEE1471!Architecture
  to
    t : MoDAF!Architecture (
      name <- s.name,
      content <- s.content,
      enterprise <- s.describedBy.identifiesS->first().has->first().isImportantTo->first().hasAn, 
      describedBy <- thisModule.mapAD(s.describedBy)
    )
}

lazy rule AD2AD {
  from
    s : IEEE1471!ArchitecturalDescription
  to
    t : MoDAF!ArchitecturalDescription (
      name <- s.name,
      content <- s.content,
      approvialAuthority <- '',
      architect <- '',
      assumptionAndConstraints <- '',
      creatingOrganisation <- '',
      dateCompleted <- '',
      purpose <- '',
      recommendations <- '',
      summaryOfFindings <- '',
      tollsUsed <- '',
      viewpoints <- s.selects->collect(v | thisModule.mapViewpoint(v)),
      products <- s.aggregates->collect(m | thisModule.mapModel(m)),
      taxonomy <- thisModule.defaultTaxonomy()
    )
}

helper def: mapAD(s : IEEE1471!ArchitecturalDescription) : MoDAF!ArchitecturalDescription =
thisModule.AD2AD(s);

lazy rule Stakeholder2Stakeholder {
  from
    s : IEEE1471!Stakeholder
  to
    t : MoDAF!Stakeholder (
      name <- s.name,
      content <- s.content
    )
}

lazy rule Concern2Concern {
  from
    s : IEEE1471!Concern
  to
    t : MoDAF!Concern (
      name <- s.name,
      content <- s.content
    )
}

lazy rule Viewpoint2View {
  from
    s : IEEE1471!Viewpoint
  to
    t : MoDAF!View (
      name <- s.name,
      content <- s.content,
      framework <- if s.hasSource.oclIsUndefined() then 'DefaultFramework' else s.hasSource.name endif,
      frameworkWebsite <- '',
      viewCode <- '',
      viewDescription <- s.content,
      viewName <- s.name,
      definingFramework <- if s.hasSource.oclIsUndefined() then
        thisModule.getDefaultFramework()
      else
        thisModule.mapLibraryViewpoint(s.hasSource)
      endif,
      usedToCover <- s.usedToCover->collect(c | thisModule.Concern2Concern(c))
    )
}

helper def: getDefaultFramework() : MoDAF!ArchitecturalFramework =
MoDAF!ArchitecturalFramework.allInstances()->any(f | f.name = 'DefaultFramework');

lazy rule View2ArchitecturalProduct {
  from
    s : IEEE1471!View
  to
    t : MoDAF!ArchitecturalProduct (
      name <- s.name,
      content <- s.content,
      description <- s.content,
      architecturalElements <- s.consitsOf->collect(m | thisModule.mapElements(m)),
      definingView <- thisModule.Viewpoint2View(s.conformsTo),
      addresses <- s.conformsTo.usedToCover->collect(c | thisModule.Concern2Concern(c))
    )
}

lazy rule Model2Element {
  from
    s : IEEE1471!Model
  to
    t : MoDAF!Elements (
      name <- s.name,
      content <- s.content
    )
}

helper def: mapModel(s : IEEE1471!Model) : MoDAF!ArchitecturalProduct =
thisModule.View2ArchitecturalProduct(s.participatesInV->first());

helper def: mapElements(s : IEEE1471!Model) : MoDAF!Elements =
thisModule.Model2Element(s);

lazy rule LibraryViewpoint2ArchitecturalFramework {
  from
    s : IEEE1471!LibraryViewpoint
  to
    t : MoDAF!ArchitecturalFramework (
      name <- s.name,
      content <- s.content,
      ownedMember <- IEEE1471!Viewpoint.allInstances()->select(v | v.hasSource = s)->collect(v | thisModule.Viewpoint2View(v))
    )
}

helper def: mapLibraryViewpoint(s : IEEE1471!LibraryViewpoint) : MoDAF!ArchitecturalFramework =
thisModule.LibraryViewpoint2ArchitecturalFramework(s);

rule StakeholderHasConcern {
  from
    sc : IEEE1471!Stakeholder (sc.has->notEmpty())
  to
    shc : MoDAF!StakeholderHasConcern (
      client <- thisModule.Stakeholder2Stakeholder(sc),
      supplier <- sc.has->first().Concern2Concern(),
      owner <- thisModule.singleMoDAFModel()
    )
}

helper def: singleMoDAFModel() : MoDAF!MoDAFModel =
MoDAF!MoDAFModel.allInstances()->first();