module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
  self.roles->exists(r | r.isPropertyGenerator = true)
  or self.subTypes->notEmpty()
  or self.superType.oclIsUndefined() = false
  or self.properties->notEmpty();

helper def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
  DSL!Role.allInstances()->select(r |
    r.source = c and
    (not r.relation.needTurnOnClass())
  );

helper context DSL!Role def: isEmbedding() : Boolean =
  if self.relation.isEmbedding then
    if self.isNavigableFrom then
      true
    else
      false
    endif
  else
    false
  endif;

helper def: getPrimitiveTypePackage(mm : KM3!Metamodel) : KM3!Package =
  mm.contents->any(p | p.name = 'PrimitiveTypes');

helper def: getMainPackage(mm : KM3!Metamodel) : KM3!Package =
  mm.contents->any(p | p.name <> 'PrimitiveTypes');

helper def: getKM3Classifier(t : DSL!Type) : KM3!Classifier =
  KM3!Classifier.allInstances()->any(c |
    c.name = t.name and c.package.name = t.namespace
  );

helper def: getKM3Class(c : DSL!Classifier) : KM3!Class =
  KM3!Class.allInstances()->any(kc | kc.name = c.name);

helper def: getKM3Enum(e : DSL!Enumeration) : KM3!Enumeration =
  KM3!Enumeration.allInstances()->any(ke | ke.name = e.name);

helper def: computeUpper(r : DSL!Role) : Integer =
  if r.isUnbounded then
    -1
  else
    r.max
  endif;

rule Metamodel {
  from
    dm : DSL!DomainModel
  to
    mm : KM3!Metamodel (
      location <- dm.location
    ),
    mainPkg : KM3!Package (
      name <- dm.name,
      location <- dm.location,
      metamodel <- mm
    ),
    primPkg : KM3!Package (
      name <- 'PrimitiveTypes',
      location <- dm.location,
      metamodel <- mm
    )
  do {
    thisModule.createPrimitiveType(primPkg, 'String');
    thisModule.createPrimitiveType(primPkg, 'Integer');
    thisModule.createPrimitiveType(primPkg, 'Boolean');
  }
}

rule Class {
  from
    c : DSL!Class
  to
    kc : KM3!Class (
      name <- c.name,
      location <- c.location,
      isAbstract <- c.isAbstract,
      package <- thisModule.getMainPackage(mm)
    )
  using {
    mm : KM3!Metamodel = KM3!Metamodel.allInstances()->first();
  }
  do {
    if c.superType.oclIsUndefined() = false then
      kc.supertypes <- Sequence{ thisModule.getKM3Class(c.superType) };
    endif;
  }
}

rule Relation2Class {
  from
    r : DSL!Relationship (r.needTurnOnClass())
  to
    kc : KM3!Class (
      name <- r.name,
      location <- r.location,
      isAbstract <- r.isAbstract,
      package <- thisModule.getMainPackage(mm)
    )
  using {
    mm : KM3!Metamodel = KM3!Metamodel.allInstances()->first();
  }
  do {
    if r.superType.oclIsUndefined() = false then
      kc.supertypes <- Sequence{ thisModule.getKM3Class(r.superType) };
    endif;
  }
}

rule SimpleReference {
  from
    rl : DSL!Role (
      not rl.relation.needTurnOnClass() and
      rl.isNavigableFrom = true
    )
  to
    ref : KM3!Reference (
      name <- rl.name,
      location <- rl.location,
      owner <- thisModule.getKM3Class(rl.source),
      type <- thisModule.getKM3Class(rl.type),
      lower <- rl.min,
      upper <- thisModule.computeUpper(rl),
      isOrdered <- rl.isOrdered,
      isUnique <- true,
      isContainer <- rl.isEmbedding()
    )
  do {
    let opp : DSL!Role = rl.relation.roles->any(r | r <> rl) in
      if opp.isNavigableFrom then
        let oppRef : KM3!Reference = thisModule.getOrCreateOpposite(ref, opp) in
          ref.opposite <- oppRef;
        endif;
  }
}

rule ComplexReference {
  from
    rl : DSL!Role (
      rl.relation.needTurnOnClass() and
      rl.isNavigableFrom = true
    )
  to
    ref : KM3!Reference (
      name <- rl.name,
      location <- rl.location,
      owner <- thisModule.getKM3Class(rl.source),
      type <- thisModule.getKM3Class(rl.relation),
      lower <- rl.min,
      upper <- thisModule.computeUpper(rl),
      isOrdered <- rl.isOrdered,
      isUnique <- true,
      isContainer <- rl.isEmbedding()
    )
  do {
    let opp : DSL!Role = rl.relation.roles->any(r | r <> rl) in
      if opp.isNavigableFrom then
        let oppRef : KM3!Reference = thisModule.getOrCreateOpposite(ref, opp) in
          ref.opposite <- oppRef;
        endif;
  }
}

helper def: getOrCreateOpposite(r : KM3!Reference, role : DSL!Role) : KM3!Reference =
  let existing : KM3!Reference = KM3!Reference.allInstances()->any(x |
    x.owner = thisModule.getKM3Class(role.type) and
    x.type = r.owner and
    x.name = role.name
  ) in
    if existing.oclIsUndefined() then
      thisModule.createOpposite(r, role)
    else
      existing
    endif;

helper def: createOpposite(r : KM3!Reference, role : DSL!Role) : KM3!Reference =
  let ownerCls : KM3!Class = thisModule.getKM3Class(role.type) in
  let newRef : KM3!Reference = KM3!Reference.newInstance() in
  (
    newRef.name <- role.name;
    newRef.location <- role.location;
    newRef.owner <- ownerCls;
    newRef.type <- r.owner;
    newRef.lower <- role.min;
    newRef.upper <- thisModule.computeUpper(role);
    newRef.isOrdered <- role.isOrdered;
    newRef.isUnique <- true;
    newRef.isContainer <- role.isEmbedding();
    newRef.opposite <- r;
    newRef
  );

rule Attribute {
  from
    vp : DSL!ValueProperty
  to
    att : KM3!Attribute (
      name <- vp.name,
      location <- vp.location,
      owner <- thisModule.getKM3Class(vp.owner),
      type <- thisModule.mapValuePropertyType(vp.type),
      lower <- 0,
      upper <- 1,
      isOrdered <- false,
      isUnique <- true
    )
}

helper def: mapValuePropertyType(t : DSL!Type) : KM3!Classifier =
  if t.oclIsKindOf(DSL!SimpleType) then
    thisModule.mapSimpleTypeToPrimitive(t.oclAsType(DSL!SimpleType))
  else
    thisModule.getKM3Classifier(t)
  endif;

helper def: mapSimpleTypeToPrimitive(t : DSL!SimpleType) : KM3!Classifier =
  let primPkg : KM3!Package = thisModule.getPrimitiveTypePackage(mm) in
  let existing : KM3!DataType = KM3!DataType.allInstances()->any(dt |
    dt.name = t.name and dt.package = primPkg
  ) in
  if existing.oclIsUndefined() then
    thisModule.createPrimitiveType(primPkg, t.name)
  else
    existing
  endif
  using {
    mm : KM3!Metamodel = KM3!Metamodel.allInstances()->first();
  };

helper def: createPrimitiveType(p : KM3!Package, n : String) : KM3!DataType =
  let dt : KM3!DataType = KM3!DataType.newInstance() in
  (
    dt.name <- n;
    dt.location <- p.location;
    dt.package <- p;
    dt
  );

rule Enumeration {
  from
    e : DSL!Enumeration
  to
    ke : KM3!Enumeration (
      name <- e.name,
      location <- e.location,
      package <- thisModule.getMainPackage(mm)
    )
  using {
    mm : KM3!Metamodel = KM3!Metamodel.allInstances()->first();
  }
}

rule EnumLiteral {
  from
    l : DSL!EnumerationLiteral
  to
    kl : KM3!EnumLiteral (
      name <- l.name,
      location <- l.location,
      package <- thisModule.getMainPackage(mm)
    )
  using {
    mm : KM3!Metamodel = KM3!Metamodel.allInstances()->first();
  }
  do {
    let ownerEnum : DSL!Enumeration = DSL!Enumeration.allInstances()->any(e |
      e.literals->includes(l)
    ) in
      if ownerEnum.oclIsUndefined() = false then
        thisModule.getKM3Enum(ownerEnum).literals <- thisModule.getKM3Enum(ownerEnum).literals->including(kl);
      endif;
  }
}

rule DataType {
  from
    st : DSL!SimpleType
  to
    dt : KM3!DataType (
      name <- st.name,
      location <- st.location,
      package <- thisModule.getMainPackage(mm)
    )
  using {
    mm : KM3!Metamodel = KM3!Metamodel.allInstances()->first();
  }
}