module AmaltheaToAscet_All;

create OUT : ascet from IN : amalthea;

helper context amalthea!Task def: isRoot() : Boolean =
	self.oclContainer().oclIsUndefined() or not self.oclContainer().oclIsKindOf(amalthea!ComponentContainer);

rule ComponentContainer2AscetModule {
	from
		src : amalthea!ComponentContainer
	to
		tgt : ascet!AscetModule (
			tasks <- src.tasks->collect(t | thisModule.Task2SoftwareTask(t))
		)
}

rule TaskRoot2SoftwareTask {
	from
		src : amalthea!Task (
			src.isRoot()
		)
	to
		tgt : ascet!SoftwareTask (
			name <- src.name
		)
}

lazy rule Task2SoftwareTask {
	from
		src : amalthea!Task
	to
		tgt : ascet!SoftwareTask (
			name <- src.name
		)
}