module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Node def: statement : CPL!Node =
  if self.oclIsTypeOf(CPL!NodeContainer) then
    self.oclAsType(CPL!NodeContainer).contents.statement
  else
    self
  endif;

helper context CPL!Node def: locations : Sequence(CPL!Location) =
  if self.oclIsTypeOf(CPL!Location) then
    Sequence{ self.oclAsType(CPL!Location) }->union(self.oclAsType(CPL!Location).contents.locations)
  else
    if self.oclIsTypeOf(CPL!NodeContainer) then
      self.oclAsType(CPL!NodeContainer).contents.locations
    else
      Sequence{}
    endif
  endif;

helper context CPL!Proxy def: isSimple : Boolean =
  self.locations->size() = 1 and
  self.busy.oclIsUndefined() and
  self.noAnswer.oclIsUndefined() and
  self.redirection.oclIsUndefined() and
  self.failure.oclIsUndefined() and
  self.default.oclIsUndefined();

rule CPL2Program {
  from
    c : CPL!CPL
  to
    p : SPL!Program (
      location <- c.location,
      service <- s
    ),
    s : SPL!Service (
      location <- c.location,
      name <- 'CPLService',
      declarations <- c.subActions->collect(sa | thisModule.SubAction2Function(sa)),
      sessions <- Sequence{}
    )
}

lazy rule SubAction2Function {
  from
    sa : CPL!SubAction
  to
    f : SPL!LocalFunctionDeclaration (
      location <- sa.location,
      name <- sa.id,
      returnType <- rt,
      arguments <- Sequence{},
      statements <- Sequence{ thisModule.statement(sa.contents.statement) }
    ),
    rt : SPL!SimpleType (
      location <- sa.location,
      type <- #void
    )
}

lazy rule Incoming2Method {
  from
    inc : CPL!Incoming
  to
    m : SPL!Method (
      location <- inc.location,
      type <- t,
      direction <- #in,
      methodName <- n,
      arguments <- Sequence{},
      statements <- Sequence{ thisModule.statement(inc.contents.statement) },
      branches <- Sequence{}
    ),
    t : SPL!SimpleType (
      location <- inc.location,
      type <- #void
    ),
    n : SPL!SIPMethodName (
      location <- inc.location,
      name <- #INVITE
    )
}

lazy rule Proxy2Return {
  from
    p : CPL!Proxy (p.isSimple)
  to
    r : SPL!ReturnStat (
      location <- p.location,
      returnedValue <- ce,
      branch <- nb
    ),
    ce : SPL!ConstantExp (
      location <- p.location,
      value <- sc
    ),
    sc : SPL!SequenceConstant (
      location <- p.location,
      values <- p.locations->collect(l | thisModule.Location2URIConstant(l))
    ),
    nb : SPL!NamedBranch (
      location <- p.location,
      name <- Sequence{'proxy'}
    )
}

lazy rule Proxy2Select {
  from
    p : CPL!Proxy (not p.isSimple)
  to
    s : SPL!SelectStat (
      location <- p.location,
      matchedExp <- me,
      selectCases <- scs,
      selectDefault <- sd
    ),
    me : SPL!RequestURIExp (
      location <- p.location
    ),
    scs : Sequence(SPL!SelectCase) (
      scs <- Sequence{}
        ->union(if not p.busy.oclIsUndefined() then Sequence{ thisModule.Busy2SelectCase(p.busy) } else Sequence{} endif)
        ->union(if not p.noAnswer.oclIsUndefined() then Sequence{ thisModule.NoAnswer2SelectCase(p.noAnswer) } else Sequence{} endif)
        ->union(if not p.redirection.oclIsUndefined() then Sequence{ thisModule.Redirection2SelectCase(p.redirection) } else Sequence{} endif)
    ),
    sd : SPL!SelectDefault (
      location <- p.location,
      statements <- Sequence{}
        ->union(if not p.default.oclIsUndefined() then Sequence{ thisModule.statement(p.default.contents.statement) } else Sequence{} endif)
        ->union(if not p.failure.oclIsUndefined() then Sequence{ thisModule.statement(p.failure.contents.statement) } else Sequence{} endif)
    )
}

lazy rule Busy2SelectCase {
  from
    b : CPL!Busy
  to
    sc : SPL!SelectCase (
      location <- b.location,
      values <- Sequence{ rc },
      statements <- Sequence{ thisModule.statement(b.contents.statement) }
    ),
    rc : SPL!ResponseConstant (
      location <- b.location,
      response <- er
    ),
    er : SPL!ClientErrorResponse (
      location <- b.location,
      errorKind <- #BUSY_HERE
    )
}

lazy rule NoAnswer2SelectCase {
  from
    n : CPL!NoAnswer
  to
    sc : SPL!SelectCase (
      location <- n.location,
      values <- Sequence{ rc },
      statements <- Sequence{ thisModule.statement(n.contents.statement) }
    ),
    rc : SPL!ResponseConstant (
      location <- n.location,
      response <- er
    ),
    er : SPL!ClientErrorResponse (
      location <- n.location,
      errorKind <- #REQUEST_TIMEOUT
    )
}

lazy rule Redirection2SelectCase {
  from
    r : CPL!Redirection
  to
    sc : SPL!SelectCase (
      location <- r.location,
      values <- Sequence{ rc },
      statements <- Sequence{ thisModule.statement(r.contents.statement) }
    ),
    rc : SPL!ResponseConstant (
      location <- r.location,
      response <- er
    ),
    er : SPL!RedirectionErrorResponse (
      location <- r.location,
      errorKind <- #USE_PROXY
    )
}

lazy rule Default2SelectDefault {
  from
    d : CPL!Default
  to
    sd : SPL!SelectDefault (
      location <- d.location,
      statements <- Sequence{ thisModule.statement(d.contents.statement) }
    )
}

lazy rule SubCall2Return {
  from
    sc : CPL!SubCall
  to
    r : SPL!ReturnStat (
      location <- sc.location,
      returnedValue <- fce,
      branch <- nb
    ),
    fce : SPL!FunctionCallExp (
      location <- sc.location,
      functionCall <- fc
    ),
    fc : SPL!FunctionCall (
      location <- sc.location,
      function <- CPL!SubAction.allInstances()->any(sa | sa.id = sc.ref),
      parameters <- Sequence{}
    ),
    nb : SPL!NamedBranch (
      location <- sc.location,
      name <- Sequence{'subcall'}
    )
}

lazy rule Redirect2Return {
  from
    r : CPL!Redirect
  to
    rs : SPL!ReturnStat (
      location <- r.location,
      returnedValue <- ce,
      branch <- nb
    ),
    ce : SPL!ConstantExp (
      location <- r.location,
      value <- rc
    ),
    rc : SPL!ResponseConstant (
      location <- r.location,
      response <- if r.permanent = 'yes' then per else tmp endif
    ),
    per : SPL!RedirectionErrorResponse (
      location <- r.location,
      errorKind <- #MOVED_PERMANENTLY
    ),
    tmp : SPL!RedirectionErrorResponse (
      location <- r.location,
      errorKind <- #MOVED_TEMPORARILY
    ),
    nb : SPL!NamedBranch (
      location <- r.location,
      name <- Sequence{'redirect'}
    )
}

lazy rule AddressSwitch2SelectStat {
  from
    as : CPL!AddressSwitch
  to
    s : SPL!SelectStat (
      location <- as.location,
      matchedExp <- me,
      selectCases <- as.addresses->collect(a | thisModule.SwitchedAddress2SelectCase(a)),
      selectDefault <- sd
    ),
    me : SPL!RequestURIExp (
      location <- as.location
    ),
    sd : SPL!SelectDefault (
      location <- as.location,
      statements <- Sequence{}
        ->union(if not as.otherwise.oclIsUndefined() then Sequence{ thisModule.statement(as.otherwise.contents.statement) } else Sequence{} endif)
        ->union(if not as.notPresent.oclIsUndefined() then Sequence{ thisModule.statement(as.notPresent.contents.statement) } else Sequence{} endif)
    )
}

lazy rule SwitchedAddress2SelectCase {
  from
    sa : CPL!SwitchedAddress
  to
    sc : SPL!SelectCase (
      location <- sa.location,
      values <- Sequence{ thisModule.Location2URIConstant(sa.contents.locations->first()) },
      statements <- Sequence{ thisModule.statement(sa.contents.statement) }
    )
}

lazy rule Otherwise2SelectDefault {
  from
    o : CPL!Otherwise
  to
    sd : SPL!SelectDefault (
      location <- o.location,
      statements <- Sequence{ thisModule.statement(o.contents.statement) }
    )
}

lazy rule Location2URIConstant {
  from
    l : CPL!Location
  to
    uc : SPL!URIConstant (
      location <- l.location,
      uri <- l.url
    )
}