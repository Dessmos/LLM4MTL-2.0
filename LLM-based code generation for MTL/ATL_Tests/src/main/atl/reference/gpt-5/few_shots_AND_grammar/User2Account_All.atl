module User2Account_All;
create OUT : Account from IN : User;

helper context User!User def: isActive() : Boolean =
  self.status = 'Active' or self.status = 'Enabled';

rule UserModel2AccountModel {
  from src : User!UserModel
  to   dst : Account!AccountModel (
    accounts <- User!User.allInstances()->collect(u | thisModule.User2Account(u))
  )
}

unique lazy rule User2Account {
  from u : User!User
  to   a : Account!Account (
    username    <- u.username,
    email       <- u.email,
    createdDate <- u.registrationDate,
    active      <- u.isActive()
  )
}