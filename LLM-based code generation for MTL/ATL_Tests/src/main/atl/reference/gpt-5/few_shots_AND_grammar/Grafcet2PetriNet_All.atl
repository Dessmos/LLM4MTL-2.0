module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
  from
    g : Grafcet!Grafcet
  to
    p : PetriNet!PetriNet (
      location <- g.location,
      name <- g.name,
      elements <- g.elements->collect(e |
        if e.oclIsTypeOf(Grafcet!Step) then
          thisModule.Place(e)
        else
          thisModule.Transition(e)
        endif
      ),
      arcs <- g.connections->collect(c |
        if c.oclIsTypeOf(Grafcet!StepToTransition) then
          thisModule.PlaceToTransition(c)
        else
          thisModule.TransitionToPlace(c)
        endif
      )
    )
}

lazy rule Place {
  from
    s : Grafcet!Step
  to
    p : PetriNet!Place (
      location <- s.location,
      name <- s.name,
      net <- s.grafcet.oclAsType(Grafcet!Grafcet).resolveone(PetriNet)
    )
}

lazy rule Transition {
  from
    t : Grafcet!Transition
  to
    pt : PetriNet!Transition (
      location <- t.location,
      name <- t.name,
      net <- t.grafcet.oclAsType(Grafcet!Grafcet).resolveone(PetriNet)
    )
}

lazy rule PlaceToTransition {
  from
    c : Grafcet!StepToTransition
  to
    a : PetriNet!PlaceToTransition (
      location <- c.location,
      name <- c.name,
      net <- c.grafcet.oclAsType(Grafcet!Grafcet).resolveone(PetriNet),
      weight <- 1,
      from <- thisModule.Place(c.from),
      to <- thisModule.Transition(c.to)
    )
}

lazy rule TransitionToPlace {
  from
    c : Grafcet!TransitionToStep
  to
    a : PetriNet!TransitionToPlace (
      location <- c.location,
      name <- c.name,
      net <- c.grafcet.oclAsType(Grafcet!Grafcet).resolveone(PetriNet),
      weight <- 1,
      from <- thisModule.Transition(c.from),
      to <- thisModule.Place(c.to)
    )
}