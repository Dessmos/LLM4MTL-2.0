module Item2Product_All;
create OUT : PRODUCT from IN : ITEM;

helper context ITEM!Item def:
	getCategory() : String =
		if self.type = 'Electronics' then
			'Tech'
		else if self.type = 'Clothing' then
			'Apparel'
		else
			'General'
		endif endif;

rule Item2Product {
	from
		s : ITEM!Item
	to
		t : PRODUCT!Product (
			name <- s.name,
			price <- s.price,
			description <- s.description,
			inStock <- s.quantity > 0,
			category <- s.getCategory()
		)
}