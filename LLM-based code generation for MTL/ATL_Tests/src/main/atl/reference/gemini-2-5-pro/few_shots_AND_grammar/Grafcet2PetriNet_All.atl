module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
	from s : Grafcet!Grafcet
	to t : PetriNet!PetriNet (
		location <- s.location,
		name <- s.name,
		elements <- s.elements,
		arcs <- s.connections
	)
}

rule Place {
	from s : Grafcet!Step
	to t : PetriNet!Place (
		location <- s.location,
		name <- s.name,
		net <- s.grafcet,
		incomingArc <- s.incomingConnections,
		outgoingArc <- s.outgoingConnections
	)
}

rule Transition {
	from s : Grafcet!Transition
	to t : PetriNet!Transition (
		location <- s.location,
		name <- s.name,
		net <- s.grafcet,
		incomingArc <- s.incomingConnections,
		outgoingArc <- s.outgoingConnections
	)
}

rule PlaceToTransition {
	from s : Grafcet!StepToTransition
	to t : PetriNet!PlaceToTransition (
		location <- s.location,
		name <- s.name,
		net <- s.grafcet,
		from <- s.from,
		to <- s.to
	)
}

rule TransitionToPlace {
	from s : Grafcet!TransitionToStep
	to t : PetriNet!TransitionToPlace (
		location <- s.location,
		name <- s.name,
		net <- s.grafcet,
		from <- s.from,
		to <- s.to
	)
}