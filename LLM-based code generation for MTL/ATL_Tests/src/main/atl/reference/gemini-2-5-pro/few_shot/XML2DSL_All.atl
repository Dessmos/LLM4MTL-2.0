module XML2DSL;
create OUT : DSL from IN : XML;

helper def: dslElementsById : Map(String, DSL!NamedElement) =
	XML!Element.allInstancesFrom('IN')->select(e | e.hasAttr('id'))->iterate(
		e; acc : Map(String, DSL!NamedElement) = Map{} |
		acc->including(e.getAttrVal('id'), e)
	);

helper def: getSubTypes(typeId : String) : Sequence(XML!Element) =
	XML!Element.allInstancesFrom('IN')->select(e |
		(e.name = 'class' or e.name = 'relationship') and e.hasAttr('superType') and e.getAttrVal('superType') = typeId
	);

helper def: findType(typeId : String) : DSL!Type =
	if typeId.oclIsUndefined() or typeId = '' then
		OclUndefined
	else
		let simpleType : DSL!SimpleType = DSL!SimpleType.allInstancesFrom('OUT')->select(t | t.identity = typeId)->first() in
		if not simpleType.oclIsUndefined() then
			simpleType
		else
			thisModule.dslElementsById->get(typeId)
		endif
	endif;

helper context XML!Element def: getAttrVal(name : String) : String =
	let attr = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->first() in
	if attr.oclIsUndefined() then OclUndefined else attr.value endif;

helper context XML!Element def: getAttrBool(name : String) : Boolean =
	let val = self.getAttrVal(name) in
	if val.oclIsUndefined() then false else val = 'true' endif;

helper context XML!Element def: hasAttr(name : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = name);

helper context XML!Element def: get(name : String) : XML!Element =
	self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = name)->first();

helper context XML!Element def: getSeq(name : String) : Sequence(XML!Element) =
	self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = name)->asSequence();

helper context XML!Element def: hasChildren(name : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Element) and c.name = name);

helper context XML!Element def: getText() : String =
	let txt = self.children->select(c | c.oclIsTypeOf(XML!Text))->first() in
	if txt.oclIsUndefined() then '' else txt.value endif;

helper context XML!Element def: isAbstract() : Boolean =
	self.getAttrBool('isAbstract');

helper context XML!Element def: getType() : String =
	self.getAttrVal('type');

helper context XML!Element def: getEnumId() : String =
	if self.hasAttr('enum') then self.getAttrVal('enum') else self.getAttrVal('id') endif;

rule DomainModel {
	from s : XML!Element (s.name = 'domainModel')
	to
		t : DSL!DomainModel (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('id'),
			namespace <- s.getAttrVal('namespace'),
			isLoaded <- true,
			classifiers <- s.getSeq('class')->union(s.getSeq('relationship'))
		),
		stringType : DSL!SimpleType (
			name <- 'String', identity <- 'String', namespace <- 'PrimitiveTypes'
		),
		integerType : DSL!SimpleType (
			name <- 'Integer', identity <- 'Integer', namespace <- 'PrimitiveTypes'
		),
		booleanType : DSL!SimpleType (
			name <- 'Boolean', identity <- 'Boolean', namespace <- 'PrimitiveTypes'
		),
		decimalType : DSL!SimpleType (
			name <- 'Decimal', identity <- 'Decimal', namespace <- 'PrimitiveTypes'
		)
	do {
		t.types <- s.getSeq('enumeration');
		t.types <- t.types->including(stringType)->including(integerType)->including(booleanType)->including(decimalType);
	}
}

rule Class {
	from s : XML!Element (s.name = 'class')
	to t : DSL!Class (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('id'),
		namespace <- s.parent.getAttrVal('namespace'),
		isLoaded <- true,
		isAbstract <- s.isAbstract(),
		properties <- s.getSeq('property'),
		domainModel <- s.parent,
		superType <- thisModule.dslElementsById->get(s.getAttrVal('superType')),
		subTypes <- thisModule.getSubTypes(s.getAttrVal('id'))
	)
}

rule Relationship {
	from s : XML!Element (s.name = 'relationship')
	to t : DSL!Relationship (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('id'),
		namespace <- s.parent.getAttrVal('namespace'),
		isLoaded <- true,
		isAbstract <- s.isAbstract(),
		isEmbedding <- s.getAttrBool('isEmbedding'),
		roles <- s.getSeq('role'),
		properties <- s.getSeq('property'),
		domainModel <- s.parent,
		superType <- thisModule.dslElementsById->get(s.getAttrVal('superType')),
		subTypes <- thisModule.getSubTypes(s.getAttrVal('id'))
	)
}

rule Role {
	from s : XML!Element (s.name = 'role')
	to t : DSL!Role (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('id'),
		min <- s.getAttrVal('min').toInteger(),
		max <- let maxVal = s.getAttrVal('max') in if maxVal = '*' then -1 else maxVal.toInteger() endif,
		isUnbounded <- s.getAttrVal('max') = '*',
		accepts <- s.getAttrVal('accepts'),
		isOrdered <- s.getAttrBool('isOrdered'),
		isNavigableFrom <- s.getAttrBool('isNavigableFrom'),
		isPropertyGenerator <- s.getAttrBool('isPropertyGenerator'),
		source <- thisModule.dslElementsById->get(s.getAttrVal('source')),
		type <- thisModule.dslElementsById->get(s.getType()),
		relation <- s.parent
	)
}

rule ValueProperty {
	from s : XML!Element (s.name = 'property')
	to t : DSL!ValueProperty (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('id'),
		owner <- s.parent,
		type <- thisModule.findType(s.getType())
	)
}

rule Enumeration {
	from s : XML!Element (s.name = 'enumeration')
	to t : DSL!Enumeration (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('id'),
		namespace <- s.parent.getAttrVal('namespace'),
		isLoaded <- true,
		literals <- s.getSeq('literal')
	)
}

rule EnumerationLiteral {
	from s : XML!Element (s.name = 'literal')
	to t : DSL!EnumerationLiteral (
		name <- s.getAttrVal('name'),
		identity <- s.getAttrVal('id'),
		value <- s.getAttrVal('value').toInteger()
	)
}