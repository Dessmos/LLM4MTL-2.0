module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrBool(attrName : String) : Boolean =
  let attr : XML!Attribute = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName)->first() in
  if attr.oclIsUndefined() then false else attr.value = 'true' endif;

helper context XML!Element def: getAttrVal(attrName : String) : String =
  let attr : XML!Attribute = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName)->first() in
  if attr.oclIsUndefined() then '' else attr.value endif;

helper context XML!Element def: get(elemName : String) : XML!Element =
  self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = elemName)->first();

helper context XML!Element def: getType() : String =
  self.getAttrVal('type');

helper context XML!Element def: getEnumId() : String =
  self.getAttrVal('enumId');

helper context XML!Element def: getText() : String =
  let txt : XML!Text = self.children->select(c | c.oclIsTypeOf(XML!Text))->first() in
  if txt.oclIsUndefined() then '' else txt.value endif;

helper context XML!Element def: getSeq(elemName : String) : Sequence(XML!Element) =
  self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = elemName);

helper context XML!Element def: hasChildren() : Boolean =
  self.children->exists(c | c.oclIsTypeOf(XML!Element));

helper context XML!Element def: hasAttr(attrName : String) : Boolean =
  self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName);

helper context XML!Element def: isAbstract() : Boolean =
  self.getAttrBool('isAbstract');

helper def: dslElementsById : Map(String, XML!Element) =
  XML!Element.allInstances()->select(e | e.hasAttr('identity'))->iterate(e; acc : Map(String, XML!Element) = Map{} | acc.including(e.getAttrVal('identity'), e));

helper def: getSubTypes(parentId : String) : Sequence(XML!Element) =
  XML!Element.allInstances()->select(e | e.hasAttr('superType') and e.getAttrVal('superType') = parentId);

helper def: findType(typeId : String) : OclAny =
  if typeId = 'Boolean' then thisModule.boolType
  else if typeId = 'Integer' then thisModule.intType
  else if typeId = 'String' then thisModule.strType
  else if typeId = 'EInt' then thisModule.intType
  else thisModule.dslElementsById.get(typeId)
  endif endif endif endif;

rule DomainModel {
  from src : XML!Element (src.name = 'DomainModel')
  to   dst : DSL!DomainModel (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    namespace <- src.getAttrVal('namespace'),
    isLoaded <- src.getAttrBool('isLoaded'),
    classifiers <- src.getSeq('classifiers'),
    types <- src.getSeq('types')
  ),
  boolType : DSL!SimpleType (
    name <- 'Boolean',
    identity <- 'Boolean',
    namespace <- 'PrimitiveTypes'
  ),
  intType : DSL!SimpleType (
    name <- 'Integer',
    identity <- 'Integer',
    namespace <- 'PrimitiveTypes'
  ),
  strType : DSL!SimpleType (
    name <- 'String',
    identity <- 'String',
    namespace <- 'PrimitiveTypes'
  ),
  eIntType : DSL!SimpleType (
    name <- 'EInt',
    identity <- 'EInt',
    namespace <- 'PrimitiveTypes'
  )
  do {
    dst.types <- dst.types->including(boolType)->including(intType)->including(strType)->including(eIntType);
    thisModule.boolType <- boolType;
    thisModule.intType <- intType;
    thisModule.strType <- strType;
    thisModule.eIntType <- eIntType;
  }
}

rule Class {
  from src : XML!Element (src.name = 'Class')
  to   dst : DSL!Class (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    namespace <- src.getAttrVal('namespace'),
    isLoaded <- src.getAttrBool('isLoaded'),
    isAbstract <- src.isAbstract(),
    properties <- src.getSeq('properties'),
    superType <- if src.hasAttr('superType') then thisModule.findType(src.getAttrVal('superType')) else OclUndefined endif,
    subTypes <- thisModule.getSubTypes(src.getAttrVal('identity'))
  )
}

rule Relationship {
  from src : XML!Element (src.name = 'Relationship')
  to   dst : DSL!Relationship (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    namespace <- src.getAttrVal('namespace'),
    isLoaded <- src.getAttrBool('isLoaded'),
    isAbstract <- src.isAbstract(),
    isEmbedding <- src.getAttrBool('isEmbedding'),
    properties <- src.getSeq('properties'),
    roles <- src.getSeq('roles'),
    superType <- if src.hasAttr('superType') then thisModule.findType(src.getAttrVal('superType')) else OclUndefined endif,
    subTypes <- thisModule.getSubTypes(src.getAttrVal('identity'))
  )
}

rule Role {
  from src : XML!Element (src.name = 'Role')
  to   dst : DSL!Role (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    min <- src.getAttrVal('min').toInteger(),
    max <- src.getAttrVal('max').toInteger(),
    isUnbounded <- src.getAttrBool('isUnbounded'),
    accepts <- src.getAttrVal('accepts'),
    isOrdered <- src.getAttrBool('isOrdered'),
    isNavigableFrom <- src.getAttrBool('isNavigableFrom'),
    isPropertyGenerator <- src.getAttrBool('isPropertyGenerator'),
    source <- thisModule.findType(src.getAttrVal('source')),
    type <- thisModule.findType(src.getType())
  )
}

rule ValueProperty {
  from src : XML!Element (src.name = 'ValueProperty')
  to   dst : DSL!ValueProperty (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    type <- thisModule.findType(src.getType())
  )
}

rule Enumeration {
  from src : XML!Element (src.name = 'Enumeration')
  to   dst : DSL!Enumeration (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    namespace <- src.getAttrVal('namespace'),
    literals <- src.getSeq('literals')
  )
}

rule EnumerationLiteral {
  from src : XML!Element (src.name = 'EnumerationLiteral')
  to   dst : DSL!EnumerationLiteral (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('identity'),
    value
