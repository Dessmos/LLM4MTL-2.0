<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:Make="Make">
  <Make:Makefile xmi:id="makefile1" name="TestMakefile">
    <elements xmi:type="Make:Macro" xmi:id="macro1" name="CC" value="gcc"/>
    <elements xmi:type="Make:Rule" xmi:id="rule1" name="all">
      <shellLines xmi:id="sh1" command="echo Build complete" display="true" ruleShellLine="rule1"/>
    </elements>
  </Make:Makefile>
</xmi:XMI>
