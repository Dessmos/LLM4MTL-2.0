<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:DSL="DSL">
  <DSL:DomainModel xmi:id="dm1" name="LibraryDomain" identity="library-domain-1" namespace="com.example.library" isLoaded="true">
    <classifiers xmi:type="DSL:Class" xmi:id="cls1" name="Book" identity="class-book" namespace="com.example.library" isLoaded="true" isAbstract="false" domainModel="dm1">
      <properties xmi:id="prop1" name="title" identity="prop-title" owner="cls1" type="str1"/>
      <properties xmi:id="prop2" name="isbn" identity="prop-isbn" owner="cls1" type="str1"/>
      <properties xmi:id="prop3" name="year" identity="prop-year" owner="cls1" type="int1"/>
    </classifiers>
    <classifiers xmi:type="DSL:Class" xmi:id="cls2" name="Author" identity="class-author" namespace="com.example.library" isLoaded="true" isAbstract="false" domainModel="dm1">
      <properties xmi:id="prop4" name="name" identity="prop-name" owner="cls2" type="str1"/>
      <properties xmi:id="prop5" name="birthYear" identity="prop-birthyear" owner="cls2" type="int1"/>
    </classifiers>
    <classifiers xmi:type="DSL:Class" xmi:id="cls3" name="Library" identity="class-library" namespace="com.example.library" isLoaded="true" isAbstract="false" domainModel="dm1">
      <properties xmi:id="prop6" name="name" identity="prop-libname" owner="cls3" type="str1"/>
    </classifiers>
    <classifiers xmi:type="DSL:Relationship" xmi:id="rel1" name="WrittenBy" identity="rel-writtenby" namespace="com.example.library" isLoaded="true" isAbstract="false" isEmbedding="false" domainModel="dm1">
      <roles xmi:id="role1" name="book" identity="role-book" min="0" max="-1" isUnbounded="true" accepts="Book" isOrdered="false" isNavigableFrom="true" isPropertyGenerator="true" source="cls1" type="cls2" relation="rel1"/>
      <roles xmi:id="role2" name="author" identity="role-author" min="1" max="1" isUnbounded="false" accepts="Author" isOrdered="false" isNavigableFrom="true" isPropertyGenerator="true" source="cls2" type="cls1" relation="rel1"/>
    </classifiers>
    <types xmi:type="DSL:SimpleType" xmi:id="str1" name="String" identity="type-string" namespace="DSL.PrimitiveTypes"/>
    <types xmi:type="DSL:SimpleType" xmi:id="int1" name="Integer" identity="type-integer" namespace="DSL.PrimitiveTypes"/>
    <types xmi:type="DSL:SimpleType" xmi:id="bool1" name="Boolean" identity="type-boolean" namespace="DSL.PrimitiveTypes"/>
    <types xmi:type="DSL:Enumeration" xmi:id="enum1" name="BookStatus" identity="enum-bookstatus" namespace="com.example.library">
      <literals xmi:id="lit1" name="Available" identity="lit-available" value="0"/>
      <literals xmi:id="lit2" name="Borrowed" identity="lit-borrowed" value="1"/>
      <literals xmi:id="lit3" name="Reserved" identity="lit-reserved" value="2"/>
    </types>
  </DSL:DomainModel>
</xmi:XMI>
