module Grafcet2PetriNet;

create OUT : PetriNet from IN : Grafcet;

helper context Grafcet!Grafcet def: toPetriNetName() : String =
  self.name + '_PN';

rule PetriNet {
  from
    g : Grafcet!Grafcet
  to
    pn : PetriNet!PetriNet (
      name     <- g.toPetriNetName(),
      location <- g.location,
      elements <- g.elements->collect(e |
                    if e.oclIsKindOf(Grafcet!Step) then
                      thisModule.Step2Place(e.oclAsType(Grafcet!Step))
                    else
                      thisModule.Transition2Transition(e.oclAsType(Grafcet!Transition))
                    endif
                 ),
      arcs     <- g.connections->collect(c |
                    if c.oclIsKindOf(Grafcet!StepToTransition) then
                      thisModule.StepToTransition2PlaceToTransition(c.oclAsType(Grafcet!StepToTransition))
                    else
                      thisModule.TransitionToStep2TransitionToPlace(c.oclAsType(Grafcet!TransitionToStep))
                    endif
                 )
    )
}

unique lazy rule Place {
  from
    s : Grafcet!Step
  to
    p : PetriNet!Place (
      name       <- s.name,
      location   <- s.location,
      incomingArc <- s.incomingConnections->collect(c |
                       thisModule.TransitionToStep2TransitionToPlace(c)
                     ),
      outgoingArc <- s.outgoingConnections->collect(c |
                       thisModule.StepToTransition2PlaceToTransition(c)
                     )
    )
}

unique lazy rule Transition {
  from
    t : Grafcet!Transition
  to
    pt : PetriNet!Transition (
      name       <- t.name,
      location   <- t.location,
      incomingArc <- t.incomingConnections->collect(c |
                       thisModule.StepToTransition2PlaceToTransition(c)
                     ),
      outgoingArc <- t.outgoingConnections->collect(c |
                       thisModule.TransitionToStep2TransitionToPlace(c)
                     )
    )
}

unique lazy rule PlaceToTransition {
  from
    c : Grafcet!StepToTransition
  to
    a : PetriNet!PlaceToTransition (
      name   <- c.name,
      location <- c.location,
      weight <- 1,
      from   <- thisModule.Step2Place(c.from),
      to     <- thisModule.Transition2Transition(c.to)
    )
}

unique lazy rule TransitionToPlace {
  from
    c : Grafcet!TransitionToStep
  to
    a : PetriNet!TransitionToPlace (
      name   <- c.name,
      location <- c.location,
      weight <- 1,
      from   <- thisModule.Transition2Transition(c.from),
      to     <- thisModule.Step2Place(c.to)
    )
}

helper def: Step2Place(s : Grafcet!Step) : PetriNet!Place =
  thisModule.Place(s);

helper def: Transition2Transition(t : Grafcet!Transition) : PetriNet!Transition =
  thisModule.Transition(t);

helper def: StepToTransition2PlaceToTransition(c : Grafcet!StepToTransition) : PetriNet!PlaceToTransition =
  thisModule.PlaceToTransition(c);

helper def: TransitionToStep2TransitionToPlace(c : Grafcet!TransitionToStep) : PetriNet!TransitionToPlace =
  thisModule.TransitionToPlace(c);