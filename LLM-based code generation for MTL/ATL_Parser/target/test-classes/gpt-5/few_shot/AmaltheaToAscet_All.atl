module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper context Amalthea!ComponentContainer def: toSoftwareTasks() : Sequence(Ascet!SoftwareTask) =
  self.tasks->collect(t | thisModule.Task2SoftwareTask(t))->asSequence();

rule ComponentContainer2AscetModule {
  from
    src : Amalthea!ComponentContainer
  to
    dst : Ascet!AscetModule (
      name         <- src.name,
      softwareTask <- src.toSoftwareTasks()
    )
}

rule TaskRoot2SoftwareTask {
  from
    src : Amalthea!Task (
      src.container.oclIsUndefined()
    )
  to
    dst : Ascet!SoftwareTask (
      name <- src.name
    )
}

lazy rule Task2SoftwareTask {
  from
    src : Amalthea!Task
  to
    dst : Ascet!SoftwareTask (
      name <- src.name
    )
}