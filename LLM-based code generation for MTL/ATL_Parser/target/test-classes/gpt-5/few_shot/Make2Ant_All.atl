module Make2Ant;

create OUT : Ant from IN : Make;

rule Makefile2Project {
  from
    m : Make!Makefile
  to
    p : Ant!Project (
      name <- m.name,
      default <- if m.defaultTarget.oclIsUndefined() then '' else m.defaultTarget.name endif,
      properties <- m.macros->collect(ma | thisModule.Macro2Property(ma)),
      targets <- m.rules->collect(r | thisModule.Rule2Target(r))
    )
}

lazy rule Macro2Property {
  from
    m : Make!Macro
  to
    pv : Ant!PropertyValue (
      name <- m.name,
      value <- m.value
    )
}

lazy rule Rule2Target {
  from
    r : Make!Rule
  to
    t : Ant!Target (
      name <- r.name,
      depends <- r.dependencies->collect(d | d.name),
      tasks <- r.shellLines->collect(sl |
        if sl.display then
          thisModule.ShellLine2Task_Display(sl)
        else
          thisModule.ShellLine2Task_NoDisplay(sl)
        endif
      )
    )
}

lazy rule ShellLine2Task_Display {
  from
    s : Make!ShellLine
  to
    e : Ant!Echo (
      message <- s.command
    )
}

lazy rule ShellLine2Task_NoDisplay {
  from
    s : Make!ShellLine
  to
    ex : Ant!Exec (
      executable <- s.command
    )
}