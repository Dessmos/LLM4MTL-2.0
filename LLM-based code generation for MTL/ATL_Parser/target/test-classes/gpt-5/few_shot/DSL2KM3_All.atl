module DSL2KM3;

create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: isEmbedding() : Boolean =
  self.isEmbedding;

helper context DSL!Relationship def: getRoles() : Sequence(DSL!Role) =
  self.roles;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
  self.isEmbedding();

rule Metamodel {
  from
    dm : DSL!DomainModel
  to
    mm : KM3!Package (
      name <- dm.namespace,
      contents <- dm.classifiers->select(c | c.oclIsKindOf(DSL!Class) or c.oclIsKindOf(DSL!Relationship))->collect(c |
        if c.oclIsKindOf(DSL!Class) then
          thisModule.resolveTemp(c, 'class')
        else
          let r : DSL!Relationship = c.oclAsType(DSL!Relationship) in
            if r.needTurnOnClass() then
              thisModule.resolveTemp(r, 'relationClass')
            else
              OclUndefined
            endif
        endif
      )->reject(oclIsUndefined())
    )
}

rule Class {
  from
    c : DSL!Class
  to
    kc : KM3!Class (
      name <- c.name,
      isAbstract <- c.isAbstract,
      structuralFeatures <- c.properties->collect(p | thisModule.resolveTemp(p, 'attribute'))
        ->union(
          DSL!Relationship.allInstances()->select(r | not r.needTurnOnClass())
            ->collect(r | r.getRoles()->select(ro | ro.source = c and ro.isNavigableFrom)
              ->collect(ro | thisModule.resolveTemp(ro, 'simpleReference')))->flatten()
        )
    )
}

rule Relation2Class {
  from
    r : DSL!Relationship (r.needTurnOnClass())
  to
    rc : KM3!Class (
      name <- r.name,
      isAbstract <- r.isAbstract,
      structuralFeatures <- r.getRoles()->collect(ro | thisModule.resolveTemp(ro, 'complexReference'))
    )
}

rule SimpleReference {
  from
    ro : DSL!Role (ro.relation.oclIsKindOf(DSL!Relationship) and not ro.relation.needTurnOnClass())
  to
    ref : KM3!Reference (
      name <- ro.name,
      type <- thisModule.resolveTemp(ro.type, 'class'),
      lower <- ro.min,
      upper <- if ro.isUnbounded then -1 else ro.max endif,
      isOrdered <- ro.isOrdered,
      isContainment <- ro.relation.isEmbedding()
    )
}

rule ComplexReference {
  from
    ro : DSL!Role (ro.relation.oclIsKindOf(DSL!Relationship) and ro.relation.needTurnOnClass())
  to
    ref : KM3!Reference (
      name <- ro.name,
      type <- thisModule.resolveTemp(ro.type, 'class'),
      lower <- ro.min,
      upper <- if ro.isUnbounded then -1 else ro.max endif,
      isOrdered <- ro.isOrdered,
      isContainment <- ro.relation.isEmbedding()
    )
}

rule Attribute {
  from
    vp : DSL!ValueProperty
  to
    at : KM3!Attribute (
      name <- vp.name,
      type <- if vp.type.oclIsKindOf(DSL!SimpleType) then
                thisModule.resolveTemp(vp.type, 'dataType')
              else
                thisModule.resolveTemp(vp.type, 'class')
              endif
    )
}

rule Enumeration {
  from
    e : DSL!Enumeration
  to
    ke : KM3!Enumeration (
      name <- e.name,
      literals <- e.literals->collect(l | thisModule.resolveTemp(l, 'enumLiteral'))
    )
}

rule EnumLiteral {
  from
    l : DSL!EnumerationLiteral
  to
    kl : KM3!EnumLiteral (
      name <- l.name
    )
}

rule DataType {
  from
    st : DSL!SimpleType
  to
    dt : KM3!DataType (
      name <- st.name
    )
}