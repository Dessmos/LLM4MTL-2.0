module BibTeX2DocBook;

create OUT : XML from IN : BibTeX;

helper context BibTeX!BibTeXModel def : authorSet() : Set(BibTeX!Author) =
  self.entries->collect(e | e.authors)->asSet();

helper context BibTeX!BibTeXModel def : titledEntrySet() : Set(BibTeX!Entry) =
  self.entries->select(e | not e.title.oclIsUndefined() and e.title <> '')->asSet();

helper context BibTeX!BibTeXModel def : articleSet() : Set(BibTeX!Article) =
  self.entries->select(e | e.oclIsKindOf(BibTeX!Article))->collect(e | e.oclAsType(BibTeX!Article))->asSet();

helper def : buildEntryPara(e : BibTeX!Entry) : String =
  let titlePart  : String = if e.title.oclIsUndefined() or e.title = '' then '' else 'Title: ' + e.title + '. ' endif in
  let authorPart : String = if e.authors->isEmpty() then '' else 'Authors: ' + e.authors->collect(a | a.name)->sortedBy(a | a)->iterate(n; acc : String = '' | if acc = '' then n else acc + ', ' + n endif) + '. ' endif in
  let journalPart : String = if e.oclIsKindOf(BibTeX!Article) and not e.oclAsType(BibTeX!Article).journal.oclIsUndefined() and e.oclAsType(BibTeX!Article).journal <> '' then 'Journal: ' + e.oclAsType(BibTeX!Article).journal + '. ' else '' endif in
  let yearPart : String = if e.year.oclIsUndefined() or e.year = '' then '' else 'Year: ' + e.year + '. ' endif in
  titlePart + authorPart + journalPart + yearPart;

rule Main {
  from
    src : BibTeX!BibTeXModel
  to
    root : XML!Root (
      name <- 'book',
      children <- Sequence{
        thisModule.createTitleElement('References'),
        thisModule.createReferencesSection(src),
        thisModule.createAuthorSection(src),
        thisModule.createTitleSection(src),
        thisModule.createJournalSection(src)
      }
    )
}

lazy rule Author {
  from
    a : BibTeX!Author
  to
    elem : XML!Element (
      name <- 'author',
      children <- Sequence{
        thisModule.createTextNode(a.name)
      }
    )
}

lazy rule UntitledEntry {
  from
    e : BibTeX!Entry (e.title.oclIsUndefined() or e.title = '')
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(e))
      }
    )
}

lazy rule TitledEntry_Title_NoArticle {
  from
    e : BibTeX!Entry (
      not e.title.oclIsUndefined() and e.title <> '' and
      e.oclIsUndefined(BibTeX!Article)
    )
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(e))
      }
    )
}

lazy rule TitledEntry_NoTitle_NoArticle {
  from
    e : BibTeX!Entry (
      (e.title.oclIsUndefined() or e.title = '') and
      e.oclIsUndefined(BibTeX!Article)
    )
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(e))
      }
    )
}

lazy rule Article_Title_Journal {
  from
    a : BibTeX!Article (
      not a.title.oclIsUndefined() and a.title <> '' and
      not a.journal.oclIsUndefined() and a.journal <> ''
    )
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(a))
      }
    )
}

lazy rule Article_NoTitle_Journal {
  from
    a : BibTeX!Article (
      (a.title.oclIsUndefined() or a.title = '') and
      not a.journal.oclIsUndefined() and a.journal <> ''
    )
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(a))
      }
    )
}

lazy rule Article_Title_NoJournal {
  from
    a : BibTeX!Article (
      not a.title.oclIsUndefined() and a.title <> '' and
      (a.journal.oclIsUndefined() or a.journal = '')
    )
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(a))
      }
    )
}

lazy rule Article_NoTitle_NoJournal {
  from
    a : BibTeX!Article (
      (a.title.oclIsUndefined() or a.title = '') and
      (a.journal.oclIsUndefined() or a.journal = '')
    )
  to
    para : XML!Element (
      name <- 'para',
      children <- Sequence{
        thisModule.createTextNode(thisModule.buildEntryPara(a))
      }
    )
}

helper def : createTitleElement(t : String) : XML!Element =
  XML!Element.new()
    .let(e | e.name <- 'title'; e.children <- Sequence{ thisModule.createTextNode(t) }; e);

helper def : createTextNode(v : String) : XML!Text =
  XML!Text.new()
    .let(t | t.name <- 'text'; t.value <- v; t);

helper def : createSection(title : String; paras : Sequence(XML!Element)) : XML!Element =
  XML!Element.new()
    .let(s |
      s.name <- 'section';
      s.children <- Sequence{ thisModule.createTitleElement(title) }->union(paras);
      s
    );

helper def : createReferencesSection(m : BibTeX!BibTeXModel) : XML!Element =
  let paras : Sequence(XML!Element) =
    m.entries->collect(e |
      if e.oclIsKindOf(BibTeX!Article) then
        if e.oclAsType(BibTeX!Article).journal.oclIsUndefined() or e.oclAsType(BibTeX!Article).journal = '' then
          if e.title.oclIsUndefined() or e.title = '' then
            thisModule.Article_NoTitle_NoJournal(e.oclAsType(BibTeX!Article))
          else
            thisModule.Article_Title_NoJournal(e.oclAsType(BibTeX!Article))
          endif
        else
          if e.title.oclIsUndefined() or e.title = '' then
            thisModule.Article_NoTitle_Journal(e.oclAsType(BibTeX!Article))
          else
            thisModule.Article_Title_Journal(e.oclAsType(BibTeX!Article))
          endif
        endif
      else
        if e.title.oclIsUndefined() or e.title = '' then
          thisModule.UntitledEntry(e)
        else
          thisModule.TitledEntry_Title_NoArticle(e)
        endif
      endif
    )->asSequence()
  in
  thisModule.createSection('All References', paras);

helper def : createAuthorSection(m : BibTeX!BibTeXModel) : XML!Element =
  let authorElems : Sequence(XML!Element) =
    m.authorSet()->asSequence()->collect(a |
      XML!Element.new().let(se |
        se.name <- 'section';
        se.children <- Sequence{
          thisModule.createTitleElement(a.name),
          thisModule.createAuthorEntries(a, m)
        };
        se
      )
    )
  in
  XML!Element.new().let(sec |
    sec.name <- 'section';
    sec.children <- Sequence{ thisModule.createTitleElement('By Author') }->union(authorElems);
    sec
  );

helper def : createAuthorEntries(a : BibTeX!Author; m : BibTeX!BibTeXModel) : XML!Element =
  let paras : Sequence(XML!Element) =
    m.entries->select(e | e.authors->includes(a))->collect(e |
      if e.oclIsKindOf(BibTeX!Article) then
        thisModule.Article_Title_Journal(e.oclAsType(BibTeX!Article))
      else
        if e.title.oclIsUndefined() or e.title = '' then
          thisModule.UntitledEntry(e)
        else
          thisModule.TitledEntry_Title_NoArticle(e)
        endif
      endif
    )->asSequence()
  in
  thisModule.createSection('References', paras);

helper def : createTitleSection(m : BibTeX!BibTeXModel) : XML!Element =
  let titleElems : Sequence(XML!Element) =
    m.titledEntrySet()->asSequence()->sortedBy(e | e.title)->collect(e |
      XML!Element.new().let(se |
        se.name <- 'section';
        se.children <- Sequence{
          thisModule.createTitleElement(e.title),
          thisModule.createSection('Entry', Sequence{
            if e.oclIsKindOf(BibTeX!Article) then
              thisModule.Article_Title_Journal(e.oclAsType(BibTeX!Article))
            else
              thisModule.TitledEntry_Title_NoArticle(e)
            endif
          })
        };
        se
      )
    )
  in
  XML!Element.new().let(sec |
    sec.name <- 'section';
    sec.children <- Sequence{ thisModule.createTitleElement('By Title') }->union(titleElems);
    sec
  );

helper def : createJournalSection(m : BibTeX!BibTeXModel) : XML!Element =
  let journals : Set(String) =
    m.articleSet()->collect(a | a.journal)->select(j | not j.oclIsUndefined() and j <> '')->asSet()
  in
  let journalSecs : Sequence(XML!Element) =
    journals->asSequence()->sortedBy(j | j)->collect(j |
      XML!Element.new().let(se |
        se.name <- 'section';
        se.children <- Sequence{
          thisModule.createTitleElement(j),
          thisModule.createSection('Articles', m.articleSet()->select(a | a.journal = j)->collect(a |
            if a.title.oclIsUndefined() or a.title = '' then
              thisModule.Article_NoTitle_Journal(a)
            else
              thisModule.Article_Title_Journal(a)
            endif
          )->asSequence())
        };
        se
      )
    )
  in
  XML!Element.new().let(sec |
    sec.name <- 'section';
    sec.children <- Sequence{ thisModule.createTitleElement('By Journal') }->union(journalSecs);
    sec
  );