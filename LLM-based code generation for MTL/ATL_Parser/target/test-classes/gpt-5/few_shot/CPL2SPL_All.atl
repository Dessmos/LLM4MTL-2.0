module CPL2SPL;

create OUT : SPL from IN : CPL;

helper context CPL!Proxy def: isSimple : Boolean =
  self.someAttribute = 'simple';

helper def: statement(e : CPL!Element) : SPL!Statement =
  SPL!Statement {
    name <- e.name + '_stmt'
  };

helper context CPL!Call def: locations : Sequence(CPL!Location) =
  self.location->asSequence();

helper def: Location2URIConstant(loc : CPL!Location) : SPL!URIConstant =
  SPL!URIConstant {
    uri <- loc.uri
  };

rule CPL2Program {
  from
    c : CPL!CPLModel
  to
    p : SPL!Program (
      name <- c.name,
      functions <- c.subActions->collect(sa | thisModule.SubAction2Function(sa))
    )
}

rule SubAction2Function {
  from
    sa : CPL!SubAction
  to
    f : SPL!Function (
      name <- sa.name,
      body <- thisModule.statement(sa)
    )
}

rule Incoming2Method {
  from
    i : CPL!Incoming
  to
    m : SPL!Method (
      name <- i.name,
      body <- thisModule.statement(i)
    )
}

rule Proxy2Return {
  from
    p : CPL!Proxy (p.isSimple)
  to
    r : SPL!Return (
      expression <- thisModule.Location2URIConstant(p.location)
    )
}

rule Proxy2Select {
  from
    p : CPL!Proxy (not p.isSimple)
  to
    s : SPL!Select (
      cases <- p.busy->collect(b | thisModule.Busy2SelectCase(b))
        ->union(p.noAnswer->collect(n | thisModule.NoAnswer2SelectCase(n)))
        ->union(p.redirection->collect(r | thisModule.Redirection2SelectCase(r))),
      default <- p.default.first().resolveone(e | thisModule.Default2SelectDefault(e))
    )
}

rule Busy2SelectCase {
  from
    b : CPL!Busy
  to
    c : SPL!SelectCase (
      condition <- 'busy',
      statement <- thisModule.statement(b)
    )
}

rule NoAnswer2SelectCase {
  from
    n : CPL!NoAnswer
  to
    c : SPL!SelectCase (
      condition <- 'noAnswer',
      statement <- thisModule.statement(n)
    )
}

rule Redirection2SelectCase {
  from
    r : CPL!Redirection
  to
    c : SPL!SelectCase (
      condition <- 'redirection',
      statement <- thisModule.Redirect2Return(r)
    )
}

rule Default2SelectDefault {
  from
    d : CPL!Default
  to
    sd : SPL!SelectDefault (
      statement <- thisModule.statement(d)
    )
}

rule SubCall2Return {
  from
    sc : CPL!SubCall
  to
    r : SPL!Return (
      expression <- SPL!CallExpression {
        function <- sc.subAction.name
      }
    )
}

rule Redirect2Return {
  from
    r : CPL!Redirect
  to
    ret : SPL!Return (
      expression <- thisModule.Location2URIConstant(r.location)
    )
}

rule AddressSwitch2SelectStat {
  from
    sw : CPL!AddressSwitch
  to
    s : SPL!Select (
      cases <- sw.switchedAddresses->collect(sa | thisModule.SwitchedAddress2SelectCase(sa)),
      default <- sw.otherwise.first().resolveone(o | thisModule.Otherwise2SelectDefault(o))
    )
}

rule SwitchedAddress2SelectCase {
  from
    sa : CPL!SwitchedAddress
  to
    c : SPL!SelectCase (
      condition <- thisModule.Location2URIConstant(sa.location).uri,
      statement <- thisModule.statement(sa)
    )
}

rule Otherwise2SelectDefault {
  from
    o : CPL!Otherwise
  to
    sd : SPL!SelectDefault (
      statement <- thisModule.statement(o)
    )
}