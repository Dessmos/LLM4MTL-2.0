module XML2DSL;

create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrVal(name : String) : String =
	if self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->size() > 0 then
		self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->first().value
	else
		''
	endif;

helper context XML!Element def: getAttrBool(name : String) : Boolean =
	let v : String = self.getAttrVal(name) in
	if v = '' then false else
		if v.toLower() = 'true' or v = '1' then true else false endif
	endif;

helper context XML!Element def: hasAttr(name : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = name);

helper context XML!Element def: get(child : String, n : String) : XML!Element =
	self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = child and c.getAttrVal('name') = n)->first();

helper context XML!Element def: getText() : String =
	self.children->select(c | c.oclIsTypeOf(XML!Text))->collect(t | t.value)->iterate(s; acc : String = '' | acc + s);

helper context XML!Element def: getSeq(child : String) : Sequence(XML!Element) =
	self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = child)->asSequence();

helper context XML!Element def: hasChildren(child : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Element) and c.name = child);

helper def: dslElementsById() : Sequence(DSL!Classifier) =
	DSL!Classifier.allInstances()->asSequence();

helper context XML!Element def: isAbstract() : Boolean =
	if self.hasAttr('abstract') then
		self.getAttrBool('abstract')
	else
		false
	endif;

helper context XML!Element def: getContainment() : Boolean =
	if self.hasAttr('containment') then
		self.getAttrBool('containment')
	else
		false
	endif;

helper context XML!Element def: getEnumId() : String =
	self.getAttrVal('id');

helper def: findType(id : String) : DSL!Type =
	DSL!Type.allInstances()->any(t | t.identity = id);

helper context XML!Element def: getType() : DSL!Type =
	let tname : String = self.getAttrVal('type') in
	if tname = 'String' then
		DSL!SimpleType.allInstances()->any(st | st.name = 'String')
	else
		if tname = 'Integer' then
			DSL!SimpleType.allInstances()->any(st | st.name = 'Integer')
		else
			if tname = 'Boolean' then
				DSL!SimpleType.allInstances()->any(st | st.name = 'Boolean')
			else
				if tname = 'Double' then
					DSL!SimpleType.allInstances()->any(st | st.name = 'Double')
				else
					thisModule.findType(tname)
				endif
			endif
		endif
	endif;

helper def: getSubTypes(c : DSL!Classifier) : Sequence(DSL!Classifier) =
	DSL!Classifier.allInstances()->select(x | x.superType = c)->asSequence();

rule DomainModel {
	from
		r : XML!Root (r.children->exists(c | c.oclIsTypeOf(XML!Element) and c.name = 'domainModel'))
	to
		dm : DSL!DomainModel (
			name <- r.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = 'domainModel')->first().getAttrVal('name'),
			identity <- r.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = 'domainModel')->first().getAttrVal('id'),
			isLoaded <- true,
			namespace <- '',
			classifiers <- r.children->select(c | c.oclIsTypeOf(XML!Element) and (c.name = 'class' or c.name = 'relationship'))->collect(e | thisModule.resolveTemp(e, 'classifier'))->asSequence(),
			types <- r.children->select(c | c.oclIsTypeOf(XML!Element) and (c.name = 'enumeration' or c.name = 'simpleType'))->collect(e | thisModule.resolveTemp(e, 'type'))->asSequence()
		),
		stringT : DSL!SimpleType (
			name <- 'String',
			identity <- 'String',
			namespace <- 'PrimitiveTypes'
		),
		intT : DSL!SimpleType (
			name <- 'Integer',
			identity <- 'Integer',
			namespace <- 'PrimitiveTypes'
		),
		boolT : DSL!SimpleType (
			name <- 'Boolean',
			identity <- 'Boolean',
			namespace <- 'PrimitiveTypes'
		),
		doubleT : DSL!SimpleType (
			name <- 'Double',
			identity <- 'Double',
			namespace <- 'PrimitiveTypes'
		)
}

rule Class {
	from
		e : XML!Element (e.name = 'class')
	to
		c : DSL!Class (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			isLoaded <- true,
			namespace <- '',
			isAbstract <- e.isAbstract(),
			properties <- e.getSeq('valueProperty')->collect(p | thisModule.resolveTemp(p, 'prop'))->asSequence(),
			superType <- if e.hasAttr('superType') then
							thisModule.findType(e.getAttrVal('superType')).oclAsType(DSL!Classifier)
						else
							OclUndefined
						endif,
			subTypes <- thisModule.getSubTypes(c),
			domainModel <- DSL!DomainModel.allInstances()->first()
		),
		classifier <- c
}

rule Relationship {
	from
		e : XML!Element (e.name = 'relationship')
	to
		r : DSL!Relationship (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			isLoaded <- true,
			namespace <- '',
			isAbstract <- e.isAbstract(),
			isEmbedding <- e.getContainment(),
			properties <- e.getSeq('valueProperty')->collect(p | thisModule.resolveTemp(p, 'prop'))->asSequence(),
			superType <- if e.hasAttr('superType') then
							thisModule.findType(e.getAttrVal('superType')).oclAsType(DSL!Classifier)
						else
							OclUndefined
						endif,
			subTypes <- thisModule.getSubTypes(r),
			domainModel <- DSL!DomainModel.allInstances()->first(),
			roles <- e.getSeq('role')->collect(ro | thisModule.resolveTemp(ro, 'role'))->asSequence()
		),
		classifier <- r
}

rule Role {
	from
		e : XML!Element (e.name = 'role')
	to
		r : DSL!Role (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			min <- if e.hasAttr('min') then e.getAttrVal('min').toInteger() else 0 endif,
			max <- if e.hasAttr('max') then e.getAttrVal('max').toInteger() else 0 endif,
			isUnbounded <- if e.hasAttr('unbounded') then e.getAttrBool('unbounded') else false endif,
			accepts <- e.getAttrVal('target'),
			isOrdered <- if e.hasAttr('ordered') then e.getAttrBool('ordered') else false endif,
			isNavigableFrom <- if e.hasAttr('navigableFrom') then e.getAttrBool('navigableFrom') else false endif,
			isPropertyGenerator <- if e.hasAttr('propertyGenerator') then e.getAttrBool('propertyGenerator') else false endif,
			source <- thisModule.findType(e.getAttrVal('source')).oclAsType(DSL!Classifier),
			type <- thisModule.findType(e.getAttrVal('target')).oclAsType(DSL!Classifier),
			relation <- thisModule.resolveTemp(e.parent, 'classifier').oclAsType(DSL!Relationship)
		),
		role <- r
}

rule ValueProperty {
	from
		e : XML!Element (e.name = 'valueProperty')
	to
		v : DSL!ValueProperty (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			owner <- thisModule.resolveTemp(e.parent, 'classifier').oclAsType(DSL!Classifier),
			type <- e.getType()
		),
		prop <- v
}

rule Enumeration {
	from
		e : XML!Element (e.name = 'enumeration')
	to
		en : DSL!Enumeration (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			namespace <- '',
			literals <- e.getSeq('literal')->collect(l | thisModule.resolveTemp(l, 'lit'))->asSequence()
		),
		type <- en
}

rule EnumerationLiteral {
	from
		e : XML!Element (e.name = 'literal')
	to
		l : DSL!EnumerationLiteral (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			value <- if e.hasAttr('value') then e.getAttrVal('value').toInteger() else 0 endif
		),
		lit <- l
}