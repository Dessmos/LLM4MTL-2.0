module AmaltheaToAscet_All;

create OUT : Ascet from IN : Amalthea;

helper context Amalthea!ComponentContainer def: toSoftwareTasks() : Sequence(Ascet!SoftwareTask) =
	self.tasks->collect(t | thisModule.Task2SoftwareTask(t));

rule ComponentContainer2AscetModule {
	from
		cc : Amalthea!ComponentContainer
	to
		m : Ascet!AscetModule (
			name <- cc.name,
			softwareTasks <- cc.toSoftwareTasks()
		)
}

rule TaskRoot2SoftwareTask {
	from
		t : Amalthea!Task (
			t.container.oclIsUndefined()
		)
	to
		st : Ascet!SoftwareTask (
			name <- t.name
		)
}

lazy rule Task2SoftwareTask {
	from
		t : Amalthea!Task
	to
		st : Ascet!SoftwareTask (
			name <- t.name
		)
}