module BibTeX2DocBook;

create OUT : XML from IN : BibTeX;

helper context BibTeX!BibTeXModel def: authorSet() : Sequence(BibTeX!Author) =
	BibTeX!Author.allInstances()
	->asSet()
	->sortedBy(name);

helper context BibTeX!BibTeXModel def: titledEntrySet() : Sequence(BibTeX!Entry) =
	BibTeX!Entry.allInstances()
	->select(e | not e.title.oclIsUndefined() and e.title <> '')
	->asSet()
	->sortedBy(title);

helper context BibTeX!BibTeXModel def: articleSet() : Sequence(BibTeX!Article) =
	BibTeX!Article.allInstances()
	->asSet()
	->sortedBy(title);

helper def: buildEntryPara(e : BibTeX!Entry) : String =
	(if not e.authors->isEmpty() then
		e.authors->collect(a | a.name)->asSequence()->iterate(n; acc : String = '' |
			if acc = '' then n else acc + ', ' + n endif
		) + '. '
	else
		''
	endif)
	+
	(if not e.title.oclIsUndefined() and e.title <> '' then
		e.title + '. '
	else
		''
	endif)
	+
	(if e.oclIsKindOf(BibTeX!Article) then
		let art : BibTeX!Article = e.oclAsType(BibTeX!Article) in
			(if not art.journal.oclIsUndefined() and art.journal <> '' then
				art.journal + '. '
			else
				''
			endif)
	else
		''
	endif)
	+
	(if not e.year.oclIsUndefined() and e.year <> '' then
		e.year
	else
		''
	endif);

rule Main {
	from
		s : BibTeX!BibTeXModel
	to
		r : XML!Root (
			name <- 'book',
			children <- Sequence{
				refsSect,
				authorsSect,
				titlesSect,
				journalsSect
			}
		),
		refsSect : XML!Element (
			name <- 'section',
			children <- Sequence{ refsTitle }->union(
				BibTeX!Entry.allInstances()->asSequence()->collect(e |
					thisModule.resolveTemp(e, 'paraForRef')
				)
			)
		),
		refsTitle : XML!Element (
			name <- 'title',
			children <- Sequence{ refsTitleText }
		),
		refsTitleText : XML!Text (
			name <- 'text',
			value <- 'References'
		),
		authorsSect : XML!Element (
			name <- 'section',
			children <- Sequence{ authorsTitle }->union(
				s.authorSet()->collect(a |
					thisModule.resolveTemp(a, 'authorSection')
				)
			)
		),
		authorsTitle : XML!Element (
			name <- 'title',
			children <- Sequence{ authorsTitleText }
		),
		authorsTitleText : XML!Text (
			name <- 'text',
			value <- 'By Author'
		),
		titlesSect : XML!Element (
			name <- 'section',
			children <- Sequence{ titlesTitle }->union(
				s.titledEntrySet()->collect(e |
					thisModule.resolveTemp(e, 'titleSection')
				)
			)
		),
		titlesTitle : XML!Element (
			name <- 'title',
			children <- Sequence{ titlesTitleText }
		),
		titlesTitleText : XML!Text (
			name <- 'text',
			value <- 'By Title'
		),
		journalsSect : XML!Element (
			name <- 'section',
			children <- Sequence{ journalsTitle }->union(
				s.articleSet()->collect(a |
					thisModule.resolveTemp(a, 'journalSection')
				)
			)
		),
		journalsTitle : XML!Element (
			name <- 'title',
			children <- Sequence{ journalsTitleText }
		),
		journalsTitleText : XML!Text (
			name <- 'text',
			value <- 'By Journal'
		)
}

rule Author {
	from
		a : BibTeX!Author
	to
		authorSection : XML!Element (
			name <- 'section',
			children <- Sequence{ authorTitle }->union(
				BibTeX!Entry.allInstances()
				->select(e | e.authors->includes(a))
				->asSequence()
				->collect(e | thisModule.resolveTemp(e, 'paraForAuthor'))
			)
		),
		authorTitle : XML!Element (
			name <- 'title',
			children <- Sequence{ authorTitleText }
		),
		authorTitleText : XML!Text (
			name <- 'text',
			value <- a.name
		)
}

rule UntitledEntry {
	from
		e : BibTeX!Entry (
			e.title.oclIsUndefined() or e.title = ''
		)
	to
		paraForRef : XML!Element (
			name <- 'para',
			children <- Sequence{ tRef }
		),
		tRef : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		),
		paraForAuthor : XML!Element (
			name <- 'para',
			children <- Sequence{ tAuth }
		),
		tAuth : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		)
}

rule TitledEntry_Title_NoArticle {
	from
		e : BibTeX!Entry (
			not e.oclIsKindOf(BibTeX!Article) and not e.title.oclIsUndefined() and e.title <> ''
		)
	to
		paraForRef : XML!Element (
			name <- 'para',
			children <- Sequence{ tRef }
		),
		tRef : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		),
		paraForAuthor : XML!Element (
			name <- 'para',
			children <- Sequence{ tAuth }
		),
		tAuth : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		),
		titleSection : XML!Element (
			name <- 'section',
			children <- Sequence{ titleElem, paraForTitle }
		),
		titleElem : XML!Element (
			name <- 'title',
			children <- Sequence{ titleText }
		),
		titleText : XML!Text (
			name <- 'text',
			value <- e.title
		),
		paraForTitle : XML!Element (
			name <- 'para',
			children <- Sequence{ tTitle }
		),
		tTitle : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		)
}

rule TitledEntry_NoTitle_NoArticle {
	from
		e : BibTeX!Entry (
			e.oclIsKindOf(BibTeX!Entry) and not e.oclIsKindOf(BibTeX!Article) and (e.title.oclIsUndefined() or e.title = '')
		)
	to
		paraForRef : XML!Element (
			name <- 'para',
			children <- Sequence{ tRef }
		),
		tRef : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		),
		paraForAuthor : XML!Element (
			name <- 'para',
			children <- Sequence{ tAuth }
		),
		tAuth : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(e)
		)
}

rule Article_Title_Journal {
	from
		a : BibTeX!Article (
			not a.title.oclIsUndefined() and a.title <> '' and
			not a.journal.oclIsUndefined() and a.journal <> ''
		)
	to
		paraForRef : XML!Element (
			name <- 'para',
			children <- Sequence{ tRef }
		),
		tRef : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(a)
		),
		paraForAuthor : XML!Element (
			name <- 'para',
			children <- Sequence{ tAuth }
		),
		tAuth : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(a)
		),
		titleSection : XML!Element (
			name <- 'section',
			children <- Sequence{ titleElem, paraForTitle }
		),
		titleElem : XML!Element (
			name <- 'title',
			children <- Sequence{ titleText }
		),
		titleText : XML!Text (
			name <- 'text',
			value <- a.title
		),
		paraForTitle : XML!Element (
			name <- 'para',
			children <- Sequence{ tTitle }
		),
		tTitle : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(a)
		),
		journalSection : XML!Element (
			name <- 'section',
			children <- Sequence{ journalTitle, paraForJournal }
		),
		journalTitle : XML!Element (
			name <- 'title',
			children <- Sequence{ journalTitleText }
		),
		journalTitleText : XML!Text (
			name <- 'text',
			value <- a.journal
		),
		paraForJournal : XML!Element (
			name <- 'para',
			children <- Sequence{ tJournal }
		),
		tJournal : XML!Text (
			name <- 'text',
			value <- thisModule.buildEntryPara(a)
		)
}

rule Article_NoTitle_Journal {
	from
		a : BibTeX!Article (
			(a.title.oclIsUndefined() or a.title = '') and
