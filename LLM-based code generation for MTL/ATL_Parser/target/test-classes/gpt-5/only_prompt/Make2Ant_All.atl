module Make2Ant;

create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		s : Make!Makefile
	to
		t : Ant!Project (
			name <- s.name,
			default <- if s.defaultTarget.oclIsUndefined() then '' else s.defaultTarget.name endif,
			properties <- s.macros->collect(m | thisModule.resolveTemp(m, 'property')),
			targets <- s.rules->collect(r | thisModule.resolveTemp(r, 'target'))
		)
}

rule Macro2Property {
	from
		s : Make!Macro
	to
		t : Ant!PropertyValue (
			name <- s.name,
			value <- s.value
		)
}

rule Rule2Target {
	from
		s : Make!Rule
	to
		t : Ant!Target (
			name <- s.name,
			depends <- s.dependencies->collect(d | d.name)->join(','),
			tasks <- s.shellLines->collect(sl |
				if sl.display then
					thisModule.resolveTemp(sl, 'echoTask')
				else
					thisModule.resolveTemp(sl, 'execTask')
				endif
			)
		)
}

rule ShellLine2Task_Display {
	from
		s : Make!ShellLine (s.display = true)
	to
		t : Ant!Echo (
			message <- s.command
		)
	do {
		thisModule.bindEchoTask(s, t);
	}
}

rule ShellLine2Task_NoDisplay {
	from
		s : Make!ShellLine (s.display = false)
	to
		t : Ant!Exec (
			executable <- s.command
		)
	do {
		thisModule.bindExecTask(s, t);
	}
}

helper context Make!ShellLine def: echoTask() : Ant!Echo =
	thisModule.resolveTemp(self, 'echoTask');

helper context Make!ShellLine def: execTask() : Ant!Exec =
	thisModule.resolveTemp(self, 'execTask');

helper def: bindEchoTask(s : Make!ShellLine, t : Ant!Echo) : Ant!Echo = t;

helper def: bindExecTask(s : Make!ShellLine, t : Ant!Exec) : Ant!Exec = t;