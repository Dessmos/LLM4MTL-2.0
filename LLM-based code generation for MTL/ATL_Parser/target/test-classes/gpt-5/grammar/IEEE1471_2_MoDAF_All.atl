rule StakeholderHasConcern {
	from
		s : IEEE1471!Stakeholder
	to
		t : MoDAF!StakeholderConcern (
			stakeholder <- s,
			concerns <- s.concerns
		)
	do {
	}
}

helper def: getOrCreateDefaultFramework(ad : IEEE1471!ArchitecturalDescription) : MoDAF!ArchitecturalFramework =
	let existing : Sequence{MoDAF!ArchitecturalFramework} = MoDAF!ArchitecturalFramework.allInstances()->select(a | a.name = 'Undefined Architectural Framework') in
	if existing->size() > 0 then
		existing->first()
	else
		let fw : MoDAF!ArchitecturalFramework = thisModule.createUndefinedFramework(ad) in
		fw
	endif;

rule CreateUndefinedFramework {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!ArchitecturalFramework (
			name <- 'Undefined Architectural Framework',
			description <- 'Default framework for viewpoints without a source',
			viewpoints <- IEEE1471!Viewpoint.allInstances()->select(vp | vp.libraryViewpoint.oclIsUndefined())
		)
	do {
	}
}

helper def: createUndefinedFramework(ad : IEEE1471!ArchitecturalDescription) : MoDAF!ArchitecturalFramework =
	MoDAF!ArchitecturalFramework.allInstances()->any(a | a.name = 'Undefined Architectural Framework');