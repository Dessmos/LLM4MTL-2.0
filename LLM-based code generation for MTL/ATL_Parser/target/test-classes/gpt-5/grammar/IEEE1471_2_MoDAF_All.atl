module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!ArchitecturalDescription def: rationale() : String =
	let r : Sequence{IEEE1471!Rationale} = self.rationales in
	if r->size() > 0 then
		r->first().name.concat(' - ').concat(r->first().content)
	else
		'No rationale'
	endif;

rule IEEE1471Model2MoDAFModel {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!ArchitectureViewModel (
			name <- s.name,
			description <- s.description,
			enterprise <- s.system,
			environment <- s.environment,
			architecture <- s.architecture,
			framework <- thisModule.getOrCreateDefaultFramework(s)
		)
	do {
	}
}

rule System2Enterprise {
	from
		s : IEEE1471!System
	to
		t : MoDAF!Enterprise (
			name <- s.name,
			content <- s.description
		)
	do {
	}
}

