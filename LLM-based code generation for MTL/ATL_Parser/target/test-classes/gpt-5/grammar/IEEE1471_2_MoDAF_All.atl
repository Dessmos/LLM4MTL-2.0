	}
}

rule AD2AD {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!ArchitectureDescription (
			name <- s.name,
			content <- s.description,
			rationale <- s.rationale()
		)
	do {
	}
}

