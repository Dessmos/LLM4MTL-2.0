module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
	from
		g : Grafcet!Grafcet
	to
		pn : PetriNet!PetriNet (
			name <- g.name,
			location <- g.location
		)
}

rule Place {
	from
		s : Grafcet!Step
	to
		p : PetriNet!Place (
			name <- s.name,
			location <- s.location,
			net <- s.grafcet.resolveone(PetriNet)
		)
}

rule Transition {
	from
		t : Grafcet!Transition
	to
		tr : PetriNet!Transition (
			name <- t.name,
			location <- t.location,
			net <- t.grafcet.resolveone(PetriNet)
		)
}

rule PlaceToTransition {
	from
		st : Grafcet!StepToTransition
	to
		pt : PetriNet!PlaceToTransition (
			name <- st.name,
			location <- st.location,
			net <- st.grafcet.resolveone(PetriNet),
			weight <- 1,
			from <- st.from.resolveone(Place),
			to <- st.to.resolveone(Transition)
		)
}

rule TransitionToPlace {
	from
		ts : Grafcet!TransitionToStep
	to
		tp : PetriNet!TransitionToPlace (
			name <- ts.name,
			location <- ts.location,
			net <- ts.grafcet.resolveone(PetriNet),
			weight <- 1,
			from <- ts.from.resolveone(Transition),
			to <- ts.to.resolveone(Place)
		)
}