module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Node def: getAttrBool(attrName : String) : Boolean =
  if self.get(child, attrName)->size() > 0 then
    self.get(child, attrName)->first().value = 'true'
  else
    false
  endif;

helper context XML!Node def: getAttrVal(attrName : String) : String =
  if self.get(child, attrName)->size() > 0 then
    self.get(child, attrName)->first().value
  else
    ''
  endif;

helper context XML!Node def: get(child : String, name : String) : Sequence(XML!Element) =
  self.oclAsType(XML!Element).children->select(e | e.oclIsKindOf(XML!Element) and e.name = child and e.getAttrVal('name') = name)->collect(e | e.oclAsType(XML!Element));

helper context XML!Node def: getType() : String =
  self.getAttrVal('type');

helper context XML!Node def: getEnumId() : String =
  self.getAttrVal('enumId');

helper context XML!Node def: getText() : String =
  self.oclAsType(XML!Element).children->select(e | e.oclIsKindOf(XML!Text))->collect(e | e.oclAsType(XML!Text).value)->first();

helper context XML!Node def: getSeq(childName : String) : Sequence(XML!Element) =
  self.oclAsType(XML!Element).children->select(e | e.oclIsKindOf(XML!Element) and e.name = childName)->collect(e | e.oclAsType(XML!Element));

helper context XML!Node def: hasChildren(childName : String) : Boolean =
  self.getSeq(childName)->size() > 0;

helper context XML!Node def: hasAttr(attrName : String) : Boolean =
  self.oclAsType(XML!Element).children->select(a | a.oclIsKindOf(XML!Attribute) and a.name = attrName)->size() > 0;

helper context XML!Node def: isAbstract() : Boolean =
  if self.hasAttr('abstract') then
    self.getAttrBool('abstract')
  else
    false
  endif;

helper def: dslElementsById() : Map(String, DSL!Classifier) =
  Map{}; 

helper context XML!Node def: getContainment() : Boolean =
  if self.hasAttr('containment') then
    self.getAttrBool('containment')
  else
    false
  endif;

helper context XML!Node def: getSubTypes() : Sequence(XML!Element) =
  self.getSeq('subType');

helper context XML!Node def: findType(typeName : String) : DSL!Type =
  DSL!Type.allInstances()->any(t | t.name = typeName);

rule DomainModel {
  from
    r : XML!Root (r.name = 'DomainModel')
  to
    dm : DSL!DomainModel (
      name <- r.getAttrVal('name'),
      identity <- r.getAttrVal('id'),
      isLoaded <- true,
      namespace <- r.getAttrVal('namespace'),
      classifiers <- r.getSeq('Class')->union(r.getSeq('Relationship'))->collect(e | thisModule.resolveTemp(e, 'classifier')),
      types <- Sequence{
        thisModule.stringType(),
        thisModule.integerType(),
        thisModule.booleanType(),
        thisModule.doubleType()
      }->union(r.getSeq('Enumeration')->collect(e | thisModule.resolveTemp(e, 'enum')))
    )
}

rule Class {
  from
    e : XML!Element (e.name = 'Class')
  to
    c : DSL!Class 'classifier' (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- e.getAttrVal('namespace'),
      isLoaded <- true,
      isAbstract <- e.isAbstract(),
      properties <- e.getSeq('ValueProperty')->collect(v | thisModule.resolveTemp(v, 'prop')),
      superType <- if e.hasAttr('super') then
                     DSL!Classifier.allInstances()->any(cl | cl.identity = e.getAttrVal('super'))
                   else
                     OclUndefined
                   endif,
      subTypes <- e.getSubTypes()->collect(st | DSL!Classifier.allInstances()->any(cl | cl.identity = st.getAttrVal('id'))),
      domainModel <- DSL!DomainModel.allInstances()->first()
    )
}

rule Relationship {
  from
    e : XML!Element (e.name = 'Relationship')
  to
    r : DSL!Relationship 'classifier' (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- e.getAttrVal('namespace'),
      isLoaded <- true,
      isAbstract <- e.isAbstract(),
      isEmbedding <- e.getContainment(),
      properties <- e.getSeq('ValueProperty')->collect(v | thisModule.resolveTemp(v, 'prop')),
      roles <- e.getSeq('Role')->collect(ro | thisModule.resolveTemp(ro, 'role')),
      superType <- if e.hasAttr('super') then
                     DSL!Classifier.allInstances()->any(cl | cl.identity = e.getAttrVal('super'))
                   else
                     OclUndefined
                   endif,
      subTypes <- e.getSubTypes()->collect(st | DSL!Classifier.allInstances()->any(cl | cl.identity = st.getAttrVal('id'))),
      domainModel <- DSL!DomainModel.allInstances()->first()
    )
}

rule Role {
  from
    e : XML!Element (e.name = 'Role')
  to
    r : DSL!Role 'role' (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- e.getAttrVal('namespace'),
      min <- e.getAttrVal('min')->toInteger(),
      max <- if e.hasAttr('max') then e.getAttrVal('max')->toInteger() else 1 endif,
      isUnbounded <- if e.hasAttr('isUnbounded') then e.getAttrBool('isUnbounded') else false endif,
      accepts <- e.getAttrVal('accepts'),
      isOrdered <- if e.hasAttr('isOrdered') then e.getAttrBool('isOrdered') else false endif,
      isNavigableFrom <- if e.hasAttr('isNavigableFrom') then e.getAttrBool('isNavigableFrom') else true endif,
      isPropertyGenerator <- if e.hasAttr('isPropertyGenerator') then e.getAttrBool('isPropertyGenerator') else false endif,
      source <- DSL!Classifier.allInstances()->any(cl | cl.identity = e.getAttrVal('source')),
      type <- DSL!Classifier.allInstances()->any(cl | cl.identity = e.getAttrVal('type')),
      relation <- thisModule.resolveTemp(e.parent, 'classifier')
    )
}

rule ValueProperty {
  from
    e : XML!Element (e.name = 'ValueProperty')
  to
    p : DSL!ValueProperty 'prop' (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- e.getAttrVal('namespace'),
      owner <- thisModule.resolveTemp(e.parent, 'classifier'),
      type <- thisModule.resolveType(e)
    )
}

rule Enumeration {
  from
    e : XML!Element (e.name = 'Enumeration')
  to
    en : DSL!Enumeration 'enum' (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      namespace <- e.getAttrVal('namespace'),
      literals <- e.getSeq('EnumerationLiteral')->collect(l | thisModule.resolveTemp(l, 'lit'))
    )
}

rule EnumerationLiteral {
  from
    e : XML!Element (e.name = 'EnumerationLiteral')
  to
    l : DSL!EnumerationLiteral 'lit' (
      name <- e.getAttrVal('name'),
      identity <- e.getAttrVal('id'),
      value <- e.getAttrVal('value')->toInteger()
    )
}

helper def: stringType() : DSL!SimpleType =
  DSL!SimpleType.allInstances()->any(t | t.name = 'String');

helper def: integerType() : DSL!SimpleType =
  DSL!SimpleType.allInstances()->any(t | t.name = 'Integer');

helper def: booleanType() : DSL!SimpleType =
  DSL!SimpleType.allInstances()->any(t | t.name = 'Boolean');

helper def: doubleType() : DSL!SimpleType =
  DSL!SimpleType.allInstances()->any(t | t.name = 'Double');

helper def: resolveType(e : XML!Element) : DSL!Type =
  let tName : String = e.getType() in
    if tName = 'String' then
      thisModule.stringType()
    else if tName = 'Integer' then
      thisModule.integerType()
    else if tName = 'Boolean' then
      thisModule.booleanType()
    else if tName = 'Double' then
      thisModule.doubleType()
    else
      DSL!Type.allInstances()->any(t | t.name = tName)
    endif
    endif
    endif
    endif