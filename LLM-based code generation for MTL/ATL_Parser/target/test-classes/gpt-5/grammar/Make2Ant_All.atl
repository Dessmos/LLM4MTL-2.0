module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		m : Make!Makefile
	to
		p : Ant!Project (
			name <- m.name,
			default <- if m.defaultTarget.oclIsUndefined() then '' else m.defaultTarget.name endif,
			properties <- m.macros,
			targets <- m.rules
		)
}

rule Macro2Property {
	from
		m : Make!Macro
	to
		p : Ant!PropertyValue (
			name <- m.name,
			value <- m.value
		)
}

rule Rule2Target {
	from
		r : Make!Rule
	to
		t : Ant!Target (
			name <- r.name,
			depends <- r.dependencies->collect(d | d.name)->implode(','),
			tasks <- r.shellLines
		)
}

rule ShellLine2Task_Display {
	from
		s : Make!ShellLine (s.display = true)
	to
		e : Ant!Echo (
			message <- s.command
		)
}

rule ShellLine2Task_NoDisplay {
	from
		s : Make!ShellLine (s.display = false)
	to
		ex : Ant!Exec (
			executable <- s.command
		)
}