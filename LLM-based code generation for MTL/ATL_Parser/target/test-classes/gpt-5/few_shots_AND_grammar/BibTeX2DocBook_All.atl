module BibTeX2DocBook;
create OUT : XML from IN : BibTeX;

helper def: authorSet() : Set(BibTeX!Author) =
  BibTeX!Author.allInstances()->asSet();

helper def: titledEntrySet() : Set(BibTeX!Entry) =
  BibTeX!Entry.allInstances()
    ->select(e | not e.title.oclIsUndefined() and e.title <> '')
    ->asSet();

helper def: articleSet() : Set(BibTeX!Article) =
  BibTeX!Article.allInstances()->asSet();

helper def: buildEntryPara(e : BibTeX!Entry) : String =
  let base : String = 
    if not e.author.oclIsUndefined() and e.author <> '' then
      e.author + ' '
    else
      ''
    endif
  in
  let withTitle : String =
    if not e.title.oclIsUndefined() and e.title <> '' then
      base + '"' + e.title + '" '
    else
      base
    endif
  in
  let withJournal : String =
    if e.oclIsKindOf(BibTeX!Article) and not e.journal.oclIsUndefined() and e.journal <> '' then
      withTitle + e.journal + ' '
    else
      withTitle
    endif
  in
  let withYear : String =
    if not e.year.oclIsUndefined() and e.year <> '' then
      withJournal + '(' + e.year + ')'
    else
      withJournal
    endif
  in
  withYear;

rule Main {
  from
    s : BibTeX!Bibliography
  to
    r : XML!Root (
      name <- 'book',
      children <- Sequence{
        thisModule.createReferencesSection(s),
        thisModule.createAuthorsSection(s),
        thisModule.createTitlesSection(s),
        thisModule.createJournalsSection(s)
      }
    )
}

rule Author {
  from
    a : BibTeX!Author
  to
    personElem : XML!Element (
      name <- 'person',
      children <- Sequence{
        nameElem,
        refList
      }
    ),
    nameElem : XML!Element (
      name <- 'name',
      children <- Sequence{ nameText }
    ),
    nameText : XML!Text (
      value <- a.name
    ),
    refList : XML!Element (
      name <- 'refs',
      children <- a.entries->collect(e | thisModule.createEntryParaNode(e))
    )
}

rule UntitledEntry {
  from
    e : BibTeX!Entry (
      e.title.oclIsUndefined() or e.title = ''
    )
  to
    paraElem : XML!Element (
      name <- 'para',
      children <- Sequence{ paraText }
    ),
    paraText : XML!Text (
      value <- thisModule.buildEntryPara(e)
    )
}

rule TitledEntry_Title_NoArticle {
  from
    e : BibTeX!Entry (
      not e.oclIsKindOf(BibTeX!Article) and not e.title.oclIsUndefined() and e.title <> ''
    )
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem,
        contentPara
      }
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- e.title
    ),
    contentPara : XML!Element (
      name <- 'para',
      children <- Sequence{ contentText }
    ),
    contentText : XML!Text (
      value <- thisModule.buildEntryPara(e)
    )
}

rule TitledEntry_NoTitle_NoArticle {
  from
    e : BibTeX!Entry (
      not e.oclIsKindOf(BibTeX!Article) and (e.title.oclIsUndefined() or e.title = '')
    )
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        contentPara
      }
    ),
    contentPara : XML!Element (
      name <- 'para',
      children <- Sequence{ contentText }
    ),
    contentText : XML!Text (
      value <- thisModule.buildEntryPara(e)
    )
}

rule Article_Title_Journal {
  from
    a : BibTeX!Article (
      not a.title.oclIsUndefined() and a.title <> '' and
      not a.journal.oclIsUndefined() and a.journal <> ''
    )
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem,
        journalElem,
        contentPara
      }
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- a.title
    ),
    journalElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        journalTitleElem,
        journalPara
      }
    ),
    journalTitleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ journalTitleText }
    ),
    journalTitleText : XML!Text (
      value <- a.journal
    ),
    journalPara : XML!Element (
      name <- 'para',
      children <- Sequence{ journalText }
    ),
    journalText : XML!Text (
      value <- a.journal
    ),
    contentPara : XML!Element (
      name <- 'para',
      children <- Sequence{ contentText }
    ),
    contentText : XML!Text (
      value <- thisModule.buildEntryPara(a)
    )
}

rule Article_NoTitle_Journal {
  from
    a : BibTeX!Article (
      (a.title.oclIsUndefined() or a.title = '') and
      not a.journal.oclIsUndefined() and a.journal <> ''
    )
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        journalElem,
        contentPara
      }
    ),
    journalElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        journalTitleElem,
        journalPara
      }
    ),
    journalTitleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ journalTitleText }
    ),
    journalTitleText : XML!Text (
      value <- a.journal
    ),
    journalPara : XML!Element (
      name <- 'para',
      children <- Sequence{ journalText }
    ),
    journalText : XML!Text (
      value <- a.journal
    ),
    contentPara : XML!Element (
      name <- 'para',
      children <- Sequence{ contentText }
    ),
    contentText : XML!Text (
      value <- thisModule.buildEntryPara(a)
    )
}

rule Article_Title_NoJournal {
  from
    a : BibTeX!Article (
      not a.title.oclIsUndefined() and a.title <> '' and
      (a.journal.oclIsUndefined() or a.journal = '')
    )
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem,
        contentPara
      }
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- a.title
    ),
    contentPara : XML!Element (
      name <- 'para',
      children <- Sequence{ contentText }
    ),
    contentText : XML!Text (
      value <- thisModule.buildEntryPara(a)
    )
}

rule Article_NoTitle_NoJournal {
  from
    a : BibTeX!Article (
      (a.title.oclIsUndefined() or a.title = '') and
      (a.journal.oclIsUndefined() or a.journal = '')
    )
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        contentPara
      }
    ),
    contentPara : XML!Element (
      name <- 'para',
      children <- Sequence{ contentText }
    ),
    contentText : XML!Text (
      value <- thisModule.buildEntryPara(a)
    )
}

rule createReferencesSection(b : BibTeX!Bibliography) {
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem
      }->union(
        b.entries->collect(e | thisModule.createEntryParaNode(e))
      )
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- 'References'
    )
}

rule createAuthorsSection(b : BibTeX!Bibliography) {
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem
      }->union(
        thisModule.authorSet()->collect(a | thisModule.Author(a))
      )
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- 'Authors'
    )
}

rule createTitlesSection(b : BibTeX!Bibliography) {
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem
      }->union(
        thisModule.titledEntrySet()->collect(e | thisModule.createEntryParaNode(e))
      )
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- 'Titles'
    )
}

rule createJournalsSection(b : BibTeX!Bibliography) {
  to
    sectionElem : XML!Element (
      name <- 'section',
      children <- Sequence{
        titleElem
      }->union(
        thisModule.articleSet()->collect(a | thisModule.createEntryParaNode(a))
      )
    ),
    titleElem : XML!Element (
      name <- 'title',
      children <- Sequence{ titleText }
    ),
    titleText : XML!Text (
      value <- 'Journals'
    )
}

rule createEntryParaNode(e : BibTeX!Entry) {
  to
    paraElem : XML!Element (
      name <- 'para',
      children <- Sequence{ paraText }
    ),
    paraText : XML!Text (
      value <- thisModule.buildEntryPara(e)
    )
}