module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Proxy def: isSimple : Boolean =
  true;

helper context CPL!Proxy def: statement : SPL!Statement =
  OclUndefined;

helper context CPL!Proxy def: locations : Sequence(CPL!Location) =
  Sequence{};

helper def: Location2URIConstant(l : CPL!Location) : SPL!URIConstant =
  OclUndefined;

rule CPL2Program {
  from
    c : CPL!CPL
  to
    p : SPL!Program (
      name <- c.name
    )
}

rule SubAction2Function {
  from
    sa : CPL!SubAction
  to
    f : SPL!Function (
      name <- sa.name
    )
}

rule Incoming2Method {
  from
    i : CPL!Incoming
  to
    m : SPL!Method (
      name <- i.name
    )
}

rule Proxy2Return {
  from
    p : CPL!Proxy (p.isSimple)
  to
    r : SPL!Return (
      expression <- p.statement
    )
}

rule Proxy2Select {
  from
    p : CPL!Proxy (not p.isSimple)
  to
    s : SPL!Select (
      cases <- p.statement
    )
}

rule Busy2SelectCase {
  from
    b : CPL!Busy
  to
    c : SPL!SelectCase (
      condition <- OclUndefined,
      statement <- OclUndefined
    )
}

rule NoAnswer2SelectCase {
  from
    n : CPL!NoAnswer
  to
    c : SPL!SelectCase (
      condition <- OclUndefined,
      statement <- OclUndefined
    )
}

rule Redirection2SelectCase {
  from
    rsrc : CPL!Redirection
  to
    c : SPL!SelectCase (
      condition <- OclUndefined,
      statement <- OclUndefined
    )
}

rule Default2SelectDefault {
  from
    d : CPL!Default
  to
    sd : SPL!SelectDefault (
      statement <- OclUndefined
    )
}

rule SubCall2Return {
  from
    sc : CPL!SubCall
  to
    r : SPL!Return (
      expression <- OclUndefined
    )
}

rule Redirect2Return {
  from
    rd : CPL!Redirect
  to
    r : SPL!Return (
      expression <- thisModule.Location2URIConstant(rd.location)
    )
}

rule AddressSwitch2SelectStat {
  from
    as : CPL!AddressSwitch
  to
    s : SPL!Select (
      cases <- as.switchedAddresses->collect(sa | thisModule.SwitchedAddress2SelectCase(sa)),
      default <- as.otherwise->collect(o | thisModule.Otherwise2SelectDefault(o))->first()
    )
}

rule SwitchedAddress2SelectCase {
  from
    sa : CPL!SwitchedAddress
  to
    c : SPL!SelectCase (
      condition <- thisModule.Location2URIConstant(sa.location),
      statement <- OclUndefined
    )
}

rule Otherwise2SelectDefault {
  from
    o : CPL!Otherwise
  to
    sd : SPL!SelectDefault (
      statement <- OclUndefined
    )
}