module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
  from src : Make!Makefile
  to   dst : Ant!Project (
    name          <- src.name,
    properties    <- Make!Macro.allInstances()->collect(m | thisModule.Macro2Property(m)),
    targets       <- Make!Rule.allInstances()->collect(r | thisModule.Rule2Target(r)),
    defaultTarget <- src.default.name
  )
}

unique lazy rule Macro2Property {
  from m : Make!Macro
  to   p : Ant!PropertyValue (
    name  <- m.name,
    value <- m.value
  )
}

unique lazy rule Rule2Target {
  from r : Make!Rule
  to   t : Ant!Target (
    name         <- r.name,
    depends      <- r.dependencies->collect(d | d.name),
    tasks        <- r.shellLines->collect(sl |
                        if sl.display then
                          thisModule.ShellLine2Task_Display(sl)
                        else
                          thisModule.ShellLine2Task_NoDisplay(sl)
                        endif
                     )
  )
}

unique lazy rule ShellLine2Task_Display {
  from sl : Make!ShellLine (sl.display = true)
  to   e  : Ant!Echo (
    message <- sl.command
  )
}

unique lazy rule ShellLine2Task_NoDisplay {
  from sl : Make!ShellLine (sl.display = false)
  to   ex : Ant!Exec (
    command <- sl.command
  )
}