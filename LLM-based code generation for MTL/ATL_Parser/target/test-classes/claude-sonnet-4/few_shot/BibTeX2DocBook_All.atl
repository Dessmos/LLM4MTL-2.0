module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper def : authorSet : Set(BibTeX!Author) = BibTeX!Author.allInstances()->asSet();

helper def : titledEntrySet : Set(BibTeX!TitledEntry) = BibTeX!TitledEntry.allInstances()->asSet();

helper def : articleSet : Set(BibTeX!Article) = BibTeX!Article.allInstances()->asSet();

helper def : buildEntryPara(entry : BibTeX!Entry) : DocBook!Para = 
  OclUndefined;

rule Main {
  from src : BibTeX!BibTeX
  to   dst : DocBook!Book (
    chapter <- Set{
      thisModule.referencesChapter(),
      thisModule.authorsChapter(),
      thisModule.titlesChapter(),
      thisModule.journalsChapter()
    }
  )
}

lazy rule referencesChapter {
  from dummy : BibTeX!BibTeX
  to   chapter : DocBook!Chapter (
    title <- 'References',
    section <- BibTeX!Entry.allInstances()
  )
}

lazy rule authorsChapter {
  from dummy : BibTeX!BibTeX
  to   chapter : DocBook!Chapter (
    title <- 'Authors',
    section <- thisModule.authorSet
  )
}

lazy rule titlesChapter {
  from dummy : BibTeX!BibTeX
  to   chapter : DocBook!Chapter (
    title <- 'Titles',
    section <- thisModule.titledEntrySet
  )
}

lazy rule journalsChapter {
  from dummy : BibTeX!BibTeX
  to   chapter : DocBook!Chapter (
    title <- 'Journals',
    section <- thisModule.articleSet
  )
}

rule Author {
  from src : BibTeX!Author
  to   dst : DocBook!Section (
    title <- src.name,
    para <- BibTeX!Entry.allInstances()->select(e | e.authors->includes(src))->collect(e | thisModule.buildEntryPara(e))
  )
}

rule UntitledEntry {
  from src : BibTeX!UntitledEntry
  to   dst : DocBook!Section (
    title <- src.key,
    para <- thisModule.buildEntryPara(src)
  )
}

rule TitledEntry_Title_NoArticle {
  from src : BibTeX!TitledEntry (
    src.title.oclIsUndefined() = false and not src.oclIsTypeOf(BibTeX!Article)
  )
  to   dst : DocBook!Section (
    title <- src.title,
    para <- thisModule.buildEntryPara(src)
  )
}

rule TitledEntry_NoTitle_NoArticle {
  from src : BibTeX!TitledEntry (
    src.title.oclIsUndefined() = true and not src.oclIsTypeOf(BibTeX!Article)
  )
  to   dst : DocBook!Section (
    title <- src.key,
    para <- thisModule.buildEntryPara(src)
  )
}

rule Article_Title_Journal {
  from src : BibTeX!Article (
    src.title.oclIsUndefined() = false and src.journal.oclIsUndefined() = false
  )
  to   dst : DocBook!Section (
    title <- src.journal,
    para <- thisModule.buildEntryPara(src)
  )
}

rule Article_NoTitle_Journal {
  from src : BibTeX!Article (
    src.title.oclIsUndefined() = true and src.journal.oclIsUndefined() = false
  )
  to   dst : DocBook!Section (
    title <- src.journal,
    para <- thisModule.buildEntryPara(src)
  )
}

rule Article_Title_NoJournal {
  from src : BibTeX!Article (
    src.title.oclIsUndefined() = false and src.journal.oclIsUndefined() = true
  )
  to   dst : DocBook!Section (
    title <- src.title,
    para <- thisModule.buildEntryPara(src)
  )
}

rule Article_NoTitle_NoJournal {
  from src : BibTeX!Article (
    src.title.oclIsUndefined() = true and src.journal.oclIsUndefined() = true
  )
  to   dst : DocBook!Section (
    title <- src.key,
    para <- thisModule.buildEntryPara(src)
  )
}