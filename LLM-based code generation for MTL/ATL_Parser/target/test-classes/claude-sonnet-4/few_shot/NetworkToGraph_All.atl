module NetworkToGraph_All;
create OUT : Graph from IN : Network;

rule Component2Entity {
  from c : Network!Component
  to   e : Graph!Entity (
    name <- c.name
  )
}

rule System2Root {
  from s : Network!System
  to   r : Graph!Root (
    name <- s.name,
    entities <- s.components->collect(c | thisModule.Component2Entity(c))
  )
}

rule Link2Link {
  from l : Network!Link
  to   tl : Graph!Link (
    name <- l.name,
    entities <- l.components->collect(c | thisModule.Component2Entity(c))
  )
}