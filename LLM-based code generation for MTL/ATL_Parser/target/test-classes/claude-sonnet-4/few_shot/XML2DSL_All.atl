module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrBool(name : String) : Boolean =
  let attr : XML!Attribute = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->first() in
  if attr.oclIsUndefined() then false else attr.value = 'true' endif;

helper context XML!Element def: getAttrVal(name : String) : String =
  let attr : XML!Attribute = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->first() in
  if attr.oclIsUndefined() then '' else attr.value endif;

helper context XML!Element def: get(child : String, name : String) : XML!Element =
  self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = child)
    ->select(e | e.getAttrVal('name') = name)->first();

helper context XML!Element def: getType() : String =
  if self.getAttrVal('type') <> '' then self.getAttrVal('type')
  else if self.getAttrVal('eType') <> '' then self.getAttrVal('eType')
  else '' endif endif;

helper context XML!Element def: getEnumId() : String =
  self.getAttrVal('name') + '_' + self.getAttrVal('value');

helper context XML!Element def: getText() : String =
  let textNode : XML!Text = self.children->select(c | c.oclIsTypeOf(XML!Text))->first() in
  if textNode.oclIsUndefined() then '' else textNode.value endif;

helper context XML!Element def: getSeq(childName : String) : Sequence(XML!Element) =
  self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = childName);

helper context XML!Element def: hasChildren() : Boolean =
  self.children->select(c | c.oclIsTypeOf(XML!Element))->size() > 0;

helper context XML!Element def: hasAttr(name : String) : Boolean =
  self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = name)->size() > 0;

helper context XML!Element def: isAbstract() : Boolean =
  self.getAttrBool('abstract');

helper def: dslElementsById : Map(String, DSL!NamedElement) =
  Map{};

helper context XML!Element def: getContainment() : Boolean =
  self.getAttrBool('containment');

helper context XML!Element def: getSubTypes() : Sequence(XML!Element) =
  XML!Element.allInstances()->select(e | e.getAttrVal('eSuperTypes').split(' ')->includes('#//' + self.getAttrVal('name')));

helper context String def: findType() : DSL!Type =
  if self = 'String' then thisModule.resolveTemp(XML!Element.allInstances()->first(), 'stringType')
  else if self = 'Integer' then thisModule.resolveTemp(XML!Element.allInstances()->first(), 'integerType')
  else if self = 'Boolean' then thisModule.resolveTemp(XML!Element.allInstances()->first(), 'booleanType')
  else if self = 'Double' then thisModule.resolveTemp(XML!Element.allInstances()->first(), 'doubleType')
  else DSL!Enumeration.allInstances()->select(e | e.name = self)->first()
  endif endif endif endif;

rule DomainModel {
  from src : XML!Element (
    src.name = 'EPackage' and src.parent.oclIsTypeOf(XML!Root)
  )
  to dst : DSL!DomainModel (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('name'),
    namespace <- src.getAttrVal('nsURI'),
    isLoaded <- true,
    classifiers <- src.getSeq('eClassifiers')->select(e | e.getAttrVal('xsi:type') = 'ecore:EClass'),
    types <- Sequence{stringType, integerType, booleanType, doubleType}->union(
      src.getSeq('eClassifiers')->select(e | e.getAttrVal('xsi:type') = 'ecore:EEnum'))
  ),
  stringType : DSL!SimpleType (
    name <- 'String',
    identity <- 'String',
    namespace <- 'PrimitiveTypes'
  ),
  integerType : DSL!SimpleType (
    name <- 'Integer',
    identity <- 'Integer',
    namespace <- 'PrimitiveTypes'
  ),
  booleanType : DSL!SimpleType (
    name <- 'Boolean',
    identity <- 'Boolean',
    namespace <- 'PrimitiveTypes'
  ),
  doubleType : DSL!SimpleType (
    name <- 'Double',
    identity <- 'Double',
    namespace <- 'PrimitiveTypes'
  )
}

rule Class {
  from src : XML!Element (
    src.name = 'eClassifiers' and src.getAttrVal('xsi:type') = 'ecore:EClass'
  )
  to dst : DSL!Class (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('name'),
    namespace <- src.parent.getAttrVal('name'),
    isLoaded <- true,
    isAbstract <- src.isAbstract(),
    properties <- src.getSeq('eStructuralFeatures')->select(f | f.getAttrVal('xsi:type') = 'ecore:EAttribute'),
    superType <- if src.hasAttr('eSuperTypes') then
      XML!Element.allInstances()->select(e | e.name = 'eClassifiers' and e.getAttrVal('name') = src.getAttrVal('eSuperTypes').split('//')->last())->first()
    else OclUndefined endif,
    domainModel <- src.parent
  )
}

rule Relationship {
  from src : XML!Element (
    src.name = 'eStructuralFeatures' and src.getAttrVal('xsi:type') = 'ecore:EReference'
  )
  to dst : DSL!Relationship (
    name <- src.getAttrVal('name') + 'Relationship',
    identity <- src.getAttrVal('name') + 'Relationship',
    namespace <- src.parent.parent.getAttrVal('name'),
    isLoaded <- true,
    isAbstract <- false,
    isEmbedding <- src.getContainment(),
    roles <- Sequence{sourceRole, targetRole},
    domainModel <- src.parent.parent
  ),
  sourceRole : DSL!Role (
    name <- 'source',
    identity <- 'source',
    min <- 1,
    max <- 1,
    isUnbounded <- false,
    accepts <- src.parent.getAttrVal('name'),
    isOrdered <- false,
    isNavigableFrom <- true,
    isPropertyGenerator <- false,
    source <- src.parent,
    type <- src.parent
  ),
  targetRole : DSL!Role (
    name <- src.getAttrVal('name'),
    identity <- src.getAttrVal('name'),
    min <- if src.hasAttr('lowerBound') then src.getAttrVal('lowerBound').toInteger() else 0 endif,
    max <- if src.hasAttr('upperBound') and src.getAttrVal('upperBound') <> '-1' then src.getAttrVal('upperBound').toInteger() else 1 endif,
    isUnbounded <- src.getAttrVal('upperBound') = '-1',
    accepts <- src.getType().split('//')->last(),
    isOrdered <- src.getAttrBool('ordered'),