module CPL2SPL;
create OUT : SPL from IN : CPL;

helper def: statement : OclAny = OclUndefined;

helper def: locations : Sequence(OclAny) = Sequence{};

helper def: isSimple : Boolean = true;

rule CPL2Program {
  from cpl : CPL!CPL
  to   prg : SPL!Program
}

rule SubAction2Function {
  from subAction : CPL!SubAction
  to   func : SPL!Function
}

rule Incoming2Method {
  from incoming : CPL!Incoming
  to   method : SPL!Method
}

rule Proxy2Return {
  from proxy : CPL!Proxy (proxy.isSimple)
  to   ret : SPL!Return
}

rule Proxy2Select {
  from proxy : CPL!Proxy (not proxy.isSimple)
  to   sel : SPL!Select
}

rule Busy2SelectCase {
  from busy : CPL!Busy
  to   selCase : SPL!SelectCase
}

rule NoAnswer2SelectCase {
  from noAnswer : CPL!NoAnswer
  to   selCase : SPL!SelectCase
}

rule Redirection2SelectCase {
  from redirection : CPL!Redirection
  to   selCase : SPL!SelectCase
}

rule Default2SelectDefault {
  from def : CPL!Default
  to   selDef : SPL!SelectDefault
}

rule SubCall2Return {
  from subCall : CPL!SubCall
  to   ret : SPL!Return
}

rule Redirect2Return {
  from redirect : CPL!Redirect
  to   ret : SPL!Return
}

rule AddressSwitch2SelectStat {
  from addrSwitch : CPL!AddressSwitch
  to   selectStat : SPL!SelectStat
}

rule SwitchedAddress2SelectCase {
  from switchedAddr : CPL!SwitchedAddress
  to   selCase : SPL!SelectCase
}

rule Otherwise2SelectDefault {
  from otherwise : CPL!Otherwise
  to   selDef : SPL!SelectDefault
}

unique lazy rule Location2URIConstant {
  from location : CPL!Location
  to   uriConst : SPL!URIConstant
}