module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper def: rationale() : String =
  let rationales : Sequence(IEEE1471!Rationale) = IEEE1471!Rationale.allInstances() in
  if rationales->notEmpty() then
    let firstRationale : IEEE1471!Rationale = rationales->first() in
    firstRationale.name + ': ' + firstRationale.content
  else
    ''
  endif;

rule IEEE1471Model2MoDAFModel {
  from src : IEEE1471!IEEE1471Model
  to   dst : MoDAF!MoDAFModel (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    enterprises <- src.systems->select(s | s.oclIsTypeOf(IEEE1471!System)),
    environments <- src.environments,
    operationalMissions <- src.missions,
    architectures <- src.architectures,
    architecturalDescriptions <- src.architecturalDescriptions,
    stakeholders <- src.stakeholders,
    views <- src.viewpoints,
    architecturalProducts <- src.views,
    elements <- src.models,
    concerns <- src.concerns,
    architecturalFrameworks <- Sequence{thisModule.createDefaultFramework()}->union(src.libraryViewpoints->collect(lv | thisModule.LibraryViewpoint2ArchitecturalFramework(lv)))
  )
}

rule System2Enterprise {
  from src : IEEE1471!System
  to   dst : MoDAF!Enterprise (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded
  )
}

rule Environment2Environment {
  from src : IEEE1471!Environment
  to   dst : MoDAF!Environment (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded
  )
}

rule Mission2OperationalMission {
  from src : IEEE1471!Mission
  to   dst : MoDAF!OperationalMission (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded
  )
}

rule Architecture2Architecture {
  from src : IEEE1471!Architecture
  to   dst : MoDAF!Architecture (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded
  )
}

rule AD2AD {
  from src : IEEE1471!ArchitecturalDescription
  to   dst : MoDAF!ArchitecturalDescription (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    system <- src.system,
    rationale <- thisModule.rationale()
  )
}

rule Stakeholder2Stakeholder {
  from src : IEEE1471!Stakeholder
  to   dst : MoDAF!Stakeholder (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    concerns <- src.concerns
  )
}

rule Viewpoint2View {
  from src : IEEE1471!Viewpoint
  to   dst : MoDAF!View (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    concerns <- src.concerns,
    stakeholders <- src.stakeholders,
    architecturalFramework <- if src.libraryViewpoint.oclIsUndefined() then thisModule.resolveTemp(thisModule.getDefaultFramework(), 'defaultFramework') else src.libraryViewpoint endif
  )
}

rule View2ArchitecturalProduct {
  from src : IEEE1471!View
  to   dst : MoDAF!ArchitecturalProduct (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    viewpoint <- src.viewpoint,
    models <- src.models
  )
}

rule Model2Element {
  from src : IEEE1471!Model
  to   dst : MoDAF!Element (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded
  )
}

rule Concern2Concern {
  from src : IEEE1471!Concern
  to   dst : MoDAF!Concern (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    stakeholders <- src.stakeholders
  )
}

rule LibraryViewpoint2ArchitecturalFramework {
  from src : IEEE1471!LibraryViewpoint
  to   dst : MoDAF!ArchitecturalFramework (
    name <- src.name,
    identity <- src.identity,
    namespace <- src.namespace,
    isLoaded <- src.isLoaded,
    views <- src.viewpoints
  )
}

lazy rule StakeholderHasConcern {
  from src : IEEE1471!Stakeholder
  to   dst : MoDAF!StakeholderHasConcern (
    name <- src.name + '_concerns',
    identity <- src.identity + '_concerns',
    namespace <- src.namespace,
    stakeholder <- src,
    concerns <- src.concerns
  )
}

helper def: getDefaultFramework() : MoDAF!ArchitecturalFramework =
  MoDAF!ArchitecturalFramework.allInstances()->select(af | af.name = 'Undefined Architectural Framework')->first();

helper def: createDefaultFramework() : MoDAF!ArchitecturalFramework =
  thisModule.DefaultFramework();

lazy rule DefaultFramework {
  from src : IEEE1471!IEEE1471Model
  to   defaultFramework : MoDAF!ArchitecturalFramework (
    name <- 'Undefined Architectural Framework',
    identity <- 'undefined_framework',
    namespace <- 'default',
    isLoaded <- true,
    views <- IEEE1471!Viewpoint.allInstances()->select(vp | vp.libraryViewpoint.oclIsUndefined())
  )
}