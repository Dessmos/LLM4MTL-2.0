module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper def : rationale : String = 
	if IEEE1471!Rationale.allInstances()->notEmpty() then
		let r : IEEE1471!Rationale = IEEE1471!Rationale.allInstances()->first() in
		r.name + ' - ' + r.content
	else
		'No rationale available'
	endif;

rule IEEE1471Model2MoDAFModel {
	from
		s : IEEE1471!IEEE1471Model
	to
		t : MoDAF!MoDAFModel (
			name <- s.name,
			content <- s.content
		)
}

rule System2Enterprise {
	from
		s : IEEE1471!System
	to
		t : MoDAF!Enterprise (
			name <- s.name,
			content <- s.content
		)
}

rule Environment2Environment {
	from
		s : IEEE1471!Environment
	to
		t : MoDAF!Environment (
			name <- s.name,
			content <- s.content
		)
}

rule Mission2OperationalMission {
	from
		s : IEEE1471!Mission
	to
		t : MoDAF!OperationalMission (
			name <- s.name,
			content <- s.content
		)
}

rule Architecture2Architecture {
	from
		s : IEEE1471!Architecture
	to
		t : MoDAF!Architecture (
			name <- s.name,
			content <- s.content,
			system <- s.system,
			environment <- s.environment,
			mission <- s.mission
		)
}

rule AD2AD {
	from
		s : IEEE1471!AD
	to
		t : MoDAF!AD (
			name <- s.name,
			content <- s.content,
			identifies <- s.identifies,
			stakeholders <- s.stakeholders,
			rationale <- thisModule.rationale
		)
}

rule Stakeholder2Stakeholder {
	from
		s : IEEE1471!Stakeholder
	to
		t : MoDAF!Stakeholder (
			name <- s.name,
			content <- s.content
		)
}

rule Viewpoint2View {
	from
		s : IEEE1471!Viewpoint
	to
		t : MoDAF!View (
			name <- s.name,
			content <- s.content,
			addresses <- s.addresses,
			stakeholders <- s.stakeholders,
			source <- s.source
		)
}

rule View2ArchitecturalProduct {
	from
		s : IEEE1471!View
	to
		t : MoDAF!ArchitecturalProduct (
			name <- s.name,
			content <- s.content,
			conformsTo <- s.conformsTo
		)
}

rule Model2Element {
	from
		s : IEEE1471!Model
	to
		t : MoDAF!Element (
			name <- s.name,
			content <- s.content
		)
}

rule Concern2Concern {
	from
		s : IEEE1471!Concern
	to
		t : MoDAF!Concern (
			name <- s.name,
			content <- s.content
		)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from
		s : IEEE1471!LibraryViewpoint
	to
		t : MoDAF!ArchitecturalFramework (
			name <- s.name,
			content <- s.content,
			viewpoints <- IEEE1471!Viewpoint.allInstances()->select(v | v.source = s)
		)
}

rule StakeholderHasConcern {
	from
		s : IEEE1471!StakeholderHasConcern
	to
		t : MoDAF!StakeholderHasConcern (
			stakeholder <- s.stakeholder,
			concern <- s.concern
		)
}

lazy rule UndefinedArchitecturalFramework {
	from
		s : IEEE1471!Viewpoint
	to
		t : MoDAF!ArchitecturalFramework (
			name <- 'Undefined Architectural Framework',
			content <- 'Default framework for viewpoints without source',
			viewpoints <- IEEE1471!Viewpoint.allInstances()->select(v | v.source.oclIsUndefined())
		)
}