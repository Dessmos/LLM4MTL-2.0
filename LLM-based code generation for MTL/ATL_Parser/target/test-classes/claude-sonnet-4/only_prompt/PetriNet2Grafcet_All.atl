module PetriNet2Grafcet;
create OUT : Grafcet from IN : PetriNet;

rule Grafcet {
	from
		pn : PetriNet!PetriNet
	to
		g : Grafcet!Grafcet (
			name <- pn.name,
			location <- pn.location,
			elements <- pn.elements,
			connections <- pn.arcs
		)
}

rule Step {
	from
		p : PetriNet!Place
	to
		s : Grafcet!Step (
			name <- p.name,
			location <- p.location,
			isInitial <- false,
			isActive <- false,
			action <- '',
			incomingConnections <- p.incomingArc,
			outgoingConnections <- p.outgoingArc
		)
}

rule Transition {
	from
		t : PetriNet!Transition
	to
		tr : Grafcet!Transition (
			name <- t.name,
			location <- t.location,
			condition <- '',
			incomingConnections <- t.incomingArc,
			outgoingConnections <- t.outgoingArc
		)
}

rule StepToTransition {
	from
		pt : PetriNet!PlaceToTransition
	to
		st : Grafcet!StepToTransition (
			name <- pt.name,
			location <- pt.location,
			from <- pt.from,
			to <- pt.to
		)
}

rule TransitionToStep {
	from
		tp : PetriNet!TransitionToPlace
	to
		ts : Grafcet!TransitionToStep (
			name <- tp.name,
			location <- tp.location,
			from <- tp.from,
			to <- tp.to
		)
}