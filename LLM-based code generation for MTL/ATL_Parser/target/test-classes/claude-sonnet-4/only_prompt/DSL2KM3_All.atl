module DSL2KM3;
create OUT: KM3 from IN: DSL;

helper def: needTurnOnClass(rel: DSL!Relationship): Boolean =
	rel.isEmbedding = false and rel.roles->exists(r | r.min <> 1 or r.max <> 1 or r.isUnbounded);

helper def: getRoles(rel: DSL!Relationship): Sequence(DSL!Role) =
	rel.roles->asSequence();

helper def: isEmbedding(rel: DSL!Relationship): Boolean =
	rel.isEmbedding;

rule Metamodel {
	from
		dm: DSL!DomainModel
	to
		mm: KM3!Metamodel (
			name <- dm.name,
			contents <- dm.classifiers->select(c | c.oclIsTypeOf(DSL!Class))
				->union(dm.classifiers->select(c | c.oclIsTypeOf(DSL!Relationship) and thisModule.needTurnOnClass(c)))
				->union(dm.types)
		)
}

rule Class {
	from
		c: DSL!Class
	to
		kc: KM3!Class (
			name <- c.name,
			isAbstract <- c.isAbstract,
			supertypes <- if c.superType.oclIsUndefined() then Sequence{} else Sequence{c.superType} endif,
			structuralFeatures <- c.properties
				->union(c.domainModel.classifiers->select(r | r.oclIsTypeOf(DSL!Relationship) and not thisModule.needTurnOnClass(r) and thisModule.getRoles(r)->exists(role | role.source = c and role.isPropertyGenerator)))
		)
}

rule Relation2Class {
	from
		r: DSL!Relationship (thisModule.needTurnOnClass(r))
	to
		kc: KM3!Class (
			name <- r.name,
			isAbstract <- r.isAbstract,
			supertypes <- if r.superType.oclIsUndefined() then Sequence{} else Sequence{r.superType} endif,
			structuralFeatures <- r.properties->union(thisModule.getRoles(r))
		)
}

rule SimpleReference {
	from
		r: DSL!Relationship (not thisModule.needTurnOnClass(r) and not thisModule.isEmbedding(r)),
		role: DSL!Role (role.relation = r and role.isPropertyGenerator)
	to
		ref: KM3!Reference (
			name <- role.name,
			type <- role.type,
			lower <- role.min,
			upper <- if role.isUnbounded then -1 else role.max endif,
			isOrdered <- role.isOrdered,
			isContainment <- false
		)
}

rule ComplexReference {
	from
		r: DSL!Relationship (not thisModule.needTurnOnClass(r) and thisModule.isEmbedding(r)),
		role: DSL!Role (role.relation = r and role.isPropertyGenerator)
	to
		ref: KM3!Reference (
			name <- role.name,
			type <- role.type,
			lower <- role.min,
			upper <- if role.isUnbounded then -1 else role.max endif,
			isOrdered <- role.isOrdered,
			isContainment <- true
		)
}

rule RoleToReference {
	from
		role: DSL!Role (thisModule.needTurnOnClass(role.relation))
	to
		ref: KM3!Reference (
			name <- role.name,
			type <- role.type,
			lower <- role.min,
			upper <- if role.isUnbounded then -1 else role.max endif,
			isOrdered <- role.isOrdered,
			isContainment <- false
		)
}

rule Attribute {
	from
		vp: DSL!ValueProperty
	to
		attr: KM3!Attribute (
			name <- vp.name,
			type <- vp.type
		)
}

rule Enumeration {
	from
		e: DSL!Enumeration
	to
		ke: KM3!Enumeration (
			name <- e.name,
			literals <- e.literals
		)
}

rule EnumLiteral {
	from
		el: DSL!EnumerationLiteral
	to
		kel: KM3!EnumerationLiteral (
			name <- el.name,
			literal <- el.name
		)
}

rule DataType {
	from
		dt: DSL!SimpleType
	to
		kdt: KM3!DataType (
			name <- dt.name
		)
}