module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper def : authorSet : Set(BibTeX!Author) = BibTeX!Author.allInstances();

helper def : titledEntrySet : Set(BibTeX!TitledEntry) = BibTeX!TitledEntry.allInstances();

helper def : articleSet : Set(BibTeX!Article) = BibTeX!Article.allInstances();

helper def : buildEntryPara(entry : BibTeX!Entry) : String =
	entry.key + ': ' + entry.author.name + ', ' + entry.year.toString();

rule Main {
	from
		s : BibTeX!BibTeX
	to
		t : DocBook!Book (
			title <- 'Bibliography',
			sections <- authorSet->collect(a | thisModule.Author(a)),
			sections <- titledEntrySet->select(e | e.title.oclIsUndefined().not())->collect(e | thisModule.TitledEntry_Title_NoArticle(e)),
			sections <- titledEntrySet->select(e | e.title.oclIsUndefined())->collect(e | thisModule.TitledEntry_NoTitle_NoArticle(e)),
			sections <- articleSet->select(a | a.title.oclIsUndefined().not() and a.journal.oclIsUndefined().not())->collect(a | thisModule.Article_Title_Journal(a)),
			sections <- articleSet->select(a | a.title.oclIsUndefined() and a.journal.oclIsUndefined().not())->collect(a | thisModule.Article_NoTitle_Journal(a)),
			sections <- articleSet->select(a | a.title.oclIsUndefined().not() and a.journal.oclIsUndefined())->collect(a | thisModule.Article_Title_NoJournal(a)),
			sections <- articleSet->select(a | a.title.oclIsUndefined() and a.journal.oclIsUndefined())->collect(a | thisModule.Article_NoTitle_NoJournal(a))
		)
}

rule Author {
	from
		s : BibTeX!Author
	to
		t : DocBook!Section (
			title <- s.name,
			paragraphs <- s.entries->collect(e | thisModule.buildEntryPara(e))
		)
}

rule UntitledEntry {
	from
		s : BibTeX!Entry (s.title.oclIsUndefined())
	to
		t : DocBook!Para (
			content <- thisModule.buildEntryPara(s)
		)
}

rule TitledEntry_Title_NoArticle {
	from
		s : BibTeX!TitledEntry (s.title.oclIsUndefined().not() and not s.oclIsKindOf(BibTeX!Article))
	to
		t : DocBook!Section (
			title <- s.title,
			paragraphs <- Sequence{thisModule.buildEntryPara(s)}
		)
}

rule TitledEntry_NoTitle_NoArticle {
	from
		s : BibTeX!TitledEntry (s.title.oclIsUndefined() and not s.oclIsKindOf(BibTeX!Article))
	to
		t : DocBook!Para (
			content <- thisModule.buildEntryPara(s)
		)
}

rule Article_Title_Journal {
	from
		s : BibTeX!Article (s.title.oclIsUndefined().not() and s.journal.oclIsUndefined().not())
	to
		t : DocBook!Section (
			title <- s.journal,
			subsections <- Sequence{
				thisModule.resolveTemp(s, 'subsection')
			}
		),
		subsection : DocBook!Section (
			title <- s.title,
			paragraphs <- Sequence{thisModule.buildEntryPara(s)}
		)
}

rule Article_NoTitle_Journal {
	from
		s : BibTeX!Article (s.title.oclIsUndefined() and s.journal.oclIsUndefined().not())
	to
		t : DocBook!Section (
			title <- s.journal,
			paragraphs <- Sequence{thisModule.buildEntryPara(s)}
		)
}

rule Article_Title_NoJournal {
	from
		s : BibTeX!Article (s.title.oclIsUndefined().not() and s.journal.oclIsUndefined())
	to
		t : DocBook!Section (
			title <- s.title,
			paragraphs <- Sequence{thisModule.buildEntryPara(s)}
		)
}

rule Article_NoTitle_NoJournal {
	from
		s : BibTeX!Article (s.title.oclIsUndefined() and s.journal.oclIsUndefined())
	to
		t : DocBook!Para (
			content <- thisModule.buildEntryPara(s)
		)
}