module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper def: collectTasksFromContainer(container : Amalthea!ComponentContainer) : Sequence(Ascet!SoftwareTask) =
	Amalthea!Task.allInstances()->select(t | t.container = container)->collect(t | thisModule.Task2SoftwareTask(t));

rule ComponentContainer2AscetModule {
	from cc : Amalthea!ComponentContainer
	to am : Ascet!AscetModule (
		name <- cc.name,
		softwareTasks <- thisModule.collectTasksFromContainer(cc)
	)
}

rule TaskRoot2SoftwareTask {
	from t : Amalthea!Task (t.container.oclIsUndefined())
	to st : Ascet!SoftwareTask (
		name <- t.name
	)
}

rule Task2SoftwareTask {
	from t : Amalthea!Task
	to st : Ascet!SoftwareTask (
		name <- t.name
	)
}