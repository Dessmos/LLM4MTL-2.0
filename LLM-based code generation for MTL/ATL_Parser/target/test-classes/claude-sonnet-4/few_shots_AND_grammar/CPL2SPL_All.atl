module CPL2SPL;
create OUT : SPL from IN : CPL;

helper def : statement : SPL!Statement = OclUndefined;

helper def : locations : Sequence(CPL!Location) = Sequence{};

helper context CPL!Proxy def : isSimple : Boolean = 
	self.proxy->isEmpty();

rule CPL2Program {
	from s : CPL!CPL
	to t : SPL!Program
}

rule SubAction2Function {
	from s : CPL!SubAction
	to t : SPL!Function
}

rule Incoming2Method {
	from s : CPL!Incoming
	to t : SPL!Method
}

rule Proxy2Return {
	from s : CPL!Proxy
	to t : SPL!Return
}

rule Proxy2Select {
	from s : CPL!Proxy
	to t : SPL!Select
}

rule Busy2SelectCase {
	from s : CPL!Busy
	to t : SPL!SelectCase
}

rule NoAnswer2SelectCase {
	from s : CPL!NoAnswer
	to t : SPL!SelectCase
}

rule Redirection2SelectCase {
	from s : CPL!Redirection
	to t : SPL!SelectCase
}

rule Default2SelectDefault {
	from s : CPL!Default
	to t : SPL!SelectDefault
}

rule SubCall2Return {
	from s : CPL!SubCall
	to t : SPL!Return
}

rule Redirect2Return {
	from s : CPL!Redirect
	to t : SPL!Return
}

rule AddressSwitch2SelectStat {
	from s : CPL!AddressSwitch
	to t : SPL!SelectStat
}

rule SwitchedAddress2SelectCase {
	from s : CPL!SwitchedAddress
	to t : SPL!SelectCase
}

rule Otherwise2SelectDefault {
	from s : CPL!Otherwise
	to t : SPL!SelectDefault
}

rule Location2URIConstant {
	from s : CPL!Location
	to t : SPL!URIConstant
}