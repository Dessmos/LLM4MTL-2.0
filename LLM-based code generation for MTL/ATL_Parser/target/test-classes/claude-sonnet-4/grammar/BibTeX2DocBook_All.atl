module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper def : authorSet : Set(BibTeX!Author) = BibTeX!Author.allInstances()->select(a | a.books->size() > 0)->asSet();

helper def : titledEntrySet : Set(BibTeX!TitledEntry) = BibTeX!TitledEntry.allInstances()->select(e | e.author.oclIsUndefined() = false)->asSet();

helper def : articleSet : Set(BibTeX!Article) = BibTeX!Article.allInstances()->select(a | a.author.oclIsUndefined() = false)->asSet();

helper context BibTeX!Entry def : buildEntryPara() : String =
	if self.oclIsTypeOf(BibTeX!TitledEntry) then
		if self.title.oclIsUndefined() then
			self.author.name + '. ' + self.note
		else
			self.author.name + '. ' + self.title + '. ' + self.note
		endif
	else
		if self.oclIsTypeOf(BibTeX!Article) then
			if self.title.oclIsUndefined() then
				if self.journal.oclIsUndefined() then
					self.author.name + '. ' + self.note
				else
					self.author.name + '. ' + self.journal + '. ' + self.note
				endif
			else
				if self.journal.oclIsUndefined() then
					self.author.name + '. ' + self.title + '. ' + self.note
				else
					self.author.name + '. ' + self.title + '. ' + self.journal + '. ' + self.note
				endif
			endif
		else
			self.author.name + '. ' + self.note
		endif
	endif;

rule Main {
	from
		lib : BibTeX!Library
	to
		book : DocBook!Book (
			info <- info,
			chapters <- articles
		),
		info : DocBook!BookInfo (
			title <- 'BibTeX Bibliography'
		),
		articles : DocBook!Article (
			infos <- articleinfo,
			sections <- Sequence{authorsection, titledsection}
		),
		articleinfo : DocBook!ArticleInfo (
			title <- 'Bibliography'
		),
		authorsection : DocBook!Sect1 (
			infos <- authorinfo,
			paras <- thisModule.authorSet->collect(a | thisModule.resolveTemp(a, 'para'))
		),
		authorinfo : DocBook!Sect1Info (
			title <- 'Authors'
		),
		titledsection : DocBook!Sect1 (
			infos <- titledinfo,
			sections <- thisModule.titledEntrySet->collect(e | thisModule.resolveTemp(e, 'section'))
		),
		titledinfo : DocBook!Sect1Info (
			title <- 'Bibliography'
		)
}

rule Author {
	from
		author : BibTeX!Author
	to
		para : DocBook!Para (
			content <- author.name + ' (' + author.books->size().toString() + ' entries)'
		)
}

rule UntitledEntry {
	from
		entry : BibTeX!Entry (not entry.oclIsTypeOf(BibTeX!TitledEntry) and not entry.oclIsTypeOf(BibTeX!Article))
	to
		para : DocBook!Para (
			content <- entry.buildEntryPara()
		)
}

rule TitledEntry_Title_NoArticle {
	from
		entry : BibTeX!TitledEntry (entry.title.oclIsUndefined() = false and not entry.oclIsTypeOf(BibTeX!Article))
	to
		section : DocBook!Sect2 (
			infos <- info,
			paras <- Sequence{para}
		),
		info : DocBook!Sect2Info (
			title <- entry.title
		),
		para : DocBook!Para (
			content <- entry.buildEntryPara()
		)
}

rule TitledEntry_NoTitle_NoArticle {
	from
		entry : BibTeX!TitledEntry (entry.title.oclIsUndefined() = true and not entry.oclIsTypeOf(BibTeX!Article))
	to
		section : DocBook!Sect2 (
			infos <- info,
			paras <- Sequence{para}
		),
		info : DocBook!Sect2Info (
			title <- 'Untitled Entry'
		),
		para : DocBook!Para (
			content <- entry.buildEntryPara()
		)
}

rule Article_Title_Journal {
	from
		article : BibTeX!Article (article.title.oclIsUndefined() = false and article.journal.oclIsUndefined() = false)
	to
		section : DocBook!Sect2 (
			infos <- info,
			sections <- Sequence{journalsection}
		),
		info : DocBook!Sect2Info (
			title <- article.title
		),
		journalsection : DocBook!Sect3 (
			infos <- journalinfo,
			paras <- Sequence{para}
		),
		journalinfo : DocBook!Sect3Info (
			title <- article.journal
		),
		para : DocBook!Para (
			content <- article.buildEntryPara()
		)
}

rule Article_NoTitle_Journal {
	from
		article : BibTeX!Article (article.title.oclIsUndefined() = true and article.journal.oclIsUndefined() = false)
	to
		section : DocBook!Sect2 (
			infos <- info,
			sections <- Sequence{journalsection}
		),
		info : DocBook!Sect2Info (
			title <- 'Untitled Article'
		),
		journalsection : DocBook!Sect3 (
			infos <- journalinfo,
			paras <- Sequence{para}
		),
		journalinfo : DocBook!Sect3Info (
			title <- article.journal
		),
		para : DocBook!Para (
			content <- article.buildEntryPara()
		)
}

rule Article_Title_NoJournal {
	from
		article : BibTeX!Article (article.title.oclIsUndefined() = false and article.journal.oclIsUndefined() = true)
	to
		section : DocBook!Sect2 (
			infos <- info,
			paras <- Sequence{para}
		),
		info : DocBook!Sect2Info (
			title <- article.title
		),
		para : DocBook!Para (
			content <- article.buildEntryPara()
		)
}

rule Article_NoTitle_NoJournal {
	from
		article : BibTeX!Article (article.title.oclIsUndefined() = true and article.journal.oclIsUndefined() = true)
	to
		section : DocBook!Sect2 (
			infos <- info,
			paras <- Sequence{para}
		),
		info : DocBook!Sect2Info (
			title <- 'Untitled Article'
		),
		para : DocBook!Para (
			content <- article.buildEntryPara()
		)
}