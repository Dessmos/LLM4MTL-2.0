module XML2DSL;
create OUT : DSL from IN : XML;

helper def: getAttrBool(element : XML!Element, name : String) : Boolean =
	if element.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->notEmpty()
	then element.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->first().value = 'true'
	else false
	endif;

helper def: getAttrVal(element : XML!Element, name : String) : String =
	if element.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->notEmpty()
	then element.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->first().value
	else ''
	endif;

helper def: get(element : XML!Element, name : String) : XML!Element =
	element.children->select(c | c.oclIsKindOf(XML!Element) and c.name = name)->first();

helper def: getType(element : XML!Element) : String =
	thisModule.getAttrVal(element, 'type');

helper def: getEnumId(element : XML!Element) : String =
	thisModule.getAttrVal(element, 'enumId');

helper def: getText(element : XML!Element) : String =
	if element.children->select(c | c.oclIsKindOf(XML!Text))->notEmpty()
	then element.children->select(c | c.oclIsKindOf(XML!Text))->first().value
	else ''
	endif;

helper def: getSeq(element : XML!Element, name : String) : Sequence(XML!Element) =
	element.children->select(c | c.oclIsKindOf(XML!Element) and c.name = name);

helper def: hasChildren(element : XML!Element) : Boolean =
	element.children->select(c | c.oclIsKindOf(XML!Element))->notEmpty();

helper def: hasAttr(element : XML!Element, name : String) : Boolean =
	element.children->select(c | c.oclIsKindOf(XML!Attribute) and c.name = name)->notEmpty();

helper def: isAbstract(element : XML!Element) : Boolean =
	thisModule.getAttrBool(element, 'abstract');

helper def: dslElementsById : Map(String, DSL!Classifier) =
	Map{};

helper def: getContainment(element : XML!Element) : Boolean =
	thisModule.getAttrBool(element, 'containment');

helper def: getSubTypes(element : XML!Element) : Sequence(XML!Element) =
	thisModule.getSeq(element, 'subtype');

helper def: findType(typeName : String) : DSL!Type =
	if typeName = 'String' then thisModule.createStringType()
	else if typeName = 'Integer' then thisModule.createIntegerType()
	else if typeName = 'Boolean' then thisModule.createBooleanType()
	else if typeName = 'Double' then thisModule.createDoubleType()
	else OclUndefined
	endif endif endif endif;

helper def: createStringType() : DSL!SimpleType =
	DSL!SimpleType.allInstancesFrom('OUT')->select(t | t.name = 'String')->first();

helper def: createIntegerType() : DSL!SimpleType =
	DSL!SimpleType.allInstancesFrom('OUT')->select(t | t.name = 'Integer')->first();

helper def: createBooleanType() : DSL!SimpleType =
	DSL!SimpleType.allInstancesFrom('OUT')->select(t | t.name = 'Boolean')->first();

helper def: createDoubleType() : DSL!SimpleType =
	DSL!SimpleType.allInstancesFrom('OUT')->select(t | t.name = 'Double')->first();

rule DomainModel {
	from
		e : XML!Element (e.name = 'domainModel')
	to
		dm : DSL!DomainModel (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			namespace <- thisModule.getAttrVal(e, 'namespace'),
			isLoaded <- true,
			classifiers <- thisModule.getSeq(e, 'class')->union(thisModule.getSeq(e, 'relationship')),
			types <- Sequence{thisModule.createStringType(), thisModule.createIntegerType(), thisModule.createBooleanType(), thisModule.createDoubleType()}->union(thisModule.getSeq(e, 'enumeration'))
		)
}

rule Class {
	from
		e : XML!Element (e.name = 'class')
	to
		c : DSL!Class (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			namespace <- thisModule.getAttrVal(e, 'namespace'),
			isLoaded <- true,
			isAbstract <- thisModule.isAbstract(e),
			properties <- thisModule.getSeq(e, 'property')
		)
}

rule Relationship {
	from
		e : XML!Element (e.name = 'relationship')
	to
		r : DSL!Relationship (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			namespace <- thisModule.getAttrVal(e, 'namespace'),
			isLoaded <- true,
			isAbstract <- thisModule.isAbstract(e),
			isEmbedding <- thisModule.getAttrBool(e, 'embedding'),
			roles <- thisModule.getSeq(e, 'role'),
			properties <- thisModule.getSeq(e, 'property')
		)
}

rule Role {
	from
		e : XML!Element (e.name = 'role')
	to
		r : DSL!Role (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			min <- thisModule.getAttrVal(e, 'min').toInteger(),
			max <- thisModule.getAttrVal(e, 'max').toInteger(),
			isUnbounded <- thisModule.getAttrBool(e, 'unbounded'),
			accepts <- thisModule.getAttrVal(e, 'accepts'),
			isOrdered <- thisModule.getAttrBool(e, 'ordered'),
			isNavigableFrom <- thisModule.getAttrBool(e, 'navigableFrom'),
			isPropertyGenerator <- thisModule.getAttrBool(e, 'propertyGenerator')
		)
}

rule ValueProperty {
	from
		e : XML!Element (e.name = 'property')
	to
		p : DSL!ValueProperty (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			type <- thisModule.findType(thisModule.getType(e))
		)
}

rule Enumeration {
	from
		e : XML!Element (e.name = 'enumeration')
	to
		enum : DSL!Enumeration (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			namespace <- thisModule.getAttrVal(e, 'namespace'),
			literals <- thisModule.getSeq(e, 'literal')
		)
}

rule EnumerationLiteral {
	from
		e : XML!Element (e.name = 'literal')
	to
		lit : DSL!EnumerationLiteral (
			name <- thisModule.getAttrVal(e, 'name'),
			identity <- thisModule.getAttrVal(e, 'id'),
			value <- thisModule.getAt