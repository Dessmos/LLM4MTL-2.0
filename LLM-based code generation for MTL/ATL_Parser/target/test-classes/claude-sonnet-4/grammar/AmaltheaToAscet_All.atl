module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper def : collectTasks(container : Amalthea!ComponentContainer) : Sequence(Amalthea!Task) =
	container.tasks;

rule ComponentContainer2AscetModule {
	from
		cc : Amalthea!ComponentContainer
	to
		am : Ascet!AscetModule (
			name <- cc.name,
			tasks <- thisModule.collectTasks(cc)->collect(t | 
				thisModule.Task2SoftwareTask(t))
		)
}

rule TaskRoot2SoftwareTask {
	from
		t : Amalthea!Task (
			t.container.oclIsUndefined()
		)
	to
		st : Ascet!SoftwareTask (
			name <- t.name
		)
}

rule Task2SoftwareTask {
	from
		t : Amalthea!Task
	to
		st : Ascet!SoftwareTask (
			name <- t.name
		)
}