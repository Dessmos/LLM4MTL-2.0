module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		makefile : Make!Makefile
	to
		project : Ant!Project (
			name <- makefile.name,
			properties <- makefile.macros,
			targets <- makefile.rules,
			defaultTarget <- makefile.default
		)
}

rule Macro2Property {
	from
		macro : Make!Macro
	to
		property : Ant!PropertyValue (
			name <- macro.name,
			value <- macro.value
		)
}

rule Rule2Target {
	from
		rule : Make!Rule
	to
		target : Ant!Target (
			name <- rule.name,
			tasks <- rule.shellLines,
			dependencies <- rule.dependencies
		)
}

rule ShellLine2Task_Display {
	from
		shellLine : Make!ShellLine (shellLine.display = true)
	to
		task : Ant!Echo (
			message <- shellLine.command
		)
}

rule ShellLine2Task_NoDisplay {
	from
		shellLine : Make!ShellLine (shellLine.display = false)
	to
		task : Ant!Exec (
			executable <- shellLine.command
		)
}