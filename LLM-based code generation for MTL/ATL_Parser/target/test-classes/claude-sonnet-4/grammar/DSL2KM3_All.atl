module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass : Boolean =
    not self.isEmbedding;

helper context DSL!Relationship def: getRoles() : Sequence(DSL!Role) =
    self.roles->asSequence();

helper context DSL!Relationship def: isEmbedding : Boolean =
    self.isEmbedding;

rule Metamodel {
    from
        s : DSL!DomainModel
    to
        t : KM3!Metamodel (
            name <- s.name,
            contents <- s.classifiers->select(c | c.oclIsTypeOf(DSL!Class))
                ->union(s.classifiers->select(c | c.oclIsTypeOf(DSL!Relationship) and c.needTurnOnClass))
                ->union(s.types),
            package <- Sequence{}
        )
}

rule Class {
    from
        s : DSL!Class
    to
        t : KM3!Class (
            name <- s.name,
            isAbstract <- s.isAbstract,
            supertypes <- if s.superType.oclIsUndefined() then Sequence{} else Sequence{s.superType} endif,
            structuralFeatures <- s.properties
        )
}

rule Relation2Class {
    from
        s : DSL!Relationship (s.needTurnOnClass)
    to
        t : KM3!Class (
            name <- s.name,
            isAbstract <- s.isAbstract,
            supertypes <- if s.superType.oclIsUndefined() then Sequence{} else Sequence{s.superType} endif,
            structuralFeatures <- s.properties->union(s.getRoles()->collect(r | thisModule.Role2Reference(r)))
        )
}

lazy rule Role2Reference {
    from
        s : DSL!Role
    to
        t : KM3!Reference (
            name <- s.name,
            type <- s.type,
            lower <- s.min,
            upper <- if s.isUnbounded then -1 else s.max endif,
            isOrdered <- s.isOrdered
        )
}

rule SimpleReference {
    from
        s : DSL!Role (s.relation.isEmbedding and s.isPropertyGenerator)
    to
        t : KM3!Reference (
            name <- s.name,
            type <- s.type,
            lower <- s.min,
            upper <- if s.isUnbounded then -1 else s.max endif,
            isOrdered <- s.isOrdered,
            isContainer <- false
        )
}

rule ComplexReference {
    from
        s : DSL!Role (s.relation.isEmbedding and s.isPropertyGenerator and s.accepts = 'contained')
    to
        t : KM3!Reference (
            name <- s.name,
            type <- s.type,
            lower <- s.min,
            upper <- if s.isUnbounded then -1 else s.max endif,
            isOrdered <- s.isOrdered,
            isContainer <- true
        )
}

rule Attribute {
    from
        s : DSL!ValueProperty
    to
        t : KM3!Attribute (
            name <- s.name,
            type <- s.type,
            lower <- 0,
            upper <- 1
        )
}

rule Enumeration {
    from
        s : DSL!Enumeration
    to
        t : KM3!Enumeration (
            name <- s.name,
            literals <- s.literals
        )
}

rule EnumLiteral {
    from
        s : DSL!EnumerationLiteral
    to
        t : KM3!EnumLiteral (
            name <- s.name
        )
}

rule DataType {
    from
        s : DSL!SimpleType
    to
        t : KM3!DataType (
            name <- s.name
        )
}