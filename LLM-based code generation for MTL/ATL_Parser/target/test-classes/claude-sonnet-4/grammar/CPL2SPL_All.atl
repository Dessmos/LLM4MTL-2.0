module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Node def: statement : SPL!StatementNode =
    SPL!ReturnStatement.allInstances()->select(s | s.oclIsUndefined())->first();

helper context CPL!Node def: locations : Sequence(CPL!Location) =
    Sequence{};

helper context CPL!Proxy def: isSimple : Boolean =
    self.timeout.oclIsUndefined() and self.busy.oclIsUndefined() and self.noAnswer.oclIsUndefined() and self.redirection.oclIsUndefined() and self.default.oclIsUndefined();

rule CPL2Program {
    from
        c : CPL!CPL
    to
        p : SPL!Program (
            name <- c.name,
            functions <- c.subActions
        )
}

rule SubAction2Function {
    from
        s : CPL!SubAction
    to
        f : SPL!Function (
            name <- s.id,
            body <- s.nodes->first().statement
        )
}

rule Incoming2Method {
    from
        i : CPL!Incoming
    to
        m : SPL!Method (
            name <- 'incoming',
            body <- i.subCall.statement
        )
}

rule Proxy2Return {
    from
        p : CPL!Proxy (p.isSimple)
    to
        r : SPL!ReturnStatement (
            value <- p.locations->collect(l | thisModule.Location2URIConstant(l))
        )
}

rule Proxy2Select {
    from
        p : CPL!Proxy (not p.isSimple)
    to
        s : SPL!SelectStatement (
            cases <- p.busy.union(p.noAnswer).union(p.redirection),
            default <- p.default
        )
}

rule Busy2SelectCase {
    from
        b : CPL!Busy
    to
        c : SPL!SelectCase (
            condition <- SPL!StringConstant { value <- 'busy' },
            body <- b.statement
        )
}

rule NoAnswer2SelectCase {
    from
        n : CPL!NoAnswer
    to
        c : SPL!SelectCase (
            condition <- SPL!StringConstant { value <- 'noanswer' },
            body <- n.statement
        )
}

rule Redirection2SelectCase {
    from
        r : CPL!Redirection
    to
        c : SPL!SelectCase (
            condition <- SPL!StringConstant { value <- 'redirection' },
            body <- r.statement
        )
}

rule Default2SelectDefault {
    from
        d : CPL!Default
    to
        sd : SPL!SelectDefault (
            body <- d.statement
        )
}

rule SubCall2Return {
    from
        s : CPL!SubCall
    to
        r : SPL!ReturnStatement (
            value <- SPL!FunctionCall { name <- s.ref.id }
        )
}

rule Redirect2Return {
    from
        r : CPL!Redirect
    to
        ret : SPL!ReturnStatement (
            value <- r.locations->collect(l | thisModule.Location2URIConstant(l))
        )
}

rule AddressSwitch2SelectStat {
    from
        a : CPL!AddressSwitch
    to
        s : SPL!SelectStatement (
            cases <- a.addresses,
            default <- a.otherwise
        )
}

rule SwitchedAddress2SelectCase {
    from
        s : CPL!SwitchedAddress
    to
        c : SPL!SelectCase (
            condition <- SPL!StringConstant { value <- s.is },
            body <- s.statement
        )
}

rule Otherwise2SelectDefault {
    from
        o : CPL!Otherwise
    to
        sd : SPL!SelectDefault (
            body <- o.statement
        )
}

rule Location2URIConstant(l : CPL!Location) {
    to
        u : SPL!URIConstant (
            value <- l.url
        )
    do {
        u;
    }
}