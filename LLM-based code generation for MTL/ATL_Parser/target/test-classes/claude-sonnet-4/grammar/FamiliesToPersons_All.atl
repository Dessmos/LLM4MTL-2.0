module FamiliesToPersons_All;
create OUT : Persons from IN : Families;

helper context Families!Member def: familyLastName() : String =
    if self.oclIsKindOf(Families!Father) then
        self.familyName
    else if self.oclIsKindOf(Families!Mother) then
        self.familyMother.familyName
    else if self.oclIsKindOf(Families!Son) then
        self.familySon.familyName
    else if self.oclIsKindOf(Families!Daughter) then
        self.familyDaughter.familyName
    else
        ''
    endif endif endif endif;

helper context Families!Member def: isFemale() : Boolean =
    self.oclIsKindOf(Families!Mother) or self.oclIsKindOf(Families!Daughter);

helper context Families!Member def: isMale() : Boolean =
    self.oclIsKindOf(Families!Father) or self.oclIsKindOf(Families!Son);

rule Member2Male {
    from
        m : Families!Member (m.isMale())
    to
        male : Persons!Male (
            fullName <- m.firstName + ' ' + m.familyLastName()
        )
}

rule Member2Female {
    from
        m : Families!Member (m.isFemale())
    to
        female : Persons!Female (
            fullName <- m.firstName + ' ' + m.familyLastName()
        )
}