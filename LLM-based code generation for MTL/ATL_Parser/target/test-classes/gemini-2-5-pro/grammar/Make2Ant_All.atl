module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		m : Make!Makefile
	to
		p : Ant!Project (
			name <- m.name,
			properties <- m.properties,
			targets <- m.elements,
			defaultTarget <- m.defaultTarget
		)
}

rule Macro2Property {
	from
		ma : Make!Macro
	to
		pv : Ant!PropertyValue (
			name <- ma.name,
			value <- ma.value
		)
}

rule Rule2Target {
	from
		r : Make!Rule
	to
		t : Ant!Target (
			name <- r.name,
			tasks <- r.shellLines,
			dependencies <- r.dependencies
		)
}

rule ShellLine2Task_Display {
	from
		sl : Make!ShellLine (
			sl.display
		)
	to
		e : Ant!Echo (
			message <- sl.command
		)
}

rule ShellLine2Task_NoDisplay {
	from
		sl : Make!ShellLine (
			not sl.display
		)
	to
		ex : Ant!Exec (
			executable <- sl.command
		)
}