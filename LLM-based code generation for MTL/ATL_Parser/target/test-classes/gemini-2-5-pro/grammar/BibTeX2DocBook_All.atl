module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context BibTeX!BibTeXFile def: authorSet : Set(BibTeX!Author) =
	self.entries->select(e | e.oclIsTypeOf(BibTeX!Author))->asSet();

helper context BibTeX!BibTeXFile def: titledEntrySet : Set(BibTeX!TitledEntry) =
	self.entries->select(e | e.oclIsKindOf(BibTeX!TitledEntry) and not e.oclIsTypeOf(BibTeX!Article))->asSet();

helper context BibTeX!BibTeXFile def: articleSet : Set(BibTeX!Article) =
	self.entries->select(e | e.oclIsTypeOf(BibTeX!Article))->asSet();

helper context BibTeX!Entry def: buildEntryPara() : String =
	'Id: ' + self.id +
	(if not self.author.oclIsUndefined() and self.author <> '' then '. Author: ' + self.author else '') +
	(if self.oclIsKindOf(BibTeX!TitledEntry) and not self.title.oclIsUndefined() and self.title <> '' then '. Title: ' + self.title else '') +
	(if self.oclIsKindOf(BibTeX!Article) and not self.journal.oclIsUndefined() and self.journal <> '' then '. Journal: ' + self.journal else '');

rule Main {
	from f : BibTeX!BibTeXFile
	to
		db : DocBook!DocBook (
			books <- book
		),
		book : DocBook!Book (
			title <- bookTitle,
			articles <- Sequence{authorsArticle, titledEntriesArticle, articlesArticle}
		),
		bookTitle : DocBook!Title (
			content <- 'Bibliography'
		),
		authorsArticle : DocBook!Article (
			title <- authorsTitle,
			sections <- f.authorSet
		),
		authorsTitle : DocBook!Title (
			content <- 'Authors'
		),
		titledEntriesArticle : DocBook!Article (
			title <- titledEntriesTitle,
			sections <- f.titledEntrySet
		),
		titledEntriesTitle : DocBook!Title (
			content <- 'Titled Entries'
		),
		articlesArticle : DocBook!Article (
			title <- articlesTitle,
			sections <- f.articleSet
		),
		articlesTitle : DocBook!Title (
			content <- 'Articles'
		)
}

rule Author {
	from a : BibTeX!Author
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- a.author
		),
		p : DocBook!Para (
			content <- a.buildEntryPara()
		)
}

rule UntitledEntry {
	from e : BibTeX!Entry (not e.oclIsKindOf(BibTeX!TitledEntry))
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- e.id
		),
		p : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule TitledEntry_Title_NoArticle {
	from e : BibTeX!TitledEntry (not e.oclIsTypeOf(BibTeX!Article) and not e.title.oclIsUndefined() and e.title <> '')
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- e.title
		),
		p : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule TitledEntry_NoTitle_NoArticle {
	from e : BibTeX!TitledEntry (not e.oclIsTypeOf(BibTeX!Article) and (e.title.oclIsUndefined() or e.title = ''))
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- e.id
		),
		p : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule Article_Title_Journal {
	from a : BibTeX!Article (not a.title.oclIsUndefined() and a.title <> '' and not a.journal.oclIsUndefined() and a.journal <> '')
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- a.title
		),
		p : DocBook!Para (
			content <- a.buildEntryPara()
		)
}

rule Article_NoTitle_Journal {
	from a : BibTeX!Article ((a.title.oclIsUndefined() or a.title = '') and not a.journal.oclIsUndefined() and a.journal <> '')
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- 'In journal: ' + a.journal
		),
		p : DocBook!Para (
			content <- a.buildEntryPara()
		)
}

rule Article_Title_NoJournal {
	from a : BibTeX!Article (not a.title.oclIsUndefined() and a.title <> '' and (a.journal.oclIsUndefined() or a.journal = ''))
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- a.title
		),
		p : DocBook!Para (
			content <- a.buildEntryPara()
		)
}

rule Article_NoTitle_NoJournal {
	from a : BibTeX!Article ((a.title.oclIsUndefined() or a.title = '') and (a.journal.oclIsUndefined() or a.journal = ''))
	to
		s : DocBook!Section (
			title <- t,
			paras <- p
		),
		t : DocBook!Title (
			content <- a.id
		),
		p : DocBook!Para (
			content <- a.buildEntryPara()
		)
}