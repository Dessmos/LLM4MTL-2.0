```atl
module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper context Amalthea!ComponentContainer def:
	getAllContainedTasks() : Sequence(Amalthea!Task) = self.tasks;

rule ComponentContainer2AscetModule {
	from
		s : Amalthea!ComponentContainer
	to
		t : Ascet!AscetModule (
			tasks <- s.getAllContainedTasks()
		)
}

rule TaskRoot2SoftwareTask {
	from
		s : Amalthea!Task (
			s.container.oclIsUndefined()
		)
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}

rule Task2SoftwareTask {
	from
		s : Amalthea!Task
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}
```