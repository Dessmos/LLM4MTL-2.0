module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Node def: getRoot() : XML!Root =
	if self.parent.oclIsUndefined() then self else self.parent.getRoot() endif;

helper context XML!Element def: getAttrBool(attrName : String) : Boolean =
	if self.hasAttr(attrName) then self.getAttrVal(attrName) = 'true' else false endif;

helper context XML!Element def: getAttrVal(attrName : String) : String =
	self.children->select(e | e.oclIsTypeOf(XML!Attribute) and e.name = attrName)->first().value;

helper context XML!Element def: get(childName : String) : XML!Element =
	self.children->select(e | e.oclIsTypeOf(XML!Element) and e.name = childName)->first();

helper context XML!Element def: getType() : String = self.getAttrVal('accepts');

helper context XML!Element def: getEnumId(name : String) : String =
	self.getRoot().getAttrVal('name') + '.' + name;

helper context XML!Element def: getText() : String =
	let textNode : XML!Text = self.children->select(e | e.oclIsTypeOf(XML!Text))->first() in
	if textNode.oclIsUndefined() then '' else textNode.value endif;

helper context XML!Element def: getSeq(childName : String) : Sequence(XML!Element) =
	self.children->select(e | e.oclIsTypeOf(XML!Element) and e.name = childName);

helper context XML!Element def: hasChildren() : Boolean =
	self.children->exists(e | e.oclIsTypeOf(XML!Element));

helper context XML!Element def: hasAttr(attrName : String) : Boolean =
	self.children->exists(e | e.oclIsTypeOf(XML!Attribute) and e.name = attrName);

helper context XML!Element def: isAbstract() : Boolean =
	if self.hasAttr('isAbstract') then self.getAttrVal('isAbstract') = 'true' else false endif;

helper def: dslElementsById() : Map(String, DSL!NamedElement) =
	DSL!NamedElement.allInstances()->iterate(e; acc : Map(String, DSL!NamedElement) = Map{} |
		acc->including(e.identity, e)
	);

helper context XML!Element def: getContainment() : Boolean = self.getAttrBool('isEmbedding');

helper context XML!Root def: getSubTypes(c : XML!Element) : Sequence(XML!Element) =
	XML!Element.allInstances()->select(e |
		(e.name = 'Class' or e.name = 'Relationship') and
		e.hasChildren() and not e.get('superType').oclIsUndefined() and
		e.get('superType').getText() = c.getAttrVal('name')
	);

helper context XML!Element def: findType(typeName : String) : DSL!Type =
	let simpleType : DSL!SimpleType = DSL!SimpleType.allInstances()->select(t | t.name = typeName)->first() in
	if not simpleType.oclIsUndefined() then
		simpleType
	else
		let enumId = self.getRoot().getAttrVal('name') + '.' + typeName in
		let enumType : DSL!Enumeration = DSL!Enumeration.allInstances()->select(e | e.identity = enumId)->first() in
		enumType
	endif;

helper context XML!Element def: getIdentity() : String =
	self.getRoot().getAttrVal('name') + '.' + self.getAttrVal('name');

rule DomainModel {
	from
		s : XML!Root (s.name = 'DomainModel')
	to
		t : DSL!DomainModel (
			name <- s.getAttrVal('name'),
			identity <- s.getAttrVal('name'),
			namespace <- '',
			isLoaded <- true,
			classifiers <- s.getSeq('Class')->union(s.getSeq('Relationship')),
			types <- s.getSeq('Enumeration')->union(Sequence{str, int, bool, dbl})
		),
		str : DSL!SimpleType ( name <- 'String', identity <- 'String', namespace <- 'PrimitiveTypes' ),
		int : DSL!SimpleType ( name <- 'Integer', identity <- 'Integer', namespace <- 'PrimitiveTypes' ),
		bool : DSL!SimpleType ( name <- 'Boolean', identity <- 'Boolean', namespace <- 'PrimitiveTypes' ),
		dbl : DSL!SimpleType ( name <- 'Double', identity <- 'Double', namespace <- 'PrimitiveTypes' )
}

rule Class {
	from
		s : XML!Element (s.name = 'Class')
	to
		t : DSL!Class (
			name <- s.getAttrVal('name'),
			identity <- s.getIdentity(),
			namespace <- s.getRoot().getAttrVal('name'),
			isLoaded <- true,
			isAbstract <- s.isAbstract(),
			properties <- s.getSeq('ValueProperty'),
			superType <- if s.hasChildren() and not s.get('superType').oclIsUndefined() then
				thisModule.dslElementsById()->get(s.getRoot().getAttrVal('name') + '.' + s.get('superType').getText())
			else
				OclUndefined
			endif,
			subTypes <- s.getRoot().getSubTypes(s)
		)
}

rule Relationship {
	from
		s : XML!Element (s.name = 'Relationship')
	to
		t : DSL!Relationship (
			name <- s.getAttrVal('name'),
			identity <- s.getIdentity(),
			namespace <- s.getRoot().getAttrVal('name'),
			isLoaded <- true,
			isAbstract <- s.isAbstract(),
			isEmbedding <- s.getContainment(),
			properties <- s.getSeq('ValueProperty'),
			roles <- s.getSeq('Role'),
			superType <- if s.hasChildren() and not s.get('superType').oclIsUndefined() then
				thisModule.dslElementsById()->get(s.getRoot().getAttrVal('name') + '.' + s.get('superType').getText())
			else
				OclUndefined
			endif,
			subTypes <- s.getRoot().getSubTypes(s)
		)
}

rule Role {
	from
		s : XML!Element (s.name = 'Role')
	to
		t : DSL!Role (
			name <- s.getAttrVal('name'),
			identity <- s.parent.getIdentity() + '.' + s.getAttrVal('name'),
			min <- s.getAttrVal('min').toInteger(),
			max <- if s.getAttrVal('max') = '*' then -1 else s.getAttrVal('max').toInteger() endif,
			isUnbounded <- s.getAttrVal('max') = '*',
			accepts <- s.getType(),
			isOrdered <- s.getAttrBool('isOrdered'),
			isNavigableFrom <- s.getAttrBool('isNavigableFrom'),
			isPropertyGenerator <- s.getAttrBool('isPropertyGenerator'),
			source <- thisModule.dslElementsById()->get(s.getRoot().getAttrVal('name') + '.' + s.getAttrVal('source')),
			type <- thisModule.dslElementsById()->get(s.getRoot().getAttrVal('name') + '.' + s.getType())
		)
}

rule ValueProperty {
	from
		s : XML!Element (s.name = 'ValueProperty')
	to
		t : DSL!ValueProperty (
			name <- s.getAttrVal('name'),
			identity <- s.parent.getIdentity() + '.' + s.getAttrVal('name'),
			type <- s.findType(s.get('type').getText())
		)
}

rule Enumeration {
	from
		s : XML!Element (s.name = 'Enumeration')
	to
		t : DSL!Enumeration (
			name <- s.getAttrVal('name'),
			identity <- s.getEnumId(s.getAttrVal('name')),
			namespace <- s.getRoot().getAttrVal('name'),
			literals <- s.getSeq('EnumerationLiteral')
		)
}

rule EnumerationLiteral {
	from
		s : XML!Element (s.name = 'EnumerationLiteral')
	to
		t : DSL!EnumerationLiteral (
			name <- s.getAttrVal('name'),
			identity <- s.parent.getEnumId(s.parent.getAttrVal('name')) + '.' + s.getAttrVal('name'),
			value <- s.getAttrVal('value').toInteger()
		)
}