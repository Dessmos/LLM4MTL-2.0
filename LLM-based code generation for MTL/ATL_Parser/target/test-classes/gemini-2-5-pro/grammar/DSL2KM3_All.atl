module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	not self.properties->isEmpty() or not self.superType.oclIsUndefined();

helper context DSL!Relationship def: getRoles() : Sequence(DSL!Role) =
	self.roles;

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding;

rule Metamodel {
	from s : DSL!DomainModel
	to t : KM3!Metamodel,
	   p : KM3!Package (
	   		name <- s.name,
	   		metamodel <- t,
	   		contents <- s.classifiers->union(s.types)
	   )
}

rule Class {
	from s : DSL!Class
	to t : KM3!Class (
		name <- s.name,
		package <- s.domainModel,
		isAbstract <- s.isAbstract,
		supertypes <- s.superType,
		structuralFeatures <- s.properties
	)
}

rule Relation2Class {
	from s : DSL!Relationship (s.needTurnOnClass())
	to t : KM3!Class (
		name <- s.name,
		package <- s.domainModel,
		isAbstract <- s.isAbstract,
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(s.roles)
	)
}

rule SimpleReference {
	from s : DSL!Role (not s.relation.needTurnOnClass() and s.relation.roles->first() = s)
	using {
		oppositeRole : DSL!Role = s.relation.roles->last();
	}
	to t : KM3!Reference (
		name <- s.name,
		owner <- oppositeRole.source,
		type <- s.type,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isContainer <- false,
		opposite <- t_opposite
	),
	t_opposite : KM3!Reference (
		name <- oppositeRole.name,
		owner <- s.source,
		type <- oppositeRole.type,
		lower <- oppositeRole.min,
		upper <- if oppositeRole.isUnbounded then -1 else oppositeRole.max endif,
		isContainer <- s.relation.isEmbedding,
		opposite <- t
	)
}

lazy rule ComplexReference {
	from s : DSL!Role
	to t : KM3!Reference (
		name <- s.name,
		type <- s.type,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isContainer <- false
	)
}

lazy rule Attribute {
	from s : DSL!ValueProperty
	to t : KM3!Attribute (
		name <- s.name,
		owner <- s.owner,
		type <- s.type,
		lower <- 1,
		upper <- 1
	)
}

rule Enumeration {
	from s : DSL!Enumeration
	to t : KM3!Enumeration (
		name <- s.name,
		package <- s.eContainer(),
		literals <- s.literals
	)
}

lazy rule EnumLiteral {
	from s : DSL!EnumerationLiteral
	to t : KM3!EnumLiteral (
		name <- s.name,
		enumeration <- s.eContainer()
	)
}

rule DataType {
	from s : DSL!SimpleType
	to t : KM3!DataType (
		name <- s.name,
		package <- s.eContainer()
	)
}