module CPL2SPL;
create OUT : SPL from IN : CPL;

helper def: statement(): SPL!Statement = thisModule.DefaultMethodCall();
helper def: locations(locs: Sequence(CPL!Location)): Sequence(SPL!Expression) =
    locs->collect(e | thisModule.Location2URIConstant(e));
helper def: isSimple(p: CPL!Proxy): Boolean =
    p.busy.oclIsUndefined() and p.noanswer.oclIsUndefined() and p.redirection->isEmpty();

-- Helper Rules
called rule Location2URIConstant(s: CPL!Location) {
    to t: SPL!URIConstant (
        value <- s.url
    )
}
called rule DefaultMethodCall {
    to t: SPL!MethodCall (
        function <- thisModule.DefaultFunction('default')
    )
}
called rule MakeMethodCall(f: CPL!SubAction) {
    to t: SPL!MethodCall (
        function <- f
    )
}
called rule EmptyReturn {
    to t: SPL!Return ()
}

lazy rule DefaultFunction {
    from s: String (s = 'default')
    to t: SPL!Function (
        name <- s,
        statement <- thisModule.EmptyReturn()
    )
}

-- Transformation Rules
rule CPL2Program {
    from s: CPL!CPL
    to t: SPL!Program (
        name <- 'cpl_program',
        functions <- s.subActions,
        methods <- s.incoming
    )
}
rule SubAction2Function {
    from s: CPL!SubAction
    to t: SPL!Function (
        name <- s.id,
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule Incoming2Method {
    from s: CPL!Incoming
    to t: SPL!Method (
        name <- if s.source.oclIsUndefined() then 'anonymous' else s.source endif,
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule Proxy2Return {
    from s: CPL!Proxy (thisModule.isSimple(s))
    to t: SPL!Return (
        locations <- thisModule.locations(s.locations)
    )
}
rule Proxy2Select {
    from s: CPL!Proxy (not thisModule.isSimple(s))
    to t: SPL!Select (
        locations <- thisModule.locations(s.locations),
        cases <- Sequence{s.busy, s.noanswer}->reject(e | e.oclIsUndefined())->union(s.redirection),
        default <- s.default
    )
}
rule Busy2SelectCase {
    from s: CPL!Busy
    to t: SPL!SelectCase (
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule NoAnswer2SelectCase {
    from s: CPL!NoAnswer
    to t: SPL!SelectCase (
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule Redirection2SelectCase {
    from s: CPL!Redirection
    to t: SPL!SelectCase (
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule Default2SelectDefault {
    from s: CPL!Default
    to t: SPL!SelectDefault (
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule SubCall2Return {
    from s: CPL!SubCall
    to t: SPL!Return (
        methodCall <- thisModule.MakeMethodCall(s.sub)
    )
}
rule Redirect2Return {
    from s: CPL!Redirect
    to t: SPL!Return (
        locations <- thisModule.locations(s.locations)
    )
}
rule AddressSwitch2SelectStat {
    from s: CPL!AddressSwitch
    to t: SPL!SelectStat (
        switchedVar <- s.field,
        cases <- s.addresses,
        default <- s.otherwise
    )
}
rule SwitchedAddress2SelectCase {
    from s: CPL!SwitchedAddress
    to t: SPL!SelectCase (
        condition <- thisModule.Location2URIConstant(s.address),
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}
rule Otherwise2SelectDefault {
    from s: CPL!Otherwise
    to t: SPL!SelectDefault (
        statement <- if s.action.oclIsUndefined() then thisModule.statement() else s.action endif
    )
}