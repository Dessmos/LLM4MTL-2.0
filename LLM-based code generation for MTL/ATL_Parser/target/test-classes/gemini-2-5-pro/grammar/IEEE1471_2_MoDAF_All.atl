module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper def: rationale(r : IEEE1471!Rationale) : String =
	r.name + ': ' + r.content;

rule IEEE1471Model2MoDAFModel {
	from
		s : IEEE1471!IEEE1471Model
	to
		t : MoDAF!MoDAFModel (
			name <- s.name,
			architectures <- s.architectures,
			stakeholders <- s.stakeholders,
			concerns <- s.concerns,
			architecturalFrameworks <- s.libraryViewpoints->union(Set{af})
		),
		af : MoDAF!ArchitecturalFramework (
			name <- 'Undefined Architectural Framework',
			views <- s.viewpoints
		)
}

rule System2Enterprise {
	from
		s : IEEE1471!System
	to
		t : MoDAF!Enterprise (
			name <- s.name,
			stakeholders <- s.stakeholders,
			environment <- s.environment
		)
}

rule Environment2Environment {
	from
		s : IEEE1471!Environment
	to
		t : MoDAF!Environment (
			name <- s.name
		)
}

rule Mission2OperationalMission {
	from
		s : IEEE1471!Mission
	to
		t : MoDAF!OperationalMission (
			name <- s.name
		)
}

rule Architecture2Architecture {
	from
		s : IEEE1471!Architecture
	to
		t : MoDAF!Architecture (
			name <- s.name,
			description <- if s.rationale->notEmpty() then thisModule.rationale(s.rationale->first()) else '' endif,
			system <- s.system,
			stakeholders <- s.stakeholders,
			views <- s.views,
			viewpoints <- s.viewpoints
		)
}

rule AD2AD {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!AD (
			name <- s.name,
			stakeholders <- s.stakeholders,
			concerns <- s.concerns,
			views <- s.views,
			viewpoints <- s.viewpoints,
			architecture <- s.architecture
		)
}

rule Stakeholder2Stakeholder {
	from
		s : IEEE1471!Stakeholder
	to
		t : MoDAF!Stakeholder (
			name <- s.name
		)
}

rule Viewpoint2View {
	from
		s : IEEE1471!Viewpoint
	to
		t : MoDAF!View (
			name <- s.name,
			addressesConcerns <- s.addresses,
			elements <- s.models
		)
}

rule View2ArchitecturalProduct {
	from
		s : IEEE1471!View
	to
		t : MoDAF!ArchitecturalProduct (
			name <- s.name,
			description <- if s.rationale->notEmpty() then thisModule.rationale(s.rationale->first()) else '' endif,
			conformsTo <- s.conformsTo
		)
}

rule Model2Element {
	from
		s : IEEE1471!Model
	to
		t : MoDAF!Element (
			name <- s.name,
			type <- s.type
		)
}

rule Concern2Concern {
	from
		s : IEEE1471!Concern
	to
		t : MoDAF!Concern (
			name <- s.name
		)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from
		s : IEEE1471!LibraryViewpoint
	to
		t : MoDAF!ArchitecturalFramework (
			name <- s.name,
			views <- s.viewpoints
		)
}

rule StakeholderHasConcern {
	from
		s : IEEE1471!StakeholderHasConcern
	do {
		let targetStakeholder : MoDAF!Stakeholder = s.stakeholder;
		let targetConcern : MoDAF!Concern = s.concern;
		targetStakeholder.concerns <- targetStakeholder.concerns->including(targetConcern);
	}
}