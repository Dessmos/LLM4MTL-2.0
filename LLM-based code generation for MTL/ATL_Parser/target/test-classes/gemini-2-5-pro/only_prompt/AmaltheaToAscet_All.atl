```atl
module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper context Amalthea!ComponentContainer def: getTasks() : Sequence(Amalthea!Task) = self.tasks;

rule ComponentContainer2AscetModule {
	from
		s : Amalthea!ComponentContainer
	to
		t : Ascet!AscetModule (
			softwareTasks <- s.getTasks()
		)
}

rule TaskRoot2SoftwareTask {
	from
		s : Amalthea!Task (
			s.eContainer().oclIsUndefined()
		)
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}

rule Task2SoftwareTask {
	from
		s : Amalthea!Task
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}
```