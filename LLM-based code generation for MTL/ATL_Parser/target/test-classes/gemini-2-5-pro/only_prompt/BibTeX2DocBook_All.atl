module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context BibTeX!BibTeXFile def: authorSet : Set(BibTeX!Author) =
	self.entries->select(e | e.oclIsTypeOf(BibTeX!Author))->asSet();

helper context BibTeX!BibTeXFile def: titledEntrySet : Set(BibTeX!TitledEntry) =
	self.entries->select(e | e.oclIsTypeOf(BibTeX!TitledEntry))->asSet();

helper context BibTeX!BibTeXFile def: articleSet : Set(BibTeX!Article) =
	self.entries->select(e | e.oclIsTypeOf(BibTeX!Article))->asSet();

helper context BibTeX!Entry def: buildEntryPara() : String =
	'(' + self.id + ')';

helper context BibTeX!Author def: buildEntryPara() : String =
	self.author;

helper context BibTeX!TitledEntry def: buildEntryPara() : String =
	'(' + self.id + ') ' + self.author + '. "' + self.title + '".';

helper context BibTeX!Article def: buildEntryPara() : String =
	'(' + self.id + ') ' + self.author + '. "' + self.title + '". In ' + self.journal + '.';

rule Main {
	from s : BibTeX!BibTeXFile
	to t : DocBook!Book (
		title <- 'Bibliography',
		content <- s.entries
	)
}

rule Author {
	from s : BibTeX!Author
	to t : DocBook!Section (
		title <- s.author,
		paras <- Sequence{p}
	),
	p : DocBook!Para (
		content <- s.buildEntryPara()
	)
}

rule UntitledEntry {
	from s : BibTeX!Entry (
		not s.oclIsKindOf(BibTeX!Author) and not s.oclIsKindOf(BibTeX!TitledEntry)
	)
	to t : DocBook!Section (
		title <- 'Reference: ' + s.id,
		paras <- Sequence{p}
	),
	p : DocBook!Para (
		content <- s.buildEntryPara()
	)
}

rule TitledEntry_Title_NoArticle {
	from s : BibTeX!TitledEntry (
		s.oclIsTypeOf(BibTeX!TitledEntry) and s.title <> null and s.title <> ''
	)
	to t : DocBook!Section (
		title <- s.title,
		paras <- Sequence{p}
	),
	p : DocBook!Para (
		content <- s.buildEntryPara()
	)
}

rule TitledEntry_NoTitle_NoArticle {
	from s : BibTeX!TitledEntry (
		s.oclIsTypeOf(BibTeX!TitledEntry) and (s.title = null or s.title = '')
	)
	to t : DocBook!Section (
		title <- 'Reference: ' + s.id,
		paras <- Sequence{p}
	),
	p : DocBook!Para (
		content <- s.buildEntryPara()
	)
}

rule Article_Title_Journal {
	from s : BibTeX!Article (
		(s.title <> null and s.title <> '') and (s.journal <> null and s.journal <> '')
	)
	to t : DocBook!Article (
		title <- s.title,
		sections <- Sequence{details, journal}
	),
	details : DocBook!Section (
		title <- 'Bibliographic Details',
		paras <- Sequence{p1}
	),
	p1 : DocBook!Para (
		content <- s.buildEntryPara()
	),
	journal : DocBook!Section (
		title <- 'Journal Information',
		paras <- Sequence{p2}
	),
	p2 : DocBook!Para (
		content <- s.journal
	)
}

rule Article_NoTitle_Journal {
	from s : BibTeX!Article (
		(s.title = null or s.title = '') and (s.journal <> null and s.journal <> '')
	)
	to t : DocBook!Article (
		title <- 'Article: ' + s.id,
		sections <- Sequence{details, journal}
	),
	details : DocBook!Section (
		title <- 'Bibliographic Details',
		paras <- Sequence{p1}
	),
	p1 : DocBook!Para (
		content <- s.buildEntryPara()
	),
	journal : DocBook!Section (
		title <- 'Journal Information',
		paras <- Sequence{p2}
	),
	p2 : DocBook!Para (
		content <- s.journal
	)
}

rule Article_Title_NoJournal {
	from s : BibTeX!Article (
		(s.title <> null and s.title <> '') and (s.journal = null or s.journal = '')
	)
	to t : DocBook!Article (
		title <- s.title,
		sections <- Sequence{details}
	),
	details : DocBook!Section (
		title <- 'Bibliographic Details',
		paras <- Sequence{p1}
	),
	p1 : DocBook!Para (
		content <- s.buildEntryPara()
	)
}

rule Article_NoTitle_NoJournal {
	from s : BibTeX!Article (
		(s.title = null or s.title = '') and (s.journal = null or s.journal = '')
	)
	to t : DocBook!Article (
		title <- 'Article: ' + s.id,
		sections <- Sequence{details}
	),
	details : DocBook!Section (
		title <- 'Bibliographic Details',
		paras <- Sequence{p1}
	),
	p1 : DocBook!Para (
		content <- s.buildEntryPara()
	)
}