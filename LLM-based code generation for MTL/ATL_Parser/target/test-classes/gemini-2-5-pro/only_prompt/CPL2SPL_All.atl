module CPL2SPL;
create OUT : SPL from IN : CPL;

helper def: Location2URIConstant(location : CPL!Location) : SPL!URIConstant =
	thisModule.resolveTemp(location, 'uriConstant');

lazy rule CreateURIConstantFromLocation {
	from l : CPL!Location
	to uriConstant : SPL!URIConstant (
		uri <- l.url
	)
}

helper context CPL!Node def: statement : SPL!Statement =
	if self.contents.oclIsUndefined() then
		OclUndefined
	else
		if self.contents.oclIsTypeOf(CPL!Location) then
			thisModule.resolveTemp(self.contents, 'ret')
		else
			self.contents
		endif
	endif;

lazy rule Location2ReturnStatement {
	from s : CPL!Location
	to ret : SPL!Return (
		returnedValue <- thisModule.Location2URIConstant(s)
	)
}

helper context CPL!Proxy def: locations : Sequence(CPL!Location) =
	let nodes : Sequence(CPL!Node) = Sequence{self.success, self.busy, self.noanswer, self.redirection, self.default}->reject(e | e.oclIsUndefined()) in
	nodes->collect(n | n.contents)->select(c | c.oclIsTypeOf(CPL!Location))->oclAsType(Sequence(CPL!Location));

helper context CPL!Proxy def: isSimple : Boolean =
	self.busy.oclIsUndefined() and
	self.noanswer.oclIsUndefined() and
	self.redirection.oclIsUndefined() and
	self.default.oclIsUndefined();

rule CPL2Program {
	from s : CPL!CPL
	to t : SPL!Program (
		declarations <- s.nodes->select(e | e.oclIsTypeOf(CPL!SubAction) or e.oclIsTypeOf(CPL!Incoming) or e.oclIsTypeOf(CPL!Outgoing))
	)
}

rule SubAction2Function {
	from s : CPL!SubAction
	to t : SPL!Function (
		name <- s.id,
		body <- s.statement()
	)
}

rule Incoming2Method {
	from s : CPL!Incoming
	to t : SPL!Method (
		name <- 'main',
		body <- s.statement()
	)
}

rule Proxy2Return {
	from s : CPL!Proxy (s.isSimple())
	to t : SPL!Return (
		returnedValue <- thisModule.Location2URIConstant(s.success.contents.oclAsType(CPL!Location))
	)
}

rule Proxy2Select {
	from s : CPL!Proxy (not s.isSimple())
	to t : SPL!SelectStat (
		cases <- Sequence{s.busy, s.noanswer, s.redirection}->reject(e | e.oclIsUndefined()),
		default <- s.default
	)
}

rule Busy2SelectCase {
	from s : CPL!Busy
	to t : SPL!SelectCase (
		body <- s.statement()
	)
}

rule NoAnswer2SelectCase {
	from s : CPL!NoAnswer
	to t : SPL!SelectCase (
		body <- s.statement()
	)
}

rule Redirection2SelectCase {
	from s : CPL!Redirection
	to t : SPL!SelectCase (
		body <- s.statement()
	)
}

rule Default2SelectDefault {
	from s : CPL!Default
	to t : SPL!SelectDefault (
		body <- s.statement()
	)
}

rule SubCall2Return {
	from s : CPL!SubCall
	to t : SPL!Return (
		returnedValue <- fcall
	),
	fcall : SPL!FunctionCall (
		function <- s.ref
	)
}

rule Redirect2Return {
	from s : CPL!Redirect
	to t : SPL!Return (
		returnedValue <- thisModule.Location2URIConstant(s.destination)
	)
}

rule AddressSwitch2SelectStat {
	from s : CPL!AddressSwitch
	to t : SPL!SelectStat (
		cases <- s.nodes->select(n | n.oclIsTypeOf(CPL!SwitchedAddress)),
		default <- s.nodes->select(n | n.oclIsTypeOf(CPL!Otherwise))->first()
	)
}

rule SwitchedAddress2SelectCase {
	from s : CPL!SwitchedAddress
	to t : SPL!SelectCase (
		body <- s.statement(),
		condition <- eq
	),
	eq : SPL!BinaryExpr (
		operator <- '==',
		lhs <- var
	),
	var : SPL!Variable (
		name <- 'origin'
	)
	do {
		eq.rhs <- thisModule.Location2URIConstant(s.address);
	}
}

rule Otherwise2SelectDefault {
	from s : CPL!Otherwise
	to t : SPL!SelectDefault (
		body <- s.statement()
	)
}