-- @nsURI DSL=http://vitruv.tools/methodologisttemplate/DSL
-- @nsURI KM3=http://vitruv.tools/methodologisttemplate/KM3
module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	self.properties->notEmpty();

helper context DSL!Relationship def: getRoles() : Sequence(DSL!Role) =
	self.roles;

helper context DSL!Relationship def: isEmbedding() : Boolean =
	self.isEmbedding;

rule Metamodel {
	from s : DSL!DomainModel
	to t : KM3!Metamodel (
		contents <- p
	),
	p : KM3!Package (
		name <- s.name,
		contents <- s.classifiers->union(s.types)
	)
}

rule Class {
	from s : DSL!Class
	to t : KM3!Class (
		name <- s.name,
		isAbstract <- s.isAbstract,
		supertypes <- s.superType,
		structuralFeatures <- s.properties
	)
}

rule Relation2Class {
	from s : DSL!Relationship (thisModule.needTurnOnClass(s))
	to t : KM3!Class (
		name <- s.name,
		isAbstract <- s.isAbstract,
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(s.roles)
	)
}

rule RoleToReference {
	from s : DSL!Role (thisModule.needTurnOnClass(s.relation))
	to t : KM3!Reference (
		name <- s.name,
		owner <- s.relation,
		type <- s.type,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isOrdered <- s.isOrdered
	)
}

rule SimpleReference {
	from s : DSL!Relationship (
		not thisModule.needTurnOnClass(s) and
		s.roles->select(r | r.isNavigableFrom)->size() = 1
	)
	using {
		navigableRole <- s.roles->select(r | r.isNavigableFrom)->first(),
		sourceRole <- s.roles->select(r | not r.isNavigableFrom)->first()
	}
	to t : KM3!Reference (
		name <- navigableRole.name,
		owner <- sourceRole.type,
		type <- navigableRole.type,
		lower <- navigableRole.min,
		upper <- if navigableRole.isUnbounded then -1 else navigableRole.max endif,
		isContainer <- s.isEmbedding,
		isOrdered <- navigableRole.isOrdered
	)
}

rule ComplexReference {
	from s : DSL!Relationship (
		not thisModule.needTurnOnClass(s) and
		s.roles->select(r | r.isNavigableFrom)->size() = 2
	)
	using {
		role1 <- s.roles->at(1),
		role2 <- s.roles->at(2)
	}
	to
		ref1 : KM3!Reference (
			name <- role2.name,
			owner <- role1.type,
			type <- role2.type,
			lower <- role2.min,
			upper <- if role2.isUnbounded then -1 else role2.max endif,
			isContainer <- s.isEmbedding,
			isOrdered <- role2.isOrdered,
			opposite <- ref2
		),
		ref2 : KM3!Reference (
			name <- role1.name,
			owner <- role2.type,
			type <- role1.type,
			lower <- role1.min,
			upper <- if role1.isUnbounded then -1 else role1.max endif,
			isContainer <- false,
			isOrdered <- role1.isOrdered,
			opposite <- ref1
		)
}

rule Attribute {
	from s : DSL!ValueProperty
	to t : KM3!Attribute (
		name <- s.name,
		owner <- s.owner,
		type <- s.type,
		lower <- 1,
		upper <- 1
	)
}

rule Enumeration {
	from s : DSL!Enumeration
	to t : KM3!Enumeration (
		name <- s.name,
		literals <- s.literals
	)
}

rule EnumLiteral {
	from s : DSL!EnumerationLiteral
	to t : KM3!EnumLiteral (
		name <- s.name
	)
}

rule DataType {
	from s : DSL!SimpleType
	to t : KM3!DataType (
		name <- s.name
	)
}