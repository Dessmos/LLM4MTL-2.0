module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	self.properties->notEmpty();

helper context DSL!Classifier def: getRoles() : Sequence(DSL!Role) =
	DSL!Role.allInstances()->select(r | r.source = self and r.isPropertyGenerator);

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding;

rule Metamodel {
	from
		s : DSL!DomainModel
	to
		t : KM3!Metamodel (
			contents <- s.classifiers->union(s.types)
		)
}

rule Class {
	from
		s : DSL!Class
	to
		t : KM3!Class (
			name <- s.name,
			isAbstract <- s.isAbstract,
			supertypes <- s.superType,
			structuralFeatures <- s.properties->union(s.getRoles())
		)
}

lazy rule Relation2Class {
	from
		s : DSL!Relationship (s.needTurnOnClass())
	to
		t : KM3!Class (
			name <- s.name,
			isAbstract <- s.isAbstract,
			supertypes <- s.superType,
			structuralFeatures <- s.properties->union(s.roles->collect(e | thisModule.RoleEndForRelationClass(e)))
		)
}

unique lazy rule RoleEndForRelationClass {
	from
		s : DSL!Role
	to
		t : KM3!Reference (
			name <- s.type.name.toLower(),
			isContainer <- false,
			lower <- 1,
			upper <- 1,
			type <- s.type
		)
}

rule SimpleReference {
	from
		s : DSL!Role (s.isPropertyGenerator and not s.relation.needTurnOnClass())
	to
		t : KM3!Reference (
			name <- s.name,
			isContainer <- s.isEmbedding(),
			lower <- s.min,
			upper <- if s.isUnbounded then -1 else s.max endif,
			type <- s.type,
			opposite <- s.relation.roles->any(e | e <> s)
		)
}

rule ComplexReference {
	from
		s : DSL!Role (s.isPropertyGenerator and s.relation.needTurnOnClass())
	to
		t : KM3!Reference (
			name <- s.relation.name.toLower(),
			isContainer <- s.isEmbedding(),
			lower <- s.min,
			upper <- if s.isUnbounded then -1 else s.max endif,
			type <- s.relation
		)
}

rule Attribute {
	from
		s : DSL!ValueProperty
	to
		t : KM3!Attribute (
			name <- s.name,
			lower <- 0,
			upper <- 1,
			type <- s.type
		)
}

rule Enumeration {
	from
		s : DSL!Enumeration
	to
		t : KM3!Enumeration (
			name <- s.name,
			literals <- s.literals
		)
}

rule EnumLiteral {
	from
		s : DSL!EnumerationLiteral
	to
		t : KM3!EnumLiteral (
			name <- s.name
		)
}

rule DataType {
	from
		s : DSL!SimpleType
	to
		t : KM3!DataType (
			name <- s.name
		)
}