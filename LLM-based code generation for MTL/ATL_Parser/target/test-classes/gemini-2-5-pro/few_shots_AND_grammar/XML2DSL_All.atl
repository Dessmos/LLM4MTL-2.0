module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def: getAttrBool(attrName : String) : Boolean =
	let val = self.getAttrVal(attrName) in
	if val.oclIsUndefined() or val = '' then
		false
	else
		val = 'true'
	endif;

helper context XML!Element def: getAttrVal(attrName : String) : String =
	let attr = self.children->any(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName) in
	if attr.oclIsUndefined() then
		OclUndefined
	else
		attr.value
	endif;

helper def: get(child : XML!Element, name : String) : XML!Element =
	child.children->any(c | c.oclIsTypeOf(XML!Element) and c.name = name);

helper context XML!Element def: getType(name : String) : XML!Element =
	thisModule.dslElementsById->get(name);

helper context XML!Element def: getEnumId(enumName : String, literalName : String) : String =
	enumName + '.' + literalName;

helper context XML!Element def: getText() : String =
	self.children->any(c | c.oclIsTypeOf(XML!Text)).value;

helper def: getSeq(children : Sequence(XML!Node), name : String) : Sequence(XML!Element) =
	children->select(c | c.oclIsTypeOf(XML!Element) and c.name = name);

helper context XML!Element def: hasChildren(name : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Element) and c.name = name);

helper context XML!Element def: hasAttr(attrName : String) : Boolean =
	self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = attrName);

helper context XML!Element def: isAbstract() : Boolean =
	if self.hasAttr('isAbstract') then self.getAttrBool('isAbstract') else false endif;

helper def: dslElementsById : Map(String, XML!Element) =
	XML!Element.allInstances()->select(e | e.name = 'DomainModel')->first().children->select(
		c | c.name='Class' or c.name='Relationship' or c.name='Enumeration'
	)->collect(e |
		Tuple{key = e.getAttrVal('id'), value = e}
	)->asMap();

helper context XML!Element def: getContainment() : Boolean =
	if self.hasAttr('containment') then self.getAttrBool('containment') else false endif;

helper context XML!Element def: getSubTypes() : Sequence(XML!Element) =
	XML!Element.allInstances()->select(e | e.name = 'DomainModel')->first().children->select(
		c | c.name='Class' or c.name='Relationship'
	)->select(sub |
		sub.hasAttr('extends') and sub.getAttrVal('extends') = self.getAttrVal('id')
	);

helper def: findType(aType : String) : DSL!Type =
	let primitiveType : DSL!SimpleType = DSL!SimpleType.allInstancesFrom('OUT')->any(t | t.name = aType) in
	if not primitiveType.oclIsUndefined() then
		primitiveType
	else
		thisModule.dslElementsById->get(aType)
	endif;

rule DomainModel {
	from s : XML!Element (s.name = 'DomainModel')
	to
		dm : DSL!DomainModel (
			name <- s.getAttrVal('id'),
			identity <- s.getAttrVal('id'),
			namespace <- s.getAttrVal('id'),
			isLoaded <- false,
			classifiers <- thisModule.getSeq(s.children, 'Class')->union(thisModule.getSeq(s.children, 'Relationship')),
			types <- thisModule.getSeq(s.children, 'Enumeration')->union(Sequence{stringType, integerType, booleanType})
		),
		stringType : DSL!SimpleType (
			name <- 'String',
			identity <- 'String',
			namespace <- 'PrimitiveTypes'
		),
		integerType : DSL!SimpleType (
			name <- 'Integer',
			identity <- 'Integer',
			namespace <- 'PrimitiveTypes'
		),
		booleanType : DSL!SimpleType (
			name <- 'Boolean',
			identity <- 'Boolean',
			namespace <- 'PrimitiveTypes'
		)
}

rule Class {
	from s : XML!Element (s.name = 'Class')
	to t : DSL!Class (
		name <- s.getAttrVal('id'),
		identity <- s.getAttrVal('id'),
		namespace <- s.parent.getAttrVal('id'),
		isLoaded <- false,
		isAbstract <- s.isAbstract(),
		properties <- thisModule.getSeq(s.children, 'ValueProperty'),
		superType <- if s.hasAttr('extends') then thisModule.dslElementsById->get(s.getAttrVal('extends')) else OclUndefined endif,
		subTypes <- s.getSubTypes()
	)
}

rule Relationship {
	from s : XML!Element (s.name = 'Relationship')
	to t : DSL!Relationship (
		name <- s.getAttrVal('id'),
		identity <- s.getAttrVal('id'),
		namespace <- s.parent.getAttrVal('id'),
		isLoaded <- false,
		isAbstract <- s.isAbstract(),
		isEmbedding <- s.getContainment(),
		properties <- thisModule.getSeq(s.children, 'ValueProperty'),
		roles <- thisModule.getSeq(s.children, 'Role'),
		superType <- if s.hasAttr('extends') then thisModule.dslElementsById->get(s.getAttrVal('extends')) else OclUndefined endif,
		subTypes <- s.getSubTypes()
	)
}

rule Role {
	from s : XML!Element (s.name = 'Role')
	to t : DSL!Role (
		name <- s.getAttrVal('id'),
		identity <- s.parent.getAttrVal('id') + '.' + s.getAttrVal('id'),
		min <- s.getAttrVal('lowerBound').toInteger(),
		max <- if s.getAttrVal('upperBound') = '*' or s.getAttrVal('upperBound') = '-1' then -1 else s.getAttrVal('upperBound').toInteger() endif,
		isUnbounded <- s.getAttrVal('upperBound') = '*' or s.getAttrVal('upperBound') = '-1',
		isOrdered <- s.getAttrBool('isOrdered'),
		isNavigableFrom <- s.getAttrBool('isNavigable'),
		isPropertyGenerator <- s.getAttrBool('propertyGenerator'),
		accepts <- s.getAttrVal('type'),
		source <- s.parent,
		type <- thisModule.findType(s.getAttrVal('type'))
	)
}

rule ValueProperty {
	from s : XML!Element (s.name = 'ValueProperty')
	to t : DSL!ValueProperty (
		name <- s.getAttrVal('id'),
		identity <- s.parent.getAttrVal('id') + '.' + s.getAttrVal('id'),
		owner <- s.parent,
		type <- thisModule.findType(s.getAttrVal('type'))
	)
}

rule Enumeration {
	from s : XML!Element (s.name = 'Enumeration')
	to t : DSL!Enumeration (
		name <- s.getAttrVal('id'),
		identity <- s.getAttrVal('id'),
		namespace <- s.parent.getAttrVal('id'),
		literals <- thisModule.getSeq(s.children, 'Literal')
	)
}

rule EnumerationLiteral {
	from s : XML!Element (s.name = 'Literal')
	to t : DSL!EnumerationLiteral (
		name <- s.getAttrVal('id'),
		identity <- s.getEnumId(s.parent.getAttrVal('id'), s.getAttrVal('id')),
		value <- s.getAttrVal('value').toInteger()
	)
}