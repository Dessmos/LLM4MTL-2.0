module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		s : Make!Makefile
	to
		t : Ant!Project (
			name <- s.name,
			defaultTarget <- s.defaultGoal,
			properties <- s.macros,
			targets <- s.rules
		)
}

rule Macro2Property {
	from
		s : Make!Macro
	to
		t : Ant!PropertyValue (
			name <- s.name,
			value <- s.value
		)
}

rule Rule2Target {
	from
		s : Make!Rule
	to
		t : Ant!Target (
			name <- s.name,
			dependencies <- s.dependencies,
			tasks <- s.shellLines
		)
}

rule ShellLine2Task_Display {
	from
		s : Make!ShellLine (s.display)
	to
		t : Ant!Echo (
			message <- s.command
		)
}

rule ShellLine2Task_NoDisplay {
	from
		s : Make!ShellLine (not s.display)
	to
		t : Ant!Exec (
			executable <- s.command
		)
}