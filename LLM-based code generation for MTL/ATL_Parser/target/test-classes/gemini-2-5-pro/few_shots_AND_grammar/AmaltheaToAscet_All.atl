module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper def: convertTasks(tasks : Sequence(Amalthea!Task)) : Sequence(Ascet!SoftwareTask) =
	tasks->collect(t | thisModule.Task2SoftwareTask(t));

rule ComponentContainer2AscetModule {
	from
		s : Amalthea!ComponentContainer
	to
		t : Ascet!AscetModule (
			softwareTasks <- thisModule.convertTasks(s.tasks)
		)
}

rule TaskRoot2SoftwareTask {
	from
		s : Amalthea!Task (
			s.componentContainer.oclIsUndefined()
		)
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}

lazy rule Task2SoftwareTask {
	from
		s : Amalthea!Task
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}