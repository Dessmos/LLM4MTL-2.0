module Grafcet2PetriNet;
create OUT : PetriNet from IN : Grafcet;

rule PetriNet {
	from
		g : Grafcet!Grafcet
	to
		pn : PetriNet!PetriNet (
			name <- g.name,
			location <- g.location,
			elements <- g.elements,
			arcs <- g.connections
		)
}

rule Place {
	from
		s : Grafcet!Step
	to
		p : PetriNet!Place (
			name <- s.name,
			location <- s.location
		)
}

rule Transition {
	from
		t_in : Grafcet!Transition
	to
		t_out : PetriNet!Transition (
			name <- t_in.name,
			location <- t_in.location
		)
}

rule PlaceToTransition {
	from
		c : Grafcet!StepToTransition
	to
		a : PetriNet!PlaceToTransition (
			name <- c.name,
			location <- c.location,
			weight <- 1,
			from <- c.from,
			to <- c.to
		)
}

rule TransitionToPlace {
	from
		c : Grafcet!TransitionToStep
	to
		a : PetriNet!TransitionToPlace (
			name <- c.name,
			location <- c.location,
			weight <- 1,
			from <- c.from,
			to <- c.to
		)
}