module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!ArchitecturalDescription def: rationale() : String =
	if self.rationales->notEmpty() then
		self.rationales->first().name + ': ' + self.rationales->first().content
	else
		''
	endif;

rule IEEE1471Model2MoDAFModel {
	from
		s : IEEE1471!Model
	to
		t : MoDAF!Model (
			architecturalDescriptions <- IEEE1471!ArchitecturalDescription.allInstances(),
			architecturalFrameworks <- IEEE1471!LibraryViewpoint.allInstances(),
			stakeholderConcernRelations <- IEEE1471!Stakeholder.allInstances(),
			undefinedFramework <- uaf
		),
		uaf : MoDAF!ArchitecturalFramework (
			name <- 'Undefined Architectural Framework',
			content <- 'A default framework for viewpoints with no library.',
			contains <- IEEE1471!Viewpoint.allInstances()->select(v | v.library.oclIsUndefined())
		)
}

rule System2Enterprise {
	from
		s : IEEE1471!System
	to
		t : MoDAF!Enterprise (
			name <- s.name
		)
}

rule Environment2Environment {
	from
		s : IEEE1471!Environment
	to
		t : MoDAF!Environment (
			name <- s.name
		)
}

rule Mission2OperationalMission {
	from
		s : IEEE1471!Mission
	to
		t : MoDAF!OperationalMission (
			name <- s.name,
			content <- s.content
		)
}

rule Architecture2Architecture {
	from
		s : IEEE1471!Architecture
	to
		t : MoDAF!Architecture (
			enterprise <- s.system
		)
}

rule AD2AD {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!ArchitecturalDescription (
			name <- s.name,
			rationale <- thisModule.rationale(s),
			enterprise <- s.system,
			environment <- s.environment,
			operationalMission <- s.mission,
			architecture <- s.architecture,
			stakeholders <- s.stakeholders,
			concerns <- s.concerns,
			views <- s.viewpoints,
			architecturalProducts <- s.views
		)
}

rule Stakeholder2Stakeholder {
	from
		s : IEEE1471!Stakeholder
	to
		t : MoDAF!Stakeholder (
			name <- s.name,
			content <- s.content
		)
}

rule Viewpoint2View {
	from
		s : IEEE1471!Viewpoint
	to
		t : MoDAF!View (
			name <- s.name,
			content <- s.content,
			addressesConcerns <- s.concerns,
			elements <- s.models
		)
}

rule View2ArchitecturalProduct {
	from
		s : IEEE1471!View
	to
		t : MoDAF!ArchitecturalProduct (
			name <- s.name,
			content <- s.content,
			conformsTo <- s.viewpoint
		)
}

rule Model2Element {
	from
		s : IEEE1471!Model
	to
		t : MoDAF!Element (
			name <- s.name,
			content <- s.content
		)
}

rule Concern2Concern {
	from
		s : IEEE1471!Concern
	to
		t : MoDAF!Concern (
			name <- s.name,
			content <- s.content
		)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from
		s : IEEE1471!LibraryViewpoint
	to
		t : MoDAF!ArchitecturalFramework (
			name <- s.name,
			content <- s.content,
			contains <- s.viewpoints
		)
}

rule StakeholderHasConcern {
	from
		s : IEEE1471!Stakeholder
	to
		t : distinct MoDAF!StakeholderHasConcern foreach (c in s.concerns) (
			from <- s,
			to <- c
		)
}