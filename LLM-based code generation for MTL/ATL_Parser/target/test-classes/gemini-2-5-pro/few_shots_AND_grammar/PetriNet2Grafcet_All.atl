module PetriNet2Grafcet;
create OUT : Grafcet from IN : PetriNet;

rule Grafcet {
	from
		pn : PetriNet!PetriNet
	to
		g : Grafcet!Grafcet (
			name <- pn.name,
			location <- pn.location,
			elements <- pn.elements,
			connections <- pn.arcs
		)
}

rule Step {
	from
		p : PetriNet!Place
	to
		s : Grafcet!Step (
			name <- p.name,
			location <- p.location,
			isInitial <- false,
			isActive <- false,
			action <- '',
			incomingConnections <- p.incomingArc,
			outgoingConnections <- p.outgoingArc
		)
}

rule Transition {
	from
		pt : PetriNet!Transition
	to
		gt : Grafcet!Transition (
			name <- pt.name,
			location <- pt.location,
			condition <- 'true',
			incomingConnections <- pt.incomingArc,
			outgoingConnections <- pt.outgoingArc
		)
}

rule StepToTransition {
	from
		p2t : PetriNet!PlaceToTransition
	to
		s2t : Grafcet!StepToTransition (
			name <- p2t.name,
			location <- p2t.location,
			from <- p2t.from,
			to <- p2t.to
		)
}

rule TransitionToStep {
	from
		t2p : PetriNet!TransitionToPlace
	to
		t2s : Grafcet!TransitionToStep (
			name <- t2p.name,
			location <- t2p.location,
			from <- t2p.from,
			to <- t2p.to
		)
}