module AmaltheaToAscet_All;
create OUT : Ascet from IN : Amalthea;

helper context Amalthea!ComponentContainer def: getSoftwareTasks() : Sequence(Ascet!SoftwareTask) =
	self.tasks->collect(t | thisModule.Task2SoftwareTask(t));

rule ComponentContainer2AscetModule {
	from
		s : Amalthea!ComponentContainer
	to
		t : Ascet!AscetModule (
			softwareTasks <- s.getSoftwareTasks()
		)
}

rule TaskRoot2SoftwareTask {
	from
		s : Amalthea!Task (
			s.container.oclIsUndefined()
		)
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}

lazy rule Task2SoftwareTask {
	from
		s : Amalthea!Task
	to
		t : Ascet!SoftwareTask (
			name <- s.name
		)
}