module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Proxy def: isSimple() : Boolean =
	self.busy.oclIsUndefined() and
	self.noanswer.oclIsUndefined() and
	self.redirection->isEmpty() and
	self.otherwise.oclIsUndefined();

helper context CPL!CPL def: statement() : SPL!Statement = thisModule.DefaultStatement();

helper context CPL!CPL def: locations() : Sequence(SPL!Expression) =
	CPL!Location.allInstances()->collect(l | thisModule.Location2URIConstant(l));

lazy rule DefaultStatement {
	to t : SPL!ReturnStat (
		returnedValue <- fc
	),
	fc : SPL!FunctionCall (
		functionName <- 'Default'
	)
}

-- "helper rule"
lazy rule Location2URIConstant {
	from s : CPL!Location
	to t : SPL!URIConstant (
		value <- s.uri
	)
}

rule CPL2Program {
	from s : CPL!CPL
	to t : SPL!Program (
		declarations <- s.subactions->union(s.incoming),
		variables <- CPL!Location.allInstances()
	)
}

lazy rule Location2VariableDeclaration {
	from s : CPL!Location
	to t : SPL!VariableDeclaration (
		name <- s.uri,
		initialValue <- thisModule.Location2URIConstant(s)
	)
}

rule SubAction2Function {
	from s : CPL!SubAction
	to t : SPL!FunctionDeclaration (
		name <- s.name,
		functionBody <- s.action
	)
}

rule Incoming2Method {
	from s : CPL!Incoming
	to t : SPL!Method (
		handler <- s.handler,
		methodBody <- s.action
	)
}

rule Proxy2Return {
	from s : CPL!Proxy (s.isSimple())
	to t : SPL!ReturnStat (
		returnedValue <- fc
	),
	fc : SPL!FunctionCall (
		functionName <- 'Proxy'
	)
}

rule Proxy2Select {
	from s : CPL!Proxy (not s.isSimple())
	to t : SPL!SelectStat (
		selectCases <- Sequence{s.busy, s.noanswer}->reject(e | e.oclIsUndefined())->union(s.redirection),
		defaultCase <- s.otherwise
	)
}

rule Busy2SelectCase {
	from s : CPL!Busy
	to t : SPL!SelectCase (
		whenCondition <- fc,
		caseBody <- s.action
	),
	fc : SPL!FunctionCall (
		functionName <- 'Busy'
	)
}

rule NoAnswer2SelectCase {
	from s : CPL!NoAnswer
	to t : SPL!SelectCase (
		whenCondition <- fc,
		caseBody <- s.action
	),
	fc : SPL!FunctionCall (
		functionName <- 'NoAnswer'
	)
}

rule Redirection2SelectCase {
	from s : CPL!Redirection
	to t : SPL!SelectCase (
		whenCondition <- fc,
		caseBody <- s.action
	),
	fc : SPL!FunctionCall (
		functionName <- 'Redirection'
	)
}

rule Default2SelectDefault {
	from s : CPL!Default
	to t : SPL!SelectDefault (
		defaultBody <- s.action
	)
}

rule SubCall2Return {
	from s : CPL!SubCall
	to t : SPL!ReturnStat (
		returnedValue <- fc
	),
	fc : SPL!FunctionCall (
		functionName <- s.ref,
		function <- CPL!SubAction.allInstances()->select(sa | sa.name = s.ref)->first()
	)
}

rule Redirect2Return {
	from s : CPL!Redirect
	to t : SPL!ReturnStat (
		returnedValue <- fc
	),
	fc : SPL!FunctionCall (
		functionName <- 'Redirect'
	)
}

rule AddressSwitch2SelectStat {
	from s : CPL!AddressSwitch
	to t : SPL!SelectStat (
		selectCases <- s.addresses,
		defaultCase <- s.otherwise
	)
}

rule SwitchedAddress2SelectCase {
	from s : CPL!SwitchedAddress
	to t : SPL!SelectCase (
		whenCondition <- fc,
		caseBody <- s.action
	),
	fc : SPL!FunctionCall (
		functionName <- 'SwitchedAddress'
	)
}

rule Otherwise2SelectDefault {
	from s : CPL!Otherwise
	to t : SPL!SelectDefault (
		defaultBody <- s.action
	)
}