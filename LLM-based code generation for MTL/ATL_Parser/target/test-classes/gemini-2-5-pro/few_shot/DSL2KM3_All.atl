module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	self.properties->notEmpty();

helper context DSL!Relationship def: getRoles() : Sequence(DSL!Role) =
	self.roles;

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding;

rule Metamodel {
	from s : DSL!DomainModel
	to mm : KM3!Metamodel (
		name <- s.name,
		contents <- s.classifiers->union(s.types)
	)
}

rule Class {
	from s : DSL!Class
	to c : KM3!Class (
		name <- s.name,
		isAbstract <- s.isAbstract,
		package <- s.domainModel,
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(
			DSL!Role.allInstances()->select(r | r.source = s and not thisModule.needTurnOnClass(r.relation))
		)
	)
}

rule Relation2Class {
	from s : DSL!Relationship (
		thisModule.needTurnOnClass(s)
	)
	to c : KM3!Class (
		name <- s.name,
		isAbstract <- s.isAbstract,
		package <- s.domainModel,
		supertypes <- s.superType,
		structuralFeatures <- thisModule.getRoles(s)->collect(e | thisModule.ComplexReference(e))
	)
}

rule SimpleReference {
	from s : DSL!Role (
		not thisModule.needTurnOnClass(s.relation)
	)
	to r : KM3!Reference (
		name <- s.name,
		isContainer <- thisModule.isEmbedding(s),
		isOrdered <- s.isOrdered,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		owner <- s.source,
		type <- s.type,
		opposite <- thisModule.getRoles(s.relation)->select(e | e <> s)->first()
	)
}

lazy rule ComplexReference {
	from s : DSL!Role
	to r : KM3!Reference (
		name <- s.name,
		isContainer <- false,
		isOrdered <- s.isOrdered,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		owner <- s.relation,
		type <- s.type
	)
}

rule Attribute {
	from s : DSL!ValueProperty
	to a : KM3!Attribute (
		name <- s.name,
		isOrdered <- false,
		lower <- 1,
		upper <- 1,
		owner <- s.owner,
		type <- s.type
	)
}

rule Enumeration {
	from s : DSL!Enumeration
	to e : KM3!Enumeration (
		name <- s.name,
		package <- s.eContainer(),
		literals <- s.literals
	)
}

rule EnumLiteral {
	from s : DSL!EnumerationLiteral
	to l : KM3!EnumLiteral (
		name <- s.name,
		enum <- s.eContainer()
	)
}

rule DataType {
	from s : DSL!SimpleType
	to d : KM3!DataType (
		name <- s.name,
		package <- s.eContainer()
	)
}