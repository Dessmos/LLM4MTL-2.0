module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		s : Make!Makefile
	to
		t : Ant!Project (
			name <- s.name,
			properties <- s.elements->select(e | e.oclIsTypeOf(Make!Macro)),
			targets <- s.elements->select(e | e.oclIsTypeOf(Make!Rule)),
			default <- s.elements->select(e | e.oclIsTypeOf(Make!Rule))->first()
		)
}

rule Macro2Property {
	from
		s : Make!Macro
	to
		t : Ant!PropertyValue (
			name <- s.name,
			value <- s.value
		)
}

rule Rule2Target {
	from
		s : Make!Rule
	to
		t : Ant!Target (
			name <- s.name,
			depends <- s.dependencies->select(dep | dep.oclIsTypeOf(Make!RuleDep))->collect(dep | dep.oclAsType(Make!RuleDep).ruledep)
		)
	do {
		for (sl in s.shellLines) {
			if sl.display then
				thisModule.ShellLine2Task_Display(sl, t)
			else
				thisModule.ShellLine2TAsk_NoDisplay(sl, t)
			endif;
		}
	}
}

entrypoint rule ShellLine2Task_Display(sl : Make!ShellLine, parentTarget : Ant!Target) {
	do {
		let echo : Ant!Echo = new Ant!Echo in {
			echo.message <- sl.command;
			echo.target <- parentTarget;
			parentTarget.tasks <- parentTarget.tasks->append(echo);
		}
		let exec : Ant!Exec = new Ant!Exec in {
			exec.executable <- sl.command;
			exec.target <- parentTarget;
			parentTarget.tasks <- parentTarget.tasks->append(exec);
		}
	}
}

entrypoint rule ShellLine2Task_NoDisplay(sl : Make!ShellLine, parentTarget : Ant!Target) {
	do {
		let exec : Ant!Exec = new Ant!Exec in {
			exec.executable <- sl.command;
			exec.target <- parentTarget;
			parentTarget.tasks <- parentTarget.tasks->append(exec);
		}
	}
}