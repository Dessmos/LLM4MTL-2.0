module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!IEEE1471Model def : rationale : String =
	self.rationale.name.concat(': ').concat(self.rationale.content);

rule IEEE1471Model2MoDAFModel {
	from
		s : IEEE1471!IEEE1471Model
	to
		t : MoDAF!MoDAFModel (
			name <- s.name,
			content <- s.content,
			enterprise <- s.system,
			environment <- s.environment,
			operationalMissions <- s.missions,
			architectures <- s.architecture,
			architecturalDescription <- s.architecturalDescription,
			stakeholders <- s.stakeholders,
			architecturalFrameworks <- s.libraryViewpoints->union(Sequence{ defaultFramework }),
			stakeholderHasConcerns <- s.stakeholders->collect(sh |
				sh.has->collect(c | thisModule.StakeholderHasConcern(sh, c))
			)->flatten()
		),
		defaultFramework : MoDAF!ArchitecturalFramework (
			name <- 'DefaultFramework',
			content <- 'Framework for viewpoints without a source library viewpoint.',
			ownedMember <- IEEE1471!Viewpoint.allInstances()->select(vp | vp.hasSource.oclIsUndefined())
		)
}

rule System2Enterprise {
	from
		s : IEEE1471!System
	to
		t : MoDAF!Enterprise (
			name <- s.name,
			content <- s.content,
			fulfills <- s.fulfills,
			inhabits <- s.inhabits
		)
}

rule Environment2Environment {
	from
		s : IEEE1471!Environment
	to
		t : MoDAF!Environment (
			name <- s.name,
			content <- s.content,
			influences <- s.influences
		)
}

rule Mission2OperationalMission {
	from
		s : IEEE1471!Mission
	to
		t : MoDAF!OperationalMission (
			name <- s.name,
			content <- s.content
		)
}

rule Architecture2Architecture {
	from
		s : IEEE1471!Architecture
	to
		t : MoDAF!Architecture (
			name <- s.name,
			content <- s.content,
			enterprise <- s.oclContainer().oclAsType(IEEE1471!IEEE1471Model).system,
			describedBy <- s.describedBy
		)
}

rule AD2AD {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!ArchitecturalDescription (
			name <- s.name,
			content <- s.content,
			purpose <- s.oclContainer().rationale,
			viewpoints <- s.selects,
			products <- s.organizedBy
		)
}

rule Stakeholder2Stakeholder {
	from
		s : IEEE1471!Stakeholder
	to
		t : MoDAF!Stakeholder (
			name <- s.name,
			content <- s.content
		)
}

rule Viewpoint2View {
	from
		s : IEEE1471!Viewpoint
	to
		t : MoDAF!View (
			name <- s.name,
			content <- s.content,
			usedToCover <- s.usedToCover,
			definingFramework <- if s.hasSource.oclIsUndefined() then
					MoDAF!ArchitecturalFramework.allInstances()->select(f | f.name = 'DefaultFramework')->first()
				else
					s.hasSource
				endif
		)
}

rule View2ArchitecturalProduct {
	from
		s : IEEE1471!View
	to
		t : MoDAF!ArchitecturalProduct (
			name <- s.name,
			content <- s.content,
			architecturalElements <- s.consitsOf,
			definingView <- s.conformsTo
		)
}

rule Model2Element {
	from
		s : IEEE1471!Model
	to
		t : MoDAF!Elements (
			name <- s.name,
			content <- s.content
		)
}

rule Concern2Concern {
	from
		s : IEEE1471!Concern
	to
		t : MoDAF!Concern (
			name <- s.name,
			content <- s.content
		)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from
		s : IEEE1471!LibraryViewpoint
	to
		t : MoDAF!ArchitecturalFramework (
			name <- s.name,
			content <- s.content,
			ownedMember <- IEEE1471!Viewpoint.allInstances()->select(v | v.hasSource = s)
		)
}

called rule StakeholderHasConcern(stakeholder : IEEE1471!Stakeholder, concern : IEEE1471!Concern) {
	to
		link : MoDAF!StakeholderHasConcern (
			client <- stakeholder,
			supplier <- concern
		)
}