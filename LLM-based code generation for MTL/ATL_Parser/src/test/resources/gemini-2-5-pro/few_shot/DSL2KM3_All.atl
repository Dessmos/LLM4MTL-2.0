module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	not self.properties->isEmpty() or not self.superType.oclIsUndefined() or not self.subTypes->isEmpty();

helper def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
	DSL!Role.allInstances()->select(r | r.source = c and not r.relation.needTurnOnClass());

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding and self.isPropertyGenerator;

rule Metamodel {
	from s : DSL!DomainModel
	to t : KM3!Metamodel (
		contents <- Sequence{mainPackage, primitivePackage}
	),
	mainPackage : KM3!Package (
		name <- s.name,
		metamodel <- t,
		contents <- s.classifiers->union(s.types->select(e | e.oclIsTypeOf(DSL!Enumeration)))
	),
	primitivePackage : KM3!Package (
		name <- 'PrimitiveTypes',
		metamodel <- t,
		contents <- s.types->select(e | e.oclIsTypeOf(DSL!SimpleType))
	)
}

rule Class {
	from s : DSL!Class
	to t : KM3!Class (
		name <- s.name,
		isAbstract <- s.isAbstract,
		package <- thisModule.resolveTemp(s.domainModel, 'mainPackage'),
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(thisModule.getRoles(s))
	)
}

rule Relation2Class {
	from s : DSL!Relationship (s.needTurnOnClass())
	to t : KM3!Class (
		name <- s.name,
		isAbstract <- s.isAbstract,
		package <- thisModule.resolveTemp(s.domainModel, 'mainPackage'),
		supertypes <- s.superType,
		structuralFeatures <- s.properties->union(s.roles)
	)
}

rule SimpleReference {
	from s : DSL!Role (not s.relation.needTurnOnClass())
	to t : KM3!Reference (
		name <- s.name,
		owner <- s.source,
		type <- s.type,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isOrdered <- s.isOrdered,
		isUnique <- true,
		isContainer <- s.isEmbedding(),
		opposite <- s.relation.roles->any(r | r <> s)
	)
}

rule ComplexReference {
	from s : DSL!Role (s.relation.needTurnOnClass())
	to t : KM3!Reference (
		name <- s.name,
		owner <- s.relation,
		type <- s.type,
		lower <- s.min,
		upper <- if s.isUnbounded then -1 else s.max endif,
		isOrdered <- s.isOrdered,
		isUnique <- true,
		isContainer <- s.isEmbedding(),
		opposite <- s.relation.roles->any(r | r <> s)
	)
}

rule Attribute {
	from s : DSL!ValueProperty
	to t : KM3!Attribute (
		name <- s.name,
		owner <- s.owner,
		type <- s.type,
		lower <- 1,
		upper <- 1,
		isOrdered <- false,
		isUnique <- true
	)
}

rule Enumeration {
	from s : DSL!Enumeration
	to t : KM3!Enumeration (
		name <- s.name,
		package <- thisModule.resolveTemp(s.eContainer(), 'mainPackage'),
		literals <- s.literals
	)
}

rule EnumLiteral {
	from s : DSL!EnumerationLiteral
	to t : KM3!EnumLiteral (
		name <- s.name,
		package <- thisModule.resolveTemp(s.eContainer().eContainer(), 'mainPackage')
	)
}

rule DataType {
	from s : DSL!SimpleType
	to t : KM3!DataType (
		name <- s.name,
		package <- thisModule.resolveTemp(s.eContainer(), 'primitivePackage')
	)
}