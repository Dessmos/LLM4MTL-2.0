module Make2Ant;

create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		s : Make!Makefile
	to
		t : Ant!Project (
			name <- s.name,
			properties <- s.elements->select(e | e.oclIsTypeOf(Make!Macro))->collect(m | thisModule.Macro2Property(m)),
			targets <- s.elements->select(e | e.oclIsTypeOf(Make!Rule))->collect(r | thisModule.Rule2Target(r)),
			default <- thisModule.Rule2Target(s.elements->select(e | e.oclIsTypeOf(Make!Rule))->first())
		)
}

lazy rule Macro2Property {
	from
		s : Make!Macro
	to
		t : Ant!PropertyValue (
			name <- s.name,
			value <- s.value
		)
}

lazy rule Rule2Target {
	from
		s : Make!Rule
	to
		t : Ant!Target (
			name <- s.name,
			tasks <- s.shellLines->collect(sl | thisModule.ShellLine2Tasks(sl))->flatten(),
			depends <- s.dependencies->select(d | d.oclIsTypeOf(Make!RuleDep))->collect(rd | thisModule.Rule2Target(rd.ruledep))
		)
}

lazy rule ShellLine2Task_Display {
	from
		s : Make!ShellLine (s.display = true)
	to
		e : Ant!Exec (
			executable <- s.command,
			dir <- ''
		),
		h : Ant!Echo (
			message <- s.command
		)
}

lazy rule ShellLine2Task_NoDisplay {
	from
		s : Make!ShellLine (s.display = false)
	to
		e : Ant!Exec (
			executable <- s.command,
			dir <- ''
		)
}

helper def : ShellLine2Tasks(sl : Make!ShellLine) : Sequence(Ant!Task) =
	if sl.display then
		Sequence{thisModule.ShellLine2Task_Display(sl).e, thisModule.ShellLine2Task_Display(sl).h}
	else
		Sequence{thisModule.ShellLine2Task_NoDisplay(sl).e}
	endif;