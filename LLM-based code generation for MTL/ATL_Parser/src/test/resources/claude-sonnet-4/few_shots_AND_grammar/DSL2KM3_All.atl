module DSL2KM3;
create OUT : KM3 from IN : DSL;

helper context DSL!Relationship def: needTurnOnClass() : Boolean =
	not self.roles->exists(r | r.source.oclIsUndefined()) or
	not self.superType.oclIsUndefined() or
	not self.subTypes->isEmpty() or
	not self.properties->isEmpty();

helper def: getRoles(c : DSL!Class) : Sequence(DSL!Role) =
	DSL!Role.allInstances()->select(r | r.source = c and not r.relation.needTurnOnClass());

helper context DSL!Role def: isEmbedding() : Boolean =
	self.relation.isEmbedding and self.relation.roles->first() = self;

rule Metamodel {
	from
		dm : DSL!DomainModel
	to
		mm : KM3!Metamodel (
			location <- '',
			contents <- Sequence{mainPkg, primPkg}
		),
		mainPkg : KM3!Package (
			location <- '',
			name <- dm.name,
			metamodel <- mm,
			contents <- dm.classifiers->union(dm.classifiers->select(c | c.oclIsTypeOf(DSL!Relationship) and c.needTurnOnClass()))
		),
		primPkg : KM3!Package (
			location <- '',
			name <- 'PrimitiveTypes',
			metamodel <- mm,
			contents <- dm.types
		)
}

rule Class {
	from
		c : DSL!Class
	to
		cls : KM3!Class (
			location <- '',
			name <- c.name,
			isAbstract <- c.isAbstract,
			supertypes <- if c.superType.oclIsUndefined() then Sequence{} else Sequence{c.superType} endif,
			structuralFeatures <- c.properties->union(thisModule.getRoles(c))
		)
}

rule Relation2Class {
	from
		r : DSL!Relationship (
			r.needTurnOnClass()
		)
	to
		cls : KM3!Class (
			location <- '',
			name <- r.name,
			isAbstract <- r.isAbstract,
			supertypes <- if r.superType.oclIsUndefined() then Sequence{} else Sequence{r.superType} endif,
			structuralFeatures <- r.properties->union(r.roles)
		)
}

rule SimpleReference {
	from
		role : DSL!Role (
			not role.relation.needTurnOnClass()
		)
	to
		ref : KM3!Reference (
			location <- '',
			name <- role.name,
			lower <- role.min,
			upper <- if role.isUnbounded then -1 else role.max endif,
			isOrdered <- role.isOrdered,
			isUnique <- true,
			type <- role.type,
			isContainer <- role.isEmbedding(),
			opposite <- if role.relation.roles->size() = 2 then role.relation.roles->excluding(role)->first() else OclUndefined endif
		)
}

rule ComplexReference {
	from
		role : DSL!Role (
			role.relation.needTurnOnClass()
		)
	to
		ref : KM3!Reference (
			location <- '',
			name <- role.name,
			lower <- role.min,
			upper <- if role.isUnbounded then -1 else role.max endif,
			isOrdered <- role.isOrdered,
			isUnique <- true,
			type <- role.type,
			isContainer <- role.isEmbedding(),
			opposite <- OclUndefined
		)
}

rule Attribute {
	from
		vp : DSL!ValueProperty
	to
		attr : KM3!Attribute (
			location <- '',
			name <- vp.name,
			lower <- 1,
			upper <- 1,
			isOrdered <- false,
			isUnique <- true,
			type <- vp.type
		)
}

rule Enumeration {
	from
		e : DSL!Enumeration
	to
		enum : KM3!Enumeration (
			location <- '',
			name <- e.name,
			literals <- e.literals
		)
}

rule EnumLiteral {
	from
		el : DSL!EnumerationLiteral
	to
		lit : KM3!EnumLiteral (
			location <- '',
			name <- el.name
		)
}

rule DataType {
	from
		st : DSL!SimpleType
	to
		dt : KM3!DataType (
			location <- '',
			name <- st.name
		)
}
