module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper def : rationale : String =
	if IN!Rationale.allInstances()->notEmpty() then
		IN!Rationale.allInstances()->first().name + ' ' + IN!Rationale.allInstances()->first().content
	else
		''
	endif;

rule IEEE1471Model2MoDAFModel {
	from
		s : IN!IEEE1471Model
	to
		t : OUT!MoDAFModel (
			name <- s.name,
			content <- s.content,
			enterprise <- s.system,
			environment <- s.environment,
			operationalMissions <- s.missions,
			architectures <- s.architecture,
			architecturalDescription <- s.architecturalDescription,
			stakeholders <- s.stakeholders,
			stakeholderHasConcerns <- IN!Stakeholder.allInstances()->collect(stk | 
				stk.has->collect(c | thisModule.createStakeholderHasConcern(stk, c, t)))->flatten(),
			architecturalFrameworks <- Sequence{thisModule.createDefaultFramework(s)}
		)
}

rule System2Enterprise {
	from
		s : IN!System
	to
		t : OUT!Enterprise (
			name <- s.name,
			content <- s.content,
			inhabits <- s.inhabits,
			fulfills <- s.fulfills
		)
}

rule Environment2Environment {
	from
		s : IN!Environment
	to
		t : OUT!Environment (
			name <- s.name,
			content <- s.content,
			influences <- s.influences
		)
}

rule Mission2OperationalMission {
	from
		s : IN!Mission
	to
		t : OUT!OperationalMission (
			name <- s.name,
			content <- s.content
		)
}

rule Architecture2Architecture {
	from
		s : IN!Architecture
	to
		t : OUT!Architecture (
			name <- s.name,
			content <- s.content,
			enterprise <- s.describedBy.identifiesS->first().has->first(),
			describedBy <- s.describedBy
		)
}

rule AD2AD {
	from
		s : IN!ArchitecturalDescription
	to
		t : OUT!ArchitecturalDescription (
			name <- s.name,
			content <- s.content,
			approvialAuthority <- '',
			architect <- '',
			assumptionAndConstraints <- '',
			creatingOrganisation <- '',
			dateCompleted <- '',
			purpose <- s.content,
			recommendations <- '',
			summaryOfFindings <- thisModule.rationale,
			tollsUsed <- '',
			viewpoints <- s.organizedBy,
			products <- s.organizedBy,
			taxonomy <- thisModule.createTaxonomy()
		)
}

rule Stakeholder2Stakeholder {
	from
		s : IN!Stakeholder
	to
		t : OUT!Stakeholder (
			name <- s.name,
			content <- s.content
		)
}

rule Viewpoint2View {
	from
		s : IN!Viewpoint
	to
		t : OUT!View (
			name <- s.name,
			content <- s.content,
			framework <- if s.hasSource.oclIsUndefined() then '' else s.hasSource.name endif,
			frameworkWebsite <- '',
			viewCode <- s.name,
			viewDescription <- s.content,
			viewName <- s.name,
			definingFramework <- if s.hasSource.oclIsUndefined() then OclUndefined else s.hasSource endif,
			usedToCover <- s.usedToCover
		)
}

rule View2ArchitecturalProduct {
	from
		s : IN!View
	to
		t : OUT!ArchitecturalProduct (
			name <- s.name,
			content <- s.content,
			description <- s.content,
			architecturalElements <- s.consitsOf,
			definingView <- s.conformsTo,
			addresses <- s.conformsTo.usedToCover
		)
}

rule Model2Element {
	from
		s : IN!Model
	to
		t : OUT!Elements (
			name <- s.name,
			content <- s.content
		)
}

rule Concern2Concern {
	from
		s : IN!Concern
	to
		t : OUT!Concern (
			name <- s.name,
			content <- s.content,
			adressedBy <- s.isImportantTo->collect(stk | stk.has->select(c | c = s))->flatten()
		)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from
		s : IN!LibraryViewpoint
	to
		t : OUT!ArchitecturalFramework (
			name <- s.name,
			content <- s.content,
			ownedMember <- IN!Viewpoint.allInstances()->select(v | v.hasSource = s)
		)
}

rule StakeholderHasConcern {
	from
		s : IN!Stakeholder,
		c : IN!Concern (
			s.has->includes(c)
		)
	to
		t : OUT!StakeholderHasConcern (
			client <- s,
			supplier <- c,
			owner <- IN!IEEE1471Model.allInstances()->first()
		)
}

helper def : createStakeholderHasConcern(stk : IN!Stakeholder, c : IN!Concern, owner : OUT!MoDAFModel) : OUT!StakeholderHasConcern =
	OclUndefined;

helper def : createDefaultFramework(s : IN!IEEE1471Model) : OUT!ArchitecturalFramework =
	let framework : OUT!ArchitecturalFramework = OUT!ArchitecturalFramework.newInstance() in
	framework;

helper def : createTaxonomy() : OUT!Taxonomy =
	let tax : OUT!Taxonomy = OUT!Taxonomy.newInstance() in
	tax;
