module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Node def: statement : CPL!Node =
	if self.oclIsKindOf(CPL!NodeContainer) then
		if self.contents.oclIsUndefined() then
			self
		else
			self.contents.statement
		endif
	else
		self
	endif;

helper context CPL!Element def: locations : Sequence(CPL!Location) =
	if self.refImmediateComposite().oclIsUndefined() then
		Sequence{}
	else
		if self.refImmediateComposite().oclIsKindOf(CPL!Location) then
			self.refImmediateComposite().locations->append(self.refImmediateComposite())
		else
			self.refImmediateComposite().locations
		endif
	endif;

helper context CPL!Proxy def: isSimple : Boolean =
	self.busy.oclIsUndefined() and
	self.noAnswer.oclIsUndefined() and
	self.redirection.oclIsUndefined() and
	self.failure.oclIsUndefined() and
	self.default.oclIsUndefined();

rule CPL2Program {
	from
		c : CPL!CPL
	to
		p : SPL!Program (
			service <- s
		),
		s : SPL!Service (
			name <- 'GeneratedService',
			declarations <- c.subActions->collect(sa | thisModule.SubAction2Function(sa)),
			sessions <- if not c.incoming.oclIsUndefined() then
							Sequence{thisModule.Incoming2Method(c.incoming)}
						else
							Sequence{}
						endif
		)
}

lazy rule SubAction2Function {
	from
		sa : CPL!SubAction
	to
		f : SPL!LocalFunctionDeclaration (
			name <- sa.id,
			returnType <- rt,
			statements <- if not sa.contents.oclIsUndefined() then
							Sequence{thisModule.resolveStatement(sa.contents)}
						else
							Sequence{}
						endif
		),
		rt : SPL!SimpleType (
			type <- #void
		)
}

lazy rule Incoming2Method {
	from
		i : CPL!Incoming
	to
		m : SPL!Method (
			type <- t,
			direction <- #"in",
			methodName <- mn,
			statements <- if not i.contents.oclIsUndefined() then
							Sequence{thisModule.resolveStatement(i.contents)}
						else
							Sequence{}
						endif,
			branches <- Sequence{}
		),
		t : SPL!SimpleType (
			type <- #void
		),
		mn : SPL!SIPMethodName (
			name <- #INVITE
		)
}

helper def: resolveStatement(n : CPL!Node) : SPL!Statement =
	if n.oclIsKindOf(CPL!Proxy) then
		if n.isSimple then
			thisModule.Proxy2Return(n)
		else
			thisModule.Proxy2Select(n)
		endif
	else if n.oclIsKindOf(CPL!SubCall) then
		thisModule.SubCall2Return(n)
	else if n.oclIsKindOf(CPL!Redirect) then
		thisModule.Redirect2Return(n)
	else if n.oclIsKindOf(CPL!AddressSwitch) then
		thisModule.AddressSwitch2SelectStat(n)
	else
		OclUndefined
	endif endif endif endif;

lazy rule Proxy2Return {
	from
		p : CPL!Proxy (p.isSimple)
	to
		r : SPL!ReturnStat (
			returnedValue <- fe
		),
		fe : SPL!ForwardExp (
			isParallel <- false,
			exp <- se
		),
		se : SPL!ConstantExp (
			value <- sc
		),
		sc : SPL!SequenceConstant (
			values <- p.locations->collect(l | thisModule.Location2URIConstant(l))
		)
}

lazy rule Proxy2Select {
	from
		p : CPL!Proxy (not p.isSimple)
	to
		s : SPL!SelectStat (
			matchedExp <- fe,
			selectCases <- Sequence{}
				->union(if not p.busy.oclIsUndefined() then Sequence{thisModule.Busy2SelectCase(p.busy)} else Sequence{} endif)
				->union(if not p.noAnswer.oclIsUndefined() then Sequence{thisModule.NoAnswer2SelectCase(p.noAnswer)} else Sequence{} endif)
				->union(if not p.redirection.oclIsUndefined() then Sequence{thisModule.Redirection2SelectCase(p.redirection)} else Sequence{} endif),
			selectDefault <- if not p.default.oclIsUndefined() then
								thisModule.Default2SelectDefault(p.default)
							else
								OclUndefined
							endif
		),
		fe : SPL!ForwardExp (
			isParallel <- false,
			exp <- ce
		),
		ce : SPL!ConstantExp (
			value <- sc
		),
		sc : SPL!SequenceConstant (
			values <- p.locations->collect(l | thisModule.Location2URIConstant(l))
		)
}

lazy rule Busy2SelectCase {
	from
		b : CPL!Busy
	to
		c : SPL!SelectCase (
			values <- Sequence{v},
			statements <- if not b.contents.oclIsUndefined() then
							Sequence{thisModule.resolveStatement(b.contents)}
						else
							Sequence{}
						endif
		),
		v : SPL!StringConstant (
			value <- 'busy'
		)
}

lazy rule NoAnswer2SelectCase {
	from
		na : CPL!NoAnswer
	to
		c : SPL!SelectCase (
			values <- Sequence{v},
			statements <- if not na.contents.oclIsUndefined() then
							Sequence{thisModule.resolveStatement(na.contents)}
						else
							Sequence{}
						endif
		),
		v : SPL!StringConstant (
			value <- 'noanswer'
		)
}

lazy rule Redirection2SelectCase {
	from
		rd : CPL!Redirection
	to
		c : SPL!SelectCase (
			values <- Sequence{v},
			statements <- if not rd.contents.oclIsUndefined() then
							Sequence{thisModule.resolveStatement(rd.contents)}
						else
							Sequence{}
						endif
		),
		v : SPL!StringConstant (
			value <- 'redirection'
		)
}

lazy rule Default2SelectDefault {
	from
		d : CPL!Default
	to
		sd : SPL!SelectDefault (
			statements <- if not d.contents.oclIsUndefined() then
							Sequence{thisModule.resolveStatement(d.contents)}
						else
							Sequence{}
						endif
		)
}

lazy rule SubCall2Return {
	from
		sc : CPL!SubCall
	to
		r : SPL!ReturnStat (
			returnedValue <- fce
		),
		fce : SPL!FunctionCallExp (
			functionCall <- fc
		),
		fc : SPL!FunctionCall (
			function <- CPL!SubAction.allInstances()->select(sa | sa.id = sc.ref)->first(),
			parameters <- Sequence{}
		)
}

lazy rule Redirect2Return {
	from
		rd : CPL!Redirect
	to
		r : SPL!ReturnStat (
			returnedValue <- ce
		),
		ce : SPL!ConstantExp (
			value <- rc
		),
		rc : SPL!ResponseConstant (
			response <- rr
		),
		rr : SPL!RedirectionErrorResponse (
			errorKind <- if rd.permanent =