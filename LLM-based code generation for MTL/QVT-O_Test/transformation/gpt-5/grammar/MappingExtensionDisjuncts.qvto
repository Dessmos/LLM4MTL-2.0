modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()[EPackage].map p2p();
}

mapping ECORE::EPackage::p2p(in inPkg : ECORE::EPackage) : ECORE::EPackage {
	init {
		result.name := inPkg.name;
	}
	inPkg.eClassifiers[EClass]->map makeClass();
}

mapping ECORE::EClass::makeClass(in inCls : ECORE::EClass) : ECORE::EClass
	disjuncts makeAClass, makeBClass {
}

mapping ECORE::EClass::makeAClass(in inCls : ECORE::EClass) : ECORE::EClass
	when { inCls.name.substring(1,1) = "A" } {
	init {
		result.name := inCls.name + "A";
	}
}

mapping ECORE::EClass::makeBClass(in inCls : ECORE::EClass) : ECORE::EClass
	when { inCls.name.substring(1,1) = "B" } {
	init {
		result.name := inCls.name + "B";
	}
}