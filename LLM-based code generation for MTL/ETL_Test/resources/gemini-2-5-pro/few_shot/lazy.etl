transformation FlowchartToHtml

model Flowchart metamodel "http://vitruv.tools/methodologisttemplate/flowchart"
model HTML metamodel "http://vitruv.tools/methodologisttemplate/HTML"

rule Flowchart2Heading
	transform f : Flowchart!Flowchart
	to d : HTML!DIV {
		d.children.addAll(f.nodes.equivalent());
	}

@lazy
rule Action2Heading
	transform a : Flowchart!Action
	to h1 : HTML!H1 {
		h1.value = a.name;
	}

@lazy
rule Decision2Heading
	transform d : Flowchart!Decision
	to h1 : HTML!H1 {
		h1.value = d.name;
	}

rule Transition2Heading
	transform t : Flowchart!Transition
	to h1 : HTML!H1 {
		h1.value = t.name;
	}