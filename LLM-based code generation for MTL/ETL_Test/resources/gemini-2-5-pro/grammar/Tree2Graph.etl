transformation TreeToGraph

model Tree metamodel uri "http://vitruv.tools/methodologisttemplate/Tree"
model Graph metamodel uri "http://vitruv.tools/methodologisttemplate/Graph"

rule Tree2Node
	transform t : Tree!Tree
	to n : Graph!Node {
	
	n.name = t.label;
	
	if (t.parent.isDefined()) {
		var e : new Graph!Edge;
		e.target = n;
		t.parent.equivalent().outgoing.add(e);
	}
}