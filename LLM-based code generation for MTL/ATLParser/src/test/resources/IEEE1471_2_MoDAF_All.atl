-- @atlcompiler emftvm
module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!IEEE1471Model def: rationale() : String =
	self.rationale.name + ': ' + self.rationale.content;

-- This lazy rule is used to create the association class between Stakeholders and Concerns.
lazy rule StakeholderHasConcern {
	from
		s : IEEE1471!Stakeholder,
		c : IEEE1471!Concern
	to
		t : MoDAF!StakeholderHasConcern (
			client <- s,
			supplier <- c,
			owner <- MoDAF!MoDAFModel.allInstancesFrom('OUT')->first()
		)
}

-- This lazy rule creates a special Architectural Framework for viewpoints that do not have a source library.
-- A guard ensures it only runs if such viewpoints exist.
lazy rule CreateUndefinedArchitecturalFramework {
	from
		m : IEEE1471!IEEE1471Model (
			IEEE1471!Viewpoint.allInstances()->exists(vp | vp.hasSource.oclIsUndefined())
		)
	to
		t : MoDAF!ArchitecturalFramework (
			name <- 'Undefined Architectural Framework',
			content <- 'A default framework for viewpoints without a specified source.',
			ownedMember <- IEEE1471!Viewpoint.allInstances()->select(vp | vp.hasSource.oclIsUndefined())
		)
}

-- Entrypoint rule: Transforms the root of the IEEE1471 model.
rule IEEE1471Model2MoDAFModel {
	from
		s : IEEE1471!IEEE1471Model
	to
		t : MoDAF!MoDAFModel (
			name <- s.name,
			content <- s.content,
			enterprise <- s.system,
			environment <- s.environment,
			operationalMissions <- s.missions,
			architectures <- s.architecture,
			architecturalDescription <- s.architecturalDescription,
			stakeholders <- s.stakeholders,
			-- Create frameworks from library viewpoints AND call the lazy rule for the undefined one.
			architecturalFrameworks <- s.libraryViewpoints->append(thisModule.CreateUndefinedArchitecturalFramework(s)),
			-- Create Stakeholder-Concern links by iterating and calling the lazy rule.
			stakeholderHasConcerns <- IEEE1471!Stakeholder.allInstances()->collect(sh |
				sh.has->collect(c | thisModule.StakeholderHasConcern(sh, c))
			)->flatten()
		)
}

rule System2Enterprise {
	from
		s : IEEE1471!System
	to
		t : MoDAF!Enterprise (
			name <- s.name,
			content <- s.content,
			fulfills <- s.fulfills,
			inhabits <- s.inhabits
		)
}

rule Environment2Environment {
	from
		s : IEEE1471!Environment
	to
		t : MoDAF!Environment (
			name <- s.name,
			content <- s.content
		)
}

rule Mission2OperationalMission {
	from
		s : IEEE1471!Mission
	to
		t : MoDAF!OperationalMission (
			name <- s.name,
			content <- s.content
		)
}

rule Architecture2Architecture {
	from
		s : IEEE1471!Architecture
	to
		t : MoDAF!Architecture (
			name <- s.name,
			content <- s.content,
			describedBy <- s.describedBy,
			enterprise <- s.eContainer().oclAsType(IEEE1471!IEEE1471Model).system
		)
}

rule AD2AD {
	from
		s : IEEE1471!ArchitecturalDescription
	to
		t : MoDAF!ArchitecturalDescription (
			name <- s.name,
			content <- s.content,
			approvialAuthority <- 'Undefined',
			architect <- 'Undefined',
			assumptionAndConstraints <- 'Undefined',
			creatingOrganisation <- 'Undefined',
			dateCompleted <- 'Undefined',
			purpose <- s.eContainer().oclAsType(IEEE1471!IEEE1471Model).rationale(),
			recommendations <- 'Undefined',
			summaryOfFindings <- 'Undefined',
			tollsUsed <- 'Undefined',
			viewpoints <- s.selects,
			products <- s.organizedBy
		)
}

rule Stakeholder2Stakeholder {
	from
		s : IEEE1471!Stakeholder
	to
		t : MoDAF!Stakeholder (
			name <- s.name,
			content <- s.content
		)
}

rule Viewpoint2View {
	from
		s : IEEE1471!Viewpoint
	to
		t : MoDAF!View (
			name <- s.name,
			content <- s.content,
			viewName <- s.name,
			viewDescription <- s.content,
			viewCode <- s.name,
			usedToCover <- s.usedToCover,
			-- This reference will be set by the containing ArchitecturalFramework
			definingFramework <- s.hasSource
		)
}

rule View2ArchitecturalProduct {
	from
		s : IEEE1471!View
	to
		t : MoDAF!ArchitecturalProduct (
			name <- s.name,
			description <- s.content,
			architecturalElements <- s.consitsOf,
			definingView <- s.conformsTo,
			addresses <- s.conformsTo.usedToCover
		)
}

rule Model2Element {
	from
		s : IEEE1471!Model
	to
		t : MoDAF!Elements (
			name <- s.name,
			content <- s.content
		)
}

rule Concern2Concern {
	from
		s : IEEE1471!Concern
	to
		t : MoDAF!Concern (
			name <- s.name,
			content <- s.content
		)
}

rule LibraryViewpoint2ArchitecturalFramework {
	from
		s : IEEE1471!LibraryViewpoint
	to
		t : MoDAF!ArchitecturalFramework (
			name <- s.name,
			content <- s.content,
			ownedMember <- IEEE1471!Viewpoint.allInstances()->select(vp | vp.hasSource = s)
		)
}