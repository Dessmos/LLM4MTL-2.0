module Make2Ant;
create OUT : Ant from IN : Make;

rule Makefile2Project {
	from
		m : Make!Makefile
	to
		p : Ant!Project (
			name <- m.name,
			description <- if m.comment.oclIsUndefined() then '' else m.comment.text endif,
			default <- m.elements->select(e | e.oclIsTypeOf(Make!Rule))->first(),
			properties <- m.elements->select(e | e.oclIsTypeOf(Make!Macro)),
			targets <- m.elements->select(e | e.oclIsTypeOf(Make!Rule))
		)
}

rule Macro2Property {
	from
		ma : Make!Macro
	to
		pr : Ant!PropertyValue (
			name <- ma.name,
			value <- ma.value
		)
}

rule Rule2Target {
	from
		r : Make!Rule
	to
		t : Ant!Target (
			name <- r.name,
			depends <- r.dependencies->select(d | d.oclIsTypeOf(Make!RuleDep))->collect(rd | rd.oclAsType(Make!RuleDep).ruledep),
			tasks <- r.shellLines
		)
}

rule ShellLine2Task_Display {
	from
		s : Make!ShellLine (s.display = true)
	to
		e : Ant!Echo (
			message <- s.command
		)
}

rule ShellLine2Task_NoDisplay {
	from
		s : Make!ShellLine (s.display = false)
	to
		e : Ant!Exec (
			executable <- s.command
		)
}