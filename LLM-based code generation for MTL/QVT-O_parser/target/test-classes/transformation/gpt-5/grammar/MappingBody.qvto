modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()[EPackage]->map p2p();
}

mapping ECORE::EPackage::p2p() : ECORE::EPackage {
	init {
		result.name := self.name;
	}
	self.eClassifiers[EClassifier]->map c2c();
}

mapping ECORE::EClassifier::c2c() : ECORE::EClassifier
	when { self.name = 'A' } {
	init {
		result := new ECORE::EDataType();
		result.name := 'mapped' + self.name;
	}
}

mapping ECORE::EClassifier::c2c() : ECORE::EClassifier
	when { self.name <> 'A' } {
	init {
		result := new ECORE::EClass();
		result.name := 'mapped' + self.name;
	}
}

constructor ECORE::EClass::InitWithNameAndOperation(n : ECORE::EString, op : ECORE::EOperation) {
	self.name := n;
	self.eOperations += op;
}