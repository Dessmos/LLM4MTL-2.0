modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation transf(in inModel : ECORE, out outModel1 : ECORE, out outModel2 : ECORE);

main() {
	var p1 : ECORE::EPackage := object ECORE::EPackage {
		name := "a";
	};
	var p2 : ECORE::EPackage := object ECORE::EPackage {
		name := "b";
	};
}

mapping ECORE::EClass::toClass() : ECORE::EClass {
	init {
		result := object ECORE::EClass {
			name := self.name;
		};
	}
}