import ecore : 'http://www.eclipse.org/emf/2002/Ecore';

modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()
		->select(oclIsKindOf(ecore::EPackage))
		->map p2p();
}

mapping ecore::EPackage::p2p() : ecore::EPackage {
	name := self.name;
	eClassifiers += self.eClassifiers->select(oclIsKindOf(ecore::EClass))->map makeClass();
}

abstract mapping ecore::EClassifier::makeClassifier() : ecore::EClassifier {
	name := self.name.concat('1');
}

mapping ecore::EClass::makeClass() : ecore::EClass
	inherits ecore::EClassifier::makeClassifier {
	init {
		var suffix : String := '2';
	}
	name := name.concat(suffix);
}