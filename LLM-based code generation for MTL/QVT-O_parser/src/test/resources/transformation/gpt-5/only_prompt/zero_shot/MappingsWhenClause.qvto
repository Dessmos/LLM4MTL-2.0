import ecore : "http://www.eclipse.org/emf/2002/Ecore";

modeltype ECORE uses ecore;

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()
		->select(oclIsKindOf(EPackage))
		->map p2p();
}

mapping EPackage::p2p() : EPackage {
	result.name := self.name;
	result.eClassifiers := self.eClassifiers
		->select(oclIsKindOf(EClassifier))
		->map c2c();
}

mapping EClassifier::c2c() : EClass
	when { self.name = 'A'; } {
	result.name := 'mapped' + self.name;
}

constructor EClass::EClass(name : String, op : EOperation) {
	self.name := name;
	self.eOperations += op;
}