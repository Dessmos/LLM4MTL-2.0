modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()[EPackage]->map p2p();
}

mapping ECORE::EPackage::p2p() : ECORE::EPackage {
	name := self.name;
	eClassifiers := self.eClassifiers->map c2c();
}

mapping ECORE::EClassifier::c2c() : ECORE::EClass
when { self.name = 'A' }
{
	name := 'mapped' + self.name;
}

constructor ECORE::EClass::EClass(newName : String, op : ECORE::EOperation) {
	self.name := newName;
	self.eOperations += op;
}