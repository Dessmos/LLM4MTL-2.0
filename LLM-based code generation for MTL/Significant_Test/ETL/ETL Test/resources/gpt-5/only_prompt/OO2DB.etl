pre {
	var db : DB!Database := new DB!Database;
	db.contents.addAll(DB!DatabaseElement.allInstances());
	Database := db;
	var trace : SimpleTrace!Trace := new SimpleTrace!Trace;
	TraceModel := trace;
}

post {
	for (s in OO!Package.allInstances().includingAll(OO!PackageableElement.allInstances()).includingAll(OO!Feature.allInstances())) {
		var targets : Sequence(EObject) := s.equivalent();
		if (not targets.isEmpty()) {
			var link : SimpleTrace!TraceLink := new SimpleTrace!TraceLink;
			link.description := "Trace for " + s.eClass().name + " " + s.toString();
			link.sources.add(s);
			link.targets.addAll(targets);
			TraceModel.links.add(link);
		}
	}
}

rule Class2Table
	transform s : OO!Class
	to t : DB!Table {
	t.name := s.name;
	t.database := Database;
	Database.contents.add(t);
	if (s.extends.isDefined()) {
		for (pk in s.extends.equivalent().select(e|e.isKindOf(DB!Table)).first().primaryKeys) {
			var inhCol : DB!Column := new DB!Column;
			inhCol.name := pk.name;
			inhCol.type := pk.type;
			inhCol.table := t;
			t.columns.add(inhCol);
			t.primaryKeys.add(inhCol);
		}
	}
	var pkCol : DB!Column := new DB!Column;
	pkCol.name := s.primaryKeyName();
	pkCol.type := "INTEGER";
	pkCol.table := t;
	t.columns.add(pkCol);
	if (t.primaryKeys.isEmpty()) {
		t.primaryKeys.add(pkCol);
	}
}

rule SingleValuedAttribute2Column
	transform a : OO!Attribute
	to c : DB!Column
when {
	not a.isMany and a.owner.isDefined() and a.owner.isKindOf(OO!Class)
} {
	var table : DB!Table := a.owner.equivalent().select(e|e.isKindOf(DB!Table)).first();
	c.name := a.name;
	if (a.type.isKindOf(OO!Datatype)) {
		c.type := a.type.toDbType();
	} else {
		c.type := "INTEGER";
	}
	c.table := table;
	table.columns.add(c);
}

rule MultiValuedAttribute2Table
	transform a : OO!Attribute
	to t : DB!Table
when {
	a.isMany and a.owner.isDefined() and a.owner.isKindOf(OO!Class)
} {
	t.name := a.valuesTableName();
	t.database := Database;
	Database.contents.add(t);
	var ownerPkName : String := a.owner.primaryKeyName();
	var ownerPkCol : DB!Column := new DB!Column;
	ownerPkCol.name := ownerPkName;
	ownerPkCol.type := "INTEGER";
	ownerPkCol.table := t;
	t.columns.add(ownerPkCol);
	t.primaryKeys.add(ownerPkCol);
	var valueCol : DB!Column := new DB!Column;
	valueCol.name := "value";
	if (a.type.isKindOf(OO!Datatype)) {
		valueCol.type := a.type.toDbType();
	} else {
		valueCol.type := "INTEGER";
	}
	valueCol.table := t;
	t.columns.add(valueCol);
}

rule Reference2ForeignKey
	transform r : OO!Reference
	to fk : DB!ForeignKey,
	   col : DB!Column
when {
	not r.isMany and r.owner.isDefined() and r.owner.isKindOf(OO!Class) and r.type.isKindOf(OO!Class)
} {
	var srcTable : DB!Table := r.owner.equivalent().select(e|e.isKindOf(DB!Table)).first();
	var trgTable : DB!Table := r.type.equivalent().select(e|e.isKindOf(DB!Table)).first();
	var trgPk : DB!Column := trgTable.primaryKeys.first();
	col.name := r.name + "_" + trgPk.name;
	col.type := trgPk.type;
	col.table := srcTable;
	srcTable.columns.add(col);
	fk.name := r.name + "_FK";
	fk.child := col;
	fk.parent := trgPk;
	fk.database := Database;
	Database.contents.add(fk);
}

operation OO!Class primaryKeyName() : String {
	return self.name.toUpperCase() + "_ID";
}

operation OO!Attribute valuesTableName() : String {
	return self.owner.name.toUpperCase() + "_" + self.name.toUpperCase();
}

operation OO!Classifier toDbType() : String {
	var tm : TM!TypeMap := TM!TypeMap.allInstances().first();
	if (tm.isUndefined()) {
		return "VARCHAR";
	}
	var mapping : TM!TypeMapping := tm.mappings.selectOne(m|m.source = self.name);
	if (mapping.isDefined()) {
		return mapping.target;
	}
	if (tm.default.isDefined()) {
		return tm.default.target;
	}
	return "VARCHAR";
}