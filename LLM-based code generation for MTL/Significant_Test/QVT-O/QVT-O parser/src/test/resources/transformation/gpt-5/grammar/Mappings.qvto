modeltype EcoreMT uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inRoot : EcoreMT::EPackage, out outRoot : EcoreMT::EPackage);

main() {
	inRoot->map p2p();
}

mapping EcoreMT::EPackage::p2p() : EcoreMT::EPackage {
	init {
		result.name := self.name;
	}
	self.eClassifiers->map c2c();
}

mapping EcoreMT::EClassifier::c2c() : EcoreMT::EClass {
	init {
		result.name := "mapped" + self.name;
	}
}