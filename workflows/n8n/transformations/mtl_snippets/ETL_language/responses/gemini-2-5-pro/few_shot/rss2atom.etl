transformation Rss2Atom

model RSS metamodel "http://vitruv.tools/methodologisttemplate/RSS"
model Atom metamodel "http://vitruv.tools/methodologisttemplate/Atom"

@primary
rule Rss2Atom
	transform rss : RSS!RSS
	to feed : Atom!Feed {
	
	feed.appendEquivalentsOfChildrenOf(rss.channel);
	feed.entries.addAll(rss.channel.items.equivalent());
}

rule Item2Entry
	transform item : RSS!Item
	to entry : Atom!Entry {
	
	entry.appendEquivalentsOfChildrenOf(item);
}

@lazy
rule Title2Title
	transform t : RSS!Title
	to t2 : Atom!Title {
	t2.text = t.text;
}

@lazy
rule Link2Link
	transform l : RSS!Link
	to l2 : Atom!Link {
	l2.href = l.text;
}

@lazy
rule Generator2Generator
	transform g : RSS!Generator
	to g2 : Atom!Generator {
	g2.text = g.text;
}

@lazy
rule Creator2Author
	transform c : RSS!Creator
	to a : Atom!Author {
	a.name = c.text;
}

@lazy
rule Description2Summary
	transform d : RSS!Description
	to s : Atom!Summary {
	s.text = d.text;
}

@lazy
rule ContentEncoded2Content
	transform ce : RSS!ContentEncoded
	to c : Atom!Content {
	c.text = ce.text;
}

@lazy
rule PubDate2Published
	transform pd : RSS!PubDate
	to p : Atom!Published {
	p.text = pd.text;
}

operation Atom!Feed appendChildren(channel : RSS!Channel) {
	self.title ::= channel.title;
	self.link ::= channel.link;
	self.summary ::= channel.description;
	if (channel.generator.isDefined()) {
		self.generator ::= channel.generator;
	}
}

operation Atom!Feed appendEquivalentsOfChildrenOf(channel : RSS!Channel) {
	self.appendChildren(channel);
}

operation Atom!Entry appendChildren(item : RSS!Item) {
	self.title ::= item.title;
	self.link ::= item.link;
	self.summary ::= item.description;
	if (item.creator.isDefined()) {
		self.author ::= item.creator;
	}
	if (item.contentEncoded.isDefined()) {
		self.content ::= item.contentEncoded;
	}
	if (item.pubDate.isDefined()) {
		self.published ::= item.pubDate;
	}
}

operation Atom!Entry appendEquivalentsOfChildrenOf(item : RSS!Item) {
	self.appendChildren(item);
}