pre {
	var db = new DB!Database;
	var trace = new SimpleTrace!Trace;
}
rule Class2Table
	transform c : OO!Class
	to t : DB!Table {
	guard : not c.isAbstract
	t.name = c.name;
	t.database = db;
	var pk = new DB!Column;
	pk.name = t.primaryKeyName();
	pk.type = "INTEGER";
	pk.table = t;
	t.primaryKeys.add(pk);
	var allFeatures = c.allFeatures();
	t.columns.addAll(allFeatures.select(f | f.isTypeOf(OO!Attribute) and not f.isMany).equivalent());
	allFeatures.select(f | (f.isTypeOf(OO!Attribute) and f.isMany) or f.isTypeOf(OO!Reference)).equivalent();
}
rule SingleValuedAttribute2Column
	transform a : OO!Attribute
	to col : DB!Column {
	guard : not a.isMany
	col.name = a.name;
	col.type = a.type.toDbType();
	col.table ::= a.owner;
}
rule MultiValuedAttribute2Table
	transform a : OO!Attribute
	to valueTable : DB!Table {
	guard : a.isMany
	valueTable.name = a.valuesTableName();
	valueTable.database = db;
	var ownerTable = a.owner.equivalent("t");
	var ownerFkCol = new DB!Column;
	ownerFkCol.name = a.owner.name.firstToLowerCase() + "Id";
	ownerFkCol.type = "INTEGER";
	ownerFkCol.table = valueTable;
	var ownerFk = new DB!ForeignKey;
	ownerFk.name = valueTable.name + "_" + ownerTable.name + "_FK";
	ownerFk.child = ownerFkCol;
	ownerFk.parent = ownerTable.primaryKeys.first();
	ownerFk.database = db;
	var valueCol = new DB!Column;
	valueCol.name = "value";
	valueCol.type = a.type.toDbType();
	valueCol.table = valueTable;
	valueTable.primaryKeys.add(ownerFkCol);
	valueTable.primaryKeys.add(valueCol);
}
rule Reference2ForeignKey
	transform r : OO!Reference
	to fk : DB!ForeignKey {
	guard : not r.isMany
	var ownerTable = r.owner.equivalent("t");
	var referencedTable = r.type.equivalent("t");
	var fkCol = new DB!Column;
	fkCol.name = r.name + "Id";
	fkCol.type = "INTEGER";
	ownerTable.columns.add(fkCol);
	fk.name = ownerTable.name + "_" + referencedTable.name + "_" + r.name + "_FK";
	fk.database = db;
	fk.child = fkCol;
	fk.parent = referencedTable.primaryKeys.first();
}
post {
	for (t in _tracemodel.traces) {
		var link = new SimpleTrace!TraceLink;
		link.sources.add(t.source);
		link.targets.addAll(t.targets);
		trace.links.add(link);
	}
}
operation DB!Table primaryKeyName() : String {
	return self.name.firstToLowerCase() + "Id";
}
operation OO!Attribute valuesTableName() : String {
	return self.owner.name + "_" + self.name;
}
operation OO!Classifier toDbType() : String {
	switch (self.name) {
		case "String": return "VARCHAR(255)";
		case "Integer": return "INT";
		case "Boolean": return "BOOLEAN";
		default: return "VARCHAR(255)";
	}
}
operation OO!Class allFeatures() : Collection {
	var features = self.features.clone();
	if (self.extends.isDefined()) {
		features.addAll(self.extends.allFeatures());
	}
	return features;
}