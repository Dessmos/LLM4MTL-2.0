transformation Rss2Atom

model RSS metamodel "http://vitruv.tools/methodologisttemplate/RSS"
model Atom metamodel "http://vitruv.tools/methodologisttemplate/Atom"

rule Rss2Atom
  transform rss : RSS!RSS
  to feed : Atom!Feed {
  feed.root ::= rss;
  feed.entries.addAll(rss.items.equivalent());
  var otherChildren = rss.eContents().reject(c | c.isTypeOf(RSS!Item));
  feed.appendChildren(otherChildren.equivalent());
}

rule Item2Entry
  transform item : RSS!Item
  to entry : Atom!Entry {
  entry.appendEquivalentsOfChildrenOf(item);
}

rule Title2Title
  transform src : RSS!Title
  to trg : Atom!Title {
  trg.text = src.text;
}

rule Link2Link
  transform src : RSS!Link
  to trg : Atom!Link {
  trg.text = src.text;
}

rule Generator2Generator
  transform src : RSS!Generator
  to trg : Atom!Generator {
  trg.text = src.text;
}

rule Creator2Author
  transform src : RSS!Creator
  to trg : Atom!Author {
  trg.name = src.text;
}

rule Description2Summary
  transform src : RSS!Description
  to trg : Atom!Summary {
  trg.text = src.text;
}

rule ContentEncoded2Content
  transform src : RSS!ContentEncoded
  to trg : Atom!Content {
  trg.text = src.text;
}

rule PubDate2Published
  transform src : RSS!PubDate
  to trg : Atom!Published {
  trg.text = src.text;
}

operation appendChildren(target, children) {
  for (child in children) {
    target.elements.add(child);
  }
}

operation appendEquivalentsOfChildrenOf(target, source) {
  target.appendChildren(source.eContents().equivalent());
}