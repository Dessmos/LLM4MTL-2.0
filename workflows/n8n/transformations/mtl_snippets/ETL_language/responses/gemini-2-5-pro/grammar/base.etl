transformation Flowchart2Html

model flowchart
	uses "http://vitruv.tools/methodologisttemplate/flowchart"

model HTML
	uses "http://vitruv.tools/methodologisttemplate/HTML"

rule Flowchart2Heading
	transform f : flowchart!Flowchart
	to h : HTML!H1 {
	
	h.value = f.name;
}

rule Action2Heading
	transform a : flowchart!Action
	to h : HTML!H1 {
	
	h.value = a.name;
}

rule Decision2Heading
	transform d : flowchart!Decision
	to h : HTML!H1 {
	
	h.value = d.name;
}

rule Transition2Heading
	transform t : flowchart!Transition
	to h : HTML!H1 {
	
	h.value = t.name;
}