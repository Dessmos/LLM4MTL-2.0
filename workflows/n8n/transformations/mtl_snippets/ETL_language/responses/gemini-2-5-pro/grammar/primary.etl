transformation Flowchart2Html

model Flowchart driver EMF { nsuri = "flowchart" }
model HTML driver EMF { nsuri = "HTML" }

rule Flowchart2Heading
  transform s : Flowchart!Flowchart
  to t : HTML!DIV {
    for (tr in s.transitions) {
      t.children.add(tr.equivalent('Transition2Heading'));
    }
  }

rule Transition2SourceLink
  transform s : Flowchart!Transition
  to t : HTML!A {
    t.value = s.source.name;
    t.ahref = "#" + s.source.name;
  }

rule Transition2TargetLink
  transform s : Flowchart!Transition
  to t : HTML!A {
    t.value = s.name;
    t.ahref = "#" + s.target.name;
  }

rule Transition2Heading
  transform s : Flowchart!Transition
  to t : HTML!H1 {
    t.value = s.name;
  }