-- ATL transformation module to convert Class models to Interface models.
-- Simple transformation: maps classes to interfaces with their methods.
module Class2Interface_All;

create OUT : Interface from IN : Class;

-- Rule to transform a Class into an Interface.
rule Class2Interface {
  from 
    c : Class!Class
  to
    i : Interface!Interface (
      name <- c.name,
      methods <- c.methods
    )
}

-- Rule to transform a Method from Class to Interface.
rule Method2Method {
  from
    m : Class!Method
  to
    im : Interface!Method (
      name <- m.name,
      returnType <- m.returnType,
      parameters <- m.parameters
    )
}

-- Rule to transform a Parameter from Class to Interface.
rule Parameter2Parameter {
  from
    p : Class!Parameter
  to
    ip : Interface!Parameter (
      name <- p.name,
      type <- p.type
    )
}

