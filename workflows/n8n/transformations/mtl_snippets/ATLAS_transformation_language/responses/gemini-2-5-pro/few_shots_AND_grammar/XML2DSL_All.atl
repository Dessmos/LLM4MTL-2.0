module XML2DSL;
create OUT : DSL from IN : XML;

helper context XML!Element def:
	getAttrBool(attName : String) : Boolean = if self.hasAttr(attName) then let v = self.getAttrVal(attName).toLower() in v = 'true' or v = 'yes' or v = '1' else false endif;
helper context XML!Element def:
	getAttrVal(attName : String) : String = self.children->select(c | c.oclIsTypeOf(XML!Attribute) and c.name = attName)->first().value;
helper context XML!Element def:
	get(elemName : String) : Sequence(XML!Element) = self.children->select(c | c.oclIsTypeOf(XML!Element) and c.name = elemName)->asSequence();
helper context XML!Element def:
	getType() : String = self.getAttrVal('type');
helper context XML!Element def:
	getEnumId() : String = self.getAttrVal('id');
helper context XML!Element def:
	getText() : String = if self.children->exists(c | c.oclIsTypeOf(XML!Text)) then self.children->select(c | c.oclIsTypeOf(XML!Text))->first().value else '' endif;
helper context XML!Element def:
	getSeq(elemName : String) : Sequence(XML!Element) = self.get(elemName);
helper context XML!Element def:
	hasChildren(elemName : String) : Boolean = self.get(elemName)->notEmpty();
helper context XML!Element def:
	hasAttr(attName : String) : Boolean = self.children->exists(c | c.oclIsTypeOf(XML!Attribute) and c.name = attName);
helper context XML!Element def:
	isAbstract() : Boolean = self.getAttrBool('isAbstract');

helper def: dslElementsById : Map(String, DSL!NamedElement) =
	let xmlElementsById : Map(String, XML!Element) =
		XML!Element.allInstancesFrom('IN')->select(e | e.hasAttr('id'))
			->iterate(e; acc : Map(String, XML!Element) = Map {} |
				acc.including(e.getAttrVal('id'), e)
			)
	in
		xmlElementsById->iterate(entry; acc : Map(String, DSL!NamedElement) = Map {} |
			acc.including(entry.key, entry.value)
		);
helper def: getSubTypes(t : XML!Element) : Sequence(XML!Element) = XML!Element.allInstancesFrom('IN')->select(e | e.hasAttr('superType') and e.getAttrVal('superType') = t.getAttrVal('id'));
helper def: findType(name : String) : DSL!Type =
	let dm : DSL!DomainModel = DSL!DomainModel.allInstancesFrom('OUT')->first() in
	if dm.oclIsUndefined() then OclUndefined else dm.types->select(t | t.name = name)->first() endif;

rule DomainModel {
	from e : XML!Element (e.name = 'DomainModel')
	to
		dm : DSL!DomainModel (
			name <- e.getAttrVal('name'),
			identity <- e.getAttrVal('id'),
			namespace <- e.getAttrVal('namespace'),
			isLoaded <- e.getAttrBool('isLoaded'),
			classifiers <- e.get('Class')->union(e.get('Relationship')),
			types <- e.get('Enumeration')->union(Sequence{stringType, integerType, booleanType, decimalType})
		),
		stringType : DSL!SimpleType (name <- 'String', identity <- 'String', namespace <- e.getAttrVal('namespace')),
		integerType : DSL!SimpleType (name <- 'Integer', identity <- 'Integer', namespace <- e.getAttrVal('namespace')),
		booleanType : DSL!SimpleType (name <- 'Boolean', identity <- 'Boolean', namespace <- e.getAttrVal('namespace')),
		decimalType : DSL!SimpleType (name <- 'Decimal', identity <- 'Decimal', namespace <- e.getAttrVal('namespace'))
}
rule Class {
	from e : XML!Element (e.name = 'Class')
	to c : DSL!Class (
		name <- e.getAttrVal('name'),
		identity <- e.getAttrVal('id'),
		namespace <- e.getAttrVal('namespace'),
		isLoaded <- e.getAttrBool('isLoaded'),
		isAbstract <- e.isAbstract(),
		properties <- e.get('ValueProperty'),
		superType <- if e.hasAttr('superType') then thisModule.dslElementsById.get(e.getAttrVal('superType')).oclAsType(DSL!Classifier) else OclUndefined endif,
		subTypes <- thisModule.getSubTypes(e),
		domainModel <- e.parent
	)
}
rule Relationship {
	from e : XML!Element (e.name = 'Relationship')
	to r : DSL!Relationship (
		name <- e.getAttrVal('name'),
		identity <- e.getAttrVal('id'),
		namespace <- e.getAttrVal('namespace'),
		isLoaded <- e.getAttrBool('isLoaded'),
		isAbstract <- e.isAbstract(),
		isEmbedding <- e.getAttrBool('isEmbedding'),
		properties <- e.get('ValueProperty'),
		roles <- e.get('Role'),
		superType <- if e.hasAttr('superType') then thisModule.dslElementsById.get(e.getAttrVal('superType')).oclAsType(DSL!Classifier) else OclUndefined endif,
		subTypes <- thisModule.getSubTypes(e),
		domainModel <- e.parent
	)
}
rule Role {
	from e : XML!Element (e.name = 'Role')
	to r : DSL!Role (
		name <- e.getAttrVal('name'),
		identity <- e.getAttrVal('id'),
		min <- e.getAttrVal('min').toInteger(),
		max <- if e.getAttrVal('max') = '-1' then -1 else e.getAttrVal('max').toInteger() endif,
		isUnbounded <- e.getAttrVal('max') = '-1',
		accepts <- e.getAttrVal('accepts'),
		isOrdered <- e.getAttrBool('isOrdered'),
		isNavigableFrom <- e.getAttrBool('isNavigableFrom'),
		isPropertyGenerator <- e.getAttrBool('isPropertyGenerator'),
		source <- thisModule.dslElementsById.get(e.getAttrVal('source')).oclAsType(DSL!Classifier),
		type <- thisModule.dslElementsById.get(e.getAttrVal('type')).oclAsType(DSL!Classifier),
		relation <- e.parent
	)
}
rule ValueProperty {
	from e : XML!Element (e.name = 'ValueProperty')
	to p : DSL!ValueProperty (
		name <- e.getAttrVal('name'),
		identity <- e.getAttrVal('id'),
		owner <- e.parent,
		type <- thisModule.findType(e.getType())
	)
}
rule Enumeration {
	from e : XML!Element (e.name = 'Enumeration')
	to en : DSL!Enumeration (
		name <- e.getAttrVal('name'),
		identity <- e.getAttrVal('id'),
		namespace <- e.getAttrVal('namespace'),
		isLoaded <- e.getAttrBool('isLoaded'),
		literals <- e.get('Literal')
	)
}
rule EnumerationLiteral {
	from e : XML!Element (e.name = 'Literal')
	to l : DSL!EnumerationLiteral (
		name <- e.getAttrVal('name'),
		identity <- e.getEnumId(),
		value <- e.getAttrVal('value').toInteger()
	)
}