module User2Account_All;
create OUT : ACCOUNT from IN : USER;

helper context USER!User def: isActive() : Boolean =
	self.status = 'Active' or self.status = 'Enabled';

rule UserModel2AccountModel {
	from
		uModel : USER!UserModel
	to
		aModel : ACCOUNT!AccountModel (
			accounts <- uModel.users
		)
}

rule User2Account {
	from
		u : USER!User
	to
		a : ACCOUNT!Account (
			username <- u.username,
			email <- u.email,
			createdDate <- u.registrationDate,
			active <- u.isActive()
		)
}