```atl
module CPL2SPL;
create OUT : SPL from IN : CPL;

helper context CPL!Proxy def: statement : CPL!Node =
  if not self.busy.oclIsUndefined() and not self.busy.contents.oclIsUndefined() then
    self.busy.contents
  else if not self.noAnswer.oclIsUndefined() and not self.noAnswer.contents.oclIsUndefined() then
    self.noAnswer.contents
  else if not self.redirection.oclIsUndefined() and not self.redirection.contents.oclIsUndefined() then
    self.redirection.contents
  else if not self.failure.oclIsUndefined() and not self.failure.contents.oclIsUndefined() then
    self.failure.contents
  else if not self.default.oclIsUndefined() and not self.default.contents.oclIsUndefined() then
    self.default.contents
  else
    OclUndefined
  endif endif endif endif endif;

helper context CPL!Location def: locations : Sequence(CPL!Location) =
  if self.refImmediateComposite().oclIsKindOf(CPL!Location) then
    self.refImmediateComposite().locations->append(self)
  else
    Sequence{self}
  endif;

helper context CPL!Proxy def: isSimple : Boolean =
  CPL!Location.allInstances()->select(l | l.refImmediateComposite() = self)->size() = 1
  and self.busy.oclIsUndefined()
  and self.noAnswer.oclIsUndefined()
  and self.redirection.oclIsUndefined()
  and self.failure.oclIsUndefined()
  and self.default.oclIsUndefined();

rule CPL2Program {
  from c : CPL!CPL
  to   p : SPL!Program (
    service <- s
  ),
  s : SPL!Service (
    name <- 'CPLService',
    sessions <- Sequence{c.incoming, c.outgoing}->union(c.subActions)
  )
}

rule SubAction2Function {
  from sa : CPL!SubAction
  to   f : SPL!LocalFunctionDeclaration (
    name <- sa.id,
    returnType <- rt,
    statements <- Sequence{rs}
  ),
  rt : SPL!SimpleType (
    type <- #void
  ),
  rs : SPL!ReturnStat
}

rule Incoming2Method {
  from i : CPL!Incoming
  to   m : SPL!Method (
    type <- t,
    direction <- #inout,
    methodName <- mn,
    statements <- if i.contents.oclIsUndefined() then Sequence{rs} else Sequence{} endif,
    branches <- Sequence{db}
  ),
  t : SPL!SimpleType (
    type <- #void
  ),
  mn : SPL!SIPMethodName (
    name <- #INVITE
  ),
  rs : SPL!ReturnStat,
  db : SPL!DefaultBranch
}

rule Proxy2Return {
  from p : CPL!Proxy (p.isSimple)
  to   r : SPL!ReturnStat (
    returnedValue <- fe
  ),
  fe : SPL!ForwardExp (
    isParallel <- false,
    exp <- thisModule.Location2URIConstant(CPL!Location.allInstances()->select(l | l.refImmediateComposite() = p)->first())
  )
}

rule Proxy2Select {
  from p : CPL!Proxy (not p.isSimple)
  to   s : SPL!SelectStat (
    matchedExp <- re,
    selectCases <- Sequence{p.busy, p.noAnswer, p.redirection}->reject(nc | nc.oclIsUndefined()),
    selectDefault <- if not p.default.oclIsUndefined() then p.default else OclUndefined endif
  ),
  re : SPL!ReasonExp
}

rule Busy2SelectCase {
  from b : CPL!Busy
  to   sc : SPL!SelectCase (
    values <- Sequence{rc},
    statements <- if b.contents.oclIsUndefined() then Sequence{} else Sequence{} endif
  ),
  rc : SPL!ResponseConstant (
    response <- sr
  ),
  sr : SPL!ClientErrorResponse (
    errorKind <- #BUSY_HERE
  )
}

rule NoAnswer2SelectCase {
  from na : CPL!NoAnswer
  to   sc : SPL!SelectCase (
    values <- Sequence{rc},
    statements <- if na.contents.oclIsUndefined() then Sequence{} else Sequence{} endif
  ),
  rc : SPL!ResponseConstant (
    response <- sr
  ),
  sr : SPL!ClientErrorResponse (
    errorKind <- #REQUEST_TIMEOUT
  )
}

rule Redirection2SelectCase {
  from r : CPL!Redirection
  to   sc : SPL!SelectCase (
    values <- Sequence{rc1, rc2, rc3},
    statements <- if r.contents.oclIsUndefined() then Sequence{} else Sequence{} endif
  ),
  rc1 : SPL!ResponseConstant (
    response <- sr1
  ),
  sr1 : SPL!RedirectionErrorResponse (
    errorKind <- #MOVED_PERMANENTLY
  ),
  rc2 : SPL!ResponseConstant (
    response <- sr2
  ),
  sr2 : SPL!RedirectionErrorResponse (
    errorKind <- #MOVED_TEMPORARILY
  ),
  rc3 : SPL!ResponseConstant (
    response <- sr3
  ),
  sr3 : SPL!RedirectionErrorResponse (
    errorKind <- #MULTIPLE_CHOICES
  )
}

rule Default2SelectDefault {
  from d : CPL!Default
  to   sd : SPL!SelectDefault (
    statements <- if d.contents.oclIsUndefined() then Sequence{} else Sequence{} endif
  )
}

rule SubCall2Return {
  from sc : CPL!SubCall
  to   rs : SPL!ReturnStat (
    returnedValue <- fce
  ),
  fce : SPL!FunctionCallExp (
    functionCall <- fc
  ),
  fc : SPL!FunctionCall (
    function <- CPL!SubAction.allInstances()->select(sa | sa.id = sc.ref)->first()
  )
}

rule Redirect2Return {
  from r : CPL!Redirect
  to   rs : SPL!ReturnStat (
    returnedValue <- fe
  ),
  fe : SPL!ForwardExp (
    isParallel <- false,
    exp <- thisModule.Location2URIConstant(CPL!Location.allInstances()->select(l | l.refImmediateComposite() = r)->first())
  )
}

rule AddressSwitch2SelectStat {
  from as : CPL!AddressSwitch
  to   ss : SPL!SelectStat (
    matchedExp <- rurie,
    selectCases <- as.addresses,
    selectDefault <- if not as.otherwise.oclIsUndefined() then as.otherwise else OclUndefined endif
  ),
  rurie : SPL!RequestURIExp
}

rule SwitchedAddress2SelectCase {
  from sa : CPL!SwitchedAddress
  to   sc : SPL!SelectCase (
    values <- Sequence{uc},
    statements <- if sa.contents.oclIsUndefined() then Sequence{} else Sequence{} endif
  ),
  uc : SPL!URIConstant (
    uri <- if not sa.is.oclIsUndefined() then sa.is else if not sa.contains.oclIsUndefined() then sa.contains else if not sa.subDomainOf.oclIsUndefined() then sa.subDomainOf else '' endif endif endif
  )
}

rule Otherwise2Select