```atl
module BibTeX2DocBook;
create OUT : DocBook from IN : BibTeX;

helper context BibTeX!BibTeXEntry def: buildEntryPara() : String =
	self.id + ' (' + self.oclType().name + '): ' +
	if self.oclIsKindOf(BibTeX!TitledEntry) then
		'title=' + self.title + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!AuthoredEntry) then
		'authors=' + self.authors->collect(a | a.author)->sep('; ') + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!DatedEntry) then
		'year=' + self.year + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!BookTitledEntry) then
		'booktitle=' + self.booktitle + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!ThesisEntry) then
		'school=' + self.school + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!Article) then
		'journal=' + self.journal + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!Unpublished) then
		'note=' + self.note + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!Book) then
		'publisher=' + self.publisher + ', '
	else
		''
	endif +
	if self.oclIsKindOf(BibTeX!InBook) then
		'chapter=' + self.chapter.toString() + ', '
	else
		''
	endif;

helper def: authorSet : Sequence(BibTeX!Author) =
	BibTeX!Author.allInstances()->asSequence()->sortedBy(a | a.author);

helper def: titledEntrySet : Sequence(BibTeX!TitledEntry) =
	BibTeX!TitledEntry.allInstances()->asSequence()->sortedBy(e | e.title);

helper def: articleSet : Sequence(BibTeX!Article) =
	BibTeX!Article.allInstances()->select(a | not a.journal.oclIsUndefined())->asSequence()->sortedBy(a | a.journal);

rule Main {
	from
		bf : BibTeX!BibTeXFile
	to
		db : DocBook!DocBook (
			books <- Sequence{bk}
		),
		bk : DocBook!Book (
			articles <- Sequence{art}
		),
		art : DocBook!Article (
			title <- 'BibTeXML to DocBook',
			sections_1 <- Sequence{sect1, sect2, sect3, sect4}
		),
		sect1 : DocBook!Sect1 (
			title <- 'References List',
			paras <- bf.entries->asSequence()->sortedBy(e | e.id)->collect(e | thisModule.resolveTemp(e, 'entryPara'))
		),
		sect2 : DocBook!Sect1 (
			title <- 'Authors list',
			paras <- thisModule.authorSet->collect(a | thisModule.resolveTemp(a, 'authorPara'))
		),
		sect3 : DocBook!Sect1 (
			title <- 'Titles List',
			paras <- thisModule.titledEntrySet->collect(e | thisModule.resolveTemp(e, 'titlePara'))
		),
		sect4 : DocBook!Sect1 (
			title <- 'Journals List',
			paras <- thisModule.articleSet->collect(a | thisModule.resolveTemp(a, 'journalPara'))
		)
}

rule UntitledEntry {
	from
		e : BibTeX!BibTeXEntry (
			not e.oclIsKindOf(BibTeX!TitledEntry)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule TitledEntry_Title_NoArticle {
	from
		e : BibTeX!TitledEntry (
			not e.oclIsKindOf(BibTeX!Article) and thisModule.titledEntrySet->includes(e)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		),
		titlePara : DocBook!Para (
			content <- e.title
		)
}

rule TitledEntry_NoTitle_NoArticle {
	from
		e : BibTeX!TitledEntry (
			not e.oclIsKindOf(BibTeX!Article) and not thisModule.titledEntrySet->includes(e)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule Article_Title_Journal {
	from
		e : BibTeX!Article (
			thisModule.titledEntrySet->includes(e) and thisModule.articleSet->includes(e)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		),
		titlePara : DocBook!Para (
			content <- e.title
		),
		journalPara : DocBook!Para (
			content <- e.journal
		)
}

rule Article_NoTitle_Journal {
	from
		e : BibTeX!Article (
			not thisModule.titledEntrySet->includes(e) and thisModule.articleSet->includes(e)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		),
		journalPara : DocBook!Para (
			content <- e.journal
		)
}

rule Article_Title_NoJournal {
	from
		e : BibTeX!Article (
			thisModule.titledEntrySet->includes(e) and not thisModule.articleSet->includes(e)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		),
		titlePara : DocBook!Para (
			content <- e.title
		)
}

rule Article_NoTitle_NoJournal {
	from
		e : BibTeX!Article (
			not thisModule.titledEntrySet->includes(e) and not thisModule.articleSet->includes(e)
		)
	to
		entryPara : DocBook!Para (
			content <- e.buildEntryPara()
		)
}

rule Author {
	from
		a : BibTeX!Author (
			thisModule.authorSet->includes(a)
		)
	to
		authorPara : DocBook!Para (
			content <- a.author
		)
}
```