module Class2Interface_All;
create OUT : Interface from IN : Class;

rule ClassModel2InterfaceModel {
  from
    src : Class!ClassModel
  to
    dst : Interface!InterfaceModel (
      interfaces <- src.classes->collect(c | thisModule.Class2Interface(c))
    )
}

unique lazy rule Class2Interface {
  from
    c : Class!Class
  to
    i : Interface!Interface (
      name    <- c.name,
      methods <- c.methods->collect(m | thisModule.Method2Method(m))
    )
}

unique lazy rule Method2Method {
  from
    m : Class!Method
  to
    im : Interface!Method (
      name       <- m.name,
      returnType <- m.returnType,
      parameters <- m.parameters->collect(p | thisModule.Parameter2Parameter(p))
    )
}

unique lazy rule Parameter2Parameter {
  from
    p : Class!Parameter
  to
    ip : Interface!Parameter (
      name <- p.name,
      type <- p.type
    )
}