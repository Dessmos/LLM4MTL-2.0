module BibTeX2DocBook;

create OUT : DocBook from IN : BibTeX;

helper context BibTeX!BibTeXFile def: authorSet : Set(BibTeX!Author) =
  self.entries->select(e | e.oclIsKindOf(BibTeX!AuthoredEntry))
    ->collect(e | e.oclAsType(BibTeX!AuthoredEntry).authors)->asSet();

helper context BibTeX!BibTeXFile def: titledEntrySet : Set(BibTeX!TitledEntry) =
  self.entries->select(e | e.oclIsKindOf(BibTeX!TitledEntry))
    ->collect(e | e.oclAsType(BibTeX!TitledEntry))->asSet();

helper context BibTeX!BibTeXFile def: articleSet : Set(BibTeX!Article) =
  self.entries->select(e | e.oclIsKindOf(BibTeX!Article))
    ->collect(e | e.oclAsType(BibTeX!Article))->asSet();

helper context BibTeX!BibTeXEntry def: buildEntryPara() : String =
  let base : String = self.id + ' (' + self.oclType().name + ')' in
  let t : String = if self.oclIsKindOf(BibTeX!TitledEntry) then
      ' title=' + self.oclAsType(BibTeX!TitledEntry).title
    else '' endif in
  let a : String = if self.oclIsKindOf(BibTeX!AuthoredEntry) then
      ' authors=' + self.oclAsType(BibTeX!AuthoredEntry).authors->collect(x | x.author)->join(', ')
    else '' endif in
  let y : String = if self.oclIsKindOf(BibTeX!DatedEntry) then
      ' year=' + self.oclAsType(BibTeX!DatedEntry).year
    else '' endif in
  let bt : String = if self.oclIsKindOf(BibTeX!BookTitledEntry) then
      ' booktitle=' + self.oclAsType(BibTeX!BookTitledEntry).booktitle
    else '' endif in
  let sc : String = if self.oclIsKindOf(BibTeX!ThesisEntry) then
      ' school=' + self.oclAsType(BibTeX!ThesisEntry).school
    else '' endif in
  let j : String = if self.oclIsKindOf(BibTeX!Article) then
      ' journal=' + self.oclAsType(BibTeX!Article).journal
    else '' endif in
  let n : String = if self.oclIsKindOf(BibTeX!Unpublished) then
      ' note=' + self.oclAsType(BibTeX!Unpublished).note
    else '' endif in
  let p : String = if self.oclIsKindOf(BibTeX!Book) then
      ' publisher=' + self.oclAsType(BibTeX!Book).publisher
    else '' endif in
  let c : String = if self.oclIsKindOf(BibTeX!InBook) then
      ' chapter=' + self.oclAsType(BibTeX!InBook).chapter.toString()
    else '' endif in
  base + t + a + y + bt + sc + j + n + p + c;

rule Main {
  from src : BibTeX!BibTeXFile
  to   db  : DocBook!DocBook (
         books <- Sequence{ b }
       ),
       b   : DocBook!Book (
         articles <- Sequence{ art }
       ),
       art : DocBook!Article (
         title      <- 'BibTeXML to DocBook',
         sections_1 <- Sequence{ refSect, authSect, titleSect, journalSect }
       ),
       refSect : DocBook!Sect1 (
         title <- 'References List',
         paras <- src.entries->sortedBy(id)->collect(e | resolveTemp(e, 'entryPara'))
       ),
       authSect : DocBook!Sect1 (
         title <- 'Authors list',
         paras <- src.authorSet->sortedBy(author)->collect(a | resolveTemp(a, 'authorPara'))
       ),
       titleSect : DocBook!Sect1 (
         title <- 'Titles List',
         paras <- src.titledEntrySet->sortedBy(title)->collect(e | resolveTemp(e, 'titlePara'))
                    ->select(p | p <> OclUndefined)
       ),
       journalSect : DocBook!Sect1 (
         title <- 'Journals List',
         paras <- src.articleSet->sortedBy(journal)->collect(a | resolveTemp(a, 'journalPara'))
                     ->select(p | p <> OclUndefined)
       )
}

lazy rule Author {
  from a : BibTeX!Author
  to   p : DocBook!Para (
    content <- a.author
  )
}

lazy rule UntitledEntry {
  from e : BibTeX!BibTeXEntry (not e.oclIsKindOf(BibTeX!TitledEntry))
  to   ep : DocBook!Para (
    content <- e.buildEntryPara()
  )
}

lazy rule TitledEntry_Title_NoArticle {
  from e : BibTeX!TitledEntry (
    e.oclIsKindOf(BibTeX!TitledEntry) and not e.oclIsKindOf(BibTeX!Article)
  )
  to   ep : DocBook!Para (
         content <- e.buildEntryPara()
       ),
       tp : DocBook!Para (
         content <- e.title
       )
}

lazy rule TitledEntry_NoTitle_NoArticle {
  from e : BibTeX!BibTeXEntry (
    not e.oclIsKindOf(BibTeX!TitledEntry) and not e.oclIsKindOf(BibTeX!Article)
  )
  to   ep : DocBook!Para (
    content <- e.buildEntryPara()
  )
}

lazy rule Article_Title_Journal {
  from e : BibTeX!Article
  to   ep : DocBook!Para (
         content <- e.buildEntryPara()
       ),
       tp : DocBook!Para (
         content <- e.title
       ),
       jp : DocBook!Para (
         content <- e.journal
       )
}

lazy rule Article_NoTitle_Journal {
  from e : BibTeX!Article
  to   ep : DocBook!Para (
         content <- e.buildEntryPara()
       ),
       jp : DocBook!Para (
         content <- e.journal
       )
}

lazy rule Article_Title_NoJournal {
  from e : BibTeX!Article
  to   ep : DocBook!Para (
         content <- e.buildEntryPara()
       ),
       tp : DocBook!Para (
         content <- e.title
       )
}

lazy rule Article_NoTitle_NoJournal {
  from e : BibTeX!Article
  to   ep : DocBook!Para (
    content <- e.buildEntryPara()
  )
}

helper def: dispatchEntry(e : BibTeX!BibTeXEntry) : OclAny =
  if e.oclIsKindOf(BibTeX!Article) then
    let a : BibTeX!Article = e.oclAsType(BibTeX!Article) in
      if a.title <> '' and a.journal <> '' then
        thisModule.Article_Title_Journal(a)
      else
        if a.title = '' and a.journal <> '' then
          thisModule.Article_NoTitle_Journal(a)
        else
          if a.title <> '' and a.journal = '' then
            thisModule.Article_Title_NoJournal(a)
          else
            thisModule.Article_NoTitle_NoJournal(a)
          endif
        endif
      endif
  else
    if e.oclIsKindOf(BibTeX!TitledEntry) then
      thisModule.TitledEntry_Title_NoArticle(e.oclAsType(BibTeX!TitledEntry))
    else
      thisModule.UntitledEntry(e)
    endif
  endif;

rule InitAllEntries {
  from e : BibTeX!BibTeXEntry
  do {
    thisModule.dispatchEntry(e);
  }
}