module IEEE1471_2_MoDAF;
create OUT : MoDAF from IN : IEEE1471;

helper context IEEE1471!IEEE1471Model def : rationale : String =
  let r : IEEE1471!Rationale = IEEE1471!Rationale.allInstances()->asSequence()->first()
  in r.name.concat(' - ').concat(r.content);

rule IEEE1471Model2MoDAFModel {
  from src : IEEE1471!IEEE1471Model
  to   dst : MoDAF!MoDAFModel (
    name        <- src.name,
    content     <- src.content,
    enterprise  <- thisModule.System2Enterprise(src.system),
    environment <- thisModule.Environment2Environment(src.environment),
    operationalMissions <- src.missions->collect(m | thisModule.Mission2OperationalMission(m)),
    architectures <- Sequence{ thisModule.Architecture2Architecture(src.architecture) },
    architecturalDescription <- Sequence{ thisModule.AD2AD(src.architecturalDescription) },
    architecturalFrameworks <- Sequence{ thisModule.createDefaultFramework(src) },
    stakeholders <- src.stakeholders->collect(s | thisModule.Stakeholder2Stakeholder(s)),
    stakeholderHasConcerns <- Sequence{}
  )
}

lazy rule System2Enterprise {
  from s : IEEE1471!System
  to   e : MoDAF!Enterprise (
    name       <- s.name,
    content    <- s.content,
    inhabits   <- thisModule.Environment2Environment(s.inhabits),
    fulfills   <- s.fulfills->collect(m | thisModule.Mission2OperationalMission(m))
  )
}

lazy rule Environment2Environment {
  from src : IEEE1471!Environment
  to   dst : MoDAF!Environment (
    name      <- src.name,
    content   <- src.content
  )
}

lazy rule Mission2OperationalMission {
  from src : IEEE1471!Mission
  to   dst : MoDAF!OperationalMission (
    name    <- src.name,
    content <- src.content
  )
}

lazy rule Architecture2Architecture {
  from src : IEEE1471!Architecture
  to   dst : MoDAF!Architecture (
    name       <- src.name,
    content    <- src.content,
    enterprise <- thisModule.System2Enterprise(src.describedBy.identifiesS->first().has->first().isImportantTo->first().has->first().has->first().hasAn), -- fallback, may be unused
    describedBy <- thisModule.AD2AD(src.describedBy)
  )
}

lazy rule AD2AD {
  from src : IEEE1471!ArchitecturalDescription
  to   dst : MoDAF!ArchitecturalDescription (
    name                     <- src.name,
    content                  <- src.content,
    approvialAuthority       <- '',
    architect                <- '',
    assumptionAndConstraints <- '',
    creatingOrganisation     <- '',
    dateCompleted            <- '',
    purpose                  <- '',
    recommendations          <- '',
    summaryOfFindings        <- '',
    tollsUsed                <- '',
    viewpoints               <- src.selects->collect(vp | thisModule.Viewpoint2View(vp)),
    products                 <- src.organizedBy->collect(v | thisModule.View2ArchitecturalProduct(v)),
    taxonomy                 <- thisModule.createDefaultTaxonomy(src)
  )
}

lazy rule Stakeholder2Stakeholder {
  from src : IEEE1471!Stakeholder
  to   dst : MoDAF!Stakeholder (
    name    <- src.name,
    content <- src.content
  )
}

lazy rule Concern2Concern {
  from src : IEEE1471!Concern
  to   dst : MoDAF!Concern (
    name    <- src.name,
    content <- src.content
  )
}

lazy rule Viewpoint2View {
  from src : IEEE1471!Viewpoint
  to   dst : MoDAF!View (
    name              <- src.name,
    content           <- src.content,
    framework         <- if src.hasSource.oclIsUndefined() then 'DefaultFramework' else src.hasSource.name endif,
    frameworkWebsite  <- '',
    viewCode          <- '',
    viewDescription   <- src.content,
    viewName          <- src.name,
    definingFramework <- thisModule.resolveFramework(src),
    usedToCover       <- src.usedToCover->collect(c | thisModule.Concern2Concern(c))
  )
}

lazy rule View2ArchitecturalProduct {
  from src : IEEE1471!View
  to   dst : MoDAF!ArchitecturalProduct (
    name                  <- src.name,
    content               <- src.content,
    description           <- src.content,
    architecturalElements <- src.consitsOf->collect(m | thisModule.Model2Element(m)),
    definingView          <- thisModule.Viewpoint2View(src.conformsTo),
    addresses             <- src.conformsTo.usedToCover->collect(c | thisModule.Concern2Concern(c))
  )
}

lazy rule Model2Element {
  from src : IEEE1471!Model
  to   dst : MoDAF!Elements (
    name    <- src.name,
    content <- src.content
  )
}

lazy rule LibraryViewpoint2ArchitecturalFramework {
  from src : IEEE1471!LibraryViewpoint
  to   dst : MoDAF!ArchitecturalFramework (
    name       <- src.name,
    content    <- src.content,
    ownedMember <- IEEE1471!Viewpoint.allInstances()
                    ->select(vp | vp.hasSource = src)
                    ->collect(vp | thisModule.Viewpoint2View(vp))
  )
}

rule StakeholderHasConcern {
  from sc : IEEE1471!Stakeholder (true)
  to   link : MoDAF!StakeholderHasConcern (
    client  <- thisModule.Stakeholder2Stakeholder(sc),
    supplier <- thisModule.Concern2Concern(sc.has->first()),
    owner   <- thisModule.theModel()
  )
}

helper def : theModel() : MoDAF!MoDAFModel =
  MoDAF!MoDAFModel.allInstances()->asSequence()->first();

helper def : createDefaultFramework(src : IEEE1471!IEEE1471Model) : MoDAF!ArchitecturalFramework =
  MoDAF!ArchitecturalFramework.allInstances()
    ->select(af | af.name = 'DefaultFramework')
    ->any(true)
    .oclAsType(MoDAF!ArchitecturalFramework)
  else
    thisModule.buildDefaultFramework(src)
  endif;

lazy rule buildDefaultFramework {
  from src : IEEE1471!IEEE1471Model
  to   dst : MoDAF!ArchitecturalFramework (
    name       <- 'DefaultFramework',
    content    <- src.rationale.name.concat(' - ').concat(src.rationale.content),
    ownedMember <- IEEE1471!Viewpoint.allInstances()
                     ->select(vp | vp.hasSource.oclIsUndefined())
                     ->collect(vp | thisModule.Viewpoint2View(vp))
  )
}

helper def : resolveFramework(vp : IEEE1471!Viewpoint) : MoDAF!ArchitecturalFramework =
  if vp.hasSource.oclIsUndefined() then
    thisModule.createDefaultFramework(vp.oclContainer().oclAsType(IEEE1471!IEEE1471Model))
  else
    thisModule.LibraryViewpoint2ArchitecturalFramework(vp.hasSource)
  endif;

lazy rule createDefaultTaxonomy {
  from src : IEEE1471!ArchitecturalDescription
  to   dst : MoDAF!Taxonomy (
    name    <- 'DefaultTaxonomy',
    content <- src.name,
    date    <- '',
    url     <- '',
    version <- ''
  )
}