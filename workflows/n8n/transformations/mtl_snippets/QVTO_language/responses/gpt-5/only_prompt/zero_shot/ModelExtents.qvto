modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation transf(in inModel : ECORE, out outModel1 : ECORE, out outModel2 : ECORE);

main() {
	inModel.rootObjects()[EPackage]->map createPackages();
}

mapping EPackage::createPackages() {
	target outPkg1 : EPackage in outModel1;
	target outPkg2 : EPackage in outModel2;
	init {
		outPkg1.name := 'a';
		outPkg2.name := 'b';
	}
}

mapping EClass::toClass() : EClass in outModel2 {
	init {
		result.name := self.name;
	}
}