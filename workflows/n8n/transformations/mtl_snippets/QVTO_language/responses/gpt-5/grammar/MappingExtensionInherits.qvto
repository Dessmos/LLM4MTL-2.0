modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()[ECORE::EPackage]->map p2p();
}

mapping ECORE::EPackage::p2p() : ECORE::EPackage {
	init {
		result.name := self.name;
	}
	self.eClassifiers[ECORE::EClass]->map makeClass();
}

abstract mapping ECORE::ENamedElement::makeClassifier() : ECORE::ENamedElement {
	init {
		result.name := self.name + "1";
	}
}

mapping ECORE::EClass::makeClass() : ECORE::EClass
	inherits ECORE::ENamedElement::makeClassifier {
	init {
		var suffix := "2";
		result.name := result.name + suffix;
	}
}