modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel::EPackage.allInstances()->select(p | p.eSuperPackage = null)->forEach(p) {
		outModel::EPackage::p2p(p);
	};
}

mapping ECORE::EPackage::p2p(src : ECORE::EPackage) : ECORE::EPackage {
	init {
		result.name := src.name;
	}
	src.eClassifiers->forEach(c) {
		result.eClassifiers += c->map makeClass();
	};
}

mapping ECORE::ENamedElement::makeClass(src : ECORE::ENamedElement) : ECORE::EClass {
	init {
		result.name := 'ENamedElement_' + src.name;
	}
}

mapping ECORE::EClassifier::makeClass(src : ECORE::EClassifier) : ECORE::EClass
	disjuncts ECORE::ENamedElement::makeClass {
	init {
		result.name := 'EClassifier_' + src.name;
	}
}

mapping ECORE::EClass::makeClass(src : ECORE::EClass) : ECORE::EClass
	disjuncts ECORE::EClassifier::makeClass {
	init {
		result.name := 'EClass_' + src.name;
	}
}

mapping ECORE::EDataType::makeClass(src : ECORE::EDataType) : ECORE::EClass
	disjuncts ECORE::EClassifier::makeClass {
	init {
		result.name := 'EDataType_' + src.name;
	}
}

mapping ECORE::EClassifier::c2c(src : ECORE::EClassifier) : ECORE::EClassifier {
	init {
		result.name := 'mapped' + src.name;
	}
}