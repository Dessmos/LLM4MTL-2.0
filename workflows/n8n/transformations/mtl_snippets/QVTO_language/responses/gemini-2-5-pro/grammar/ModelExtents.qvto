modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation transf(in inEcore : ECORE, out outEcore1 : ECORE, out outEcore2 : ECORE);

main() {
	outEcore1 := object ECORE::EPackage {
		name := 'a';
	};
	outEcore2 := object ECORE::EPackage {
		name := 'b';
		eClassifiers += inEcore.eClassifiers[ECORE::EClass]->map toClass();
	};
}

mapping ECORE::EClass::toClass() : ECORE::EClass @ outEcore2 {
	name := self.name;
}