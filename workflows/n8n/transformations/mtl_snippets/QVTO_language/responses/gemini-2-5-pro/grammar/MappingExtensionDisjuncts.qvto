modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
	inModel.rootObjects()[EPackage]->map p2p();
}

mapping ECORE::EPackage::p2p(in p : EPackage) : EPackage {
	name := p.name;
	eClassifiers += p.eClassifiers[EClass]->map makeClass();
}

mapping disjuncts makeAClass, makeBClass ECORE::EClass::makeClass(in c : EClass) : EClass;

mapping ECORE::EClass::makeAClass(in c : EClass) : EClass
when { c.name.startsWith('A') }
{
	name := c.name + 'A';
}

mapping ECORE::EClass::makeBClass(in c : EClass) : EClass
when { c.name.startsWith('B') }
{
	name := c.name + 'B';
}