modeltype ECORE uses "http://www.eclipse.org/emf/2002/Ecore";

transformation t(in input : ECORE, out output : ECORE);

main() {
	input.objects()[ECORE::EPackage]->map p2p();
}

mapping ECORE::EPackage::p2p(in p : EPackage) : EPackage {
	name := p.name;
	eClassifiers := p.eClassifiers->map c2c();
}

mapping ECORE::EClassifier::c2c(in c : EClassifier) : EClassifier {
	init {
		if c.name = 'A' then
			result := object EDataType {};
		else
			result := object EClass {};
		endif;
	}
	name := 'mapped' + c.name;
}

constructor ECORE::EClass::EClass(in aName : String, in anOp : EOperation) {
	name := aName;
	eOperations += anOp;
}