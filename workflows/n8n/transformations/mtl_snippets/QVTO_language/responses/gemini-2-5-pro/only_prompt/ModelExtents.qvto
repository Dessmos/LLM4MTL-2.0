modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation transf(in source : ECORE, out target1 : ECORE, out target2 : ECORE);

main() {
	object EPackage {
		name := 'a';
	};
	object EPackage {
		name := 'b';
		eClassifiers := source.objects(EClass)->map toClass();
	} model(target2);
}

mapping EClass::toClass() : EClass {
	name := self.name;
}