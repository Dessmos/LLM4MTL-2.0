modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation t(inModel : ECORE, outModel : ECORE);

main() {
	inModel.rootObjects()[EPackage]->map p2p();
}

mapping EPackage::p2p() : EPackage {
	name := self.name;
	eClassifiers := self.eClassifiers->map c2c();
}

mapping EClassifier::c2c() : EClassifier disjuncts EClassifier::whenA, EClassifier::otherwise;

mapping EClassifier::whenA() : EDataType
when { self.name = 'A' }
{
	name := 'mapped' + self.name;
}

mapping EClassifier::otherwise() : EClass {
	name := 'mapped' + self.name;
}

constructor EClass(theName : String, theOp : EOperation) {
	name := theName;
	eOperations += theOp;
}