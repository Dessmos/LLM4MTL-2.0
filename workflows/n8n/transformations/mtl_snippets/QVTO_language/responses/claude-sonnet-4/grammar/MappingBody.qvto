modeltype ECORE uses 'http://www.eclipse.org/emf/2002/Ecore';

transformation t(in inModel : ECORE, out outModel : ECORE);

main() {
    inModel.rootObjects()[EPackage]->map p2p();
}

mapping EPackage::p2p() : EPackage {
    name := self.name;
    eClassifiers += self.eClassifiers->map c2c();
}

mapping EClassifier::c2c() : EClassifier
when { self.name = 'A' } {
    result := object EDataType {
        name := 'mapped' + self.name;
    };
}

mapping EClassifier::c2c() : EClassifier {
    result := object EClass {
        name := 'mapped' + self.name;
    };
}

constructor EClass::EClass(n : String, op : EOperation) {
    name := n;
    eOperations += op;
}
