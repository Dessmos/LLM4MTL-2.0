      "parameters": {
        "jsCode": "const strategies = $json.strategies;\nconst llms = $json.llms;\n\nconst combinations = [];\n\nfor (const strategy of strategies) {\n  for (const llm of llms) {\n    combinations.push({\n      strategyName: strategy.name,\n      Few_shot: strategy.Few_shot,\n      Grammar: strategy.Grammar,\n      Helper_methods: strategy.Helper_methods,\n      llmName: llm.name,\n      llmNode: llm.node\n    });\n  }\n}\n\nreturn combinations.map(c => ({ json: c }));"
      },
