      "parameters": {
        "jsCode": "const promptItems = $items(\"Read prompt files\", 0);   // keep binary + json\nconst configs = $items(\"Build Matrix\", 0).map(i => i.json);\n\nconst out = [];\n\nfor (const pItem of promptItems) {\n  for (const c of configs) {\n    out.push({\n      json: {\n        ...pItem.json,   // mimeType, fileName, etc.\n        ...c             // llmName, strategyName, flags...\n      },\n      binary: pItem.binary // <-- IMPORTANT: carry the file content forward\n    });\n  }\n}\n\nreturn out;"
